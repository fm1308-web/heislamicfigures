tiently endured"}, {"w": 5, "t": "மிக்க நல்லதாயிற்று"}, {"w": 6, "t": "இறுதி"}, {"w": 7, "t": "வீடு"}, {"w": 8, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இன்னும் எவர்கள்"}, {"w": 2, "t": "முறிக்கிறார்கள்"}, {"w": 3, "t": "வாக்குறுதியை"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "பின்னர்"}, {"w": 6, "t": "after"}, {"w": 7, "t": "அது உறுதியான"}, {"w": 8, "t": "இன்னும் துண்டிக்கிறார்கள்"}, {"w": 9, "t": "எதை"}, {"w": 10, "t": "ஏவினான்"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "அதை"}, {"w": 13, "t": "சேர்க்கப்படும்"}, {"w": 14, "t": "be joined"}, {"w": 15, "t": "இன்னும் விஷமம் செய்வார்கள்"}, {"w": 16, "t": "பூமியில்"}, {"w": 17, "t": "the earth"}, {"w": 18, "t": "இவர்கள்"}, {"w": 19, "t": "இவர்களுக்கு/சாபம்"}, {"w": 20, "t": "(is) the curse"}, {"w": 21, "t": "இன்னும் இவர்களுக்கு"}, {"w": 22, "t": "மிகக் கெட்டது"}, {"w": 23, "t": "வீடு"}, {"w": 24, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "விரிவுபடுத்துகிறான்"}, {"w": 3, "t": "வாழ்க்கை வசதியை"}, {"w": 4, "t": "எவருக்கு"}, {"w": 5, "t": "நாடுகின்றான்"}, {"w": 6, "t": "இன்னும் சுருக்குகிறான்"}, {"w": 7, "t": "இன்னும் மகிழ்கின்றனர்"}, {"w": 8, "t": "வாழ்வைக் கொண்டு"}, {"w": 9, "t": "உலகம்/இல்லை"}, {"w": 10, "t": "and nothing"}, {"w": 11, "t": "உலக வாழ்க்கை"}, {"w": 12, "t": "of the world"}, {"w": 13, "t": "மறுமையில்"}, {"w": 14, "t": "the Hereafter"}, {"w": 15, "t": "தவிர/ஒரு சுகம்"}, {"w": 16, "t": "an enjoyment"}, {"w": 17, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "கூறுகிறார்(கள்)"}, {"w": 2, "t": "எவர்கள்/நிராகரித்தனர்"}, {"w": 3, "t": "disbelieved"}, {"w": 4, "t": "இறக்கப்பட வேண்டாமா?"}, {"w": 5, "t": "been sent down"}, {"w": 6, "t": "இவர் மீது"}, {"w": 7, "t": "ஓர் அத்தாட்சி"}, {"w": 8, "t": "இவருடைய இறைவனிடமிருந்து"}, {"w": 9, "t": "his Lord"}, {"w": 10, "t": "கூறுவீராக"}, {"w": 11, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 12, "t": "Allah"}, {"w": 13, "t": "வழிகெடுக்கிறான்"}, {"w": 14, "t": "தான் நாடுகின்றவர்களை"}, {"w": 15, "t": "He wills"}, {"w": 16, "t": "இன்னும் நேர்வழி செலுத்துகிறான்"}, {"w": 17, "t": "தன் பக்கம்"}, {"w": 18, "t": "எவர்/திரும்பினார்"}, {"w": 19, "t": "turns back"}, {"w": 20, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 3, "t": "இன்னும் நிம்மதியடைகின்றன"}, {"w": 4, "t": "உள்ளங்கள்/அவர்களுடைய"}, {"w": 5, "t": "நினைவால்"}, {"w": 6, "t": "அல்லாஹ்வின்"}, {"w": 7, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 8, "t": "நினைவைக் கொண்டே"}, {"w": 9, "t": "அல்லாஹ்வின்"}, {"w": 10, "t": "நிம்மதியடைகின்றன"}, {"w": 11, "t": "உள்ளங்கள்"}, {"w": 12, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டு"}, {"w": 3, "t": "செய்தார்கள்"}, {"w": 4, "t": "நற்செயல்களை"}, {"w": 5, "t": "நற்பாக்கியம்"}, {"w": 6, "t": "அவர்களுக்கு"}, {"w": 7, "t": "அழகிய"}, {"w": 8, "t": "மீளுமிடம்"}, {"w": 9, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "இவ்வாறே"}, {"w": 2, "t": "அனுப்பினோம்/உம்மை"}, {"w": 3, "t": "ஒரு சமுதாயத்திடம்"}, {"w": 4, "t": "a nation"}, {"w": 5, "t": "சென்றிருக்கின்றன"}, {"w": 6, "t": "have passed away"}, {"w": 7, "t": "இவர்களுக்கு முன்னரும்"}, {"w": 8, "t": "before it"}, {"w": 9, "t": "பல சமுதாயங்கள்"}, {"w": 10, "t": "நீர் ஓதுவதற்காக"}, {"w": 11, "t": "இவர்கள் முன்"}, {"w": 12, "t": "எது/நாம் வஹீ  அறிவித்தோம்"}, {"w": 13, "t": "We revealed"}, {"w": 14, "t": "உமக்கு"}, {"w": 15, "t": "இவர்களோ"}, {"w": 16, "t": "நிராகரிக்கின்றனர்"}, {"w": 17, "t": "ரஹ்மானை"}, {"w": 18, "t": "கூறுவீராக"}, {"w": 19, "t": "அவன்தான்"}, {"w": 20, "t": "என் இறைவன்"}, {"w": 21, "t": "அறவே இல்லை"}, {"w": 22, "t": "வணக்கத்திற்குரியவன்"}, {"w": 23, "t": "தவிர"}, {"w": 24, "t": "அவனை"}, {"w": 25, "t": "அவன் மீது"}, {"w": 26, "t": "நம்பிக்கை வைத்தேன்"}, {"w": 27, "t": "இன்னும் அவனிடமே"}, {"w": 28, "t": "என் பாவ மீட்சி"}, {"w": 29, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "வேதம்/இருந்தால்"}, {"w": 2, "t": "that was"}, {"w": 3, "t": "any Quran"}, {"w": 4, "t": "நகர்த்தப்பட்டது"}, {"w": 5, "t": "அதைக் கொண்டு"}, {"w": 6, "t": "மலைகள்"}, {"w": 7, "t": "அல்லது/துண்டு துண்டாக்கப்பட்டிருந்தால்"}, {"w": 8, "t": "could be cloven asunder"}, {"w": 9, "t": "அதைக் கொண்டு"}, {"w": 10, "t": "பூமி"}, {"w": 11, "t": "அல்லது/பேச வைக்கப்பட்டிருந்தால்..."}, {"w": 12, "t": "could be made to speak"}, {"w": 13, "t": "அதைக் கொண்டு"}, {"w": 14, "t": "மரணித்தவர்கள்"}, {"w": 15, "t": "மாறாக/அல்லாஹ்வுக்குரியனவே"}, {"w": 16, "t": "with Allah"}, {"w": 17, "t": "அதிகாரம்"}, {"w": 18, "t": "அனைத்தும்"}, {"w": 19, "t": "அறியவில்லையா?"}, {"w": 20, "t": "know"}, {"w": 21, "t": "எவர்கள்"}, {"w": 22, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 23, "t": "நாடினால்"}, {"w": 24, "t": "if"}, {"w": 25, "t": "had willed"}, {"w": 26, "t": "அல்லாஹ்"}, {"w": 27, "t": "நேர்வழி படுத்தியிருப்பான்"}, {"w": 28, "t": "மக்களை"}, {"w": 29, "t": "அனைவரை"}, {"w": 30, "t": "தொடர்ந்து இருக்கும்"}, {"w": 31, "t": "will cease"}, {"w": 32, "t": "எவர்கள்"}, {"w": 33, "t": "நிராகரித்தனர்"}, {"w": 34, "t": "அடையும்/அவர்களை"}, {"w": 35, "t": "காரணமாக"}, {"w": 36, "t": "செய்தனர்"}, {"w": 37, "t": "ஒரு திடுக்கம்"}, {"w": 38, "t": "அல்லது"}, {"w": 39, "t": "நீர் இறங்குவீர்"}, {"w": 40, "t": "அருகாமையில்"}, {"w": 41, "t": "அவர்களின் ஊருக்கு"}, {"w": 42, "t": "their homes"}, {"w": 43, "t": "இறுதியாக"}, {"w": 44, "t": "வரும்"}, {"w": 45, "t": "வாக்குறுதி"}, {"w": 46, "t": "அல்லாஹ்வின்"}, {"w": 47, "t": "நிச்சயமாக"}, {"w": 48, "t": "அல்லாஹ்"}, {"w": 49, "t": "மாற்ற மாட்டான்"}, {"w": 50, "t": "fail"}, {"w": 51, "t": "வாக்குறுதியை"}, {"w": 52, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "திட்டமாக பரிகசிக்கப்பட்டனர்"}, {"w": 2, "t": "were mocked"}, {"w": 3, "t": "தூதர்கள்"}, {"w": 4, "t": "உமக்கு முன்னர்"}, {"w": 5, "t": "before you"}, {"w": 6, "t": "நீட்டினேன்"}, {"w": 7, "t": "எவர்களுக்கு"}, {"w": 8, "t": "நிராகரித்தனர்"}, {"w": 9, "t": "பிறகு"}, {"w": 10, "t": "பிடித்தேன்/அவர்களை"}, {"w": 11, "t": "எப்படி?"}, {"w": 12, "t": "இருந்தது"}, {"w": 13, "t": "என் தண்டனை"}, {"w": 14, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "யார்?"}, {"w": 2, "t": "அவன்"}, {"w": 3, "t": "நிர்வகிப்பவன்"}, {"w": 4, "t": "மீது"}, {"w": 5, "t": "ஒவ்வொரு"}, {"w": 6, "t": "ஆன்மா"}, {"w": 7, "t": "அவை செய்தவற்றுக்கு"}, {"w": 8, "t": "it has earned"}, {"w": 9, "t": "அவர்கள் ஏற்படுத்தினர்"}, {"w": 10, "t": "அல்லாஹ்வுக்கு"}, {"w": 11, "t": "இணைகளை"}, {"w": 12, "t": "கூறுவீராக"}, {"w": 13, "t": "பெயரிடுங்கள் அவற்றுக்கு"}, {"w": 14, "t": "அல்லது/அறிவிக்கிறீர்களா?/அவனுக்கு"}, {"w": 15, "t": "(do) you inform Him"}, {"w": 16, "t": "அவன் அறியாததை"}, {"w": 17, "t": "not"}, {"w": 18, "t": "He knows"}, {"w": 19, "t": "பூமியில்"}, {"w": 20, "t": "the earth"}, {"w": 21, "t": "அல்லது"}, {"w": 22, "t": "பொய்யான சொல்லை"}, {"w": 23, "t": "of"}, {"w": 24, "t": "the words"}, {"w": 25, "t": "மாறாக"}, {"w": 26, "t": "அலங்கரிக்கப்பட்டது"}, {"w": 27, "t": "எவர்களுக்கு"}, {"w": 28, "t": "நிராகரித்தனர்"}, {"w": 29, "t": "சூழ்ச்சி அவர்களுடைய"}, {"w": 30, "t": "இன்னும் தடுக்கப்பட்டனர்"}, {"w": 31, "t": "பாதையிலிருந்து"}, {"w": 32, "t": "the Path"}, {"w": 33, "t": "எவரை/ வழிகெடுப்பான்"}, {"w": 34, "t": "(by) Allah"}, {"w": 35, "t": "அல்லாஹ்"}, {"w": 36, "t": "அவருக்கு இல்லை"}, {"w": 37, "t": "for him"}, {"w": 38, "t": "நேர்வழிகாட்டுபவர் எவரும்"}, {"w": 39, "t": "guide"}, {"w": 40, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "அவர்களுக்கு"}, {"w": 2, "t": "வேதனை"}, {"w": 3, "t": "வாழ்வில்"}, {"w": 4, "t": "the life"}, {"w": 5, "t": "உலகம்"}, {"w": 6, "t": "வேதனைதான்"}, {"w": 7, "t": "மறுமையின்"}, {"w": 8, "t": "மிக சிரமமானது"}, {"w": 9, "t": "இல்லை"}, {"w": 10, "t": "அவர்களை"}, {"w": 11, "t": "இருந்து"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "பாதுகாப்பவர் எவரும்"}, {"w": 14, "t": "defender"}, {"w": 15, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "தன்மை"}, {"w": 2, "t": "சொர்க்கத்தின்"}, {"w": 3, "t": "எது/வாக்களிக்கப்பட்டார்(கள்)"}, {"w": 4, "t": "(is) promised"}, {"w": 5, "t": "அஞ்சியவர்கள்"}, {"w": 6, "t": "ஓடும்"}, {"w": 7, "t": "அவற்றின் கீழ்"}, {"w": 8, "t": "underneath it"}, {"w": 9, "t": "நதிகள்"}, {"w": 10, "t": "அதன் உணவுகள்"}, {"w": 11, "t": "நிலையானவை"}, {"w": 12, "t": "இன்னும் அதன் நிழல்"}, {"w": 13, "t": "இதுதான்"}, {"w": 14, "t": "முடிவு"}, {"w": 15, "t": "எவர்கள்"}, {"w": 16, "t": "அஞ்சினர்"}, {"w": 17, "t": "முடிவோ"}, {"w": 18, "t": "நிராகரிப்பாளர்களின்"}, {"w": 19, "t": "நரகம்தான்"}, {"w": 20, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "எவர்கள்/கொடுத்தோம்/அவர்களுக்கு"}, {"w": 2, "t": "We have given them"}, {"w": 3, "t": "வேதத்தை"}, {"w": 4, "t": "மகிழ்வார்கள்"}, {"w": 5, "t": "இறக்கப்பட்டதைக் கொண்டு/உமக்கு"}, {"w": 6, "t": "has been revealed"}, {"w": 7, "t": "to you"}, {"w": 8, "t": "இன்னும் கூட்டங்களில்"}, {"w": 9, "t": "the groups"}, {"w": 10, "t": "எவர் மறுப்பார்"}, {"w": 11, "t": "deny"}, {"w": 12, "t": "அதில் சிலவற்றை"}, {"w": 13, "t": "கூறுவீராக"}, {"w": 14, "t": "நான் கட்டளையிடப்பட்டதெல்லாம்"}, {"w": 15, "t": "I have been commanded"}, {"w": 16, "t": "நான் வணங்குவதற்கு"}, {"w": 17, "t": "I worship"}, {"w": 18, "t": "அல்லாஹ்வை"}, {"w": 19, "t": "நான் இணைவைக்காமல் இருக்க/அவனுக்கு"}, {"w": 20, "t": "I associate partners"}, {"w": 21, "t": "with Him"}, {"w": 22, "t": "அவன் பக்கமே"}, {"w": 23, "t": "அழைக்கிறேன்"}, {"w": 24, "t": "இன்னும் அவன் பக்கமே"}, {"w": 25, "t": "என் திரும்புதல்"}, {"w": 26, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "இதை இறக்கினோம்"}, {"w": 3, "t": "சட்டமாக"}, {"w": 4, "t": "அரபி மொழியில்"}, {"w": 5, "t": "நீங்கள் பின்பற்றினால்"}, {"w": 6, "t": "you follow"}, {"w": 7, "t": "விருப்பங்களை அவர்களுடைய"}, {"w": 8, "t": "பின்னர் உமக்கு வந்தது"}, {"w": 9, "t": "came to you"}, {"w": 10, "t": "கல்வி"}, {"w": 11, "t": "the knowledge"}, {"w": 12, "t": "இல்லை/உமக்கு"}, {"w": 13, "t": "for you"}, {"w": 14, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 15, "t": "Allah"}, {"w": 16, "t": "உதவியாளர் எவரும்"}, {"w": 17, "t": "protector"}, {"w": 18, "t": "பாதுகாவலர் இல்லை"}, {"w": 19, "t": "defender"}, {"w": 20, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "அனுப்பி இருக்கிறோம்"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "தூதர்களை"}, {"w": 4, "t": "உமக்கு முன்னர்"}, {"w": 5, "t": "before you"}, {"w": 6, "t": "இன்னும் ஆக்கினோம்"}, {"w": 7, "t": "அவர்களுக்கு"}, {"w": 8, "t": "மனைவிகளை"}, {"w": 9, "t": "இன்னும் சந்ததியை(யும்)"}, {"w": 10, "t": "முடியாது"}, {"w": 11, "t": "was"}, {"w": 12, "t": "(எந்த) தூதருக்கு"}, {"w": 13, "t": "அவர் வருவது"}, {"w": 14, "t": "he comes"}, {"w": 15, "t": "அத்தாட்சியைக் கொண்டு"}, {"w": 16, "t": "தவிர"}, {"w": 17, "t": "அனுமதி கொண்டே"}, {"w": 18, "t": "அல்லாஹ்வின்"}, {"w": 19, "t": "ஒவ்வொரு"}, {"w": 20, "t": "தவணைக்கும்"}, {"w": 21, "t": "ஒரு விதி"}, {"w": 22, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "அழிக்கிறான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "அவன் நாடியதை"}, {"w": 4, "t": "He wills"}, {"w": 5, "t": "தரிபடுத்துகிறான்"}, {"w": 6, "t": "இன்னும் அவனிடம்தான்"}, {"w": 7, "t": "தாய்"}, {"w": 8, "t": "புத்தகம்"}, {"w": 9, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நிச்சயமாக நாம் காண்பித்தால்/உமக்கு"}, {"w": 2, "t": "(what)"}, {"w": 3, "t": "We show you"}, {"w": 4, "t": "சிலதை/எது"}, {"w": 5, "t": "(of) what"}, {"w": 6, "t": "நாம் வாக்களிக்கிறோம் அவர்களுக்கு"}, {"w": 7, "t": "அல்லது/கைப்பற்றிக் கொள்வோம்/உம்மை"}, {"w": 8, "t": "We cause you to die"}, {"w": 9, "t": "ஆகவே, எல்லாம்"}, {"w": 10, "t": "உம்மீது"}, {"w": 11, "t": "எடுத்துரைப்பதுதான்"}, {"w": 12, "t": "நம்மீதுதான்"}, {"w": 13, "t": "விசாரணை"}, {"w": 14, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவர்கள் காணவில்லையா?"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "நிச்சயமாக நாம்"}, {"w": 4, "t": "வருகிறோம்"}, {"w": 5, "t": "பூமியை"}, {"w": 6, "t": "குறைக்கிறோம்/அதை"}, {"w": 7, "t": "இருந்து"}, {"w": 8, "t": "அதன் ஓரங்கள்"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "தீர்ப்பளிக்கிறான்"}, {"w": 11, "t": "அறவே இல்லை"}, {"w": 12, "t": "தடுப்பவர்"}, {"w": 13, "t": "அவனுடைய தீர்ப்பை"}, {"w": 14, "t": "அவன்"}, {"w": 15, "t": "மிகத் தீவிரமானவன்"}, {"w": 16, "t": "விசாரிப்பதில்"}, {"w": 17, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "சூழ்ச்சி செய்தனர்"}, {"w": 3, "t": "இவர்களுக்கு முன்னிருந்தவர்கள்"}, {"w": 4, "t": "(were) from"}, {"w": 5, "t": "before them"}, {"w": 6, "t": "அல்லாஹ்விற்கே"}, {"w": 7, "t": "சூழ்ச்சி"}, {"w": 8, "t": "அனைத்தும்"}, {"w": 9, "t": "அறிவான்"}, {"w": 10, "t": "எதை/செய்கிறது"}, {"w": 11, "t": "earns"}, {"w": 12, "t": "ஒவ்வொரு"}, {"w": 13, "t": "ஆன்மா"}, {"w": 14, "t": "அறிவார்(கள்)"}, {"w": 15, "t": "நிராகரிப்பவர்கள்"}, {"w": 16, "t": "எவருக்கு"}, {"w": 17, "t": "முடிவு"}, {"w": 18, "t": "மறுமை"}, {"w": 19, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "கூறுகிறார்(கள்)"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "நிராகரித்தனர்"}, {"w": 4, "t": "நீர் இல்லை"}, {"w": 5, "t": "தூதராக"}, {"w": 6, "t": "கூறுவீராக"}, {"w": 7, "t": "போதுமாகி விட்டான்"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "சாட்சியால்"}, {"w": 10, "t": "எனக்கு மத்தியில்"}, {"w": 11, "t": "இன்னும் உங்களுக்கு மத்தியில்"}, {"w": 12, "t": "இன்னும் எவர்"}, {"w": 13, "t": "அவரிடம்"}, {"w": 14, "t": "ஞானம்"}, {"w": 15, "t": "வேதத்தின்"}, {"w": 16, "t": "(43)"}]}]}