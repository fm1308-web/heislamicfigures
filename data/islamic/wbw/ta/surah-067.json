{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அருள் வளமிக்கவன்"}, {"w": 2, "t": "எவன்"}, {"w": 3, "t": "அவனுடைய கரத்தில்"}, {"w": 4, "t": "ஆட்சி"}, {"w": 5, "t": "அவன்"}, {"w": 6, "t": "எல்லாப் பொருள்கள் மீதும்"}, {"w": 7, "t": "every"}, {"w": 8, "t": "thing"}, {"w": 9, "t": "பேராற்றலுடையவன்"}, {"w": 10, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "எவன்"}, {"w": 2, "t": "படைத்தான்"}, {"w": 3, "t": "மரணத்தை(யும்)"}, {"w": 4, "t": "வாழ்க்கையையும்"}, {"w": 5, "t": "அவன் உங்களை சோதிப்பதற்காக"}, {"w": 6, "t": "உங்களில் யார்"}, {"w": 7, "t": "மிக அழகானவர்"}, {"w": 8, "t": "செயலால்"}, {"w": 9, "t": "அவன்தான்"}, {"w": 10, "t": "மிகைத்தவன்"}, {"w": 11, "t": "மகா மன்னிப்பாளன்"}, {"w": 12, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "எவன்/படைத்தான்"}, {"w": 2, "t": "created"}, {"w": 3, "t": "ஏழு வானங்களை"}, {"w": 4, "t": "heavens"}, {"w": 5, "t": "அடுக்கடுக்காக"}, {"w": 6, "t": "நீர் பார்ப்பதில்லை"}, {"w": 7, "t": "you see"}, {"w": 8, "t": "படைப்பில்"}, {"w": 9, "t": "(the) creation"}, {"w": 10, "t": "பேரருளாளனின்"}, {"w": 11, "t": "எவ்வித ஏற்றத் தாழ்வையும்"}, {"w": 12, "t": "fault"}, {"w": 13, "t": "நீர் மீண்டும் திருப்புவீராக!/பார்வையை"}, {"w": 14, "t": "the vision"}, {"w": 15, "t": "நீர் பார்க்கிறீரா?"}, {"w": 16, "t": "you see"}, {"w": 17, "t": "ஏதாவது பிளவுகளை"}, {"w": 18, "t": "flaw"}, {"w": 19, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "மீண்டும் திருப்புவீராக!"}, {"w": 3, "t": "பார்வையை"}, {"w": 4, "t": "இரு முறை"}, {"w": 5, "t": "திரும்பிவிடும்"}, {"w": 6, "t": "உம் பக்கம்"}, {"w": 7, "t": "அந்தப் பார்வை"}, {"w": 8, "t": "இழிவடைந்ததாக"}, {"w": 9, "t": "இன்னும் அது"}, {"w": 10, "t": "கலைத்துவிடும்"}, {"w": 11, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அலங்கரித்தோம்"}, {"w": 3, "t": "வானத்தை/கீழ்"}, {"w": 4, "t": "nearest"}, {"w": 5, "t": "விளக்குகளால்"}, {"w": 6, "t": "இன்னும் அவற்றை ஏற்படுத்தினோம்"}, {"w": 7, "t": "எறிவதற்காக"}, {"w": 8, "t": "ஷைத்தான்களை"}, {"w": 9, "t": "இன்னும் தயார் செய்துள்ளோம்"}, {"w": 10, "t": "அவர்களுக்கு"}, {"w": 11, "t": "கொழுந்து விட்டெரியும் நரகநெருப்பின் வேதனையை"}, {"w": 12, "t": "(of) the Blaze"}, {"w": 13, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிராகரிப்பவர்களுக்கு"}, {"w": 2, "t": "disbelieved"}, {"w": 3, "t": "தங்கள் இறைவனை"}, {"w": 4, "t": "தண்டனை"}, {"w": 5, "t": "நரகத்தின்"}, {"w": 6, "t": "இன்னும் மிகக் கெட்டது"}, {"w": 7, "t": "மீளுமிடங்களில்"}, {"w": 8, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவர்கள் எறியப்பட்டால்"}, {"w": 2, "t": "they are thrown"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "செவியுறுவார்கள்"}, {"w": 5, "t": "அதில்"}, {"w": 6, "t": "கடுமையான சப்தத்தை"}, {"w": 7, "t": "இன்னும் அது"}, {"w": 8, "t": "கொதிக்கும்"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அது நெருங்கிவிடும்"}, {"w": 2, "t": "தெரித்துவிட"}, {"w": 3, "t": "கோபத்தால்"}, {"w": 4, "t": "rage"}, {"w": 5, "t": "எறியப்படும் போதெல்லாம்"}, {"w": 6, "t": "is thrown"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "ஒரு கூட்டம்"}, {"w": 9, "t": "அவர்களிடம் கேட்பார்(கள்)"}, {"w": 10, "t": "அதன் காவலாளிகள்"}, {"w": 11, "t": "உங்களிடம் வரவில்லையா?"}, {"w": 12, "t": "come to you"}, {"w": 13, "t": "ஓர் எச்சரிப்பாளர்"}, {"w": 14, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "ஏன் வரவில்லை"}, {"w": 3, "t": "திட்டமாக"}, {"w": 4, "t": "எங்களிடம் வந்தார்"}, {"w": 5, "t": "எச்சரிப்பாளர்"}, {"w": 6, "t": "ஆனால் பொய்ப்பித்தோம்"}, {"w": 7, "t": "இன்னும் கூறினோம்"}, {"w": 8, "t": "இறக்கவில்லை"}, {"w": 9, "t": "has sent down"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "எதையும்"}, {"w": 12, "t": "thing"}, {"w": 13, "t": "நீங்கள் இல்லை"}, {"w": 14, "t": "you (are)"}, {"w": 15, "t": "தவிர"}, {"w": 16, "t": "வழிகேட்டிலேயே"}, {"w": 17, "t": "error"}, {"w": 18, "t": "பெரிய"}, {"w": 19, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் கூறுவார்கள்"}, {"w": 2, "t": "நாங்கள் இருந்தால்"}, {"w": 3, "t": "we had"}, {"w": 4, "t": "செவி ஏற்பவர்களாக"}, {"w": 5, "t": "அல்லது"}, {"w": 6, "t": "சிந்தித்து புரிபவர்களாக"}, {"w": 7, "t": "ஆகி இருக்க மாட்டோம்"}, {"w": 8, "t": "we (would) have been"}, {"w": 9, "t": "நரகவாசிகளில்"}, {"w": 10, "t": "(the) companions"}, {"w": 11, "t": "(of) the Blaze"}, {"w": 12, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஒப்புக் கொள்வார்கள்"}, {"w": 2, "t": "தங்கள் குற்றத்தை"}, {"w": 3, "t": "ஆகவே கேடுதான்"}, {"w": 4, "t": "நரகவாசிகளுக்கு"}, {"w": 5, "t": "(of) the Blaze"}, {"w": 6, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "பயப்படுகின்றார்கள்"}, {"w": 4, "t": "தங்கள் இறைவனை"}, {"w": 5, "t": "மறைவில்"}, {"w": 6, "t": "அவர்களுக்கு உண்டு"}, {"w": 7, "t": "மன்னிப்பு(ம்)"}, {"w": 8, "t": "பெரிய கூலியும்"}, {"w": 9, "t": "great"}, {"w": 10, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இரகசியமாகப் பேசுங்கள்"}, {"w": 2, "t": "உங்கள் பேச்சை"}, {"w": 3, "t": "அல்லது உரக்கப் பேசுங்கள்"}, {"w": 4, "t": "proclaim"}, {"w": 5, "t": "அதை"}, {"w": 6, "t": "நிச்சயமாக அவன்"}, {"w": 7, "t": "நன்கறிந்தவன்"}, {"w": 8, "t": "நெஞ்சங்களில் உள்ளதை"}, {"w": 9, "t": "the breasts"}, {"w": 10, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவன் அறிய மாட்டானா?"}, {"w": 2, "t": "know"}, {"w": 3, "t": "எவன்"}, {"w": 4, "t": "படைத்தான்"}, {"w": 5, "t": "அவன்தான்"}, {"w": 6, "t": "நுட்பமானவன்"}, {"w": 7, "t": "ஆழ்ந்தறிபவன்"}, {"w": 8, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "ஆக்கினான்"}, {"w": 4, "t": "உங்களுக்கு"}, {"w": 5, "t": "பூமியை"}, {"w": 6, "t": "இலகுவாக"}, {"w": 7, "t": "ஆகவே செல்லுங்கள்"}, {"w": 8, "t": "அதன் பல பகுதிகளில்"}, {"w": 9, "t": "(the) paths thereof"}, {"w": 10, "t": "இன்னும் உண்ணுங்கள்"}, {"w": 11, "t": "அவனுடைய உணவில் இருந்து"}, {"w": 12, "t": "His provision"}, {"w": 13, "t": "அவன் பக்கம்தான்"}, {"w": 14, "t": "எழுப்பப்படுதல்"}, {"w": 15, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "பயமற்று இருக்கின்றீர்களா?"}, {"w": 2, "t": "வானத்தின் மேல் உள்ளவன்"}, {"w": 3, "t": "(is) in"}, {"w": 4, "t": "the heaven"}, {"w": 5, "t": "சொருகிவிடுவதை"}, {"w": 6, "t": "He will cause to swallow"}, {"w": 7, "t": "உங்களை"}, {"w": 8, "t": "பூமியில்"}, {"w": 9, "t": "அப்போது அது"}, {"w": 10, "t": "it"}, {"w": 11, "t": "குலுங்கும்"}, {"w": 12, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அல்லது பயமற்று இருக்கின்றீர்களா?"}, {"w": 2, "t": "do you feel secure"}, {"w": 3, "t": "வானத்தின் மேல் உள்ளவன்"}, {"w": 4, "t": "(is) in"}, {"w": 5, "t": "the heaven"}, {"w": 6, "t": "அனுப்புவதை"}, {"w": 7, "t": "He will send"}, {"w": 8, "t": "உங்கள் மீது"}, {"w": 9, "t": "கல் மழையை"}, {"w": 10, "t": "விரைவில் அறிவீர்கள்"}, {"w": 11, "t": "எப்படி (இருந்தது)"}, {"w": 12, "t": "என் எச்சரிக்கை"}, {"w": 13, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "பொய்ப்பித்தார்(கள்)"}, {"w": 3, "t": "எவர்கள்"}, {"w": 4, "t": "இவர்களுக்கு முன்னர்"}, {"w": 5, "t": "before them"}, {"w": 6, "t": "எப்படி?"}, {"w": 7, "t": "இருந்தது"}, {"w": 8, "t": "எனது மறுப்பு"}, {"w": 9, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவர்கள் பார்க்கவில்லையா?"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "பறவைகளை"}, {"w": 4, "t": "the birds"}, {"w": 5, "t": "தங்களுக்கு மேல்"}, {"w": 6, "t": "விரித்தவைகளாகவும்"}, {"w": 7, "t": "மடக்கியவைகளாகவும்"}, {"w": 8, "t": "அவற்றை தடுக்க முடியாது"}, {"w": 9, "t": "holds them"}, {"w": 10, "t": "ரஹ்மானைத் தவிர"}, {"w": 11, "t": "the Most Gracious"}, {"w": 12, "t": "நிச்சயமாக அவன்"}, {"w": 13, "t": "எல்லாப் பொருளையும்"}, {"w": 14, "t": "thing"}, {"w": 15, "t": "உற்று நோக்குபவன்"}, {"w": 16, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "மாறாக, யார்?"}, {"w": 2, "t": "இவர்(கள்)"}, {"w": 3, "t": "எவர்(கள்)/அவர்(கள்)"}, {"w": 4, "t": "he"}, {"w": 5, "t": "உங்கள் ராணுவமாக"}, {"w": 6, "t": "for you"}, {"w": 7, "t": "உங்களுக்கு உதவுகின்றார்(கள்)"}, {"w": 8, "t": "அன்றி"}, {"w": 9, "t": "besides"}, {"w": 10, "t": "பேரருளாளனை"}, {"w": 11, "t": "நிராகரிப்பாளர்கள் இல்லை"}, {"w": 12, "t": "(are) the disbelievers"}, {"w": 13, "t": "தவிர"}, {"w": 14, "t": "ஏமாற்றத்தில்"}, {"w": 15, "t": "delusion"}, {"w": 16, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "மாறாக, யார்?"}, {"w": 2, "t": "இவர்(கள்)/எவர்(கள்)"}, {"w": 3, "t": "the one"}, {"w": 4, "t": "உங்களுக்கு உணவளிக்கின்றார்(கள்)"}, {"w": 5, "t": "அவன் தடுத்துவிட்டால்"}, {"w": 6, "t": "He withheld"}, {"w": 7, "t": "தனது உணவை"}, {"w": 8, "t": "மாறாக,"}, {"w": 9, "t": "பிடிவாதம் பிடித்தனர்"}, {"w": 10, "t": "வரம்பு மீறுவதிலும்"}, {"w": 11, "t": "pride"}, {"w": 12, "t": "விலகிச் செல்வதிலும்தான்"}, {"w": 13, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "யார்?/நடக்கின்றான்"}, {"w": 2, "t": "walks"}, {"w": 3, "t": "கவிழ்ந்தவனாக"}, {"w": 4, "t": "தனது முகத்தின் மீது"}, {"w": 5, "t": "his face"}, {"w": 6, "t": "நேர்வழி பெற்றவனா"}, {"w": 7, "t": "அல்லது யார்?"}, {"w": 8, "t": "நடக்கின்றான்/சரியாக"}, {"w": 9, "t": "upright"}, {"w": 10, "t": "பாதையில்"}, {"w": 11, "t": "(the) Path"}, {"w": 12, "t": "நேரான"}, {"w": 13, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அவன்தான்"}, {"w": 3, "t": "(is) the One Who"}, {"w": 4, "t": "உங்களை உருவாக்கினான்"}, {"w": 5, "t": "இன்னும் ஏற்படுத்தினான்"}, {"w": 6, "t": "உங்களுக்கு"}, {"w": 7, "t": "செவியை(யும்)"}, {"w": 8, "t": "பார்வைகளையும்"}, {"w": 9, "t": "உள்ளங்களையும்"}, {"w": 10, "t": "மிகக் குறைவாகவே"}, {"w": 11, "t": "நீங்கள் நன்றி செலுத்துகின்றீர்கள்"}, {"w": 12, "t": "you give thanks"}, {"w": 13, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அவன்தான்"}, {"w": 3, "t": "(is) the One Who"}, {"w": 4, "t": "உங்களை பரத்தினான்"}, {"w": 5, "t": "பூமியில்"}, {"w": 6, "t": "the earth"}, {"w": 7, "t": "அவன் பக்கமே"}, {"w": 8, "t": "ஒன்று திரட்டப்படுவீர்கள்"}, {"w": 9, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவர்கள் கூறுகின்றனர்"}, {"w": 2, "t": "எப்போது நிகழும்"}, {"w": 3, "t": "இந்த"}, {"w": 4, "t": "வாக்கு"}, {"w": 5, "t": "நீங்கள் இருந்தால்"}, {"w": 6, "t": "you are"}, {"w": 7, "t": "உண்மையாளர்களாக"}, {"w": 8, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அறிவெல்லாம்"}, {"w": 3, "t": "the knowledge"}, {"w": 4, "t": "அல்லாஹ்விடம்தான்"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "நான் எல்லாம்"}, {"w": 7, "t": "I am"}, {"w": 8, "t": "எச்சரிப்பாளர்தான்"}, {"w": 9, "t": "தெளிவான"}, {"w": 10, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அவர்கள் அதை பார்க்கின்றபோது"}, {"w": 2, "t": "they (will) see it"}, {"w": 3, "t": "மிக நெருக்கமாக"}, {"w": 4, "t": "கெட்டுவிடும்"}, {"w": 5, "t": "முகங்கள்"}, {"w": 6, "t": "நிராகரித்தவர்களின்"}, {"w": 7, "t": "disbelieved"}, {"w": 8, "t": "இன்னும் கூறப்படும்"}, {"w": 9, "t": "இதுதான்"}, {"w": 10, "t": "எதை"}, {"w": 11, "t": "நீங்கள் இருந்தீர்களோ"}, {"w": 12, "t": "அதை"}, {"w": 13, "t": "தேடுபவர்களாக"}, {"w": 14, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "கூறுவிராக"}, {"w": 2, "t": "அறிவியுங்கள்"}, {"w": 3, "t": "என்னை(யும்) அழித்துவிட்டால்"}, {"w": 4, "t": "destroys me"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "என்னுடன் இருப்பவர்களையும்"}, {"w": 7, "t": "(is) with me"}, {"w": 8, "t": "அல்லது"}, {"w": 9, "t": "எங்கள் மீது கருணை புரிந்தால்"}, {"w": 10, "t": "யார்?"}, {"w": 11, "t": "காப்பாற்றுவார்"}, {"w": 12, "t": "நிராகரிப்பாளர்களை"}, {"w": 13, "t": "தண்டனையிலிருந்து"}, {"w": 14, "t": "a punishment"}, {"w": 15, "t": "வலி தரக்கூடிய(து)"}, {"w": 16, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அவன்தான்"}, {"w": 3, "t": "பேரருளாளன்"}, {"w": 4, "t": "நாங்கள் நம்பிக்கை கொண்டோம்"}, {"w": 5, "t": "அவனை"}, {"w": 6, "t": "இன்னும் அவன் மீதே"}, {"w": 7, "t": "நாங்கள் நம்பிக்கை வைத்தோம்"}, {"w": 8, "t": "விரைவில் அறிவீர்கள்"}, {"w": 9, "t": "வழிகேட்டில் உள்ளவர்களை"}, {"w": 10, "t": "(is) it"}, {"w": 11, "t": "(that is) in"}, {"w": 12, "t": "error"}, {"w": 13, "t": "தெளிவான"}, {"w": 14, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "கூறுவீராக"}, {"w": 2, "t": "அறிவியுங்கள்"}, {"w": 3, "t": "சென்று விட்டால்"}, {"w": 4, "t": "becomes"}, {"w": 5, "t": "உங்கள் தண்ணீர்"}, {"w": 6, "t": "ஆழத்தில்/யார்"}, {"w": 7, "t": "then who"}, {"w": 8, "t": "உங்களுக்கு தண்ணீரைக் கொண்டு வருவார்"}, {"w": 9, "t": "water"}, {"w": 10, "t": "மதுரமான"}, {"w": 11, "t": "(30)"}]}]}