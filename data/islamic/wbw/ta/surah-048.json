{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "வெற்றி வழங்கினோம்"}, {"w": 3, "t": "உமக்கு"}, {"w": 4, "t": "தெளிவானவெற்றியாக"}, {"w": 5, "t": "clear"}, {"w": 6, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "மன்னிப்பதற்காக(வும்)"}, {"w": 2, "t": "உமக்கு/அல்லாஹ்"}, {"w": 3, "t": "Allah"}, {"w": 4, "t": "முந்தியதையும்"}, {"w": 5, "t": "preceded"}, {"w": 6, "t": "உமது பாவத்தில்"}, {"w": 7, "t": "your sins"}, {"w": 8, "t": "பிந்தியதையும்"}, {"w": 9, "t": "will follow"}, {"w": 10, "t": "முழுமைப்படுத்துவதற்காகவும்"}, {"w": 11, "t": "அவனது அருளை"}, {"w": 12, "t": "உம்மீது"}, {"w": 13, "t": "உமக்கு வழி காண்பிப்பதற்காகவும்"}, {"w": 14, "t": "நேரான பாதையை"}, {"w": 15, "t": "Straight"}, {"w": 16, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "உமக்கு உதவி செய்வதற்காகவும்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "உதவி"}, {"w": 4, "t": "மிக கம்பீரமான"}, {"w": 5, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "எப்படிப்பட்டவன்"}, {"w": 3, "t": "இறக்கினான்"}, {"w": 4, "t": "அமைதியை"}, {"w": 5, "t": "உள்ளங்களில்"}, {"w": 6, "t": "(the) hearts"}, {"w": 7, "t": "நம்பிக்கையாளர்களின்"}, {"w": 8, "t": "அவர்கள் அதிகரிப்பதற்காக"}, {"w": 9, "t": "நம்பிக்கையால்"}, {"w": 10, "t": "அவர்கள் தங்கள் நம்பிக்கையுடன்"}, {"w": 11, "t": "their faith"}, {"w": 12, "t": "அல்லாஹ்விற்கு உரியனவே"}, {"w": 13, "t": "இராணுவங்கள்"}, {"w": 14, "t": "வானங்கள்"}, {"w": 15, "t": "இன்னும் பூமியின்"}, {"w": 16, "t": "இருக்கின்றான்"}, {"w": 17, "t": "அல்லாஹ்"}, {"w": 18, "t": "நன்கறிந்தவனாக"}, {"w": 19, "t": "மகா ஞானவானாக"}, {"w": 20, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவன் நுழைப்பதற்காக(வும்)"}, {"w": 2, "t": "நம்பிக்கை கொண்ட ஆண்களையும்"}, {"w": 3, "t": "நம்பிக்கை கொண்ட பெண்களையும்"}, {"w": 4, "t": "சொர்க்கங்களில்"}, {"w": 5, "t": "ஓடும்"}, {"w": 6, "t": "அவற்றின் கீழ்"}, {"w": 7, "t": "underneath them"}, {"w": 8, "t": "நதிகள்"}, {"w": 9, "t": "அவர்கள் நிரந்தரமாக தங்குவார்கள்"}, {"w": 10, "t": "அதில்"}, {"w": 11, "t": "அகற்றுவதற்காகவும்"}, {"w": 12, "t": "அவர்களை விட்டும்"}, {"w": 13, "t": "அவர்களின் பாவங்களை"}, {"w": 14, "t": "இருக்கின்றது"}, {"w": 15, "t": "இதுதான்"}, {"w": 16, "t": "அல்லாஹ்விடம்"}, {"w": 17, "t": "Allah"}, {"w": 18, "t": "வெற்றியாக"}, {"w": 19, "t": "மகத்தான"}, {"w": 20, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "வேதனை செய்வதற்காகவும்"}, {"w": 2, "t": "நயவஞ்சக ஆண்களை(யும்)"}, {"w": 3, "t": "நயவஞ்சக பெண்களையும்"}, {"w": 4, "t": "இணைவைக்கின்ற ஆண்களையும்"}, {"w": 5, "t": "இணைவைக்கின்ற பெண்களையும்"}, {"w": 6, "t": "எண்ணுகின்றனர்"}, {"w": 7, "t": "அல்லாஹ்வின் விஷயத்தில்"}, {"w": 8, "t": "கெட்ட எண்ணம்"}, {"w": 9, "t": "evil"}, {"w": 10, "t": "அவர்கள் மீதுதான்"}, {"w": 11, "t": "சுழற்சி இருக்கிறது"}, {"w": 12, "t": "கெட்ட"}, {"w": 13, "t": "கோபப்படுகின்றான்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "அவர்கள் மீது"}, {"w": 16, "t": "இன்னும் அவர்களை சபிக்கின்றான்"}, {"w": 17, "t": "இன்னும் தயார் செய்துள்ளான்"}, {"w": 18, "t": "அவர்களுக்கு"}, {"w": 19, "t": "நரகத்தை"}, {"w": 20, "t": "அது மிகக் கெட்ட மீளுமிடமாகும்"}, {"w": 21, "t": "(is the) destination"}, {"w": 22, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அல்லாஹ்விற்கே"}, {"w": 2, "t": "இராணுவங்கள்"}, {"w": 3, "t": "வானங்கள்"}, {"w": 4, "t": "இன்னும் பூமியின்"}, {"w": 5, "t": "இருக்கின்றான்"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "மிகைத்தவனாக"}, {"w": 8, "t": "மகா ஞானவானாக"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "உம்மை அனுப்பினோம்"}, {"w": 3, "t": "சாட்சியாளராக(வும்)"}, {"w": 4, "t": "நற்செய்தி கூறுபவராகவும்"}, {"w": 5, "t": "எச்சரிப்பவராகவும்"}, {"w": 6, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நீங்கள் நம்பிக்கை கொள்வதற்காக(வும்)"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "அவனது தூதரையும்"}, {"w": 4, "t": "அவரை கண்ணியப்படுத்துவதற்காகவும்"}, {"w": 5, "t": "அவரை மதிப்பதற்காகவும்"}, {"w": 6, "t": "அவனைப் புகழ்ந்து துதிப்பதற்காகவும்"}, {"w": 7, "t": "காலை(யிலும்)"}, {"w": 8, "t": "மாலையிலும்"}, {"w": 9, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நிச்சயமாக/எவர்கள்/உம்மிடம் விசுவாச உறுதிமொழி செய்கின்றார்கள்"}, {"w": 2, "t": "those who"}, {"w": 3, "t": "pledge allegiance to you"}, {"w": 4, "t": "அவர்கள் விசுவாச உறுதி மொழி செய்வதெல்லாம்"}, {"w": 5, "t": "they pledge allegiance"}, {"w": 6, "t": "அல்லாஹ்விடம்தான்"}, {"w": 7, "t": "கை"}, {"w": 8, "t": "அல்லாஹ்வின்"}, {"w": 9, "t": "மேல் இருக்கிறது"}, {"w": 10, "t": "அவர்களின் கைகளுக்கு"}, {"w": 11, "t": "ஆகவேயார் முறிப்பாரோ"}, {"w": 12, "t": "breaks (his oath)"}, {"w": 13, "t": "அவர்முறிப்பதெல்லாம்"}, {"w": 14, "t": "he breaks"}, {"w": 15, "t": "தனக்கு எதிராகத்தான்"}, {"w": 16, "t": "himself"}, {"w": 17, "t": "யார் நிறைவேற்றுவாரோ"}, {"w": 18, "t": "fulfils"}, {"w": 19, "t": "எதை/ ஒப்பந்தம் செய்தாரோ"}, {"w": 20, "t": "he has covenanted"}, {"w": 21, "t": "அதன் மீது"}, {"w": 22, "t": "அல்லாஹ்விடம்"}, {"w": 23, "t": "அவருக்குக்"}, {"w": 24, "t": "கூலியை"}, {"w": 25, "t": "மகத்தான(து)"}, {"w": 26, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "கூறுவார்(கள்)"}, {"w": 2, "t": "உமக்கு"}, {"w": 3, "t": "பின்தங்கியவர்கள்"}, {"w": 4, "t": "கிராம அரபிகளில்"}, {"w": 5, "t": "the Bedouins"}, {"w": 6, "t": "எங்களைஈடுபடுத்தின"}, {"w": 7, "t": "எங்கள்செல்வங்களும்"}, {"w": 8, "t": "எங்கள் குடும்பங்களும்"}, {"w": 9, "t": "ஆகவே, நீர் பாவமன்னிப்புக் கோருவீராக!"}, {"w": 10, "t": "எங்களுக்காக"}, {"w": 11, "t": "அவர்கள் கூறுகின்றனர்"}, {"w": 12, "t": "தங்கள் நாவுகளினால்"}, {"w": 13, "t": "இல்லாதவற்றை"}, {"w": 14, "t": "is not"}, {"w": 15, "t": "தங்கள் உள்ளங்களில்"}, {"w": 16, "t": "their hearts"}, {"w": 17, "t": "கூறுவீராக!"}, {"w": 18, "t": "யார்?"}, {"w": 19, "t": "உரிமை பெறுவார்"}, {"w": 20, "t": "உங்களுக்காக"}, {"w": 21, "t": "அல்லாஹ்விடம்"}, {"w": 22, "t": "Allah"}, {"w": 23, "t": "எதற்கும்"}, {"w": 24, "t": "நாடினால்"}, {"w": 25, "t": "He intends"}, {"w": 26, "t": "உங்களுக்கு"}, {"w": 27, "t": "தீங்கை"}, {"w": 28, "t": "அல்லது/நாடினால்"}, {"w": 29, "t": "He intends"}, {"w": 30, "t": "உங்களுக்கு"}, {"w": 31, "t": "நன்மையை"}, {"w": 32, "t": "மாறாக"}, {"w": 33, "t": "இருக்கின்றான்"}, {"w": 34, "t": "அல்லாஹ்"}, {"w": 35, "t": "நீங்கள் செய்வதை"}, {"w": 36, "t": "you do"}, {"w": 37, "t": "ஆழ்ந்தறிபவனாக"}, {"w": 38, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "நீங்கள் எண்ணினீர்கள்"}, {"w": 3, "t": "அறவே திரும்ப மாட்டார்(கள்) என்று"}, {"w": 4, "t": "(would) never"}, {"w": 5, "t": "return"}, {"w": 6, "t": "தூதரும்"}, {"w": 7, "t": "நம்பிக்கையாளர்களும்"}, {"w": 8, "t": "தங்கள் குடும்பங்களுக்கு"}, {"w": 9, "t": "their families"}, {"w": 10, "t": "ஒருபோதும்"}, {"w": 11, "t": "இன்னும் அலங்கரிக்கப்பட்டு விட்டது"}, {"w": 12, "t": "இது"}, {"w": 13, "t": "உங்கள் உள்ளங்களில்"}, {"w": 14, "t": "your hearts"}, {"w": 15, "t": "(இன்னும் நீ) எண்ணினீர்கள்"}, {"w": 16, "t": "எண்ணம்"}, {"w": 17, "t": "கெட்ட"}, {"w": 18, "t": "நீங்கள் இருக்கின்றீர்கள்"}, {"w": 19, "t": "மக்களாக"}, {"w": 20, "t": "அழிந்து போகின்ற"}, {"w": 21, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "எவர்(கள்)"}, {"w": 2, "t": "நம்பிக்கை கொள்ளவில்லையோ"}, {"w": 3, "t": "(has) not believed"}, {"w": 4, "t": "அல்லாஹ்வை(யும்)"}, {"w": 5, "t": "அவனது தூதரையும்"}, {"w": 6, "t": "நிச்சயமாக நாம்"}, {"w": 7, "t": "தயார் செய்துள்ளோம்"}, {"w": 8, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 9, "t": "கொழுந்து விட்டெரியும் நரகத்தை"}, {"w": 10, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அல்லாஹ்விற்கே"}, {"w": 2, "t": "ஆட்சி"}, {"w": 3, "t": "வானங்கள்"}, {"w": 4, "t": "பூமியின்"}, {"w": 5, "t": "மன்னிக்கின்றான்"}, {"w": 6, "t": "தான் நாடுகின்றவர்களை"}, {"w": 7, "t": "He wills"}, {"w": 8, "t": "இன்னும் வேதனை செய்கின்றான்"}, {"w": 9, "t": "தான் நாடுகின்றவர்களை"}, {"w": 10, "t": "He wills"}, {"w": 11, "t": "இருக்கின்றான்"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "மகா மன்னிப்பாளனாக"}, {"w": 14, "t": "மகாகருணையாளனாக"}, {"w": 15, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "கூறுவார்(கள்)"}, {"w": 2, "t": "பின்தங்கியவர்கள்"}, {"w": 3, "t": "நீங்கள் சென்றால்"}, {"w": 4, "t": "you set forth"}, {"w": 5, "t": "கனீமத்துகளை நோக்கி"}, {"w": 6, "t": "(the) spoils of war"}, {"w": 7, "t": "அவற்றை நீங்கள் எடுப்பதற்காக"}, {"w": 8, "t": "எங்களை விடுங்கள்"}, {"w": 9, "t": "நாங்களும் உங்களைப் பின்பற்றி வருகிறோம்"}, {"w": 10, "t": "அவர்கள் நாடுகின்றனர்"}, {"w": 11, "t": "அவர்கள் மாற்றிவிட"}, {"w": 12, "t": "change"}, {"w": 13, "t": "பேச்சை"}, {"w": 14, "t": "அல்லாஹ்வின்"}, {"w": 15, "t": "நீர் கூறுவீராக!"}, {"w": 16, "t": "அறவே நீங்கள் எங்களை பின்பற்ற மாட்டீர்கள்"}, {"w": 17, "t": "will you follow us"}, {"w": 18, "t": "இப்படித்தான்"}, {"w": 19, "t": "கூறி இருக்கின்றான்"}, {"w": 20, "t": "அல்லாஹ்"}, {"w": 21, "t": "இதற்கு முன்னரே"}, {"w": 22, "t": "before"}, {"w": 23, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 24, "t": "இல்லை"}, {"w": 25, "t": "நீங்கள் எங்கள் மீது பொறாமைப்படுகின்றீர்கள்"}, {"w": 26, "t": "மாறாக"}, {"w": 27, "t": "இருக்கின்றனர்"}, {"w": 28, "t": "விளங்காதவர்களாக"}, {"w": 29, "t": "understanding"}, {"w": 30, "t": "தவிர"}, {"w": 31, "t": "குறைந்த விஷயங்களை"}, {"w": 32, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "பின்தங்கியவர்களை நோக்கி"}, {"w": 3, "t": "கிராமவாசிகளில்"}, {"w": 4, "t": "the Bedouins"}, {"w": 5, "t": "அழைக்கப்படுவீர்கள்"}, {"w": 6, "t": "கூட்டத்தின் பக்கம்"}, {"w": 7, "t": "a people"}, {"w": 8, "t": "பலமுடைய(வர்கள்)"}, {"w": 9, "t": "possessors of military might"}, {"w": 10, "t": "கடுமையான(து)"}, {"w": 11, "t": "அவர்களிடம் நீங்கள் சண்டை செய்வதற்காக"}, {"w": 12, "t": "அல்லது/அவர்கள் பணிந்து விடுவதற்காக"}, {"w": 13, "t": "they will submit"}, {"w": 14, "t": "நீங்கள் கீழ்ப்படிந்தால்"}, {"w": 15, "t": "you obey"}, {"w": 16, "t": "உங்களுக்கு கொடுப்பான்"}, {"w": 17, "t": "அல்லாஹ்"}, {"w": 18, "t": "கூலியை"}, {"w": 19, "t": "அழகிய(து)"}, {"w": 20, "t": "நீங்கள் விலகினால்"}, {"w": 21, "t": "you turn away"}, {"w": 22, "t": "நீங்கள் விலகியதை போன்று"}, {"w": 23, "t": "you turned away"}, {"w": 24, "t": "இதற்கு முன்பு"}, {"w": 25, "t": "before"}, {"w": 26, "t": "உங்களை தண்டிப்பான்"}, {"w": 27, "t": "தண்டனையால்"}, {"w": 28, "t": "வலி தரக்கூடிய(து)"}, {"w": 29, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "குருடர் மீது"}, {"w": 3, "t": "the blind"}, {"w": 4, "t": "சிரமம்"}, {"w": 5, "t": "இன்னும் இல்லை"}, {"w": 6, "t": "ஊனமானவர் மீது"}, {"w": 7, "t": "the lame"}, {"w": 8, "t": "சிரமம்"}, {"w": 9, "t": "இல்லை"}, {"w": 10, "t": "நோயாளி மீது"}, {"w": 11, "t": "the sick"}, {"w": 12, "t": "சிரமம்"}, {"w": 13, "t": "எவர்"}, {"w": 14, "t": "கீழ்ப்படிவாரோ"}, {"w": 15, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 16, "t": "அவனது தூதருக்கும்"}, {"w": 17, "t": "அவரை நுழைப்பான்"}, {"w": 18, "t": "சொர்க்கங்களில்"}, {"w": 19, "t": "ஓடும்"}, {"w": 20, "t": "அவற்றின் கீழ்"}, {"w": 21, "t": "underneath them"}, {"w": 22, "t": "நதிகள்"}, {"w": 23, "t": "எவர்"}, {"w": 24, "t": "விலகுவாரோ"}, {"w": 25, "t": "அவரை தண்டிப்பான்"}, {"w": 26, "t": "தண்டனையால்"}, {"w": 27, "t": "வலி தரக்கூடிய"}, {"w": 28, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "திருப்தி அடைந்தான்"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "நம்பிக்கையாளர்களை"}, {"w": 5, "t": "the believers"}, {"w": 6, "t": "உம்மிடம் அவர்கள் விசுவாச வாக்குறுதி செய்தபோது"}, {"w": 7, "t": "they pledged allegiance to you"}, {"w": 8, "t": "மரத்தின் கீழ்"}, {"w": 9, "t": "the tree"}, {"w": 10, "t": "அவன் அறிந்தான்"}, {"w": 11, "t": "அவர்களின் உள்ளங்களில் உள்ளதை"}, {"w": 12, "t": "(was) in"}, {"w": 13, "t": "their hearts"}, {"w": 14, "t": "ஆகவே, இறக்கினான்"}, {"w": 15, "t": "அமைதியை"}, {"w": 16, "t": "அவர்கள் மீது"}, {"w": 17, "t": "இன்னும் வெகுமதியாக கொடுத்தான்"}, {"w": 18, "t": "ஒரு வெற்றியை(யும்)"}, {"w": 19, "t": "சமீபமான(து)"}, {"w": 20, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் கனீமத்துகளை"}, {"w": 2, "t": "அதிகமான"}, {"w": 3, "t": "அவர்கள் அவற்றை பெறுவார்கள்"}, {"w": 4, "t": "இருக்கின்றான்"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "மிகைத்தவனாக"}, {"w": 7, "t": "மகா ஞானவானாக"}, {"w": 8, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "வாக்களித்தான் உங்களுக்கு"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "கனீமத்துகளை"}, {"w": 4, "t": "அதிகமான"}, {"w": 5, "t": "அவற்றை நீங்கள் பெறுவீர்கள்"}, {"w": 6, "t": "விரைவாக கொடுத்தான்"}, {"w": 7, "t": "உங்களுக்கு/இதை"}, {"w": 8, "t": "this"}, {"w": 9, "t": "இன்னும் அவன் தடுத்தான்"}, {"w": 10, "t": "கரங்களை"}, {"w": 11, "t": "மக்களின்"}, {"w": 12, "t": "உங்களை விட்டும்"}, {"w": 13, "t": "இருப்பதற்காகவும்"}, {"w": 14, "t": "இறை அத்தாட்சியாக"}, {"w": 15, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 16, "t": "உங்களை வழி நடத்துவதற்காகவும்"}, {"w": 17, "t": "பாதையில்"}, {"w": 18, "t": "நேரான"}, {"w": 19, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "இன்னும் வேறு பல"}, {"w": 2, "t": "நீங்கள் ஆற்றல் பெறவில்லை"}, {"w": 3, "t": "you had power"}, {"w": 4, "t": "அவற்றின் மீது"}, {"w": 5, "t": "திட்டமாக"}, {"w": 6, "t": "சூழ்ந்திருக்கின்றான்"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "அவற்றை"}, {"w": 9, "t": "இருக்கின்றான்"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "எல்லாவற்றின் மீதும்"}, {"w": 12, "t": "all"}, {"w": 13, "t": "things"}, {"w": 14, "t": "பேராற்றலுடையவனாக"}, {"w": 15, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "உங்களிடம் போருக்கு வந்தால்"}, {"w": 2, "t": "fight you"}, {"w": 3, "t": "நிராகரிப்பாளர்கள்"}, {"w": 4, "t": "disbelieve"}, {"w": 5, "t": "புறமுதுகு காட்டியிருப்பார்கள்"}, {"w": 6, "t": "the backs"}, {"w": 7, "t": "பிறகு"}, {"w": 8, "t": "காணமாட்டார்கள்"}, {"w": 9, "t": "they would find"}, {"w": 10, "t": "பாதுகாவலரையும்"}, {"w": 11, "t": "உதவியாளரையும்"}, {"w": 12, "t": "any helper"}, {"w": 13, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நடைமுறைப்படிதான்"}, {"w": 2, "t": "அல்லாஹ்வின்"}, {"w": 3, "t": "எது/சென்றுவிட்டது"}, {"w": 4, "t": "passed away"}, {"w": 5, "t": "passed away"}, {"w": 6, "t": "இதற்கு முன்னர்"}, {"w": 7, "t": "before"}, {"w": 8, "t": "நீர் காணமாட்டீர்"}, {"w": 9, "t": "you will find"}, {"w": 10, "t": "நடைமுறைக்கு"}, {"w": 11, "t": "அல்லாஹ்வின்"}, {"w": 12, "t": "மாற்றத்தை(யும்)"}, {"w": 13, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "த