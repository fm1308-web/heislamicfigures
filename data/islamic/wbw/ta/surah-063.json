{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "உம்மிடம் வந்தால்"}, {"w": 2, "t": "come to you"}, {"w": 3, "t": "நயவஞ்சகர்கள்"}, {"w": 4, "t": "கூறுவார்கள்"}, {"w": 5, "t": "நாங்கள் சாட்சி பகருகிறோம்"}, {"w": 6, "t": "நிச்சயமாக நீர்"}, {"w": 7, "t": "தூதர்தான் என்று"}, {"w": 8, "t": "அல்லாஹ்வின்"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "நன்கறிவான்"}, {"w": 11, "t": "நிச்சயமாக நீர்"}, {"w": 12, "t": "அவனது தூதர்தான் என்று"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "சாட்சி பகருகின்றான்"}, {"w": 15, "t": "நிச்சயமாக"}, {"w": 16, "t": "நயவஞ்சகர்கள்"}, {"w": 17, "t": "பொய்யர்கள்தான்"}, {"w": 18, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "ஆக்கிக் கொண்டனர்"}, {"w": 2, "t": "தங்கள் சத்தியங்களை"}, {"w": 3, "t": "கேடயமாக"}, {"w": 4, "t": "தடுத்தனர்"}, {"w": 5, "t": "பாதையை விட்டு"}, {"w": 6, "t": "(the) Way"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "நிச்சயமாக அவர்கள்"}, {"w": 9, "t": "மிகக் கெட்டுவிட்டன"}, {"w": 10, "t": "அவர்கள் செய்துகொண்டிருந்தவை"}, {"w": 11, "t": "they used to"}, {"w": 12, "t": "do"}, {"w": 13, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அதற்கு காரணம்"}, {"w": 2, "t": "நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 4, "t": "பிறகு"}, {"w": 5, "t": "நிராகரித்தனர்"}, {"w": 6, "t": "ஆகவே, முத்திரை இடப்பட்டுவிட்டது"}, {"w": 7, "t": "அவர்களின் உள்ளங்கள் மீது"}, {"w": 8, "t": "their hearts"}, {"w": 9, "t": "ஆகவே, அவர்கள்"}, {"w": 10, "t": "புரிய மாட்டார்கள்"}, {"w": 11, "t": "understand"}, {"w": 12, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நீர் அவர்களைப் பார்த்தால்"}, {"w": 2, "t": "you see them"}, {"w": 3, "t": "உம்மைக் கவரும்"}, {"w": 4, "t": "அவர்களின் உடல்கள்"}, {"w": 5, "t": "அவர்கள் கூறினால்"}, {"w": 6, "t": "they speak"}, {"w": 7, "t": "நீர் செவியுறுவீர்"}, {"w": 8, "t": "அவர்களின் கூற்றை"}, {"w": 9, "t": "அவர்கள் மரப்பலகைகளைப் போல்"}, {"w": 10, "t": "pieces of wood"}, {"w": 11, "t": "சாய்த்து வைக்கப்பட்ட"}, {"w": 12, "t": "எண்ணுவார்கள்"}, {"w": 13, "t": "ஒவ்வொரு"}, {"w": 14, "t": "சப்தத்தையும்"}, {"w": 15, "t": "தங்களுக்கு பாதகமாகவே"}, {"w": 16, "t": "அவர்கள்தான்"}, {"w": 17, "t": "எதிரிகள்"}, {"w": 18, "t": "ஆகவே அவர்களிடம் கவனமாக இருப்பீராக!"}, {"w": 19, "t": "அவர்களை அழிப்பான்"}, {"w": 20, "t": "அல்லாஹ்"}, {"w": 21, "t": "எவ்வாறு"}, {"w": 22, "t": "அவர்கள் திருப்பப்படுகின்றார்கள்"}, {"w": 23, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "கூறப்பட்டால்"}, {"w": 2, "t": "it is said"}, {"w": 3, "t": "அவர்களிடம்"}, {"w": 4, "t": "வாருங்கள்"}, {"w": 5, "t": "மன்னிப்புத் தேடுவார்"}, {"w": 6, "t": "உங்களுக்காக"}, {"w": 7, "t": "தூதர்"}, {"w": 8, "t": "அல்லாஹ்வின்"}, {"w": 9, "t": "வேகமாக அசைக்கிறார்கள்"}, {"w": 10, "t": "தங்கள் தலைகளை"}, {"w": 11, "t": "இன்னும் அவர்களை நீர் பார்ப்பீர்"}, {"w": 12, "t": "புறக்கணிப்பவர்களாகவே"}, {"w": 13, "t": "அவர்கள்"}, {"w": 14, "t": "கர்வம் கொள்பவர்கள்"}, {"w": 15, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "சமம்தான்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "நீர் பாவமன்னிப்புத் தேடினாலும்"}, {"w": 4, "t": "அவர்களுக்காக"}, {"w": 5, "t": "நீர் பாவமன்னிப்புத் தேடவில்லை என்றாலும்"}, {"w": 6, "t": "(do) not"}, {"w": 7, "t": "ask forgiveness"}, {"w": 8, "t": "அவர்களுக்காக"}, {"w": 9, "t": "மன்னிக்கவே மாட்டான்"}, {"w": 10, "t": "will forgive"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "அவர்களை"}, {"w": 13, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 14, "t": "Allah"}, {"w": 15, "t": "நேர்வழி செலுத்த மாட்டான்"}, {"w": 16, "t": "guide"}, {"w": 17, "t": "மக்களை"}, {"w": 18, "t": "பாவிகளான"}, {"w": 19, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இவர்கள்தான்"}, {"w": 2, "t": "(are) those who"}, {"w": 3, "t": "கூறுகிறார்கள்"}, {"w": 4, "t": "தர்மம் செய்யாதீர்கள்"}, {"w": 5, "t": "spend"}, {"w": 6, "t": "மீது"}, {"w": 7, "t": "அல்லாஹ்வின் தூதரிடம் இருப்பவர்கள்"}, {"w": 8, "t": "(are) with"}, {"w": 9, "t": "(the) Messenger"}, {"w": 10, "t": "(of) Allah"}, {"w": 11, "t": "இறுதியாக"}, {"w": 12, "t": "பிரிந்து விடுவார்கள்"}, {"w": 13, "t": "அல்லாஹ்விற்கே"}, {"w": 14, "t": "பொக்கிஷங்கள்"}, {"w": 15, "t": "வானங்கள்"}, {"w": 16, "t": "இன்னும் பூமியின்"}, {"w": 17, "t": "என்றாலும்"}, {"w": 18, "t": "நயவஞ்சகர்கள்"}, {"w": 19, "t": "புரிய மாட்டார்கள்"}, {"w": 20, "t": "understand"}, {"w": 21, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "கூறுகின்றனர்"}, {"w": 2, "t": "நாம் திரும்பினால்"}, {"w": 3, "t": "we return"}, {"w": 4, "t": "மதீனாவிற்கு"}, {"w": 5, "t": "Al-Madinah"}, {"w": 6, "t": "நிச்சயமாக வெளியேற்றவேண்டும்"}, {"w": 7, "t": "கண்ணியவான்கள்"}, {"w": 8, "t": "அதிலிருந்து"}, {"w": 9, "t": "தாழ்ந்தவர்களை"}, {"w": 10, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 11, "t": "கண்ணியம்"}, {"w": 12, "t": "அவனது தூதருக்கும்"}, {"w": 13, "t": "நம்பிக்கையாளர்களுக்கும்தான்"}, {"w": 14, "t": "என்றாலும்"}, {"w": 15, "t": "நயவஞ்சகர்கள்"}, {"w": 16, "t": "அறியமாட்டார்கள்"}, {"w": 17, "t": "know"}, {"w": 18, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "you (who)"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "உங்களை ஈடுபடுத்தி விடவேண்டாம்"}, {"w": 5, "t": "divert you"}, {"w": 6, "t": "உங்கள் செல்வங்களும்"}, {"w": 7, "t": "உங்கள் பிள்ளைகளும்"}, {"w": 8, "t": "your children"}, {"w": 9, "t": "அல்லாஹ்வின் நினைவை விட்டும்"}, {"w": 10, "t": "(the) remembrance"}, {"w": 11, "t": "(of) Allah"}, {"w": 12, "t": "யார்"}, {"w": 13, "t": "செய்துவிடுவார்களோ"}, {"w": 14, "t": "அப்படி"}, {"w": 15, "t": "அவர்கள்தான்"}, {"w": 16, "t": "[they]"}, {"w": 17, "t": "நஷ்டவாளிகள்"}, {"w": 18, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "தர்மம் செய்யுங்கள்"}, {"w": 2, "t": "நாம் உங்களுக்கு கொடுத்தவற்றில் இருந்து"}, {"w": 3, "t": "what"}, {"w": 4, "t": "We have provided you"}, {"w": 5, "t": "முன்னர்"}, {"w": 6, "t": "before"}, {"w": 7, "t": "வருவதற்கு"}, {"w": 8, "t": "comes"}, {"w": 9, "t": "உங்களில் ஒருவருக்கு"}, {"w": 10, "t": "மரணம்"}, {"w": 11, "t": "அவர் கூறுவார்"}, {"w": 12, "t": "என் இறைவா!"}, {"w": 13, "t": "நீ என்னை பிற்படுத்தி வைக்கமாட்டாயா!"}, {"w": 14, "t": "You delay me"}, {"w": 15, "t": "தவணை வரை"}, {"w": 16, "t": "a term"}, {"w": 17, "t": "கொஞ்சம் சமீபமான"}, {"w": 18, "t": "நான் தர்மம் செய்வேனே"}, {"w": 19, "t": "இன்னும் ஆகிவிடுவேனே"}, {"w": 20, "t": "நல்லவர்களில்"}, {"w": 21, "t": "the righteous"}, {"w": 22, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "தாமதப்படுத்தவே மாட்டான்"}, {"w": 2, "t": "will (be) delayed"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "ஓர் உயிரை"}, {"w": 5, "t": "வந்துவிட்டால்"}, {"w": 6, "t": "has come"}, {"w": 7, "t": "அதற்குரிய தவணை"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "ஆழ்ந்தறிபவன்"}, {"w": 10, "t": "நீங்கள் செய்பவற்றை"}, {"w": 11, "t": "you do"}, {"w": 12, "t": "(11)"}]}]}