{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "தூர் மலையின் மீது சத்தியமாக!"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "புத்தகத்தின் மீது சத்தியமாக!"}, {"w": 2, "t": "எழுதப்பட்டது"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "காகிதத்தில்"}, {"w": 2, "t": "parchment"}, {"w": 3, "t": "விரிக்கப்பட்டது"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "ஆலயத்தின் மீது சத்தியமாக!"}, {"w": 2, "t": "செழிப்பான(து)"}, {"w": 3, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "முகட்டின் மீது சத்தியமாக!"}, {"w": 2, "t": "உயர்த்தப்பட்ட(து)"}, {"w": 3, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கடலின் மீது சத்தியமாக!"}, {"w": 2, "t": "நீரால் நிரம்பிய(து)"}, {"w": 3, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "தண்டனை"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "நிகழ்ந்தே தீரும்"}, {"w": 5, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இல்லை/அதை"}, {"w": 2, "t": "for it"}, {"w": 3, "t": "தடுப்பவர்"}, {"w": 4, "t": "preventer"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நாளில்/குலுங்குகின்ற"}, {"w": 2, "t": "will shake"}, {"w": 3, "t": "வானம்/குலுங்குதல்"}, {"w": 4, "t": "(with violent) shake"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் செல்லும்"}, {"w": 2, "t": "மலைகள்"}, {"w": 3, "t": "செல்வது"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஆகவே நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பிப்பவர்களுக்கு"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "எவர்கள்/அவர்கள்"}, {"w": 2, "t": "[they]"}, {"w": 3, "t": "குழப்பத்தில் இருந்துகொண்டு"}, {"w": 4, "t": "(vain) discourse"}, {"w": 5, "t": "விளையாடுகிறார்கள்"}, {"w": 6, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "அவர்கள் தள்ளப்படுகின்ற(னர்)"}, {"w": 3, "t": "நரக நெருப்பின் பக்கம்"}, {"w": 4, "t": "(the) Fire"}, {"w": 5, "t": "(of) Hell"}, {"w": 6, "t": "தள்ளப்படுதல்"}, {"w": 7, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இது/நெருப்பு"}, {"w": 2, "t": "(is) the Fire"}, {"w": 3, "t": "எது/நீங்கள் இருந்தீர்கள்"}, {"w": 4, "t": "you used to"}, {"w": 5, "t": "அதை/பொய்ப்பிப்பவர்களாக"}, {"w": 6, "t": "deny"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "என்ன சூனியமா?"}, {"w": 2, "t": "இது"}, {"w": 3, "t": "?/நீங்கள்"}, {"w": 4, "t": "you"}, {"w": 5, "t": "பார்க்கவில்லையா"}, {"w": 6, "t": "see"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இதில் எரிந்து பொசுங்குங்கள்!"}, {"w": 2, "t": "பொறுமையாக இருங்கள்!"}, {"w": 3, "t": "அல்லது"}, {"w": 4, "t": "பொறுக்காதீர்கள்!"}, {"w": 5, "t": "be patient"}, {"w": 6, "t": "இரண்டும் சமம்தான்"}, {"w": 7, "t": "உங்களுக்கு"}, {"w": 8, "t": "நீங்கள் கூலி கொடுக்கப்படுவதெல்லாம்"}, {"w": 9, "t": "you are being recompensed"}, {"w": 10, "t": "நீங்கள் செய்து கொண்டிருந்தவற்றுக்குத்தான்"}, {"w": 11, "t": "you used to"}, {"w": 12, "t": "do"}, {"w": 13, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இறையச்சமுடையவர்கள்"}, {"w": 3, "t": "சொர்க்கங்களிலும்"}, {"w": 4, "t": "Gardens"}, {"w": 5, "t": "இன்பங்களிலும்"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவர்களிடம் பழங்கள்"}, {"w": 2, "t": "அவர்களுக்கு வழங்கியதால்"}, {"w": 3, "t": "has given them"}, {"w": 4, "t": "அவர்களின் இறைவன்"}, {"w": 5, "t": "இன்னும் அவர்களை பாதுகாப்பான்"}, {"w": 6, "t": "அவர்களின் இறைவன்"}, {"w": 7, "t": "நரக வேதனையை விட்டும்"}, {"w": 8, "t": "(of) Hellfire"}, {"w": 9, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "உண்ணுங்கள்"}, {"w": 2, "t": "இன்னும் பருகுங்கள்"}, {"w": 3, "t": "மகிழ்ச்சியாக"}, {"w": 4, "t": "for what"}, {"w": 5, "t": "நீங்கள் செய்துகொண்டிருந்த காரணத்தால்"}, {"w": 6, "t": "do"}, {"w": 7, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "சாய்ந்தவர்களாக இருப்பார்கள்"}, {"w": 2, "t": "கட்டில்களில்"}, {"w": 3, "t": "thrones"}, {"w": 4, "t": "வரிசையாக வைக்கப்பட்ட தலையணைகளில்"}, {"w": 5, "t": "அவர்களுக்கு நாம் மணமுடித்துவைப்போம்"}, {"w": 6, "t": "கண்ணழகிகளான கருவிழிகளுடைய பெண்களை"}, {"w": 7, "t": "(with) large eyes"}, {"w": 8, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டார்களோ"}, {"w": 3, "t": "இன்னும் அவர்களைப் பின்பற்றினார்களோ"}, {"w": 4, "t": "அவர்களின் சந்ததிகளும்"}, {"w": 5, "t": "இறை நம்பிக்கையில்"}, {"w": 6, "t": "அவர்களுடன் சேர்த்து வைப்போம்"}, {"w": 7, "t": "with them"}, {"w": 8, "t": "அவர்களின் சந்ததிகளை"}, {"w": 9, "t": "அவர்களுக்கு நாம் குறைக்க மாட்டோம்"}, {"w": 10, "t": "We will deprive them"}, {"w": 11, "t": "அவர்களின் அமல்களில்"}, {"w": 12, "t": "their deeds"}, {"w": 13, "t": "எதையும்"}, {"w": 14, "t": "thing"}, {"w": 15, "t": "ஒவ்வொரு/மனிதனும்"}, {"w": 16, "t": "person"}, {"w": 17, "t": "தான் செய்த செயலுக்காக"}, {"w": 18, "t": "he earned"}, {"w": 19, "t": "தடுத்து வைக்கப்பட்டிருப்பான்"}, {"w": 20, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நாம் இவர்களுக்கு கொடுத்துக் கொண்டே இருப்போம்"}, {"w": 2, "t": "பழங்களை(யும்)"}, {"w": 3, "t": "மாமிசங்களையும்"}, {"w": 4, "t": "அவர்கள் விரும்புகின்றவற்றின்"}, {"w": 5, "t": "they desire"}, {"w": 6, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அதில் ஒருவருக்கொருவர் பரிமாறிக் கொள்வார்கள்"}, {"w": 2, "t": "therein"}, {"w": 3, "t": "குடிபானம் நிறைந்த குவளைகளை"}, {"w": 4, "t": "அதில் பொய் இருக்காது"}, {"w": 5, "t": "ill speech"}, {"w": 6, "t": "therein"}, {"w": 7, "t": "பிறரை பாவத்தில் தள்ளுகின்ற செயல்கள் இருக்காது"}, {"w": 8, "t": "sin"}, {"w": 9, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "சுற்றி வருவார்கள்"}, {"w": 2, "t": "அவர்களை"}, {"w": 3, "t": "சிறுவர்கள்"}, {"w": 4, "t": "அவர்களுக்குரிய"}, {"w": 5, "t": "அவர்களோ இருப்பார்கள்"}, {"w": 6, "t": "முத்துக்களைப் போன்று"}, {"w": 7, "t": "பாதுகாக்கப்பட்ட"}, {"w": 8, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "முன்னோக்கி வருவார்கள்"}, {"w": 2, "t": "அவர்களில் சிலர்"}, {"w": 3, "t": "சிலரை"}, {"w": 4, "t": "others"}, {"w": 5, "t": "தங்களுக்குள் கேட்டவர்களாக"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "நிச்சயமாக நாங்கள்"}, {"w": 3, "t": "இருந்தோம்"}, {"w": 4, "t": "இதற்கு முன்னர்"}, {"w": 5, "t": "எங்கள் குடும்பங்களில்"}, {"w": 6, "t": "our families"}, {"w": 7, "t": "பயந்தவர்களாகவே"}, {"w": 8, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "ஆக, உபகாரம் புரிந்தான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "எங்கள் மீது"}, {"w": 4, "t": "இன்னும் எங்களை பாதுகாத்தான்"}, {"w": 5, "t": "வேதனையை விட்டும்"}, {"w": 6, "t": "நரகத்தின்"}, {"w": 7, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "இருந்தோம்"}, {"w": 3, "t": "இதற்கு முன்னர்"}, {"w": 4, "t": "before"}, {"w": 5, "t": "அவனை அழைப்பவர்களாக"}, {"w": 6, "t": "நிச்சயமாக அவன்தான்"}, {"w": 7, "t": "[He]"}, {"w": 8, "t": "மிகவும் அருளுடையவன்"}, {"w": 9, "t": "மகா கருணையாளன்"}, {"w": 10, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "ஆகவே, நல்லுபதேசம் செய்வீராக!"}, {"w": 2, "t": "நீர் இல்லை"}, {"w": 3, "t": "you"}, {"w": 4, "t": "அருட்கொடையால்"}, {"w": 5, "t": "உமது இறைவனின்"}, {"w": 6, "t": "குறிசொல்பவராக(வும்)"}, {"w": 7, "t": "பைத்தியக்காரராகவும்"}, {"w": 8, "t": "a madman"}, {"w": 9, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "அல்லது கூறுகிறார்களா?"}, {"w": 2, "t": "(do) they say"}, {"w": 3, "t": "ஒரு கவிஞர்"}, {"w": 4, "t": "நாங்கள் எதிர்பார்க்கின்றோம்"}, {"w": 5, "t": "அவருக்கு"}, {"w": 6, "t": "அசம்பாவிதங்களை"}, {"w": 7, "t": "காலத்தின்"}, {"w": 8, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நீங்கள் எதிர்பாருங்கள்"}, {"w": 3, "t": "நிச்சயமாக நானும்"}, {"w": 4, "t": "உங்களுடன்"}, {"w": 5, "t": "எதிர்பார்ப்பவர்களில்"}, {"w": 6, "t": "those who wait"}, {"w": 7, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அவர்களை ஏவுகின்றதா?"}, {"w": 2, "t": "command them"}, {"w": 3, "t": "அவர்களது அறிவுகள்"}, {"w": 4, "t": "இதற்கு"}, {"w": 5, "t": "அல்லது அவர்கள்"}, {"w": 6, "t": "they"}, {"w": 7, "t": "மக்களா?"}, {"w": 8, "t": "வரம்பு மீறுகின்ற(வர்கள்)"}, {"w": 9, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "அல்லது கூறுகிறார்களா?"}, {"w": 2, "t": "(do) they say"}, {"w": 3, "t": "இதை புனைந்து கூறுகிறார்"}, {"w": 4, "t": "மாறாக/நம்பிக்கை கொள்ளவே மாட்டார்கள்"}, {"w": 5, "t": "not"}, {"w": 6, "t": "they believe"}, {"w": 7, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இது போன்ற ஒரு பேச்சை அவர்கள் கொண்டு வரட்டும்!"}, {"w": 2, "t": "a statement"}, {"w": 3, "t": "like it"}, {"w": 4, "t": "இவர்கள் உண்மையாளர்களாக இருந்தால்"}, {"w": 5, "t": "they are"}, {"w": 6, "t": "truthful"}, {"w": 7, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இவர்கள் படைக்கப்பட்டார்களா?"}, {"w": 2, "t": "they were created"}, {"w": 3, "t": "ஏதும் இன்றி"}, {"w": 4, "t": "nothing"}, {"w": 5, "t": "nothing"}, {"w": 6, "t": "அல்லது"}, {"w": 7, "t": "இவர்கள்தான்"}, {"w": 8, "t": "படைத்தவர்களா?"}, {"w": 9, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "இவர்கள்தான் படைத்தார்களா?"}, {"w": 2, "t": "(did) they create"}, {"w": 3, "t": "வானங்களை(யும்)"}, {"w": 4, "t": "பூமியையும்"}, {"w": 5, "t": "மாறாக"}, {"w": 6, "t": "நம்பிக்கை கொள்ள மாட்டார்கள்"}, {"w": 7, "t": "they are certain"}, {"w": 8, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இவர்களிடம் இருக்கின்றனவா?"}, {"w": 2, "t": "with them"}, {"w": 3, "t": "பொக்கிஷங்கள்"}, {"w": 4, "t": "உமது இறைவனின்"}, {"w": 5, "t": "அல்லது அவர்கள் அடக்கிவிடக் கூடியவர்களா?"}, {"w": 6, "t": "(are) they"}, {"w": 7, "t": "the controllers"}, {"w": 8, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "?/அவர்களுக்கு"}, {"w": 2, "t": "for them"}, {"w": 3, "t": "ஓர் ஏணி"}, {"w": 4, "t": "செவியுறுகின்றனரா"}, {"w": 5, "t": "அதில்"}, {"w": 6, "t": "வரட்டும்"}, {"w": 7, "t": "அவர்களில் செவியுற்றவர்"}, {"w": 8, "t": "தெளிவான ஓர் ஆதாரத்தைக் கொண்டு"}, {"w": 9, "t": "clear"}, {"w": 10, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "?/அவனுக்கு"}, {"w": 2, "t": "for Him"}, {"w": 3, "t": "பெண் பிள்ளைகளும்"}, {"w": 4, "t": "உங்களுக்கு"}, {"w": 5, "t": "ஆண் பிள்ளைகளும்"}, {"w": 6, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "அவர்களிடம் நீர் கேட்கின்றீரா?"}, {"w": 2, "t": "(do) you ask from them"}, {"w": 3, "t": "கூலி எதையும்"}, {"w": 4, "t": "அவர்கள்"}, {"w": 5, "t": "கடன் தொகையினால்"}, {"w": 6, "t": "a debt"}, {"w": 7, "t": "சுமைக்குள்ளாகி விட்டார்களா?"}, {"w": 8, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவர்களிடம் இருக்கின்றதா"}, {"w": 2, "t": "with them"}, {"w": 3, "t": "மறைவானவற்றின் அறிவு"}, {"w": 4, "t": "அதை அவர்கள்"}, {"w": 5, "t": "எழுதுகின்றார்களா?"}, {"w": 6, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "?"}, {"w": 2, "t": "நாடுகின்றனர்"}, {"w": 3, "t": "சூழ்ச்சியை"}, {"w": 4, "t": "ஆனால், நிராகரித்தவர்கள்தான்"}, {"w": 5, "t": "disbelieve"}, {"w": 6, "t": "சூழ்ச்சி செய்யப்பட்டவர்கள்"}, {"w": 7, "t": "(are in) the plot"}, {"w": 8, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "அவர்களுக்கு உண்டா?"}, {"w": 2, "t": "for them"}, {"w": 3, "t": "(வேறு) கடவுள்"}, {"w": 4, "t": "அல்லாஹ்வை அன்றி"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "மகா பரிசுத்தமானவன்"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "அவர்கள் இணைவைப்பதை விட்டும்"}, {"w": 9, "t": "they associate (with Him)"}, {"w": 10, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "அவர்கள் பார்த்தால்"}, {"w": 2, "t": "they were to see"}, {"w": 3, "t": "துண்டுகளை"}, {"w": 4, "t": "வானத்திலிருந்து"}, {"w": 5, "t": "the sky"}, {"w": 6, "t": "விழக்கூடிய(து)"}, {"w": 7, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 8, "t": "மேகங்கள்"}, {"w": 9, "t": "ஒன்று சேர்ந்த(வை)"}, {"w": 10, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "ஆகவே, அவர்களை விட்டுவிடுவீராக!"}, {"w": 2, "t": "வரை"}, {"w": 3, "t": "அவர்கள் சந்திக்கின்ற"}, {"w": 4, "t": "அவர்களுடைய நாள்"}, {"w": 5, "t": "எது"}, {"w": 6, "t": "அதில்"}, {"w": 7, "t": "அழிந்துவிடுகின்ற"}, {"w": 8, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "அந்நாளில்"}, {"w": 2, "t": "தடுக்காது"}, {"w": 3, "t": "will avail"}, {"w": 4, "t": "அவர்களை விட்டும்"}, {"w": 5, "t": "அவர்களின் சூழ்ச்சி"}, {"w": 6, "t": "எதையும்"}, {"w": 7, "t": "அவர்கள் உதவியும் செய்யப்பட மாட்டார்கள்"}, {"w": 8, "t": "they"}, {"w": 9, "t": "will be helped"}, {"w": 10, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "நிச்சயமாக அநியாயம் செய்தவர்களுக்கு"}, {"w": 2, "t": "for those who"}, {"w": 3, "t": "do wrong"}, {"w": 4, "t": "வேதனை"}, {"w": 5, "t": "அதற்கு முன்னரே"}, {"w": 6, "t": "that"}, {"w": 7, "t": "என்றாலும்"}, {"w": 8, "t": "அவர்களில் அதிகமானவர்கள்"}, {"w": 9, "t": "அறியமாட்டார்கள்"}, {"w": 10, "t": "know"}, {"w": 11, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "பொறுமையாக இருப்பீராக!"}, {"w": 2, "t": "தீர்ப்புக்காக"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "நிச்சயமாக நீர்"}, {"w": 5, "t": "நமது கண்களுக்கு முன்னால்"}, {"w": 6, "t": "நீர் துதிப்பீராக"}, {"w": 7, "t": "புகழ்ந்து"}, {"w": 8, "t": "உமது இறைவனை"}, {"w": 9, "t": "நேரத்தில்"}, {"w": 10, "t": "எழும்"}, {"w": 11, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "இன்னும் இரவில்"}, {"w": 2, "t": "the night"}, {"w": 3, "t": "அவனை துதிப்பீராக!"}, {"w": 4, "t": "இன்னும் மறைந்த பின்னர்"}, {"w": 5, "t": "நட்சத்திரங்கள்"}, {"w": 6, "t": "(49)"}]}]}