 "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "நிச்சயமாக இது"}, {"w": 2, "t": "that"}, {"w": 3, "t": "உண்மைதான்"}, {"w": 4, "t": "தங்களுக்குள் தர்க்கிப்பது"}, {"w": 5, "t": "நரகவாசிகள்"}, {"w": 6, "t": "(of) the Fire"}, {"w": 7, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் எல்லாம்"}, {"w": 3, "t": "I am"}, {"w": 4, "t": "ஓர் எச்சரிப்பாளர்தான்"}, {"w": 5, "t": "இல்லை"}, {"w": 6, "t": "வணக்கத்திற்குரியவன் யாரும்"}, {"w": 7, "t": "god"}, {"w": 8, "t": "அல்லாஹ்வைத் தவிர"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "ஒருவன்"}, {"w": 11, "t": "அடக்கி ஆளுபவன்"}, {"w": 12, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "இறைவன்"}, {"w": 2, "t": "வானங்கள்"}, {"w": 3, "t": "இன்னும் பூமி"}, {"w": 4, "t": "அவை இரண்டுக்கும் இடையில் உள்ளவற்றின்"}, {"w": 5, "t": "(is) between them"}, {"w": 6, "t": "மிகைத்தவன்"}, {"w": 7, "t": "மகா மன்னிப்பாளன்"}, {"w": 8, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "இது"}, {"w": 3, "t": "ஒரு செய்தியாகும்"}, {"w": 4, "t": "மகத்தான"}, {"w": 5, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "நீங்கள்"}, {"w": 2, "t": "இதை"}, {"w": 3, "t": "புறக்கணிக்கின்றீர்கள்"}, {"w": 4, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "is"}, {"w": 3, "t": "எனக்கு"}, {"w": 4, "t": "அறவே ஞானம்"}, {"w": 5, "t": "knowledge"}, {"w": 6, "t": "வானவர்களைப் பற்றி"}, {"w": 7, "t": "மிக உயர்ந்த"}, {"w": 8, "t": "அவர்கள் தர்க்கித்த போது"}, {"w": 9, "t": "they were disputing"}, {"w": 10, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "வஹீ  அறிவிக்கப்படுவதில்லை"}, {"w": 2, "t": "has been revealed"}, {"w": 3, "t": "எனக்கு"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "நிச்சயமாக நான் எல்லாம்"}, {"w": 6, "t": "I am"}, {"w": 7, "t": "ஓர் எச்சரிப்பாளர்தான்"}, {"w": 8, "t": "தெளிவான"}, {"w": 9, "t": "(70)"}]}, {"ayah": 71, "words": [{"w": 1, "t": "கூறிய சமயத்தை நினைவு கூர்வீராக!"}, {"w": 2, "t": "said"}, {"w": 3, "t": "உமது இறைவன்"}, {"w": 4, "t": "வானவர்களை நோக்கி"}, {"w": 5, "t": "நிச்சயமாக நான்"}, {"w": 6, "t": "படைக்கப்போகிறேன்"}, {"w": 7, "t": "ஒரு மனிதரை"}, {"w": 8, "t": "களிமண்ணிலிருந்து"}, {"w": 9, "t": "clay"}, {"w": 10, "t": "(71)"}]}, {"ayah": 72, "words": [{"w": 1, "t": "ஆக, நான் அவரை சிறப்பாக படைத்து(விட்டால்)"}, {"w": 2, "t": "I have proportioned him"}, {"w": 3, "t": "இன்னும் ஊதினால்"}, {"w": 4, "t": "அவரில்"}, {"w": 5, "t": "என் உயிர்களிலிருந்து"}, {"w": 6, "t": "My spirit"}, {"w": 7, "t": "விழுந்து விடுங்கள்!"}, {"w": 8, "t": "அவருக்கு முன்"}, {"w": 9, "t": "சிரம் பணிந்தவர்களாக"}, {"w": 10, "t": "(72)"}]}, {"ayah": 73, "words": [{"w": 1, "t": "சிரம் பணிந்தனர்"}, {"w": 2, "t": "வானவர்கள்"}, {"w": 3, "t": "அவர்கள் எல்லோரும்"}, {"w": 4, "t": "அனைவரும்"}, {"w": 5, "t": "(73)"}]}, {"ayah": 74, "words": [{"w": 1, "t": "இப்லீஸைத் தவிர"}, {"w": 2, "t": "Iblis"}, {"w": 3, "t": "அவன் பெருமை அடித்தான்"}, {"w": 4, "t": "இன்னும் ஆகிவிட்டான்"}, {"w": 5, "t": "நிராகரிப்பவர்களில்"}, {"w": 6, "t": "the disbelievers"}, {"w": 7, "t": "(74)"}]}, {"ayah": 75, "words": [{"w": 1, "t": "அவன் கூறினான்"}, {"w": 2, "t": "இப்லீஸே!"}, {"w": 3, "t": "உன்னை தடுத்தது எது?"}, {"w": 4, "t": "prevented you"}, {"w": 5, "t": "நீ ஸஜ்தா செய்வதிலிருந்து"}, {"w": 6, "t": "you (should) prostrate"}, {"w": 7, "t": "நான் படைத்தவருக்கு"}, {"w": 8, "t": "I created"}, {"w": 9, "t": "எனது இரு கரத்தால்"}, {"w": 10, "t": "நீ பெருமையடிக்கிறாயா?"}, {"w": 11, "t": "நீ இருந்தாயா?"}, {"w": 12, "t": "are you"}, {"w": 13, "t": "பெருமையடிப்பவர்களில்தான்"}, {"w": 14, "t": "the exalted ones"}, {"w": 15, "t": "(75)"}]}, {"ayah": 76, "words": [{"w": 1, "t": "அவன் கூறினான்"}, {"w": 2, "t": "நான்"}, {"w": 3, "t": "சிறந்தவன்"}, {"w": 4, "t": "அவரை விட"}, {"w": 5, "t": "என்னை படைத்தாய்"}, {"w": 6, "t": "நெருப்பில் இருந்து"}, {"w": 7, "t": "fire"}, {"w": 8, "t": "அவரை படைத்தாய்"}, {"w": 9, "t": "களிமண்ணிலிருந்து"}, {"w": 10, "t": "clay"}, {"w": 11, "t": "(76)"}]}, {"ayah": 77, "words": [{"w": 1, "t": "அவன் கூறினான்"}, {"w": 2, "t": "வெளியேறி விடு!"}, {"w": 3, "t": "அதில் இருந்து"}, {"w": 4, "t": "நிச்சயமாக நீசபிக்கப்பட்டவன்"}, {"w": 5, "t": "(are) accursed"}, {"w": 6, "t": "(77)"}]}, {"ayah": 78, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உம்மீது"}, {"w": 3, "t": "என் சாபம்"}, {"w": 4, "t": "கூலி நாள் வரை"}, {"w": 5, "t": "(the) Day"}, {"w": 6, "t": "(of) Judgment"}, {"w": 7, "t": "(78)"}]}, {"ayah": 79, "words": [{"w": 1, "t": "அவன் கூறினான்"}, {"w": 2, "t": "என் இறைவா!"}, {"w": 3, "t": "எனக்கு அவகாசம் அளி!"}, {"w": 4, "t": "நாள் வரை"}, {"w": 5, "t": "(the) Day"}, {"w": 6, "t": "அவர்கள் எழுப்பப்படுகின்ற(£ர்கள்)"}, {"w": 7, "t": "(79)"}]}, {"ayah": 80, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "நிச்சயமாக நீ"}, {"w": 3, "t": "அவகாசமளிக்கப்பட்டவர்களில்"}, {"w": 4, "t": "those given respite"}, {"w": 5, "t": "(80)"}]}, {"ayah": 81, "words": [{"w": 1, "t": "நாள் வரை"}, {"w": 2, "t": "(the) Day"}, {"w": 3, "t": "நேரம்"}, {"w": 4, "t": "அறியப்பட்ட"}, {"w": 5, "t": "(81)"}]}, {"ayah": 82, "words": [{"w": 1, "t": "அவன் கூறினான்"}, {"w": 2, "t": "உனது கண்ணியத்தின் மீது சத்தியமாக"}, {"w": 3, "t": "அவர்களை நிச்சயமாக நான் வழிகெடுப்பேன்"}, {"w": 4, "t": "அனைவரையும்"}, {"w": 5, "t": "(82)"}]}, {"ayah": 83, "words": [{"w": 1, "t": "உனது அடியார்களை தவிர"}, {"w": 2, "t": "Your slaves"}, {"w": 3, "t": "அவர்களில்"}, {"w": 4, "t": "பரிசுத்தமான(வர்கள்)"}, {"w": 5, "t": "(83)"}]}, {"ayah": 84, "words": [{"w": 1, "t": "அவன் கூறினான்"}, {"w": 2, "t": "உண்மை"}, {"w": 3, "t": "உண்மையைத்தான்"}, {"w": 4, "t": "நான் கூறுவேன்"}, {"w": 5, "t": "(84)"}]}, {"ayah": 85, "words": [{"w": 1, "t": "நிச்சயமாக நிரப்புவேன்"}, {"w": 2, "t": "நரகத்தை"}, {"w": 3, "t": "உன்னைக்கொண்டும்"}, {"w": 4, "t": "உன்னை பின்பற்றியவர்களைக் கொண்டும்"}, {"w": 5, "t": "follow you"}, {"w": 6, "t": "அவர்களில்"}, {"w": 7, "t": "அனைவர்களையும்"}, {"w": 8, "t": "(85)"}]}, {"ayah": 86, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் உங்களிடம் கேட்கவில்லை"}, {"w": 3, "t": "I ask of you"}, {"w": 4, "t": "இதற்காக"}, {"w": 5, "t": "கூலி எதையும்"}, {"w": 6, "t": "payment"}, {"w": 7, "t": "இன்னும் நான் இல்லை"}, {"w": 8, "t": "I am"}, {"w": 9, "t": "வரட்டு கௌரவம் தேடுபவர்களில்"}, {"w": 10, "t": "the ones who pretend"}, {"w": 11, "t": "(86)"}]}, {"ayah": 87, "words": [{"w": 1, "t": "இது இல்லை"}, {"w": 2, "t": "it (is)"}, {"w": 3, "t": "அன்றி"}, {"w": 4, "t": "ஓர் அறிவுரையே"}, {"w": 5, "t": "அகிலத்தார்களுக்கு"}, {"w": 6, "t": "(87)"}]}, {"ayah": 88, "words": [{"w": 1, "t": "நிச்சயமாகநீங்கள்அறிவீர்கள்"}, {"w": 2, "t": "இதன் செய்தியை"}, {"w": 3, "t": "பின்னர்"}, {"w": 4, "t": "சில காலத்திற்கு"}, {"w": 5, "t": "(88)"}]}]}