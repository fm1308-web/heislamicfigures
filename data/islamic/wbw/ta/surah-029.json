}, {"w": 15, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "இறக்கப்பட வேண்டாமா?"}, {"w": 3, "t": "are sent down"}, {"w": 4, "t": "இவர் மீது"}, {"w": 5, "t": "அத்தாட்சிகள்"}, {"w": 6, "t": "அவரது இறைவனிடமிருந்து"}, {"w": 7, "t": "his Lord"}, {"w": 8, "t": "கூறுவீராக!"}, {"w": 9, "t": "எல்லாம்"}, {"w": 10, "t": "அத்தாட்சிகள்"}, {"w": 11, "t": "அல்லாஹ்விடம்"}, {"w": 12, "t": "Allah"}, {"w": 13, "t": "எல்லாம்"}, {"w": 14, "t": "நான்"}, {"w": 15, "t": "எச்சரிப்பாளர்தான்"}, {"w": 16, "t": "தெளிவான"}, {"w": 17, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "அவர்களுக்கு போதுமாகாதா?"}, {"w": 2, "t": "sufficient for them"}, {"w": 3, "t": "நிச்சயமாக நாம்"}, {"w": 4, "t": "இறக்கியது"}, {"w": 5, "t": "உம்மீது"}, {"w": 6, "t": "இந்த வேதத்தை"}, {"w": 7, "t": "ஓதப்படுகின்ற"}, {"w": 8, "t": "அவர்கள் மீது"}, {"w": 9, "t": "நிச்சயமாக"}, {"w": 10, "t": "இதில் இருக்கின்றன"}, {"w": 11, "t": "that"}, {"w": 12, "t": "அருளும்"}, {"w": 13, "t": "அறிவுரையும்"}, {"w": 14, "t": "மக்களுக்கு"}, {"w": 15, "t": "நம்பிக்கை கொள்கின்ற"}, {"w": 16, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "போதுமானவன்"}, {"w": 3, "t": "அல்லாஹ்வே"}, {"w": 4, "t": "எனக்கிடையில்"}, {"w": 5, "t": "உங்களுக்குஇடையில்"}, {"w": 6, "t": "சாட்சியால்"}, {"w": 7, "t": "அவன் நன்கறிவான்"}, {"w": 8, "t": "உள்ளவற்றை"}, {"w": 9, "t": "வானங்களில்"}, {"w": 10, "t": "the heavens"}, {"w": 11, "t": "இன்னும் பூமியில்"}, {"w": 12, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 13, "t": "believe"}, {"w": 14, "t": "பொய்யை"}, {"w": 15, "t": "நிராகரித்தவர்கள்"}, {"w": 16, "t": "அல்லாஹ்வை"}, {"w": 17, "t": "அவர்கள்தான்"}, {"w": 18, "t": "they"}, {"w": 19, "t": "நஷ்டவாளிகள்"}, {"w": 20, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "அவர்கள் உம்மிடம் அவசரமாகக் கேட்கின்றனர்"}, {"w": 2, "t": "தண்டனையை"}, {"w": 3, "t": "ஒரு தவணை இல்லை என்றால்"}, {"w": 4, "t": "(for) a term"}, {"w": 5, "t": "குறிப்பிடப்பட்ட"}, {"w": 6, "t": "வந்தே இருக்கும் அவர்களுக்கு"}, {"w": 7, "t": "தண்டனை"}, {"w": 8, "t": "அவர்களிடம் வரும்"}, {"w": 9, "t": "திடீரென"}, {"w": 10, "t": "நிச்சயமாக அவர்கள்"}, {"w": 11, "t": "உணராதவர்களாக இருக்க"}, {"w": 12, "t": "perceive"}, {"w": 13, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "அவர்கள் உம்மிடம் அவசரமாகக் கேட்கின்றனர்"}, {"w": 2, "t": "தண்டனையை"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "நரகம்"}, {"w": 5, "t": "சூழ்ந்தே உள்ளது"}, {"w": 6, "t": "நிராகரிப்பாளர்களை"}, {"w": 7, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "அவர்களை மூடிக்கொள்கின்ற"}, {"w": 3, "t": "தண்டனை"}, {"w": 4, "t": "அவர்களுக்கு மேலிருந்தும்"}, {"w": 5, "t": "above them"}, {"w": 6, "t": "கீழே இருந்தும்"}, {"w": 7, "t": "below"}, {"w": 8, "t": "அவர்களின் கால்களுக்கு"}, {"w": 9, "t": "கூறுவான்"}, {"w": 10, "t": "நீங்கள் சுவையுங்கள்"}, {"w": 11, "t": "நீங்கள் செய்து கொண்டிருந்ததை"}, {"w": 12, "t": "you used"}, {"w": 13, "t": "(to) do"}, {"w": 14, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "என் அடியார்களே!"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "நிச்சயமாக"}, {"w": 5, "t": "எனது பூமி"}, {"w": 6, "t": "விசாலமானது"}, {"w": 7, "t": "ஆகவே, என்னையே"}, {"w": 8, "t": "நீங்கள் வணங்குங்கள்!"}, {"w": 9, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "எல்லா"}, {"w": 2, "t": "ஆன்மாவும்"}, {"w": 3, "t": "சுவைக்கக் கூடியதே"}, {"w": 4, "t": "மரணத்தை"}, {"w": 5, "t": "பிறகு"}, {"w": 6, "t": "நம்மிடமே"}, {"w": 7, "t": "நீங்கள் திரும்பக் கொண்டு வரப்படுவீர்கள்"}, {"w": 8, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 3, "t": "இன்னும் செய்தார்கள்"}, {"w": 4, "t": "நன்மைகளை"}, {"w": 5, "t": "அவர்களுக்கு நாம் தயார்படுத்திக் கொடுப்போம்"}, {"w": 6, "t": "சொர்க்கத்தில்"}, {"w": 7, "t": "Paradise"}, {"w": 8, "t": "பல அறைகளை"}, {"w": 9, "t": "ஓடும்"}, {"w": 10, "t": "அவற்றின் கீழ்"}, {"w": 11, "t": "underneath it"}, {"w": 12, "t": "நதிகள்"}, {"w": 13, "t": "அவர்கள் நிரந்தரமானவர்கள்"}, {"w": 14, "t": "அதில்"}, {"w": 15, "t": "மிகச் சிறப்பானதே"}, {"w": 16, "t": "கூலி"}, {"w": 17, "t": "அமல் செய்தவர்களின்"}, {"w": 18, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "அவர்கள் பொறுமையாக இருந்தனர்"}, {"w": 2, "t": "(are) patient"}, {"w": 3, "t": "இன்னும் மீதே"}, {"w": 4, "t": "தங்கள் இறைவன்"}, {"w": 5, "t": "சார்ந்து இருந்தனர்"}, {"w": 6, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "கால்நடைகள்"}, {"w": 3, "t": "a creature"}, {"w": 4, "t": "சுமப்பதில்லை"}, {"w": 5, "t": "carry"}, {"w": 6, "t": "தனது உணவை"}, {"w": 7, "t": "அல்லாஹ்தான்"}, {"w": 8, "t": "அவற்றுக்கும் உணவளிக்கிறான்"}, {"w": 9, "t": "உங்களுக்கும்"}, {"w": 10, "t": "அவன்தான்"}, {"w": 11, "t": "நன்கு செவியுறுபவன்"}, {"w": 12, "t": "நன்கறிந்தவன்"}, {"w": 13, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "அவர்களிடம் நீர் கேட்டால்"}, {"w": 2, "t": "யார் படைத்தான்?"}, {"w": 3, "t": "Who"}, {"w": 4, "t": "வானங்களையும்"}, {"w": 5, "t": "பூமியையும்"}, {"w": 6, "t": "வசப்படுத்தினான்"}, {"w": 7, "t": "சூரியனையும்"}, {"w": 8, "t": "சந்திரனையும்"}, {"w": 9, "t": "நிச்சயமாக அவர்கள் கூறுவார்கள்"}, {"w": 10, "t": "அல்லாஹ்தான்"}, {"w": 11, "t": "ஆக, அவர்கள் எப்படி"}, {"w": 12, "t": "திருப்பப்படுகிறார்கள்"}, {"w": 13, "t": "are they deluded"}, {"w": 14, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "விசாலமாக்குகின்றான்"}, {"w": 3, "t": "உணவை"}, {"w": 4, "t": "தான் நாடியவர்களுக்கு"}, {"w": 5, "t": "He wills"}, {"w": 6, "t": "தனது அடியார்களில்"}, {"w": 7, "t": "His slaves"}, {"w": 8, "t": "இன்னும் சுருக்குகின்றான்"}, {"w": 9, "t": "அவருக்கு"}, {"w": 10, "t": "நிச்சயமாக"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "எல்லாவற்றையும்"}, {"w": 13, "t": "thing"}, {"w": 14, "t": "நன்கறிந்தவன்"}, {"w": 15, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "நீர் அவர்களிடம் கேட்டால்"}, {"w": 2, "t": "யார்/இறக்கினான்"}, {"w": 3, "t": "Who"}, {"w": 4, "t": "வானத்திலிருந்து"}, {"w": 5, "t": "from"}, {"w": 6, "t": "மழையை"}, {"w": 7, "t": "உயிர்ப்பிப்பவன்"}, {"w": 8, "t": "அதன் மூலம்"}, {"w": 9, "t": "பூமியை"}, {"w": 10, "t": "பின்னர்"}, {"w": 11, "t": "after"}, {"w": 12, "t": "அது இறந்து விட்ட"}, {"w": 13, "t": "நிச்சயமாக அவர்கள் கூறுவார்கள்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "நீர் கூறுவீராக!"}, {"w": 16, "t": "புகழ் எல்லாம்"}, {"w": 17, "t": "அல்லாஹ்விற்கே!"}, {"w": 18, "t": "மாறாக"}, {"w": 19, "t": "அதிகமானவர்கள் அவர்களில்"}, {"w": 20, "t": "சிந்தித்து புரிய மாட்டார்கள்"}, {"w": 21, "t": "(do) not"}, {"w": 22, "t": "use reason"}, {"w": 23, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "(is) this"}, {"w": 3, "t": "வாழ்க்கை"}, {"w": 4, "t": "இவ்வுலக"}, {"w": 5, "t": "தவிர"}, {"w": 6, "t": "வேடிக்கையாகவும்"}, {"w": 7, "t": "விளையாட்டாகவும்"}, {"w": 8, "t": "நிச்சயமாக"}, {"w": 9, "t": "வீடு"}, {"w": 10, "t": "மறுமை/அதுதான்"}, {"w": 11, "t": "surely, it"}, {"w": 12, "t": "நிரந்தரமானது"}, {"w": 13, "t": "அவர்கள் அறிந்து கொள்ளவேண்டுமே!"}, {"w": 14, "t": "they"}, {"w": 15, "t": "know"}, {"w": 16, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "அவர்கள் பயணித்தால்"}, {"w": 2, "t": "they embark"}, {"w": 3, "t": "கப்பலில்"}, {"w": 4, "t": "the ship"}, {"w": 5, "t": "அழைக்கின்றனர்"}, {"w": 6, "t": "அல்லாஹ்வை"}, {"w": 7, "t": "தூய்மைப்படுத்தியவர்களாக"}, {"w": 8, "t": "அவனுக்கு மட்டும்"}, {"w": 9, "t": "வணக்க வழிபாட்டை"}, {"w": 10, "t": "அவன் அவர்களை காப்பாற்றிக் கொண்டு வந்தால்"}, {"w": 11, "t": "He delivers them"}, {"w": 12, "t": "கரைக்கு"}, {"w": 13, "t": "the land"}, {"w": 14, "t": "அப்போது அவர்கள்"}, {"w": 15, "t": "they"}, {"w": 16, "t": "இணைவைக்கின்றனர்"}, {"w": 17, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "இறுதியாக, நிராகரிப்பதற்காகவும்"}, {"w": 2, "t": "நாம் அவர்களுக்கு கொடுத்தவற்றை"}, {"w": 3, "t": "We have given them"}, {"w": 4, "t": "அவர்கள் இன்புறுவதற்காகவும்"}, {"w": 5, "t": "அவர்கள் அறிவார்கள்"}, {"w": 6, "t": "they will know"}, {"w": 7, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "அவர்கள் பார்க்கவில்லையா?"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "நிச்சயமாக நா