{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அலிஃப், லாம், மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நினைத்துக் கொண்டனரா"}, {"w": 2, "t": "மக்கள்"}, {"w": 3, "t": "அவர்கள் விடப்படுவார்கள்"}, {"w": 4, "t": "they will be left"}, {"w": 5, "t": "என்று அவர்கள் கூறுவதால்"}, {"w": 6, "t": "they say"}, {"w": 7, "t": "நாங்கள் நம்பிக்கை கொண்டோம்"}, {"w": 8, "t": "அவர்கள்"}, {"w": 9, "t": "சோதிக்கப்படாமல்"}, {"w": 10, "t": "will not be tested"}, {"w": 11, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் சோதித்தோம்"}, {"w": 3, "t": "இவர்களுக்கு முன்னர் இருந்தவர்களை"}, {"w": 4, "t": "(were) before them"}, {"w": 5, "t": "(were) before them"}, {"w": 6, "t": "ஆகவே, நிச்சயமாக அறிவான்"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "உண்மையாளர்களை(யும்)"}, {"w": 9, "t": "(are) truthful"}, {"w": 10, "t": "இன்னும் நிச்சயமாக அறிவான்"}, {"w": 11, "t": "பொய்யர்களை(யும்)"}, {"w": 12, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அல்லது எண்ணிக் கொண்டார்களா?"}, {"w": 2, "t": "think"}, {"w": 3, "t": "செய்பவர்கள்"}, {"w": 4, "t": "do"}, {"w": 5, "t": "தீமைகளை"}, {"w": 6, "t": "நம்மை முந்தி விடுவார்கள் என்று"}, {"w": 7, "t": "they can outrun Us"}, {"w": 8, "t": "மிகக் கெட்டது"}, {"w": 9, "t": "அவர்கள் தீர்ப்பளிப்பது"}, {"w": 10, "t": "they judge"}, {"w": 11, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "இருப்பாரோ"}, {"w": 3, "t": "ஆதரவு வைக்கின்றார்"}, {"w": 4, "t": "சந்திப்பை"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "நிச்சயமாக"}, {"w": 7, "t": "தவணை"}, {"w": 8, "t": "அல்லாஹ்வின்"}, {"w": 9, "t": "வரக்கூடியதுதான்"}, {"w": 10, "t": "அவன்தான்"}, {"w": 11, "t": "நன்கு செவியுறுபவன்"}, {"w": 12, "t": "நன்கறிந்தவன்"}, {"w": 13, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "போரிடுவாரோ"}, {"w": 3, "t": "அவர் போரிடுவதெல்லாம்"}, {"w": 4, "t": "he strives"}, {"w": 5, "t": "தனக்காகத்தான்"}, {"w": 6, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "முற்றிலும் தேவையற்றவன்"}, {"w": 9, "t": "அகிலத்தார்களை விட்டு"}, {"w": 10, "t": "the worlds"}, {"w": 11, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 3, "t": "இன்னும் செய்தார்கள்"}, {"w": 4, "t": "நன்மைகளை"}, {"w": 5, "t": "நாம் நீக்கி விடுவோம்"}, {"w": 6, "t": "அவர்களை விட்டும்"}, {"w": 7, "t": "அவர்களின் பாவங்களை"}, {"w": 8, "t": "நாம் அவர்களுக்கு கூலியாகத் தருவோம்"}, {"w": 9, "t": "மிகச் சிறந்ததை"}, {"w": 10, "t": "அவர்கள் செய்து கொண்டிருந்ததை விட"}, {"w": 11, "t": "they used"}, {"w": 12, "t": "(to) do"}, {"w": 13, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நாம் உபதேசித்தோம்"}, {"w": 2, "t": "மனிதனுக்கு"}, {"w": 3, "t": "அவன் தனது பெற்றோரிடம்"}, {"w": 4, "t": "அழகிய முறையில்"}, {"w": 5, "t": "அவர்கள் உன்னை வற்புறுத்தினால்"}, {"w": 6, "t": "they both strive against you"}, {"w": 7, "t": "நீ இணைஆக்கும்படி"}, {"w": 8, "t": "எனக்கு"}, {"w": 9, "t": "எதை/இல்லை"}, {"w": 10, "t": "not"}, {"w": 11, "t": "உனக்கு"}, {"w": 12, "t": "அதைப் பற்றி"}, {"w": 13, "t": "அறிவு"}, {"w": 14, "t": "அவர்களுக்கு நீ கீழ்ப்படியாதே!"}, {"w": 15, "t": "obey both of them"}, {"w": 16, "t": "என் பக்கமே"}, {"w": 17, "t": "உங்கள் மீட்சி இருக்கிறது"}, {"w": 18, "t": "நான் உங்களுக்கு அறிவிப்பேன்"}, {"w": 19, "t": "நீங்கள் செய்து கொண்டிருந்தவற்றை"}, {"w": 20, "t": "you used"}, {"w": 21, "t": "(to) do"}, {"w": 22, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 3, "t": "இன்னும் செய்தார்கள்"}, {"w": 4, "t": "நன்மைகளை"}, {"w": 5, "t": "அவர்களை நாம் நிச்சயமாக நுழைவிப்போம்"}, {"w": 6, "t": "நல்லோரில்"}, {"w": 7, "t": "the righteous"}, {"w": 8, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "மக்களில் இருக்கின்றனர்"}, {"w": 2, "t": "the people"}, {"w": 3, "t": "எவர்/கூறுகின்றார்"}, {"w": 4, "t": "says"}, {"w": 5, "t": "நாங்கள் நம்பிக்கை கொண்டோம்"}, {"w": 6, "t": "அல்லாஹ்வை"}, {"w": 7, "t": "அவர்கள் துன்புறுத்தப்பட்டால்"}, {"w": 8, "t": "he is harmed"}, {"w": 9, "t": "அல்லாஹ்வின் விஷயத்தில்"}, {"w": 10, "t": "(the Way of) Allah"}, {"w": 11, "t": "ஆக்கிவிடுகிறார்"}, {"w": 12, "t": "சோதனையை"}, {"w": 13, "t": "மக்களுடைய"}, {"w": 14, "t": "தண்டனையைப் போன்று"}, {"w": 15, "t": "அல்லாஹ்வின்"}, {"w": 16, "t": "வந்தால்"}, {"w": 17, "t": "comes"}, {"w": 18, "t": "ஓர் உதவி"}, {"w": 19, "t": "உமது இறைவனிடமிருந்து"}, {"w": 20, "t": "your Lord"}, {"w": 21, "t": "நிச்சயமாக கூறுகின்றனர்"}, {"w": 22, "t": "நிச்சயமாக நாம்"}, {"w": 23, "t": "இருக்கின்றோம்"}, {"w": 24, "t": "உங்களுடன்"}, {"w": 25, "t": "இல்லையா?"}, {"w": 26, "t": "அல்லாஹ்"}, {"w": 27, "t": "மிக அறிந்தவனாக"}, {"w": 28, "t": "நெஞ்சங்களில் உள்ளவற்றை"}, {"w": 29, "t": "(is) in"}, {"w": 30, "t": "(the) breasts"}, {"w": 31, "t": "அகிலத்தாரின்"}, {"w": 32, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நிச்சயமாக நன்கறிவான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "நம்பிக்கை கொண்டவர்களை"}, {"w": 4, "t": "believe"}, {"w": 5, "t": "இன்னும் நிச்சயமாக நன்கறிவான்"}, {"w": 6, "t": "நயவஞ்சகர்களை"}, {"w": 7, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "கூறினர்"}, {"w": 2, "t": "நிராகரித்தவர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "நம்பிக்கையாளர்களை நோக்கி"}, {"w": 5, "t": "believe"}, {"w": 6, "t": "நீங்கள் பின்பற்றுங்கள்!"}, {"w": 7, "t": "எங்கள் பாதையை"}, {"w": 8, "t": "நாங்கள் சுமந்து கொள்கிறோம்"}, {"w": 9, "t": "உங்கள் தவறுகளை"}, {"w": 10, "t": "அவர்கள் அல்லர்"}, {"w": 11, "t": "they"}, {"w": 12, "t": "சுமப்பவர்கள்"}, {"w": 13, "t": "அவர்களுடைய தவறுகளில்"}, {"w": 14, "t": "their sins"}, {"w": 15, "t": "எதையும்"}, {"w": 16, "t": "thing"}, {"w": 17, "t": "நிச்சயமாக அவர்கள்"}, {"w": 18, "t": "பொய்யர்கள்தான்"}, {"w": 19, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நிச்சயம் அவர்கள் சுமப்பார்கள்"}, {"w": 2, "t": "தங்கள்சுமைகளையும்"}, {"w": 3, "t": "இன்னும் பல சுமைகளையும்"}, {"w": 4, "t": "தங்களது சுமைகளுடன்"}, {"w": 5, "t": "their burdens"}, {"w": 6, "t": "நிச்சயம் விசாரிக்கப்படுவார்கள்"}, {"w": 7, "t": "மறுமை நாளில்"}, {"w": 8, "t": "(of) the Resurrection"}, {"w": 9, "t": "பற்றி"}, {"w": 10, "t": "இன்னும் அவர்கள் பொய்யை இட்டுக்கட்டிக் கொண்டிருந்தார்கள்"}, {"w": 11, "t": "(to) invent"}, {"w": 12, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "நூஹை"}, {"w": 4, "t": "அவரது மக்களிடம்"}, {"w": 5, "t": "his people"}, {"w": 6, "t": "அவர் தங்கி இருந்தார்"}, {"w": 7, "t": "அவர்களுடன்"}, {"w": 8, "t": "ஆயிரம்"}, {"w": 9, "t": "ஆண்டுகள்"}, {"w": 10, "t": "தவிர"}, {"w": 11, "t": "ஐம்பது"}, {"w": 12, "t": "ஆண்டுகள்"}, {"w": 13, "t": "இறுதியில் பிடித்தது அவர்களை"}, {"w": 14, "t": "வெள்ளப் பிரளயம்"}, {"w": 15, "t": "அவர்கள் இருக்க"}, {"w": 16, "t": "அநியாயக்காரர்களாக"}, {"w": 17, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவரை(யும்) நாம் பாதுகாத்தோம்"}, {"w": 2, "t": "இன்னும் கப்பலுடையவர்களை(யும்)"}, {"w": 3, "t": "(of) the ship"}, {"w": 4, "t": "இன்னும் அதை ஆக்கினோம்"}, {"w": 5, "t": "ஓர் அத்தாட்சியாக"}, {"w": 6, "t": "அகிலத்தாருக்கு"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இன்னும் இப்ராஹீம்"}, {"w": 2, "t": "அவர்கள் கூறிய சமயத்தை நினைவு கூருங்கள்"}, {"w": 3, "t": "he said"}, {"w": 4, "t": "தனது மக்களுக்கு"}, {"w": 5, "t": "வணங்குங்கள்"}, {"w": 6, "t": "அல்லாஹ்வை"}, {"w": 7, "t": "இன்னும் அவனை அஞ்சுங்கள்"}, {"w": 8, "t": "இதுதான்"}, {"w": 9, "t": "சிறந்ததாகும்"}, {"w": 10, "t": "உங்களுக்கு"}, {"w": 11, "t": "நீங்கள் இருந்தால்"}, {"w": 12, "t": "you"}, {"w": 13, "t": "அறிகின்றவர்களாக"}, {"w": 14, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நீங்கள் வணங்குவதெல்லாம்"}, {"w": 2, "t": "you worship"}, {"w": 3, "t": "அல்லாஹ்வையன்றி"}, {"w": 4, "t": "besides"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "சிலைகளைத்தான்"}, {"w": 7, "t": "இன்னும் இட்டுக்கட்டுகிறீர்கள்"}, {"w": 8, "t": "பொய்யை"}, {"w": 9, "t": "நிச்சயமாக எவர்களை"}, {"w": 10, "t": "those whom"}, {"w": 11, "t": "நீங்கள் வணங்குகிறீர்கள்"}, {"w": 12, "t": "அல்லாஹ்வையன்றி"}, {"w": 13, "t": "besides"}, {"w": 14, "t": "Allah"}, {"w": 15, "t": "உரிமை பெறமாட்டார்கள்"}, {"w": 16, "t": "possess"}, {"w": 17, "t": "உங்களுக்கு"}, {"w": 18, "t": "உணவளிக்க"}, {"w": 19, "t": "ஆகவே, தேடுங்கள்"}, {"w": 20, "t": "அல்லாஹ்விடம்"}, {"w": 21, "t": "Allah"}, {"w": 22, "t": "உணவை"}, {"w": 23, "t": "இன்னும் அவனை வணங்குங்கள்"}, {"w": 24, "t": "இன்னும் நன்றி செலுத்துங்கள்"}, {"w": 25, "t": "அவனுக்கு"}, {"w": 26, "t": "அவன் பக்கமே"}, {"w": 27, "t": "திரும்பக் கொண்டுவரப்படுவீர்கள்"}, {"w": 28, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நீங்கள் பொய்ப்பித்தால்"}, {"w": 2, "t": "you deny"}, {"w": 3, "t": "திட்டமாக"}, {"w": 4, "t": "பொய்ப்பித்துள்ளனர்"}, {"w": 5, "t": "பல சமுதாயத்தினர்"}, {"w": 6, "t": "உங்களுக்கு முன்னர்"}, {"w": 7, "t": "before you"}, {"w": 8, "t": "வேறில்லை"}, {"w": 9, "t": "மீது"}, {"w": 10, "t": "தூதர்"}, {"w": 11, "t": "தவிர"}, {"w": 12, "t": "எடுத்துரைத்தலே"}, {"w": 13, "t": "தெளிவான"}, {"w": 14, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவர்கள் பார்க்கவில்லையா?"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "எப்படி"}, {"w": 4, "t": "ஆரம்பமாக படைத்தான்"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "படைப்புகளை/பிறகு"}, {"w": 7, "t": "then"}, {"w": 8, "t": "அவற்றை அவன் மீண்டும் உருவாக்குகிறான்"}, {"w": 9, "t": "நிச்சயமாக"}, {"w": 10, "t": "இது"}, {"w": 11, "t": "அல்லாஹ்விற்கு"}, {"w": 12, "t": "Allah"}, {"w": 13, "t": "இலகுவானதாகும்"}, {"w": 14, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "சுற்றுங்கள்!"}, {"w": 3, "t": "பூமியில்"}, {"w": 4, "t": "the earth"}, {"w": 5, "t": "பாருங்கள்!"}, {"w": 6, "t": "எப்படி"}, {"w": 7, "t": "அவன்ஆரம்பித்தான்"}, {"w": 8, "t": "படைப்புகளை"}, {"w": 9, "t": "பிறகு"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "உருவாக்குவான்"}, {"w": 12, "t": "உருவாக்குதல்"}, {"w": 13, "t": "மற்றொரு முறை"}, {"w": 14, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 15, "t": "Allah"}, {"w": 16, "t": "மீது"}, {"w": 17, "t": "எல்லாவற்றின்"}, {"w": 18, "t": "thing"}, {"w": 19, "t": "பேராற்றலுடையவன்"}, {"w": 20, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "வேதனை செய்வான்"}, {"w": 2, "t": "தான் நாடியவரை"}, {"w": 3, "t": "He wills"}, {"w": 4, "t": "இன்னும் கருணை காட்டுவான்"}, {"w": 5, "t": "அவன் நாடியவருக்கு"}, {"w": 6, "t": "He wills"}, {"w": 7, "t": "அவனிடமே"}, {"w": 8, "t": "நீங்கள் திரும்பக் கொண்டு வரப்படுவீர்கள்"}, {"w": 9, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நீங்கள் பலவீனப்படுத்திவிட முடியாது"}, {"w": 2, "t": "you"}, {"w": 3, "t": "can escape"}, {"w": 4, "t": "பூமியில்"}, {"w": 5, "t": "the earth"}, {"w": 6, "t": "இன்னும் வானத்தில்"}, {"w": 7, "t": "in"}, {"w": 8, "t": "the heaven"}, {"w": 9, "t": "இன்னும் உங்களுக்கு இல்லை"}, {"w": 10, "t": "for you"}, {"w": 11, "t": "அல்லாஹ்வையன்றி"}, {"w": 12, "t": "besides"}, {"w": 13, "t": "Allah"}, {"w": 14, "t": "ஒரு பாதுகாவலரும்"}, {"w": 15, "t": "protector"}, {"w": 16, "t": "உதவியாளரும்"}, {"w": 17, "t": "a helper"}, {"w": 18, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நிராகரிக்கின்றவர்கள்"}, {"w": 2, "t": "disbelieve"}, {"w": 3, "t": "அத்தாட்சிகளையும்"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "அவனது சந்திப்பையும்"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "நிராசை அடைந்து விட்டனர்"}, {"w": 8, "t": "எனது கருணையிலிருந்து"}, {"w": 9, "t": "My Mercy"}, {"w": 10, "t": "அவர்கள்"}, {"w": 11, "t": "அவர்களுக்கு உண்டு"}, {"w": 12, "t": "தண்டனை"}, {"w": 13, "t": "வேதனை தரும்"}, {"w": 14, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "was"}, {"w": 3, "t": "பதில்"}, {"w": 4, "t": "அவருடைய மக்களின்"}, {"w": 5, "t": "தவிர"}, {"w": 6, "t": "என்று கூறியே"}, {"w": 7, "t": "they said"}, {"w": 8, "t": "அவரைகொள்ளுங்கள்"}, {"w": 9, "t": "அல்லது"}, {"w": 10, "t": "அவரை எரித்து விடுங்கள்"}, {"w": 11, "t": "ஆக, அவரை பாதுகாத்தான்"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "நெருப்பிலிருந்து"}, {"w": 14, "t": "the fire"}, {"w": 15, "t": "நிச்சயமாக"}, {"w": 16, "t": "இதில் உள்ளன"}, {"w": 17, "t": "that"}, {"w": 18, "t": "பல அத்தாட்சிகள்"}, {"w": 19, "t": "மக்களுக்கு"}, {"w": 20, "t": "நம்பிக்கை கொள்கின்ற"}, {"w": 21, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இன்னும் கூறினார்"}, {"w": 2, "t": "நீங்கள் எடுத்துக் கொண்டதெல்லாம்"}, {"w": 3, "t": "you have taken"}, {"w": 4, "t": "அல்லாஹ்வையன்றி"}, {"w": 5, "t": "besides"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "சிலைகளை"}, {"w": 8, "t": "அன்பினால்தான்"}, {"w": 9, "t": "உங்களுக்கு மத்தியில்"}, {"w": 10, "t": "வாழ்வில்"}, {"w": 11, "t": "the life"}, {"w": 12, "t": "இவ்வுலக"}, {"w": 13, "t": "பிறகு"}, {"w": 14, "t": "மறுமை நாளில்"}, {"w": 15, "t": "(of) the Resurrection"}, {"w": 16, "t": "மறுத்து விடுவார்கள்"}, {"w": 17, "t": "உங்களில் சிலர்"}, {"w": 18, "t": "சிலரை"}, {"w": 19, "t": "சபிப்பார்கள்"}, {"w": 20, "t": "உங்களில் சிலர்"}, {"w": 21, "t": "சிலரை"}, {"w": 22, "t": "உங்கள் தங்குமிடம்"}, {"w": 23, "t": "நரகம்தான்"}, {"w": 24, "t": "உங்களுக்கு யாரும் இல்லை"}, {"w": 25, "t": "for you"}, {"w": 26, "t": "உதவியாளர்கள்"}, {"w": 27, "t": "helpers"}, {"w": 28, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "ஆக, நம்பிக்கைகொண்டார்"}, {"w": 2, "t": "அவரை"}, {"w": 3, "t": "லூத்"}, {"w": 4, "t": "இன்னும் அவர் கூறினார்"}, {"w": 5, "t": "நிச்சயமாக நான்"}, {"w": 6, "t": "வெளியேறிசெல்கிறேன்"}, {"w": 7, "t": "என் இறைவனின் பக்கம்"}, {"w": 8, "t": "my Lord"}, {"w": 9, "t": "நிச்சயமாக அவன்தான்"}, {"w": 10, "t": "[He] (is)"}, {"w": 11, "t": "மிகைத்தவன்"}, {"w": 12, "t": "மகா ஞானவான்"}, {"w": 13, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நாம் வழங்கினோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "இஸ்ஹாக்கையும்"}, {"w": 4, "t": "யஃகூபையும்"}, {"w": 5, "t": "இன்னும் ஆக்கினோம்"}, {"w": 6, "t": "அவரது சந்ததிகளில்"}, {"w": 7, "t": "his offsprings"}, {"w": 8, "t": "நபித்துவத்தையும்"}, {"w": 9, "t": "வேதங்களையும்"}, {"w": 10, "t": "இன்னும் அவருக்கு நாம் கொடுத்தோம்"}, {"w": 11, "t": "அவருடைய கூலியை"}, {"w": 12, "t": "இம்மையில்"}, {"w": 13, "t": "the world"}, {"w": 14, "t": "நிச்சயமாக அவர்"}, {"w": 15, "t": "மறுமையில்"}, {"w": 16, "t": "the Hereafter"}, {"w": 17, "t": "நல்லவர்களில் இருப்பார்"}, {"w": 18, "t": "the righteous"}, {"w": 19, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இன்னும் லூத்தை"}, {"w": 2, "t": "அவர் கூறிய சமயத்தை நினைவு கூறுவீராக!"}, {"w": 3, "t": "he said"}, {"w": 4, "t": "தனது மக்களுக்கு"}, {"w": 5, "t": "நிச்சயமாக நீங்கள்"}, {"w": 6, "t": "செய்கிறீர்கள்"}, {"w": 7, "t": "மானக்கேடான செயலை"}, {"w": 8, "t": "உங்களுக்கு முன் செய்ததில்லை"}, {"w": 9, "t": "has preceded you"}, {"w": 10, "t": "இதை/ஒருவரும்"}, {"w": 11, "t": "any"}, {"w": 12, "t": "one"}, {"w": 13, "t": "அகிலத்தாரில்"}, {"w": 14, "t": "the worlds"}, {"w": 15, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "நீங்கள் உறவு கொள்கிறீர்களா?"}, {"w": 2, "t": "ஆண்களிடம்"}, {"w": 3, "t": "தடுக்கிறீர்கள்"}, {"w": 4, "t": "பாதைகளை"}, {"w": 5, "t": "செய்கிறீர்கள்"}, {"w": 6, "t": "உங்கள் சபைகளில்"}, {"w": 7, "t": "in"}, {"w": 8, "t": "கெட்டசெயலை"}, {"w": 9, "t": "இருக்கவில்லை"}, {"w": 10, "t": "And not"}, {"w": 11, "t": "பதில்"}, {"w": 12, "t": "அவருடைய மக்களின்"}, {"w": 13, "t": "தவிர"}, {"w": 14, "t": "என்று கூறியதை"}, {"w": 15, "t": "that"}, {"w": 16, "t": "எங்களிடம் கொண்டு வருவீராக"}, {"w": 17, "t": "தண்டனையை"}, {"w": 18, "t": "அல்லாஹ்வின்"}, {"w": 19, "t": "நீர் இருந்தால்"}, {"w": 20, "t": "if"}, {"w": 21, "t": "உண்மையாளர்களில்"}, {"w": 22, "t": "of"}, {"w": 23, "t": "the truthful"}, {"w": 24, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவா!"}, {"w": 3, "t": "எனக்கு நீ உதவுவாயாக"}, {"w": 4, "t": "எதிராக"}, {"w": 5, "t": "மக்களுக்கு"}, {"w": 6, "t": "கெடுதி செய்கின்ற(வர்கள்)"}, {"w": 7, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "வந்த போது"}, {"w": 2, "t": "came"}, {"w": 3, "t": "நமது தூதர்கள்"}, {"w": 4, "t": "இப்ராஹீமிடம்"}, {"w": 5, "t": "நற்செய்தியுடன்"}, {"w": 6, "t": "அவர்கள் கூறினார்கள்"}, {"w": 7, "t": "நிச்சயமாக நாங்கள்"}, {"w": 8, "t": "அழிக்கப் போகிறோம்"}, {"w": 9, "t": "வசிப்பவர்"}, {"w": 10, "t": "இந்த"}, {"w": 11, "t": "ஊரில்"}, {"w": 12, "t": "நிச்சயமாக"}, {"w": 13, "t": "இதில் வசிப்பவர்கள்"}, {"w": 14, "t": "இருக்கின்றனர்"}, {"w": 15, "t": "தீயவர்களாக"}, {"w": 16, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "அதில் இருக்கிறார்"}, {"w": 4, "t": "லூத்"}, {"w": 5, "t": "அவர்கள் கூறினார்கள்"}, {"w": 6, "t": "நாங்கள்"}, {"w": 7, "t": "நன்கறிந்தவர்கள்"}, {"w": 8, "t": "அதில்உள்ளவர்களை"}, {"w": 9, "t": "(is) in it"}, {"w": 10, "t": "நிச்சயமாக அவரையும் நாம் பாதுகாப்போம்"}, {"w": 11, "t": "அவருடைய குடும்பத்தாரையும்"}, {"w": 12, "t": "தவிர/அவருடைய மனைவியை"}, {"w": 13, "t": "his wife"}, {"w": 14, "t": "அவள்ஆகிவிடுவாள்"}, {"w": 15, "t": "மீதம் இருப்பவர்களில்"}, {"w": 16, "t": "those who remain behind"}, {"w": 17, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "வந்த போது"}, {"w": 2, "t": "[that]"}, {"w": 3, "t": "came"}, {"w": 4, "t": "நமது தூதர்கள்"}, {"w": 5, "t": "லூத்திடம்"}, {"w": 6, "t": "அவர் மனம் புண்பட்டார்"}, {"w": 7, "t": "அவர்களால்"}, {"w": 8, "t": "இன்னும் அவர் நெருக்கடிக்கு உள்ளானார்"}, {"w": 9, "t": "அவர்களால்"}, {"w": 10, "t": "மன"}, {"w": 11, "t": "அவர்கள் கூறினார்கள்"}, {"w": 12, "t": "பயப்படாதீர்"}, {"w": 13, "t": "fear"}, {"w": 14, "t": "இன்னும் கவலைப்படாதீர்!"}, {"w": 15, "t": "grieve"}, {"w": 16, "t": "நிச்சயமாக நாம்"}, {"w": 17, "t": "உம்மைபாதுகாப்போம்"}, {"w": 18, "t": "உமது குடும்பத்தையும்"}, {"w": 19, "t": "தவிர"}, {"w": 20, "t": "உமது மனைவியை"}, {"w": 21, "t": "அவள்ஆகிவிடுவாள்"}, {"w": 22, "t": "மீதம் இருப்பவர்களில்"}, {"w": 23, "t": "those who remain behind"}, {"w": 24, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இறக்குவோம்"}, {"w": 3, "t": "மீது"}, {"w": 4, "t": "வசிப்பவர்"}, {"w": 5, "t": "இந்த"}, {"w": 6, "t": "ஊரில்"}, {"w": 7, "t": "தண்டனையை"}, {"w": 8, "t": "வானத்திலிருந்து"}, {"w": 9, "t": "(the) sky"}, {"w": 10, "t": "அவர்கள் பாவம் செய்துகொண்டு இருந்ததால்"}, {"w": 11, "t": "they have been"}, {"w": 12, "t": "defiantly disobedient"}, {"w": 13, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் விட்டுள்ளோம்"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "அத்தாட்சியை"}, {"w": 5, "t": "தெளிவான"}, {"w": 6, "t": "மக்களுக்கு"}, {"w": 7, "t": "சிந்தித்து புரிகின்ற"}, {"w": 8, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "இன்னும் ‘மத்யன்’க்கு"}, {"w": 2, "t": "Madyan"}, {"w": 3, "t": "சகோதரர் அவர்களுடைய"}, {"w": 4, "t": "ஷுஐபை"}, {"w": 5, "t": "அவர் கூறினார்"}, {"w": 6, "t": "என் மக்களே!"}, {"w": 7, "t": "வணங்குங்கள்!"}, {"w": 8, "t": "அல்லாஹ்வை"}, {"w": 9, "t": "இன்னும் ஆதரவு வையுங்கள்!"}, {"w": 10, "t": "நாளை"}, {"w": 11, "t": "மறுமை"}, {"w": 12, "t": "வரம்பு மீறி அழிச்சாட்டியம் செய்யாதீர்கள்"}, {"w": 13, "t": "commit evil"}, {"w": 14, "t": "பூமியில்"}, {"w": 15, "t": "the earth"}, {"w": 16, "t": "தீயவர்களாக இருந்து"}, {"w": 17, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "அவர்கள் அவரைப் பொய்ப்பித்தனர்"}, {"w": 2, "t": "ஆகவே, அவர்களைப் பிடித்தது"}, {"w": 3, "t": "நிலநடுக்கம்"}, {"w": 4, "t": "அவர்கள் காலையில் ஆகிவிட்டனர்"}, {"w": 5, "t": "தங்கள் இல்லத்தில்"}, {"w": 6, "t": "their home"}, {"w": 7, "t": "இறந்தவர்களாக"}, {"w": 8, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "இன்னும் ஆதை"}, {"w": 2, "t": "இன்னும் சமூதை"}, {"w": 3, "t": "தெளிவாக இருக்கின்றது"}, {"w": 4, "t": "(has) become clear"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "அவர்களின் தங்குமிடங்களில் இருந்து"}, {"w": 7, "t": "their dwellings"}, {"w": 8, "t": "அலங்கரித்தான்"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "ஷைத்தான்"}, {"w": 11, "t": "அவர்களின் செயல்களை"}, {"w": 12, "t": "தடுத்தான் அவர்களை"}, {"w": 13, "t": "பாதையிலிருந்து"}, {"w": 14, "t": "the Way"}, {"w": 15, "t": "அவர்கள் இருந்தனர்"}, {"w": 16, "t": "தெளிவானவர்களாக"}, {"w": 17, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "இன்னும் காரூனையும்"}, {"w": 2, "t": "ஃபிர்அவ்னையும்"}, {"w": 3, "t": "ஹாமானையும்"}, {"w": 4, "t": "திட்டவட்டமாக"}, {"w": 5, "t": "அவர்களிடம் வந்தார்"}, {"w": 6, "t": "மூசா"}, {"w": 7, "t": "தெளிவான அத்தாட்சிகளுடன்"}, {"w": 8, "t": "அவர்கள் பெருமையடித்தனர்"}, {"w": 9, "t": "பூமியில்"}, {"w": 10, "t": "the earth"}, {"w": 11, "t": "அவர்கள் இல்லை"}, {"w": 12, "t": "they could"}, {"w": 13, 