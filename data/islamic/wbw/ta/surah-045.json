{"w": 9, "t": "தவிர"}, {"w": 10, "t": "அவர்கள் சொல்வதே"}, {"w": 11, "t": "they say"}, {"w": 12, "t": "எங்கள் மூதாதைகளைக் கொண்டு வாருங்கள்"}, {"w": 13, "t": "our forefathers"}, {"w": 14, "t": "நீங்கள் இருந்தால்"}, {"w": 15, "t": "you are"}, {"w": 16, "t": "உண்மையாளர்களாக"}, {"w": 17, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அல்லாஹ்தான்"}, {"w": 3, "t": "உங்களை உயிர்ப்பிக்கின்றான்"}, {"w": 4, "t": "பிறகு"}, {"w": 5, "t": "உங்களை மரணிக்க வைப்பான்"}, {"w": 6, "t": "பிறகு"}, {"w": 7, "t": "அவன் உங்களை ஒன்று சேர்ப்பான்"}, {"w": 8, "t": "மறுமை நாளில்"}, {"w": 9, "t": "(the) Day"}, {"w": 10, "t": "(of) the Resurrection"}, {"w": 11, "t": "அறவே சந்தேகம் இல்லை"}, {"w": 12, "t": "doubt"}, {"w": 13, "t": "அதில்"}, {"w": 14, "t": "என்றாலும்"}, {"w": 15, "t": "அதிகமானவர்கள்"}, {"w": 16, "t": "மக்களில்"}, {"w": 17, "t": "அறியமாட்டார்கள்"}, {"w": 18, "t": "know"}, {"w": 19, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அல்லாஹ்விற்கே உரியது"}, {"w": 2, "t": "ஆட்சி"}, {"w": 3, "t": "வானங்கள்"}, {"w": 4, "t": "இன்னும் பூமியின்"}, {"w": 5, "t": "நாளில்"}, {"w": 6, "t": "நிகழ்கின்றது"}, {"w": 7, "t": "மறுமை நாள்"}, {"w": 8, "t": "அந்நாளில்"}, {"w": 9, "t": "நஷ்டமடைவார்கள்"}, {"w": 10, "t": "பொய்யர்கள்"}, {"w": 11, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நீர் பார்ப்பீர்"}, {"w": 2, "t": "ஒவ்வொரு"}, {"w": 3, "t": "சமுதாயத்தையும்"}, {"w": 4, "t": "முழந்தாளிட்ட வர்களாக"}, {"w": 5, "t": "ஒவ்வொரு"}, {"w": 6, "t": "சமுதாயமும்"}, {"w": 7, "t": "அழைக்கப்படும்"}, {"w": 8, "t": "தமது பதிவு புத்தகத்தின் பக்கம்"}, {"w": 9, "t": "its record"}, {"w": 10, "t": "இன்று"}, {"w": 11, "t": "கூலி கொடுக்கப்படுவீர்கள்"}, {"w": 12, "t": "நீங்கள் செய்துகொண்டிருந்த செயல்களுக்கு"}, {"w": 13, "t": "you used to"}, {"w": 14, "t": "do"}, {"w": 15, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "இதோ"}, {"w": 2, "t": "நமது பதிவேடு"}, {"w": 3, "t": "அது பேசும்"}, {"w": 4, "t": "உங்கள் மீது"}, {"w": 5, "t": "உண்மையாக"}, {"w": 6, "t": "நிச்சயமாக நாம்"}, {"w": 7, "t": "எழுதிக் கொண்டிருந்தோம்"}, {"w": 8, "t": "transcribe"}, {"w": 9, "t": "நீங்கள் செய்து கொண்டிருந்தவற்றை"}, {"w": 10, "t": "you used to"}, {"w": 11, "t": "do"}, {"w": 12, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "ஆகவே/எவர்கள்"}, {"w": 2, "t": "those who"}, {"w": 3, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நன்மைகளை"}, {"w": 6, "t": "அவர்களை நுழைவிப்பான்"}, {"w": 7, "t": "அவர்களது இறைவன்"}, {"w": 8, "t": "தனது அருளில்"}, {"w": 9, "t": "His mercy"}, {"w": 10, "t": "இதுதான்"}, {"w": 11, "t": "[it]"}, {"w": 12, "t": "வெற்றி"}, {"w": 13, "t": "மிகத் தெளிவான(து)"}, {"w": 14, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "நிராகரித்தவர்கள்"}, {"w": 3, "t": "disbelieved"}, {"w": 4, "t": "இருக்கவில்லையா?"}, {"w": 5, "t": "Then were not"}, {"w": 6, "t": "எனது வசனங்கள்"}, {"w": 7, "t": "ஓதப்படுகின்றன"}, {"w": 8, "t": "உங்கள் மீது"}, {"w": 9, "t": "நீங்கள் பெருமை அடித்தீர்கள்"}, {"w": 10, "t": "இன்னும் நீங்கள் இருந்தீர்கள்"}, {"w": 11, "t": "மக்களாக"}, {"w": 12, "t": "குற்றம் புரிகின்றவர்கள்"}, {"w": 13, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "கூறப்பட்டால்"}, {"w": 2, "t": "it was said"}, {"w": 3, "t": "நிச்சயமாக வாக்கு"}, {"w": 4, "t": "(the) Promise"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "உண்மையானது"}, {"w": 7, "t": "இன்னும் மறுமை"}, {"w": 8, "t": "அறவே சந்தேகம் இல்லை"}, {"w": 9, "t": "doubt"}, {"w": 10, "t": "அதில்"}, {"w": 11, "t": "நீங்கள் கூறுவீர்கள்"}, {"w": 12, "t": "அறியமாட்டோம்"}, {"w": 13, "t": "we know"}, {"w": 14, "t": "மறுமை என்றால் என்ன?"}, {"w": 15, "t": "the Hour (is)"}, {"w": 16, "t": "நாங்கள் எண்ணவில்லை"}, {"w": 17, "t": "we think"}, {"w": 18, "t": "தவிர"}, {"w": 19, "t": "ஒரு எண்ணமாகவே"}, {"w": 20, "t": "நாங்கள் உறுதிசெய்பவர்களாக இல்லை"}, {"w": 21, "t": "we"}, {"w": 22, "t": "(are) convinced"}, {"w": 23, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "வெளிப்படும்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "தீமைகள்"}, {"w": 4, "t": "அவர்கள் செய்தவற்றின்"}, {"w": 5, "t": "they did"}, {"w": 6, "t": "இன்னும் சூழ்ந்துகொள்ளும்"}, {"w": 7, "t": "அவர்களை"}, {"w": 8, "t": "எது/ இருந்தார்களோ/அதை"}, {"w": 9, "t": "they used"}, {"w": 10, "t": "[at it]"}, {"w": 11, "t": "பரிகாசம் செய்பவர்களாக"}, {"w": 12, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "கூறப்படும்"}, {"w": 2, "t": "இன்று"}, {"w": 3, "t": "உங்களை விட்டுவிடுவோம்"}, {"w": 4, "t": "நீங்கள் விட்டதுபோன்று"}, {"w": 5, "t": "you forgot"}, {"w": 6, "t": "சந்திப்பை"}, {"w": 7, "t": "உங்களது இன்றைய தினத்தின்"}, {"w": 8, "t": "(of) this Day of yours"}, {"w": 9, "t": "உங்கள் ஒதுங்குமிடம்"}, {"w": 10, "t": "நரகம்தான்"}, {"w": 11, "t": "உங்களுக்கு இல்லை"}, {"w": 12, "t": "for you"}, {"w": 13, "t": "உதவியாளர்கள் யாரும்"}, {"w": 14, "t": "helpers"}, {"w": 15, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இதற்கு காரணம் நிச்சயமாக நீங்கள்"}, {"w": 2, "t": "(is) because you"}, {"w": 3, "t": "எடுத்துக்கொண்டீர்கள்"}, {"w": 4, "t": "வசனங்களை"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "கேலியாக"}, {"w": 7, "t": "இன்னும் உங்களை மயக்கிவிட்டது"}, {"w": 8, "t": "உலக வாழ்க்கை"}, {"w": 9, "t": "(of) the world"}, {"w": 10, "t": "ஆகவே, இன்று"}, {"w": 11, "t": "வெளியேற்றப்பட மாட்டார்கள்"}, {"w": 12, "t": "they will be brought forth"}, {"w": 13, "t": "அதிலிருந்து"}, {"w": 14, "t": "இன்னும் அவர்களிடமிருந்து காரணங்கள் அங்கீகரிக்கப்படாது"}, {"w": 15, "t": "they"}, {"w": 16, "t": "will be asked to appease"}, {"w": 17, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "அல்லாஹ்விற்கே"}, {"w": 2, "t": "எல்லாப் புகழும்"}, {"w": 3, "t": "அதிபதி"}, {"w": 4, "t": "வானங்களின்"}, {"w": 5, "t": "இன்னும் அதிபதி"}, {"w": 6, "t": "பூமியின்"}, {"w": 7, "t": "அதிபதி"}, {"w": 8, "t": "அகிலத்தார்களின்"}, {"w": 9, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இன்னும் அவனுக்கே உரியது"}, {"w": 2, "t": "பெருமை"}, {"w": 3, "t": "வானங்களிலும்"}, {"w": 4, "t": "the heavens"}, {"w": 5, "t": "பூமியிலும்"}, {"w": 6, "t": "அவன்தான்"}, {"w": 7, "t": "மிகைத்தவன்"}, {"w": 8, "t": "மகா ஞானவான்"}, {"w": 9, "t": "(37)"}]}]}