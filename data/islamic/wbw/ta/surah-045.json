{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "ஹா மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இறக்கப்பட்டது"}, {"w": 2, "t": "இந்த வேதம்"}, {"w": 3, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "மிகைத்தவன்"}, {"w": 6, "t": "மகா ஞானவான்"}, {"w": 7, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "வானங்களில்"}, {"w": 3, "t": "the heavens"}, {"w": 4, "t": "இன்னும் பூமியில்"}, {"w": 5, "t": "பல அத்தாட்சிகள்"}, {"w": 6, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 7, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "உங்களைப் படைத்திருப்பதிலும்"}, {"w": 2, "t": "your creation"}, {"w": 3, "t": "பரப்பி இருப்பதிலும்"}, {"w": 4, "t": "He disperses"}, {"w": 5, "t": "உயிரினங்களை"}, {"w": 6, "t": "(the) moving creatures"}, {"w": 7, "t": "பல அத்தாட்சிகள்"}, {"w": 8, "t": "மக்களுக்கு"}, {"w": 9, "t": "உறுதியாக நம்பிக்கை கொள்கின்றனர்"}, {"w": 10, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "மாறிமாறிவருவதிலும்"}, {"w": 2, "t": "இரவு, பகல்"}, {"w": 3, "t": "and the day"}, {"w": 4, "t": "இன்னும் எது/இறக்கினான்"}, {"w": 5, "t": "Allah sends down"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "வானத்திலிருந்து"}, {"w": 8, "t": "the sky"}, {"w": 9, "t": "மழையை"}, {"w": 10, "t": "(the) provision"}, {"w": 11, "t": "உயிர்ப்பித்தான்"}, {"w": 12, "t": "அதன் மூலம்"}, {"w": 13, "t": "பூமியை"}, {"w": 14, "t": "பின்னர்"}, {"w": 15, "t": "அது இறந்த"}, {"w": 16, "t": "திருப்புவதிலும்"}, {"w": 17, "t": "காற்றுகளை"}, {"w": 18, "t": "பல அத்தாட்சிகள்"}, {"w": 19, "t": "மக்களுக்கு"}, {"w": 20, "t": "சிந்தித்து புரிகின்றனர்"}, {"w": 21, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இவை"}, {"w": 2, "t": "வசனங்களாகும்"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "இவற்றை ஓதுகிறோம்"}, {"w": 5, "t": "உம்மீது"}, {"w": 6, "t": "உண்மையாகவே"}, {"w": 7, "t": "எந்த செய்தியை"}, {"w": 8, "t": "statement"}, {"w": 9, "t": "பின்னர்/அல்லாஹ்"}, {"w": 10, "t": "Allah"}, {"w": 11, "t": "இன்னும் அவனது அத்தாட்சிகளுக்கு"}, {"w": 12, "t": "இவர்கள் நம்பிக்கை கொள்வார்கள்"}, {"w": 13, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "எல்லோருக்கும்"}, {"w": 3, "t": "பாவிகள்"}, {"w": 4, "t": "பொய் பேசுகின்ற"}, {"w": 5, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "செவியுறுகின்றான்"}, {"w": 2, "t": "வசனங்கள்"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "ஓதப்படுவதை"}, {"w": 5, "t": "தன் மீது"}, {"w": 6, "t": "பிறகு"}, {"w": 7, "t": "பிடிவாதம் காட்டுகின்றான்"}, {"w": 8, "t": "பெருமை பிடித்தவனாக"}, {"w": 9, "t": "அவனோ அவற்றை செவியுறாதவனைப் போல"}, {"w": 10, "t": "not"}, {"w": 11, "t": "he heard them"}, {"w": 12, "t": "அவனுக்கு நற்செய்தி கூறுங்கள்!"}, {"w": 13, "t": "வேதனையைக் கொண்டு"}, {"w": 14, "t": "வலி தரக்கூடிய(து)"}, {"w": 15, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவன் அறிந்து கொண்டால்"}, {"w": 2, "t": "he knows"}, {"w": 3, "t": "நமது வசனங்களில்"}, {"w": 4, "t": "Our Verses"}, {"w": 5, "t": "எதையும்"}, {"w": 6, "t": "அதை எடுத்துக்கொள்கிறான்"}, {"w": 7, "t": "கேலியாக"}, {"w": 8, "t": "இவர்களுக்கு உண்டு"}, {"w": 9, "t": "for them"}, {"w": 10, "t": "வேதனை"}, {"w": 11, "t": "இழிவுதரும்"}, {"w": 12, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இவர்களுக்கு முன்னால் இருக்கின்றது"}, {"w": 2, "t": "Before them"}, {"w": 3, "t": "நரகம்"}, {"w": 4, "t": "எதையும் தடுக்காது"}, {"w": 5, "t": "will avail"}, {"w": 6, "t": "அவர்களை விட்டும்"}, {"w": 7, "t": "அவர்கள் சம்பாதித்தது"}, {"w": 8, "t": "they had earned"}, {"w": 9, "t": "எதையும்"}, {"w": 10, "t": "இன்னும் எவற்றை/அவர்கள் எடுத்துக் கொண்டார்களோ"}, {"w": 11, "t": "what"}, {"w": 12, "t": "they had taken"}, {"w": 13, "t": "அல்லாஹ்வையன்றி"}, {"w": 14, "t": "besides"}, {"w": 15, "t": "Allah"}, {"w": 16, "t": "பாதுகாவலர்களாக"}, {"w": 17, "t": "அவர்களுக்கு உண்டு"}, {"w": 18, "t": "வேதனை"}, {"w": 19, "t": "பெரிய(து)"}, {"w": 20, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "இதுதான்/நேர்வழி"}, {"w": 2, "t": "(is) guidance"}, {"w": 3, "t": "நிராகரித்தவர்கள்"}, {"w": 4, "t": "disbelieve"}, {"w": 5, "t": "அத்தாட்சிகளை"}, {"w": 6, "t": "தங்கள் இறைவனின்"}, {"w": 7, "t": "அவர்களுக்கு உண்டு"}, {"w": 8, "t": "வேதனை"}, {"w": 9, "t": "தண்டனை"}, {"w": 10, "t": "filth"}, {"w": 11, "t": "வலி தரக்கூடிய(து)"}, {"w": 12, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "எப்படிப்பட்டவன்"}, {"w": 3, "t": "வசப்படுத்தினான்"}, {"w": 4, "t": "உங்களுக்கு/கடலை"}, {"w": 5, "t": "the sea"}, {"w": 6, "t": "செல்வதற்காகவும்"}, {"w": 7, "t": "கப்பல்கள்/அதில்"}, {"w": 8, "t": "therein"}, {"w": 9, "t": "அவனது கட்டளைப்படி"}, {"w": 10, "t": "நீங்கள் தேடுவதற்காகவும்"}, {"w": 11, "t": "அவனுடைய அருளிலிருந்து"}, {"w": 12, "t": "His Bounty"}, {"w": 13, "t": "நீங்கள் நன்றி செலுத்துவதற்காகவும்"}, {"w": 14, "t": "give thanks"}, {"w": 15, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இன்னும் வசப்படுத்தினான்"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "வானங்களில் உள்ளவற்றை(யும்)"}, {"w": 4, "t": "(is) in"}, {"w": 5, "t": "the heavens"}, {"w": 6, "t": "பூமியில் உள்ளவற்றையும்"}, {"w": 7, "t": "(is) in"}, {"w": 8, "t": "the earth "}, {"w": 9, "t": "அனைத்தையும்"}, {"w": 10, "t": "தன் புறத்திலிருந்து"}, {"w": 11, "t": "நிச்சயமாக இதில் உள்ளன"}, {"w": 12, "t": "in"}, {"w": 13, "t": "that"}, {"w": 14, "t": "பல அத்தாட்சிகள்"}, {"w": 15, "t": "மக்களுக்கு"}, {"w": 16, "t": "சிந்திக்கின்ற"}, {"w": 17, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "அவர்கள் மன்னித்து விடட்டும்"}, {"w": 5, "t": "ஆதரவு வைக்காதவர்களை"}, {"w": 6, "t": "(do) not"}, {"w": 7, "t": "hope"}, {"w": 8, "t": "அல்லாஹ்வின் நடவடிக்கைகளை"}, {"w": 9, "t": "(of) Allah"}, {"w": 10, "t": "இறுதியாக தண்டனை கொடுப்பான்"}, {"w": 11, "t": "ஒரு கூட்டத்திற்கு"}, {"w": 12, "t": "அவர்கள் செய்து கொண்டிருந்தவற்றுக்கு"}, {"w": 13, "t": "they used to"}, {"w": 14, "t": "earn"}, {"w": 15, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "யார் செய்வாரோ"}, {"w": 2, "t": "does"}, {"w": 3, "t": "ஒரு நன்மையை"}, {"w": 4, "t": "அது அவருக்குத்தான் நல்லது"}, {"w": 5, "t": "எவர்"}, {"w": 6, "t": "தீமை செய்வாரோ"}, {"w": 7, "t": "அது அவருக்குத்தான் கேடாகும்"}, {"w": 8, "t": "பிறகு"}, {"w": 9, "t": "உங்கள் இறைவனிடம்"}, {"w": 10, "t": "your Lord"}, {"w": 11, "t": "நீங்கள் திரும்பக் கொண்டு வரப்படுவீர்கள்"}, {"w": 12, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் கொடுத்தோம்"}, {"w": 3, "t": "இஸ்ரவேலர்களுக்கு"}, {"w": 4, "t": "(the) Children of Israel"}, {"w": 5, "t": "வேதங்களை(யும்)"}, {"w": 6, "t": "ஞானத்தையும்"}, {"w": 7, "t": "நபித்துவத்தையும்"}, {"w": 8, "t": "இன்னும் அவர்களுக்கு நாம் வழங்கினோம்"}, {"w": 9, "t": "நல்ல உணவுகளை"}, {"w": 10, "t": "the good things"}, {"w": 11, "t": "அவர்களை மேன்மையாக்கினோம்"}, {"w": 12, "t": "அக்கால மக்களைவிட"}, {"w": 13, "t": "the worlds"}, {"w": 14, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நாம் அவர்களுக்குக் கொடுத்தோம்"}, {"w": 2, "t": "தெளிவான சட்டங்களை"}, {"w": 3, "t": "இந்த மார்க்கத்தின்"}, {"w": 4, "t": "the matter"}, {"w": 5, "t": "அவர்கள் கருத்து வேறுபடவில்லை"}, {"w": 6, "t": "they differed"}, {"w": 7, "t": "தவிர/அவர்களிடம் வந்த பின்னர்"}, {"w": 8, "t": "after"}, {"w": 9, "t": "after"}, {"w": 10, "t": "[what]"}, {"w": 11, "t": "came to them"}, {"w": 12, "t": "கல்வி"}, {"w": 13, "t": "பொறாமையினால்"}, {"w": 14, "t": "தங்களுக்கு மத்தியில்"}, {"w": 15, "t": "நிச்சயமாக"}, {"w": 16, "t": "உமது இறைவன்"}, {"w": 17, "t": "தீர்ப்பளிப்பான்"}, {"w": 18, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 19, "t": "மறுமை நாளில்"}, {"w": 20, "t": "(of) the Resurrection"}, {"w": 21, "t": "அவர்கள் கருத்துவேறுபாடு கொண்டிருந்தவற்றில்"}, {"w": 22, "t": "they used to"}, {"w": 23, "t": "therein"}, {"w": 24, "t": "differ"}, {"w": 25, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "உம்மை அமைத்தோம்"}, {"w": 3, "t": "தெளிவான சட்டங்கள் மீது"}, {"w": 4, "t": "an ordained way"}, {"w": 5, "t": "இந்த மார்க்கத்தினுடைய"}, {"w": 6, "t": "the matter"}, {"w": 7, "t": "ஆகவே அதையே பின்பற்றுவீராக!"}, {"w": 8, "t": "பின்பற்றாதீர்"}, {"w": 9, "t": "follow"}, {"w": 10, "t": "மன விருப்பங்களை"}, {"w": 11, "t": "அறியாதவர்களின்"}, {"w": 12, "t": "(do) not"}, {"w": 13, "t": "know"}, {"w": 14, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "அறவே தடுக்க மாட்டார்கள்"}, {"w": 3, "t": "will avail"}, {"w": 4, "t": "உம்மை விட்டு"}, {"w": 5, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "எதையும்/நிச்சயமாக"}, {"w": 8, "t": "And indeed"}, {"w": 9, "t": "அநியாயக்காரர்கள்"}, {"w": 10, "t": "அவர்களில் சிலர்"}, {"w": 11, "t": "நண்பர்கள்/சிலருக்கு"}, {"w": 12, "t": "(of) others"}, {"w": 13, "t": "அல்லாஹ்/நண்பன்"}, {"w": 14, "t": "(is the) Protector"}, {"w": 15, "t": "இறையச்சமுள்ளவர்களின்"}, {"w": 16, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "தெளிவான ஆதாரங்களும்"}, {"w": 3, "t": "மக்களுக்கு"}, {"w": 4, "t": "நேர்வழியும்"}, {"w": 5, "t": "கருணையுமாகும்"}, {"w": 6, "t": "மக்களுக்கு"}, {"w": 7, "t": "உறுதி கொள்கின்றனர்"}, {"w": 8, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "எண்ணுகின்றார்களா?"}, {"w": 2, "t": "think"}, {"w": 3, "t": "எவர்கள்"}, {"w": 4, "t": "செய்தார்கள்"}, {"w": 5, "t": "பாவங்களை"}, {"w": 6, "t": "அவர்களை ஆக்குவோம் என்று"}, {"w": 7, "t": "We will make them"}, {"w": 8, "t": "எவர்களைப் போன்று"}, {"w": 9, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 10, "t": "செய்தவர்களை"}, {"w": 11, "t": "நன்மைகளை"}, {"w": 12, "t": "சமமாக்கிவிடுவோம்"}, {"w": 13, "t": "வாழ்க்கையும் இவர்களின்"}, {"w": 14, "t": "இவர்களின் மரணத்தையும்"}, {"w": 15, "t": "அது மிகக் கெட்டது"}, {"w": 16, "t": "எதை தீர்ப்பளிக்கின்றார்களோ"}, {"w": 17, "t": "they judge"}, {"w": 18, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "படைத்தான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "வானங்களையும்"}, {"w": 4, "t": "பூமியையும்"}, {"w": 5, "t": "உண்மையான காரணத்திற்காக(வும்)"}, {"w": 6, "t": "கூலி கொடுக்கப்படுவதற்காகவும்"}, {"w": 7, "t": "ஒவ்வொரு ஆன்மாவும்"}, {"w": 8, "t": "soul"}, {"w": 9, "t": "அது எதை செய்ததோ"}, {"w": 10, "t": "it has earned"}, {"w": 11, "t": "இன்னு