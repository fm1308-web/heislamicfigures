{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நிராகரித்து(விட்டனர்)"}, {"w": 3, "t": "இன்னும் தடுத்தார்களோ"}, {"w": 4, "t": "பாதையிலிருந்து"}, {"w": 5, "t": "(the) way of Allah"}, {"w": 6, "t": "அல்லாஹ்வின்"}, {"w": 7, "t": "வழிகெடுத்து விட்டான்"}, {"w": 8, "t": "அவர்களின் செயல்களை"}, {"w": 9, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 3, "t": "இன்னும் நன்மைகளை செய்தனர்"}, {"w": 4, "t": "righteous deeds"}, {"w": 5, "t": "இன்னும் நம்பிக்கை கொண்டார்கள்"}, {"w": 6, "t": "இறக்கப்பட்டதை(யும்)"}, {"w": 7, "t": "is revealed"}, {"w": 8, "t": "முஹம்மது நபியின் மீது"}, {"w": 9, "t": "Muhammad"}, {"w": 10, "t": "அதுதான்"}, {"w": 11, "t": "உண்மையாகும்"}, {"w": 12, "t": "அவர்களின் இறைவனிடம் இருந்து வந்த"}, {"w": 13, "t": "their Lord"}, {"w": 14, "t": "போக்கிவிடுவான்"}, {"w": 15, "t": "அவர்களை விட்டு"}, {"w": 16, "t": "அவர்களின் பாவங்களை"}, {"w": 17, "t": "இன்னும் சீர் செய்துவிடுவான்"}, {"w": 18, "t": "அவர்களின் காரியத்தை"}, {"w": 19, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "ஏனெனில் நிச்சயமாக"}, {"w": 3, "t": "நிராகரித்தவர்கள்"}, {"w": 4, "t": "disbelieve"}, {"w": 5, "t": "பின்பற்றினர்"}, {"w": 6, "t": "பொய்யை"}, {"w": 7, "t": "நிச்சயமாக"}, {"w": 8, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 9, "t": "believe"}, {"w": 10, "t": "பின்பற்றினார்கள்"}, {"w": 11, "t": "உண்மையை"}, {"w": 12, "t": "தங்கள் இறைவனிடமிருந்து"}, {"w": 13, "t": "their Lord"}, {"w": 14, "t": "இவ்வாறுதான்"}, {"w": 15, "t": "விவரிக்கின்றான்"}, {"w": 16, "t": "அல்லாஹ்"}, {"w": 17, "t": "மக்களுக்கு"}, {"w": 18, "t": "அவர்களுக்குரிய தன்மைகளை"}, {"w": 19, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நீங்கள் சந்தித்தால்"}, {"w": 2, "t": "you meet"}, {"w": 3, "t": "நிராகரித்தவர்களை"}, {"w": 4, "t": "disbelieve"}, {"w": 5, "t": "வெட்டுங்கள்!"}, {"w": 6, "t": "பிடரிகளை"}, {"w": 7, "t": "இறுதியாக"}, {"w": 8, "t": "அவர்களை நீங்கள் மிகைத்துவிட்டால்"}, {"w": 9, "t": "you have subdued them"}, {"w": 10, "t": "உறுதியாகக் கட்டுங்கள்!"}, {"w": 11, "t": "கயிறுகளில்"}, {"w": 12, "t": "ஒன்று"}, {"w": 13, "t": "உபகாரம் புரியுங்கள்!"}, {"w": 14, "t": "அதற்குப் பின்னர்"}, {"w": 15, "t": "அல்லது"}, {"w": 16, "t": "பிணைத்தொகை கொடுக்கட்டும்!"}, {"w": 17, "t": "இறுதியாக"}, {"w": 18, "t": "முடிக்கின்ற (வரை)"}, {"w": 19, "t": "போர்"}, {"w": 20, "t": "அதன் சுமைகளை"}, {"w": 21, "t": "இதுதான்"}, {"w": 22, "t": "அல்லாஹ் நாடினால்"}, {"w": 23, "t": "Allah had willed"}, {"w": 24, "t": "Allah had willed"}, {"w": 25, "t": "பழிதீர்த்திருப்பான்"}, {"w": 26, "t": "அவர்களிடம்"}, {"w": 27, "t": "என்றாலும்"}, {"w": 28, "t": "அவன்சோதிப்பதற்காக"}, {"w": 29, "t": "உங்களில் சிலரை"}, {"w": 30, "t": "சிலர் மூலமாக"}, {"w": 31, "t": "எவர்கள்"}, {"w": 32, "t": "கொல்லப்பட்டார்களோ"}, {"w": 33, "t": "பாதையில்"}, {"w": 34, "t": "(the) way of Allah"}, {"w": 35, "t": "அல்லாஹ்வின்"}, {"w": 36, "t": "வீணாக்கிவிட மாட்டான்"}, {"w": 37, "t": "He will cause to be lost"}, {"w": 38, "t": "அவர்களின் அமல்களை"}, {"w": 39, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவர்களுக்கு அவன் நேர்வழி காட்டுவான்"}, {"w": 2, "t": "இன்னும் சீர் செய்வான்"}, {"w": 3, "t": "அவர்களின் காரியத்தை"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இன்னும் அவர்களை நுழைப்பான்"}, {"w": 2, "t": "சொர்க்கத்தில்"}, {"w": 3, "t": "அதை காண்பித்துக் கொடுப்பான்"}, {"w": 4, "t": "அவர்களுக்கு"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "நீங்கள் உதவினால்"}, {"w": 5, "t": "you help"}, {"w": 6, "t": "அல்லாஹ்விற்கு"}, {"w": 7, "t": "அவன் உதவுவான் உங்களுக்கு"}, {"w": 8, "t": "இன்னும் உறுதிப்படுத்துவான்"}, {"w": 9, "t": "உங்கள் பாதங்களை"}, {"w": 10, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நிராகரித்தார்களோ"}, {"w": 3, "t": "அவர்களுக்கு கேடு உண்டாகட்டும்"}, {"w": 4, "t": "for them"}, {"w": 5, "t": "இன்னும் அவன் வழிகேட்டில் விட்டு விடுவான்"}, {"w": 6, "t": "அவர்களின் செயல்களை"}, {"w": 7, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அது"}, {"w": 2, "t": "ஏனெனில், நிச்சயமாக"}, {"w": 3, "t": "வெறுத்தார்கள்"}, {"w": 4, "t": "இறக்கியதை"}, {"w": 5, "t": "Allah has revealed"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "ஆகவே, அவன் வீணாக்கிவிட்டான்"}, {"w": 8, "t": "அவர்களின் அமல்களை"}, {"w": 9, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அவர்கள் பயணித்து"}, {"w": 2, "t": "they travel"}, {"w": 3, "t": "பூமியில்"}, {"w": 4, "t": "the earth"}, {"w": 5, "t": "பார்க்க வேண்டாமா?"}, {"w": 6, "t": "எவ்வாறு"}, {"w": 7, "t": "இருந்தது"}, {"w": 8, "t": "முடிவு"}, {"w": 9, "t": "தங்களுக்கு முன்னர் இருந்தவர்களின்"}, {"w": 10, "t": "before them"}, {"w": 11, "t": "before them"}, {"w": 12, "t": "அழித்துவிட்டான்"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "அவர்களை"}, {"w": 15, "t": "இந்நிராகரிப்பாளர்களுக்கும் நிகழும்"}, {"w": 16, "t": "அதைப் போன்ற முடிவுகளே"}, {"w": 17, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஏனெனில், நிச்சயமாக அது"}, {"w": 2, "t": "(is) because"}, {"w": 3, "t": "அல்லாஹ்தான்"}, {"w": 4, "t": "எஜமானன்"}, {"w": 5, "t": "நம்பிக்கையாளர்களின்"}, {"w": 6, "t": "believe"}, {"w": 7, "t": "இன்னும் நிச்சயமாக"}, {"w": 8, "t": "நிராகரிப்பாளர்கள்"}, {"w": 9, "t": "எஜமானன் இல்லை"}, {"w": 10, "t": "protector"}, {"w": 11, "t": "அவர்களுக்கு"}, {"w": 12, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 2, "t": "Allah"}, {"w": 3, "t": "நுழைப்பான்"}, {"w": 4, "t": "எவர்கள்"}, {"w": 5, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 6, "t": "இன்னும் செய்தார்கள்"}, {"w": 7, "t": "நன்மைகளை"}, {"w": 8, "t": "சொர்க்கங்களில்"}, {"w": 9, "t": "ஓடும்"}, {"w": 10, "t": "அவற்றின் கீழ்"}, {"w": 11, "t": "underneath it"}, {"w": 12, "t": "ஆறுகள்"}, {"w": 13, "t": "நிராகரித்தவர்கள்"}, {"w": 14, "t": "disbelieve"}, {"w": 15, "t": "இன்புறுகிறார்கள்"}, {"w": 16, "t": "இன்னும் சாப்பிடுகிறார்கள்"}, {"w": 17, "t": "போல்"}, {"w": 18, "t": "சாப்பிடுவது"}, {"w": 19, "t": "கால்நடைகள்"}, {"w": 20, "t": "நரகம்தான்"}, {"w": 21, "t": "தங்குமிடமாகும்"}, {"w": 22, "t": "அவர்களுக்கு"}, {"w": 23, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "ஊர் (மக்)கள்"}, {"w": 3, "t": "a town"}, {"w": 4, "t": "அவை"}, {"w": 5, "t": "மிக உறுதியான(து)"}, {"w": 6, "t": "பலத்தால்"}, {"w": 7, "t": "உமது ஊரைவிட"}, {"w": 8, "t": "your town"}, {"w": 9, "t": "எது/உம்மை வெளியேற்றிய(து)"}, {"w": 10, "t": "has driven you out"}, {"w": 11, "t": "நாம் அவர்களை அழித்தோம்"}, {"w": 12, "t": "அறவே இல்லை"}, {"w": 13, "t": "உதவியாளர்"}, {"w": 14, "t": "அவர்களுக்கு"}, {"w": 15, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "ஆவார்களா?"}, {"w": 2, "t": "இருப்பவர்கள்"}, {"w": 3, "t": "தெளிவான அத்தாட்சியில்"}, {"w": 4, "t": "a clear proof"}, {"w": 5, "t": "தமது இறைவனின்"}, {"w": 6, "t": "his Lord"}, {"w": 7, "t": "போன்று/எவர்களுக்கு"}, {"w": 8, "t": "அலங்கரிக்கப்பட்டது"}, {"w": 9, "t": "தமக்கு"}, {"w": 10, "t": "கெட்ட"}, {"w": 11, "t": "தங்களது செயல்கள்"}, {"w": 12, "t": "இன்னும் பின்பற்றுகின்றார்கள்"}, {"w": 13, "t": "தங்கள் மன இச்சைகளை"}, {"w": 14, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "தன்மையாவது"}, {"w": 2, "t": "சொர்க்கத்தின்/எது"}, {"w": 3, "t": "which"}, {"w": 4, "t": "வாக்களிக்கப்பட்டது"}, {"w": 5, "t": "இறையச்ச முள்ளவர்களுக்கு"}, {"w": 6, "t": "அதில்"}, {"w": 7, "t": "ஆறுகளும்"}, {"w": 8, "t": "தண்ணீரின்"}, {"w": 9, "t": "water"}, {"w": 10, "t": "துர் வாடை வீசாத"}, {"w": 11, "t": "polluted"}, {"w": 12, "t": "ஆறுகளும்"}, {"w": 13, "t": "பாலின்"}, {"w": 14, "t": "milk"}, {"w": 15, "t": "மாறவில்லை"}, {"w": 16, "t": "changes"}, {"w": 17, "t": "அதன் ருசி"}, {"w": 18, "t": "ஆறுகளும்"}, {"w": 19, "t": "மதுவின்"}, {"w": 20, "t": "wine"}, {"w": 21, "t": "ருசியான"}, {"w": 22, "t": "அருந்துபவர்களுக்கு"}, {"w": 23, "t": "ஆறுகளும்"}, {"w": 24, "t": "தேனின்"}, {"w": 25, "t": "honey"}, {"w": 26, "t": "தூய்மையான(து)"}, {"w": 27, "t": "இன்னும் அவர்களுக்கு"}, {"w": 28, "t": "அதில்"}, {"w": 29, "t": "எல்லாவற்றிலிருந்து(ம்)"}, {"w": 30, "t": "all"}, {"w": 31, "t": "கனிகள்"}, {"w": 32, "t": "மன்னிப்பும்"}, {"w": 33, "t": "அவர்களின் இறைவனிடமிருந்து"}, {"w": 34, "t": "their Lord"}, {"w": 35, "t": "போன்று/எவர்(கள்)/ அவர்(கள்)"}, {"w": 36, "t": "like he who"}, {"w": 37, "t": "நிரந்தரமானவர்(கள்)"}, {"w": 38, "t": "நரகத்தில்"}, {"w": 39, "t": "the Fire"}, {"w": 40, "t": "இன்னும் புகட்டப்படுவார்கள்"}, {"w": 41, "t": "நீரை"}, {"w": 42, "t": "கொதிக்கின்றது"}, {"w": 43, "t": "அது துண்டு துண்டாக ஆக்கிவிடும்"}, {"w": 44, "t": "குடல்களை அவர்களின்"}, {"w": 45, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவர்களில் உள்ளனர்"}, {"w": 2, "t": "செவி சாய்க்கின்றவர்களும்"}, {"w": 3, "t": "listen"}, {"w": 4, "t": "உம் பக்கம்"}, {"w": 5, "t": "இறுதியில்"}, {"w": 6, "t": "அவர்கள் வெளியே புறப்பட்டால்"}, {"w": 7, "t": "they depart"}, {"w": 8, "t": "உம்மிடமிருந்து"}, {"w": 9, "t": "you"}, {"w": 10, "t": "கூறுகின்றனர்"}, {"w": 11, "t": "கொடுக்கப்பட்டவர்களிடம்"}, {"w": 12, "t": "were given"}, {"w": 13, "t": "கல்வி"}, {"w": 14, "t": "என்ன/இவர் கூறினார்"}, {"w": 15, "t": "(has) he said"}, {"w": 16, "t": "சற்று நேரத்திற்கு முன்பு"}, {"w": 17, "t": "இவர்கள்தான்/எவர்கள்"}, {"w": 18, "t": "(are) the ones"}, {"w": 19, "t": "முத்திரையிட்டு விட்டான்"}, {"w": 20, "t": "அல்லாஹ்"}, {"w": 21, "t": "இவர்களின் உள்ளங்களில்"}, {"w": 22, "t": "their hearts"}, {"w": 23, "t": "இன்னும் இவர்கள் பின்பற்றினார்கள்"}, {"w": 24, "t": "தங்கள் மன இச்சைகளை"}, {"w": 25, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நேர்வழி பெற்றார்களோ"}, {"w": 3, "t": "அவர்களுக்கு அதிகப்படுத்துவான்"}, {"w": 4, "t": "நேர்வழியை"}, {"w": 5, "t": "இன்னும் , அவர்களுக்கு வழங்குவான்"}, {"w": 6, "t": "அவர்களின் தக்வாவை"}, {"w": 7, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவர்கள் எதிர்பார்க்கின்றார்களா?"}, {"w": 2, "t": "they wait"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "மறுமை"}, {"w": 5, "t": "அவர்களிடம் வருவதை"}, {"w": 6, "t": "it should come to them"}, {"w": 7, "t": "திடீரென"}, {"w": 8, "t": "திட்டமாக"}, {"w": 9, "t": "வந்துவிட்டன"}, {"w": 10, "t": "அதன் அடையாளங்கள்"}, {"w": 11, "t": "எப்படி பலனளிக்கும்!"}, {"w": 12, "t": "அவர்களுக்கு"}, {"w": 13, "t": "அவர்களிடம் வரும் போது"}, {"w": 14, "t": "has come to them"}, {"w": 15, "t": "அவர்கள் நல்லறிவு பெறுவது"}, {"w": 16, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நன்கறிந்து கொள்வீராக!"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "அறவே இல்லை"}, {"w": 4, "t": "வணக்கத்திற்குரியவன்"}, {"w": 5, "t": "அல்லாஹ்வைத் தவிர"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "இன்னும் பாவமன்னிப்பு கோருவீராக!"}, {"w": 8, "t": "உமது தவறுகளுக்காக"}, {"w": 9, "t": "நம்பிக்கை கொண்ட ஆண்களுக்காகவும்"}, {"w": 10, "t": "நம்பிக்கை கொண்ட பெண்களுக்காகவும்"}, {"w": 11, "t": "அல்லாஹ் நன்கறிவான்"}, {"w": 12, "t": "knows"}, {"w": 13, "t": "நீங்கள் சுற்றித்திரியும் இடங்களை(யும்)"}, {"w": 14, "t": "நீங்கள் தங்குமிடங்களையும்"}, {"w": 15, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "கூறுகின்றார்(கள்)"}, {"w": 2, "t": "நம்பிக்கையாளர்கள்"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "இறக்கப்பட வேண்டாமா"}, {"w": 5, "t": "has been revealed"}, {"w": 6, "t": "ஓர் அத்தியாயம்"}, {"w": 7, "t": "இறக்கப்பட்டால்"}, {"w": 8, "t": "is revealed"}, {"w": 9, "t": "ஓர் அத்தியாயம்"}, {"w": 10, "t": "உறுதி செய்யப்பட்டது"}, {"w": 11, "t": "இன்னும் கூறப்பட்டது"}, {"w": 12, "t": "அதில்/போர்"}, {"w": 13, "t": "the fighting"}, {"w": 14, "t": "பார்ப்பீர்"}, {"w": 15, "t": "எவர்கள்"}, {"w": 16, "t": "தங்கள் உள்ளங்களில்"}, {"w": 17, "t": "their hearts"}, {"w": 18, "t": "நோய்"}, {"w": 19, "t": "பார்ப்பார்கள்"}, {"w": 20, "t": "உம் பக்கம்"}, {"w": 21, "t": "பார்ப்பது போல்"}, {"w": 22, "t": "மயக்கமுற்றவர்கள்"}, {"w": 23, "t": "(of) one fainting"}, {"w": 24, "t": "மரண பயத்தால்"}, {"w": 25, "t": "the death"}, {"w": 26, "t": "ஆகவே"}, {"w": 27, "t": "அவர்களுக்கு"}, {"w": 28, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "கீழ்ப்படிவது(ம்)"}, {"w": 2, "t": "பேசுவதும்(தான்)"}, {"w": 3, "t": "நேர்மையாக"}, {"w": 4, "t": "உறுதியாகிவிட்டால்"}, {"w": 5, "t": "(is) determined"}, {"w": 6, "t": "கட்டளை"}, {"w": 7, "t": "அவர்கள் உண்மையாக நடந்திருந்தால்"}, {"w": 8, "t": "they had been true"}, {"w": 9, "t": "அல்லாஹ்வுடன்"}, {"w": 10, "t": "இருக்கும்"}, {"w": 11, "t": "சிறந்ததாக"}, {"w": 12, "t": "அவர்களுக்கு"}, {"w": 13, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நீங்கள் குழப்பம் செய்வீர்கள்தானே!"}, {"w": 2, "t": "you perhaps"}, {"w": 3, "t": "நீங்கள்விலகிவிட்டால்"}, {"w": 4, "t": "you are given authority"}, {"w": 5, "t": "குழப்பம் செய்வீர்கள்"}, {"w": 6, "t": "you cause corruption"}, {"w": 7, "t": "பூமியில்"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "இன்னும் துண்டித்து விடுவீர்கள்"}, {"w": 10, "t": "உங்கள் இரத்த உறவுகளை"}, {"w": 11, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அவர்கள்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "அவர்களை சபித்தான்"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "செவிடாக்கி விட்டான்"}, {"w": 6, "t": "இன்னும் குருடாக்கி விட்டான்"}, {"w": 7, "t": "அவர்களின் பார்வைகளை"}, {"w": 8, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவர்கள் ஆழ்ந்து சிந்திக்க வேண்டாமா?"}, {"w": 2, "t": "they ponder"}, {"w": 3, "t": "குர்ஆனை"}, {"w": 4, "t": "?"}, {"w": 5, "t": "உள்ளங்கள் மீது"}, {"w": 6, "t": "(their) hearts"}, {"w": 7, "t": "அவற்றின் பூட்டுகளா போடப்பட்டுள்ளன?"}, {"w": 8, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "திரும்பிச்"}, {"w": 3, "t": "return"}, {"w": 4, "t": "தங்களது பின் புறங்களின் மீதே"}, {"w": 5, "t": "their backs"}, {"w": 6, "t": "தெளிவானதற்குப் பின்னர்"}, {"w": 7, "t": "after"}, {"w": 8, "t": "what"}, {"w": 9, "t": "(has) become clear"}, {"w": 10, "t": "சென்றவர்கள் தங்களுக்கு/நேர்வழி"}, {"w": 11, "t": "(of) the guidance"}, {"w": 12, "t": "ஷைத்தான்"}, {"w": 13, "t": "அலங்கரித்துவிட்டான்"}, {"w": 14, "t": "அவர்களுக்கு"}, {"w": 15, "t": "(அல்லாஹ்) விட்டு வைத்துள்ளான்"}, {"w": 16, "t": "அவர்களை"}, {"w": 17, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "ஏனெனில், நிச்சயமாக"}, {"w": 3, "t": "கூறினார்கள்"}, {"w": 4, "t": "வெறுத்தவர்களிடம்"}, {"w": 5, "t": "hate"}, {"w": 6, "t": "எதை/இறக்கினான்"}, {"w": 7, "t": "Allah has revealed"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "உங்களுக்கு நாங்கள் கீழ்ப்படிவோம்"}, {"w": 10, "t": "சில விஷங்களில்"}, {"w": 11, "t": "part"}, {"w": 12, "t": "(of) the matter"}, {"w": 13, "t": "அல்லாஹ் நன்கறிவான்"}, {"w": 14, "t": "knows"}, {"w": 15, "t": "இவர்கள் தங்களுக்குள் பேசுவதை"}, {"w": 16, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "எப்படி"}, {"w": 2, "t": "அவர்களை உயிர் வாங்கும்போது"}, {"w": 3, "t": "take them in death"}, {"w": 4, "t": "வானவர்கள்"}, {"w": 5, "t": "அடிப்பார்கள்"}, {"w": 6, "t": "அவர்களின் முகங்களை(யும்)"}, {"w": 7, "t": "அவர்களின் பின் புறங்களையும்"}, {"w": 8, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "ஏனெனில், நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "பின்பற்றினார்கள்"}, {"w": 4, "t": "கோபமூட்டியதை"}, {"w": 5, "t": "angered"}, {"w": 6, "t": "அல்லாஹ்விற்கு"}, {"w": 7, "t": "இன்னும் வெறுத்தார்கள்"}, {"w": 8, "t": "அவனது பொருத்தத்தை"}, {"w": 9, "t": "ஆகவே, வீணாக்கி விட்டான்"}, {"w": 10, "t": "அவர்களின் செயல்களை"}, {"w": 11, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "எண்ணிக் கொண்டார்களா"}, {"w": 2, "t": "think"}, {"w": 3, "t": "தங்களதுஉள்ளங்களில்"}, {"w": 4, "t": "in"}, {"w": 5, "t": "their hearts"}, {"w": 6, "t": "நோய்"}, {"w": 7, "t": "வெளிப்படுத்தி காண்பிக்க மாட்டான் என்று"}, {"w": 8, "t": "never"}, {"w": 9, "t": "will Allah bring forth"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "அவர்களின் குரோதங்களை"}, {"w": 12, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "நாம் நாடினால்"}, {"w": 2, "t": "We willed"}, {"w": 3, "t": "அவர்களை உமக்கு காண்பித்து விடுவோம்"}, {"w": 4, "t": "அவர்களை நீர் அறிந்து கொள்வீர்"}, {"w": 5, "t": "அவர்களின் வெளிப்படையான அடையாளங்களினால்"}, {"w": 6, "t": "இன்னும் அவர்களை நிச்சயமாக நீர் அறிவீர்"}, {"w": 7, "t": "அவர்களின் பேச்சின் தொனியிலும்"}, {"w": 8, "t": "(the) tone"}, {"w": 9, "t": "(of their) speech"}, {"w": 10, "t": "அல்லாஹ் நன்கறிவான்"}, {"w": 11, "t": "knows"}, {"w": 12, "t": "உங்கள் செயல்களை"}, {"w": 13, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நிச்சயமாக நாம் உங்களை சோதிப்போம்"}, {"w": 2, "t": "நாம் அறிகின்றவரை"}, {"w": 3, "t": "We make evident"}, {"w": 4, "t": "ஜிஹாது செய்பவர்களை"}, {"w": 5, "t": "உங்களில்"}, {"w": 6, "t": "பொறுமையாளர் களையும்"}, {"w": 7, "t": "இன்னும் நாம் சோதிப்போம்"}, {"w": 8, "t": "உங்கள் செய்திகளை"}, {"w": 9, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "நிச்சயமாக எவர்கள்"}, {"w": 2, "t": "those who"}, {"w": 3, "t": "நிராகரித்தார்கள்"}, {"w": 4, "t": "இன்னும் தடுத்தார்கள்"}, {"w": 5, "t": "பாதையில் இருந்து"}, {"w": 6, "t": "(the) way of Allah"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "இன்னும் மாறுசெய்தார்கள்"}, {"w": 9, "t": "தூதருக்கு"}, {"w": 10, "t": "தெளிவானதற்குப் பின்னர்"}, {"w": 11, "t": "after"}, {"w": 12, "t": "[what]"}, {"w": 13, "t": "(has been) made clear"}, {"w": 14, "t": "தங்களுக்கு"}, {"w": 15, "t": "நேர்வழி"}, {"w": 16, "t": "அறவே அவர்கள் தீங்கு செய்ய முடியாது"}, {"w": 17, "t": "will they harm"}, {"w": 18, "t": "அல்லாஹ்விற்கு"}, {"w": 19, "t": "எதையும்"}, {"w": 20, "t": "இன்னும் வீணாக்கி விடுவான்"}, {"w": 21, "t": "அவர்களின் செயல்களை"}, {"w": 22, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "கீழ்ப்படியுங்கள்!"}, {"w": 5, "t": "அல்லாஹ்விற்கு"}, {"w": 6, "t": "இன்னும் கீழ்ப்படியுங்கள்!"}, {"w": 7, "t": "தூதருக்கு"}, {"w": 8, "t": "வீணாக்காதீர்கள்!"}, {"w": 9, "t": "make vain"}, {"w": 10, "t": "உங்கள் அமல்களை"}, {"w": 11, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நிச்சயமாக எவர்கள்"}, {"w": 2, "t": "those who"}, {"w": 3, "t": "நிராகரித்தார்கள்"}, {"w": 4, "t": "இன்னும் தடுத்தார்கள்"}, {"w": 5, "t": "பாதையில் இருந்து"}, {"w": 6, "t": "(the) way"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "பிறகு மரணித்தார்கள்"}, {"w": 9, "t": "died"}, {"w": 10, "t": "தாங்கள் இருக்கின்ற நிலையில்"}, {"w": 11, "t": "நிராகரிப்பாளர்களாக"}, {"w": 12, "t": "மன்னிக்கவே மாட்டான்"}, {"w": 13, "t": "will Allah forgive"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "அவர்களை"}, {"w": 16, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "பலவீனப்படாதீர்கள்"}, {"w": 2, "t": "weaken"}, {"w": 3, "t": "அழைத்து விடாதீர்கள்!"}, {"w": 4, "t": "சமாதானத்திற்கு"}, {"w": 5, "t": "peace"}, {"w": 6, "t": "நீங்கள்தான்"}, {"w": 7, "t": "மிக உயர்வானவர்கள்"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "உங்களுடன் இருக்கின்றான்"}, {"w": 10, "t": "உங்களுக்கு குறைக்கவேமாட்டான்"}, {"w": 11, "t": "will deprive you"}, {"w": 12, "t": "உங்கள் அமல்களை"}, {"w": 13, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "உலக வாழ்க்கை எல்லாம்"}, {"w": 2, "t": "the life"}, {"w": 3, "t": "(of) the world"}, {"w": 4, "t": "விளையாட்டு(ம்)"}, {"w": 5, "t": "வேடிக்கையும்தான்"}, {"w": 6, "t": "நீங்கள் நம்பிக்கை கொண்டால்"}, {"w": 7, "t": "you believe"}, {"w": 8, "t": "இன்னும் நீங்கள் அஞ்சி நடந்தால்"}, {"w": 9, "t": "அவன் உங்களுக்கு கொடுப்பான்"}, {"w": 10, "t": "உங்கள் கூலிகளை"}, {"w": 11, "t": "அவன் உங்களிடம் கேட்கமாட்டான்"}, {"w": 12, "t": "will ask you"}, {"w": 13, "t": "உங்கள்செல்வங்களை"}, {"w": 14, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "அவன் அவற்றை உங்களிடம் கேட்டால்"}, {"w": 2, "t": "He were to ask you for it"}, {"w": 3, "t": "இன்னும் அவன் உங்களை வலியுறுத்தினால்"}, {"w": 4, "t": "நீங்கள் கருமித்தனம் செய்வீர்கள்"}, {"w": 5, "t": "இன்னும் வெளிப்படுத்தி காண்பித்து விடுவான்"}, {"w": 6, "t": "உங்கள் குரோதங்களை"}, {"w": 7, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "நீங்கள்தான்"}, {"w": 2, "t": "these"}, {"w": 3, "t": "அழைக்கப்படுகிறீர்கள்"}, {"w": 4, "t": "நீங்கள் தர்மம் செய்வதற்கு"}, {"w": 5, "t": "பாதையில்"}, {"w": 6, "t": "(the) way"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "உங்களில் இருக்கின்றார்"}, {"w": 9, "t": "கருமித்தனம் செய்பவரும்"}, {"w": 10, "t": "withhold"}, {"w": 11, "t": "எவர் கருமித்தனம் செய்வாரோ"}, {"w": 12, "t": "withholds"}, {"w": 13, "t": "அவர் கருமித்தனம் செய்வதெல்லாம்"}, {"w": 14, "t": "he withholds"}, {"w": 15, "t": "அவருடைய ஆன்மாவின் கருமித்தனத்தினால்தான்"}, {"w": 16, "t": "himself"}, {"w": 17, "t": "அல்லாஹ்தான்"}, {"w": 18, "t": "முற்றிலும் நிறைவானவன்"}, {"w": 19, "t": "நீங்கள்தான்"}, {"w": 20, "t": "தேவையுள்ளவர்கள்"}, {"w": 21, "t": "நீங்கள் விலகிச்சென்றால்"}, {"w": 22, "t": "you turn away"}, {"w": 23, "t": "அவன் மாற்றுவான்"}, {"w": 24, "t": "ஒரு சமுதாயத்தை"}, {"w": 25, "t": "நீங்கள் அல்லாத"}, {"w": 26, "t": "பிறகு"}, {"w": 27, "t": "அவர்கள் இருக்க மாட்டார்கள்"}, {"w": 28, "t": "they will be"}, {"w": 29, "t": "உங்களைப் போன்று"}, {"w": 30, "t": "(38)"}]}]}