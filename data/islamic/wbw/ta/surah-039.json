{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "இறக்கப்பட்டது"}, {"w": 2, "t": "வேதமாகும்"}, {"w": 3, "t": "அல்லாஹ்வின் புறத்தில் இருந்து"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "மிகைத்தவனும்"}, {"w": 6, "t": "மகா ஞானவானுமான"}, {"w": 7, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இறக்கினோம்"}, {"w": 3, "t": "உமக்கு"}, {"w": 4, "t": "இந்த வேதத்தை"}, {"w": 5, "t": "உண்மையுடன்"}, {"w": 6, "t": "ஆகவே, வணங்குவீராக"}, {"w": 7, "t": "அல்லாஹ்வை"}, {"w": 8, "t": "தூய்மைப்படுத்தியவராக"}, {"w": 9, "t": "அவனுக்கு"}, {"w": 10, "t": "வழிபாட்டை"}, {"w": 11, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 2, "t": "அல்லாஹ்விற்கே"}, {"w": 3, "t": "வழிபாடுகள்"}, {"w": 4, "t": "பரிசுத்தமான(து)"}, {"w": 5, "t": "எவர்கள்"}, {"w": 6, "t": "எடுத்துக் கொண்டார்கள்"}, {"w": 7, "t": "அவனையன்றி"}, {"w": 8, "t": "besides Him"}, {"w": 9, "t": "தெய்வங்களை"}, {"w": 10, "t": "நாங்கள்வணங்குவதில்லை"}, {"w": 11, "t": "நாங்கள்வணங்குவதில்லை அவர்களை"}, {"w": 12, "t": "தவிர"}, {"w": 13, "t": "அவர்கள் எங்களை நெருக்கமாக்குவதற்காக"}, {"w": 14, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 15, "t": "Allah"}, {"w": 16, "t": "அந்தஸ்தால்"}, {"w": 17, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 18, "t": "Allah"}, {"w": 19, "t": "தீர்ப்பளிப்பான்"}, {"w": 20, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 21, "t": "அவர்கள் தர்க்கிப்பவற்றில்"}, {"w": 22, "t": "what"}, {"w": 23, "t": "they"}, {"w": 24, "t": "[in it]"}, {"w": 25, "t": "differ"}, {"w": 26, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 27, "t": "Allah"}, {"w": 28, "t": "நேர்வழி செலுத்த மாட்டான்"}, {"w": 29, "t": "guide"}, {"w": 30, "t": "எவர்"}, {"w": 31, "t": "அவர்"}, {"w": 32, "t": "பொய்யர்களை"}, {"w": 33, "t": "நிராகரிப்பாளர்களை"}, {"w": 34, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நாடினால்"}, {"w": 2, "t": "Allah (had) intended"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "எடுத்துக்கொள்ள"}, {"w": 5, "t": "take"}, {"w": 6, "t": "ஒரு குழந்தையை"}, {"w": 7, "t": "தேர்ந்தெடுத்து இருப்பான்"}, {"w": 8, "t": "தான் படைத்த