: 12, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "ஏற்பட்டால்"}, {"w": 2, "t": "touches"}, {"w": 3, "t": "மனிதனுக்கு"}, {"w": 4, "t": "ஒரு தீங்கு"}, {"w": 5, "t": "நம்மிடம் பிரார்த்திக்கின்றான்"}, {"w": 6, "t": "பிறகு நாம் அவனுக்கு வழங்கினால்"}, {"w": 7, "t": "when"}, {"w": 8, "t": "We bestow (on) him"}, {"w": 9, "t": "ஓர்அருட்கொடையை"}, {"w": 10, "t": "நம்மிடமிருந்து"}, {"w": 11, "t": "அவன் கூறுகிறான்"}, {"w": 12, "t": "இது எனக்கு கொடுக்கப்பட்டதெல்லாம்"}, {"w": 13, "t": "I have been given it"}, {"w": 14, "t": "அறிந்ததினால்தான்"}, {"w": 15, "t": "knowledge"}, {"w": 16, "t": "மாறாக, அது"}, {"w": 17, "t": "it"}, {"w": 18, "t": "ஒரு சோதனையாகும்"}, {"w": 19, "t": "என்றாலும்/அவர்களில் அதிகமானவர்கள்/அறியமாட்டார்கள்"}, {"w": 20, "t": "most of them"}, {"w": 21, "t": "(do) not"}, {"w": 22, "t": "know"}, {"w": 23, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "திட்டமாக இதைச் சொல்லி இருக்கின்றார்கள்"}, {"w": 2, "t": "said it"}, {"w": 3, "t": "இவர்களுக்கு முன்னுள்ளவர்களும்"}, {"w": 4, "t": "before them"}, {"w": 5, "t": "before them"}, {"w": 6, "t": "தடுக்கவில்லை"}, {"w": 7, "t": "avail"}, {"w": 8, "t": "அவர்களை விட்டும்"}, {"w": 9, "t": "அவர்கள் செய்து வந்தவை"}, {"w": 10, "t": "they used to"}, {"w": 11, "t": "earn"}, {"w": 12, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "அவர்களை அடைந்தன"}, {"w": 2, "t": "தீங்குகள்"}, {"w": 3, "t": "அவர்கள் செய்ததின்"}, {"w": 4, "t": "they earned"}, {"w": 5, "t": "அநியாயம் செய்தவர்களையும்"}, {"w": 6, "t": "have wronged"}, {"w": 7, "t": "இவர்களில்"}, {"w": 8, "t": "these"}, {"w": 9, "t": "விரைவில் அடையும்"}, {"w": 10, "t": "தீங்குகள்"}, {"w": 11, "t": "அவர்கள் செய்தவற்றின்"}, {"w": 12, "t": "they earned"}, {"w": 13, "t": "அவர்கள் தப்பிக்க மாட்டார்கள்"}, {"w": 14, "t": "they"}, {"w": 15, "t": "will be able to escape"}, {"w": 16, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "அவர்கள் அறியவில்லையா?"}, {"w": 2, "t": "they know"}, {"w": 3, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "விசாலமாகக் கொடுக்கின்றான்"}, {"w": 6, "t": "வாழ்வாதாரத்தை"}, {"w": 7, "t": "தான் நாடியவர்களுக்கு"}, {"w": 8, "t": "He wills"}, {"w": 9, "t": "சுருக்கமாகக் கொடுக்கின்றான்"}, {"w": 10, "t": "நிச்சயமாக இதில் உள்ளன"}, {"w": 11, "t": "in"}, {"w": 12, "t": "that"}, {"w": 13, "t": "பல அத்தாட்சிகள்"}, {"w": 14, "t": "மக்களுக்கு"}, {"w": 15, "t": "நம்பிக்கை கொள்கின்றனர்"}, {"w": 16, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "என் அடியார்களே"}, {"w": 3, "t": "வரம்புமீறிய(வர்கள்)"}, {"w": 4, "t": "have transgressed"}, {"w": 5, "t": "தங்கள் மீது"}, {"w": 6, "t": "themselves"}, {"w": 7, "t": "நிராசை ஆகாதீர்கள்"}, {"w": 8, "t": "despair"}, {"w": 9, "t": "இருந்து"}, {"w": 10, "t": "கருணையில்"}, {"w": 11, "t": "அல்லாஹ்வின்"}, {"w": 12, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 13, "t": "Allah"}, {"w": 14, "t": "மன்னிப்பான்"}, {"w": 15, "t": "பாவங்களையும்"}, {"w": 16, "t": "எல்லா"}, {"w": 17, "t": "நிச்சயமாக அவன்"}, {"w": 18, "t": "He"}, {"w": 19, "t": "மகா மன்னிப்பாளன்"}, {"w": 20, "t": "பெரும் கருணையாளன்"}, {"w": 21, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "இன்னும் திரும்புங்கள்!"}, {"w": 2, "t": "உங்கள் இறைவன் பக்கம்"}, {"w": 3, "t": "your Lord"}, {"w": 4, "t": "இன்னும் முற்றிலும் பணிந்து விடுங்கள்"}, {"w": 5, "t": "அவனுக்கு"}, {"w": 6, "t": "முன்னர்"}, {"w": 7, "t": "before"}, {"w": 8, "t": "உங்களுக்கு வருவதற்கு"}, {"w": 9, "t": "comes to you"}, {"w": 10, "t": "வேதனை"}, {"w": 11, "t": "பிறகு"}, {"w": 12, "t": "நீங்கள் உதவப்பட மாட்டீர்கள்"}, {"w": 13, "t": "you will be helped"}, {"w": 14, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "இன்னும் பின்பற்றுங்கள்"}, {"w": 2, "t": "மிக அழகியவற்றை"}, {"w": 3, "t": "இறக்கப்பட்ட(து)"}, {"w": 4, "t": "is revealed"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "உங்கள் இறைவனிடமிருந்து"}, {"w": 7, "t": "your Lord"}, {"w": 8, "t": "முன்னர்"}, {"w": 9, "t": "before"}, {"w": 10, "t": "உங்களுக்கு வருவதற்கு"}, {"w": 11, "t": "comes to you"}, {"w": 12, "t": "வேதனை"}, {"w": 13, "t": "திடீரென"}, {"w": 14, "t": "நீங்கள் உணராமல் இருக்கின்ற நிலையில்"}, {"w": 15, "t": "(do) not"}, {"w": 16, "t": "perceive"}, {"w": 17, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "சொல்லாமல் இருப்பதற்காக"}, {"w": 2, "t": "should say"}, {"w": 3, "t": "ஓர் ஆன்மா"}, {"w": 4, "t": "எனக்கு நேர்ந்த துக்கமே!"}, {"w": 5, "t": "நான் குறைசெய்து விட்டதனால்"}, {"w": 6, "t": "what"}, {"w": 7, "t": "I neglected"}, {"w": 8, "t": "விஷயங்களில்"}, {"w": 9, "t": "regard (to)"}, {"w": 10, "t": "அல்லாஹ்வின்"}, {"w": 11, "t": "நிச்சயமாக நான் இருந்தேன்"}, {"w": 12, "t": "I was"}, {"w": 13, "t": "பரிகாசம் செய்வோரில்தான்"}, {"w": 14, "t": "the mockers"}, {"w": 15, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "அல்லது சொல்லாமல் இருப்பதற்காக"}, {"w": 2, "t": "it should say"}, {"w": 3, "t": "நிச்சயமாக அல்லாஹ் எனக்கு நேர்வழிகாட்டி இருந்தால்"}, {"w": 4, "t": "If that"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "(had) guided me"}, {"w": 7, "t": "நானும் ஆகி இருப்பேனே"}, {"w": 8, "t": "இறையச்சமுள்ளவர்களில்"}, {"w": 9, "t": "the righteous"}, {"w": 10, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "அல்லது/அது சொல்லாமல் இருப்பதற்காக"}, {"w": 2, "t": "it should say"}, {"w": 3, "t": "அது கண்ணால் பார்க்கும் நேரத்தில்"}, {"w": 4, "t": "it sees"}, {"w": 5, "t": "வேதனையை"}, {"w": 6, "t": "நிச்சயமாக எனக்கு திரும்பி வரமுடிந்தால்"}, {"w": 7, "t": "only"}, {"w": 8, "t": "for me"}, {"w": 9, "t": "another chance"}, {"w": 10, "t": "நானும் ஆகிவிடுவேன்"}, {"w": 11, "t": "நல்லவர்களில்"}, {"w": 12, "t": "the good-doers"}, {"w": 13, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "திட்டமாக"}, {"w": 3, "t": "உன்னிடம் வந்தன"}, {"w": 4, "t": "எனது வசனங்கள்"}, {"w": 5, "t": "ஆனால், நீ பொய்ப்பித்தாய்"}, {"w": 6, "t": "அவற்றை"}, {"w": 7, "t": "இன்னும் பெருமை அடித்தாய்"}, {"w": 8, "t": "இன்னும் நீ ஆகி இருந்தாய்"}, {"w": 9, "t": "நிராகரிப்பவர்களில்"}, {"w": 10, "t": "the disbelievers"}, {"w": 11, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "மறுமை நாளில்"}, {"w": 2, "t": "(of) the Resurrection"}, {"w": 3, "t": "நீர் பார்ப்பீர்"}, {"w": 4, "t": "பொய்யுரைத்தவர்களை"}, {"w": 5, "t": "lied"}, {"w": 6, "t": "அல்லாஹ்வின் மீது"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "அவர்களின் முகங்கள்"}, {"w": 9, "t": "கருப்பாக"}, {"w": 10, "t": "இல்லையா?"}, {"w": 11, "t": "நரகத்தில்"}, {"w": 12, "t": "Hell"}, {"w": 13, "t": "தங்குமிடம்"}, {"w": 14, "t": "பெருமை அடிப்பவர்களுக்கு"}, {"w": 15, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "இன்னும் பாதுகாப்பான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "அல்லாஹ்வை அஞ்சியவர்களை"}, {"w": 4, "t": "feared (Him)"}, {"w": 5, "t": "அவர்களின் நல்லமல்களினால்"}, {"w": 6, "t": "அவர்களுக்கு ஏற்படாது"}, {"w": 7, "t": "will touch them"}, {"w": 8, "t": "எந்தத் தீங்கும்"}, {"w": 9, "t": "இன்னும் அவர்கள் கவலைப்படவும் மாட்டார்கள்"}, {"w": 10, "t": "they"}, {"w": 11, "t": "will grieve"}, {"w": 12, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "படைத்தவன்"}, {"w": 3, "t": "எல்லாவற்றையும்"}, {"w": 4, "t": "things"}, {"w": 5, "t": "அவன்தான்"}, {"w": 6, "t": "எல்லாவற்றையும்"}, {"w": 7, "t": "all"}, {"w": 8, "t": "things"}, {"w": 9, "t": "பாதுகாப்பவன்"}, {"w": 10, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "அவனுக்கே உரியன"}, {"w": 2, "t": "பொக்கிஷங்களின் சாவிகள்"}, {"w": 3, "t": "வானங்கள்"}, {"w": 4, "t": "இன்னும் பூமி(யிலுள்ள)"}, {"w": 5, "t": "நிராகரித்தவர்கள்"}, {"w": 6, "t": "disbelieve"}, {"w": 7, "t": "அத்தாட்சிகளை"}, {"w": 8, "t": "அல்லாஹ்வின்"}, {"w": 9, "t": "அவர்கள்தான்"}, {"w": 10, "t": "they"}, {"w": 11, "t": "(உண்மையான) நஷ்டவாளிகள்"}, {"w": 12, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அல்லாதவர்களையா?"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "என்னை ஏவுகிறீர்கள்"}, {"w": 5, "t": "நான் வணங்க வேண்டும் என்று"}, {"w": 6, "t": "முட்டாள்களே!"}, {"w": 7, "t": "ignorant ones"}, {"w": 8, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "வஹீ  அறிவிக்கப்பட்டது"}, {"w": 3, "t": "உமக்கு(ம்)"}, {"w": 4, "t": "உமக்கு முன்னுள்ளவர்களுக்கும்"}, {"w": 5, "t": "those who"}, {"w": 6, "t": "(were) before you"}, {"w": 7, "t": "(were) before you"}, {"w": 8, "t": "நீர் இணைவைத்தால்"}, {"w": 9, "t": "you associate (with Allah)"}, {"w": 10, "t": "நாசமாகிவிடும்"}, {"w": 11, "t": "உமது அமல்கள்"}, {"w": 12, "t": "இன்னும் நீர் ஆகிவிடுவீர்"}, {"w": 13, "t": "நஷ்டவாளிகளில்"}, {"w": 14, "t": "the losers"}, {"w": 15, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "மாறாக/அல்லாஹ்வை"}, {"w": 2, "t": "But worship Allah"}, {"w": 3, "t": "நீர் வணங்குவீராக!"}, {"w": 4, "t": "இன்னும் நீர்ஆகிவிடுவீராக!"}, {"w": 5, "t": "நன்றிசெலுத்துவோரில்"}, {"w": 6, "t": "the thankful ones"}, {"w": 7, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "அவர்கள் கண்ணியப்படுத்தவில்லை"}, {"w": 2, "t": "they appraised"}, {"w": 3, "t": "அல்லாஹ்வை"}, {"w": 4, "t": "முறையில்"}, {"w": 5, "t": "அவனை கண்ணியப்படுத்தவேண்டிய"}, {"w": 6, "t": "பூமி"}, {"w": 7, "t": "அனைத்தும்"}, {"w": 8, "t": "அவனது கைப்பிடியில்"}, {"w": 9, "t": "மறுமை நாளில்"}, {"w": 10, "t": "(of) the Resurrection"}, {"w": 11, "t": "இன்னும் வானங்கள்"}, {"w": 12, "t": "சுருட்டப்பட்டதாக இருக்கும்"}, {"w": 13, "t": "அவனதுவலக்கையில்"}, {"w": 14, "t": "அவன் மிகப் பரிசுத்தமானவன்"}, {"w": 15, "t": "இன்னும் அவன் மிக உயர்ந்தவன்"}, {"w": 16, "t": "அவர்கள் இணைவைப்பதை விட்டு"}, {"w": 17, "t": "they associate (with Him)"}, {"w": 18, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "ஊதப்படும்"}, {"w": 2, "t": "சூரில்"}, {"w": 3, "t": "the trumpet"}, {"w": 4, "t": "இறந்து விடுவார்(கள்)"}, {"w": 5, "t": "வானங்களில் உள்ளவர்களும்"}, {"w": 6, "t": "(is) in"}, {"w": 7, "t": "the heavens"}, {"w": 8, "t": "இன்னும் பூமியில் உள்ளவர்களும்"}, {"w": 9, "t": "(is) on"}, {"w": 10, "t": "the earth"}, {"w": 11, "t": "நாடியவர்களைத்தவிர"}, {"w": 12, "t": "whom"}, {"w": 13, "t": "Allah wills"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "பிறகு ஊதப்படும்"}, {"w": 16, "t": "(it will) be blown"}, {"w": 17, "t": "அதில்"}, {"w": 18, "t": "மற்றொரு முறை"}, {"w": 19, "t": "அப்போது அவர்கள்"}, {"w": 20, "t": "They"}, {"w": 21, "t": "எழுந்து நின்று"}, {"w": 22, "t": "பார்ப்பார்கள்"}, {"w": 23, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "பிரகாசிக்கும்"}, {"w": 2, "t": "பூமி"}, {"w": 3, "t": "ஒளியால்"}, {"w": 4, "t": "தனது இறைவனின்"}, {"w": 5, "t": "வைக்கப்படும்"}, {"w": 6, "t": "புத்தகம்"}, {"w": 7, "t": "கொண்டு வரப்படுவார்(கள்)"}, {"w": 8, "t": "நபிமார்கள்"}, {"w": 9, "t": "இன்னும் ஷஹீதுகள்"}, {"w": 10, "t": "தீர்ப்பளிக்கப்படும்"}, {"w": 11, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 12, "t": "நீதமாக"}, {"w": 13, "t": "அவர்கள்"}, {"w": 14, "t": "அநீதி இழைக்கப்பட மாட்டார்கள்"}, {"w": 15, "t": "will not be wronged"}, {"w": 16, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "முழுமையாக கூலி வழங்கப்படும்"}, {"w": 2, "t": "ஒவ்வோர்"}, {"w": 3, "t": "ஆன்மாவும்"}, {"w": 4, "t": "தாம் செய்தவற்றுக்கு"}, {"w": 5, "t": "it did"}, {"w": 6, "t": "அவன்/மிகஅறிந்தவன்"}, {"w": 7, "t": "(is the) Best-Knower"}, {"w": 8, "t": "அவர்கள் செய்கின்ற அனைத்தையும்"}, {"w": 9, "t": "they do"}, {"w": 10, "t": "(70)"}]}, {"ayah": 71, "words": [{"w": 1, "t": "ஓட்டிக் கொண்டு வரப்படுவார்கள்"}, {"w": 2, "t": "நிராகரித்தவர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "நரகத்தின் பக்கம்"}, {"w": 5, "t": "Hell"}, {"w": 6, "t": "கூட்டம் கூட்டமாக"}, {"w": 7, "t": "இறுதியாக"}, {"w": 8, "t": "அதற்கு அவர்கள் வந்தவுடன்"}, {"w": 9, "t": "they reach it"}, {"w": 10, "t": "திறக்கப்படும்"}, {"w": 11, "t": "அதன் வாசல்கள்"}, {"w": 12, "t": "இன்னும் கூறுவார்கள்"}, {"w": 13, "t": "அவர்களுக்கு"}, {"w": 14, "t": "அதன் காவலாளிகள்"}, {"w": 15, "t": "உங்களுக்கு வரவில்லையா?"}, {"w": 16, "t": "come to you"}, {"w": 17, "t": "தூதர்கள்"}, {"w": 18, "t": "உங்களில் இருந்தே"}, {"w": 19, "t": "ஓதிக் காட்டினார்களே"}, {"w": 20, "t": "உங்களுக்கு"}, {"w": 21, "t": "வசனங்களை"}, {"w": 22, "t": "உங்கள் இறைவனின்"}, {"w": 23, "t": "இன்னும் உங்களை எச்சரித்தார்களே"}, {"w": 24, "t": "நீங்கள் சந்திக்கவேண்டிய இந்த நாளைப் பற்றி"}, {"w": 25, "t": "(of) your Day"}, {"w": 26, "t": "this"}, {"w": 27, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 28, "t": "ஏன் வரவில்லை"}, {"w": 29, "t": "எனினும்"}, {"w": 30, "t": "உறுதியாகி விட்டது"}, {"w": 31, "t": "வாக்கு"}, {"w": 32, "t": "வேதனையின்"}, {"w": 33, "t": "நிராகரிப்பவர்கள் மீது"}, {"w": 34, "t": "the disbelievers"}, {"w": 35, "t": "(71)"}]}, {"ayah": 72, "words": [{"w": 1, "t": "கூறப்படும்"}, {"w": 2, "t": "நீங்கள் நுழையுங்கள்!"}, {"w": 3, "t": "வாசல்களில்"}, {"w": 4, "t": "நரகத்தின்"}, {"w": 5, "t": "நிரந்தரமாகத் தங்கிவிடுவீர்கள்"}, {"w": 6, "t": "அதில்"}, {"w": 7, "t": "மிகக் கெட்டது"}, {"w": 8, "t": "தங்குமிடம்"}, {"w": 9, "t": "பெருமையடிப்பவர்களின்"}, {"w": 10, "t": "(72)"}]}, {"ayah": 73, "words": [{"w": 1, "t": "கொண்டு வரப்படுவார்(கள்)"}, {"w": 2, "t": "அஞ்சியவர்களை"}, {"w": 3, "t": "feared"}, {"w": 4, "t": "தங்கள் இறைவனை"}, {"w": 5, "t": "சொர்க்கத்திற்கு"}, {"w": 6, "t": "Paradise"}, {"w": 7, "t": "கூட்டம் கூட்டமாக"}, {"w": 8, "t": "இறுதியாக"}, {"w": 9, "t": "அதற்கருகில் அவர்கள் வரும்போது"}, {"w": 10, "t": "they reach it"}, {"w": 11, "t": "இன்னும் திறக்கப்படும்"}, {"w": 12, "t": "அதன் வாசல்கள்"}, {"w": 13, "t": "கூறுவார்கள்"}, {"w": 14, "t": "அவர்களுக்கு"}, {"w": 15, "t": "அதன் காவலாளிகள்"}, {"w": 16, "t": "ஈடேற்றம் உண்டாகட்டும்"}, {"w": 17, "t": "உங்களுக்கு"}, {"w": 18, "t": "நீங்கள் நல்லவர்களாக இருந்தீர்கள்"}, {"w": 19, "t": "ஆகவே, இதில் நுழைந்து விடுங்கள்!"}, {"w": 20, "t": "நிரந்தரமானவர்களாக"}, {"w": 21, "t": "(73)"}]}, {"ayah": 74, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "எல்லாப் புகழும்"}, {"w": 3, "t": "அல்லாஹ்விற்கே!"}, {"w": 4, "t": "எவன்/எங்களுக்கு உண்மையாக்கினான்"}, {"w": 5, "t": "has fulfilled for us"}, {"w": 6, "t": "தனது வாக்கை"}, {"w": 7, "t": "இன்னும் எங்களுக்கு சொந்தமாக்கித் தந்தான்"}, {"w": 8, "t": "இந்த பூமியை"}, {"w": 9, "t": "நாங்கள் தங்குவோம்"}, {"w": 10, "t": "இந்த சொர்க்கத்தில்"}, {"w": 11, "t": "(in) Paradise"}, {"w": 12, "t": "நாங்கள் நாடிய இடத்தில்"}, {"w": 13, "t": "we wish"}, {"w": 14, "t": "மிகச் சிறந்ததாகும்"}, {"w": 15, "t": "கூலி"}, {"w": 16, "t": "நல்லமல் செய்வோரின்"}, {"w": 17, "t": "(74)"}]}, {"ayah": 75, "words": [{"w": 1, "t": "பார்ப்பீர்கள்"}, {"w": 2, "t": "வானவர்களை"}, {"w": 3, "t": "சூழ்ந்தவர்களாக"}, {"w": 4, "t": "சுற்றி"}, {"w": 5, "t": "around"}, {"w": 6, "t": "அர்ஷை"}, {"w": 7, "t": "அவர்கள் துதிப்பார்கள்"}, {"w": 8, "t": "புகழை"}, {"w": 9, "t": "தங்கள் இறைவனின்"}, {"w": 10, "t": "தீர்ப்பளிக்கப்படும்"}, {"w": 11, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 12, "t": "சத்தியமான முறையில்"}, {"w": 13, "t": "கூறப்படும்"}, {"w": 14, "t": "எல்லாப் புகழும்"}, {"w": 15, "t": "அல்லாஹ்வுக்கே"}, {"w": 16, "t": "இறைவனாகிய"}, {"w": 17, "t": "அகிலங்களின்"}, {"w": 18, "t": "(75)"}]}]}