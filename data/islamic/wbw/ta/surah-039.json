"w": 30, "t": "ஆட்சி அனைத்தும்"}, {"w": 31, "t": "அறவே இல்லை"}, {"w": 32, "t": "வணக்கத்திற்குரியவன்"}, {"w": 33, "t": "அவனைத் தவிர"}, {"w": 34, "t": "He"}, {"w": 35, "t": "ஆகவே எவ்வாறு"}, {"w": 36, "t": "நீங்கள் திருப்பப்படுகிறீர்கள்"}, {"w": 37, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நீங்கள் நிராகரித்தால்"}, {"w": 2, "t": "you disbelieve"}, {"w": 3, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "தேவையற்ற முழு நிறைவானவன்"}, {"w": 6, "t": "உங்களை விட்டு"}, {"w": 7, "t": "அவன் விரும்ப மாட்டான்"}, {"w": 8, "t": "He likes"}, {"w": 9, "t": "தனது அடியார்களுக்கு"}, {"w": 10, "t": "நிராகரிப்பை"}, {"w": 11, "t": "நீங்கள் நன்றி செலுத்தினால்"}, {"w": 12, "t": "you are grateful"}, {"w": 13, "t": "அதை அவன் விரும்புவான்"}, {"w": 14, "t": "உங்களுக்கு"}, {"w": 15, "t": "சுமக்காது"}, {"w": 16, "t": "will bear"}, {"w": 17, "t": "பாவியான ஓர் ஆன்மா"}, {"w": 18, "t": "பாவத்தை"}, {"w": 19, "t": "இன்னொரு ஆன்மாவின்"}, {"w": 20, "t": "பிறகு உங்கள் இறைவன் பக்கமே"}, {"w": 21, "t": "to"}, {"w": 22, "t": "your Lord"}, {"w": 23, "t": "உங்கள் மீளுமிடம் இருக்கின்றது"}, {"w": 24, "t": "அவன் உங்களுக்கு அறிவிப்பான்"}, {"w": 25, "t": "நீங்கள் செய்து கொண்டிருந்ததை"}, {"w": 26, "t": "you used to"}, {"w": 27, "t": "do"}, {"w": 28, "t": "நிச்சயமாக அவன்"}, {"w": 29, "t": "நன்கறிந்தவன்"}, {"w": 30, "t": "நெஞ்சங்களில் உள்ளதை"}, {"w": 31, "t": "of what (is) in the breasts"}, {"w": 32, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஏற்பட்டால்"}, {"w": 2, "t": "touches"}, {"w": 3, "t": "மனிதனுக்கு"}, {"w": 4, "t": "ஒரு தீங்கு"}, {"w": 5, "t": "பிரார்திக்கின்றான்"}, {"w": 6, "t": "தான் இறைவனை"}, {"w": 7, "t": "முற்றிலும் திரும்பியவனாக"}, {"w": 8, "t": "அவன் பக்கம்"}, {"w": 9, "t": "பிறகு/அவனுக்கு அவன் வழங்கினான்"}, {"w": 10, "t": "when"}, {"w": 11, "t": "He bestows on him"}, {"w": 12, "t": "ஓர் அருளை"}, {"w": 13, "t": "தான் புறத்திலிருந்து"}, {"w": 14, "t": "அவன் விட்டு விடுகிறான்"}, {"w": 15, "t": "நான் பிரார்த்தித்து வந்ததை"}, {"w": 16, "t": "he used to call"}, {"w": 17, "t": "he used to call"}, {"w": 18, "t": "அவனிடம்"}, {"w": 19, "t": "இதற்கு முன்னர்"}, {"w": 20, "t": "before"}, {"w": 21, "t": "இன்னும் ஏற்படுத்துகிறான்"}, {"w": 22, "t": "அல்லாஹ்விற்கு"}, {"w": 23, "t": "இணைகளை"}, {"w": 24, "t": "வழிகெடுப்பதற்காக"}, {"w": 25, "t": "அவனுடைய பாதையை விட்டு"}, {"w": 26, "t": "His Path"}, {"w": 27, "t": "கூறுவிராக"}, {"w": 28, "t": "நீ சுகமடைந்து கொள்"}, {"w": 29, "t": "உனது நிராகரிப்பை கொண்டு/கொஞ்ச காலம்"}, {"w": 30, "t": "(for) a little"}, {"w": 31, "t": "நிச்சயமாக நீ"}, {"w": 32, "t": "நரகவாசிகளில்"}, {"w": 33, "t": "(the) companions"}, {"w": 34, "t": "(of) the Fire"}, {"w": 35, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "?/எவர்/அவர்/வணங்கக்கூடியவர்"}, {"w": 2, "t": "[he]"}, {"w": 3, "t": "(is) devoutly obedient "}, {"w": 4, "t": "இரவு நேரங்களில்"}, {"w": 5, "t": "(of) the night"}, {"w": 6, "t": "சிரம் பணிந்தவராக(வும்)"}, {"w": 7, "t": "நின்றவராகவும்"}, {"w": 8, "t": "பயப்படுகிறார்"}, {"w": 9, "t": "மறுமையை"}, {"w": 10, "t": "இன்னும் ஆதரவு வைக்கிறார்"}, {"w": 11, "t": "அருளை"}, {"w": 12, "t": "தன் இறைவனின்"}, {"w": 13, "t": "கூறுவீராக!"}, {"w": 14, "t": "சமமாவார்களா?"}, {"w": 15, "t": "equal"}, {"w": 16, "t": "அறிந்தவர்களும்"}, {"w": 17, "t": "know"}, {"w": 18, "t": "அறியாதவர்களும்"}, {"w": 19, "t": "(do) not"}, {"w": 20, "t": "know"}, {"w": 21, "t": "நல்லுபதேசம் பெறுவதெல்லாம்"}, {"w": 22, "t": "will take heed"}, {"w": 23, "t": "அறிவுள்ளவர்கள்தான்"}, {"w": 24, "t": "those of understanding"}, {"w": 25, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "என் அடியார்களே!"}, {"w": 3, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 4, "t": "believe"}, {"w": 5, "t": "அஞ்சுங்கள்!"}, {"w": 6, "t": "உங்கள் இறைவனை"}, {"w": 7, "t": "நன்மை செய்தவர்களுக்கு"}, {"w": 8, "t": "do good"}, {"w": 9, "t": "இவ்வுலகில்"}, {"w": 10, "t": "this"}, {"w": 11, "t": "world"}, {"w": 12, "t": "நன்மை"}, {"w": 13, "t": "இன்னும் பூமி"}, {"w": 14, "t": "அல்லாஹ்வின்"}, {"w": 15, "t": "விசாலமானது"}, {"w": 16, "t": "வழங்கப்படுவதெல்லாம்"}, {"w": 17, "t": "will be paid back in full"}, {"w": 18, "t": "பொறுமையாளர்களுக்கு"}, {"w": 19, "t": "கூலி அவர்களது"}, {"w": 20, "t": "கணக்கின்றிதான்"}, {"w": 21, "t": "account"}, {"w": 22, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் கட்டளையிடப்பட்டுள்ளேன்"}, {"w": 3, "t": "[I] am commanded"}, {"w": 4, "t": "நான் வணங்க வேண்டும் என்று"}, {"w": 5, "t": "I worship"}, {"w": 6, "t": "அல்லாஹ்வை/தூய்மையாக செய்யவேண்டும்"}, {"w": 7, "t": "(being) sincere"}, {"w": 8, "t": "அவனுக்கு"}, {"w": 9, "t": "வழிபாடுகளை"}, {"w": 10, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நான் கட்டளையிடப் பட்டுள்ளேன்"}, {"w": 2, "t": "நான் இருக்க வேண்டும்"}, {"w": 3, "t": "I be"}, {"w": 4, "t": "முதலாமவனாக"}, {"w": 5, "t": "முஸ்லிம்களில்"}, {"w": 6, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "பயப்படுகிறேன்"}, {"w": 4, "t": "மாறுசெய்தால்"}, {"w": 5, "t": "I disobey"}, {"w": 6, "t": "என் இறைவனுக்கு"}, {"w": 7, "t": "வேதனையை"}, {"w": 8, "t": "நாளின்"}, {"w": 9, "t": "மகத்தான"}, {"w": 10, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "கூறுவிராக"}, {"w": 2, "t": "அல்லாஹ்வைத்தான்"}, {"w": 3, "t": "நான் வணங்குவேன்"}, {"w": 4, "t": "பரிசுத்தப்படுத்தியவனாக"}, {"w": 5, "t": "அவனுக்கு"}, {"w": 6, "t": "என் வழிபாட்டை"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "வணங்குங்கள்"}, {"w": 2, "t": "நீங்கள் நாடியவர்களை"}, {"w": 3, "t": "you will"}, {"w": 4, "t": "அவனையன்றி"}, {"w": 5, "t": "besides Him"}, {"w": 6, "t": "கூறுவீராக!"}, {"w": 7, "t": "நிச்சயமாக"}, {"w": 8, "t": "நஷ்டவாளிகள்"}, {"w": 9, "t": "நஷ்டமிழைத்தவர்கள்தான்"}, {"w": 10, "t": "(will) lose"}, {"w": 11, "t": "தங்களுக்கு(ம்)"}, {"w": 12, "t": "தங்கள் குடும்பத்தாருக்கும்"}, {"w": 13, "t": "மறுமையில்"}, {"w": 14, "t": "(of) the Resurrection"}, {"w": 15, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 16, "t": "இதுதான்"}, {"w": 17, "t": "it"}, {"w": 18, "t": "நஷ்டமாகும்"}, {"w": 19, "t": "மிகத்தெளிவான"}, {"w": 20, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவர்களுக்கு"}, {"w": 2, "t": "அவர்களின் மேலிருந்து(ம்)"}, {"w": 3, "t": "above them"}, {"w": 4, "t": "நிழல்களும்"}, {"w": 5, "t": "நரகத்தின்"}, {"w": 6, "t": "the Fire"}, {"w": 7, "t": "அவர்களுக்கு கீழிருந்தும்"}, {"w": 8, "t": "below them"}, {"w": 9, "t": "நிழல்களும்"}, {"w": 10, "t": "இது"}, {"w": 11, "t": "பயமுறுத்துகிறான்"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "இதன் மூலம்"}, {"w": 14, "t": "தனது அடியார்களை"}, {"w": 15, "t": "என் அடியார்களே!"}, {"w": 16, "t": "என்னை பயந்துகொள்ளுங்கள்!"}, {"w": 17, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "எவர்கள்/ விலகினார்கள்"}, {"w": 2, "t": "avoid"}, {"w": 3, "t": "தாகூத்துகளை"}, {"w": 4, "t": "இவர்களை வணங்குவதை விட்டு"}, {"w": 5, "t": "they worship them"}, {"w": 6, "t": "இன்னும் திரும்பினார்கள்"}, {"w": 7, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 8, "t": "Allah"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "நற்செய்தி"}, {"w": 11, "t": "ஆகவே, நற்செய்தி சொல்லுங்கள்"}, {"w": 12, "t": "என் அடியார்களுக்கு"}, {"w": 13, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "எவர்கள்/செவியுறுவார்கள்"}, {"w": 2, "t": "they listen (to)"}, {"w": 3, "t": "பேச்சுகளை"}, {"w": 4, "t": "பின்பற்றுவார்கள்"}, {"w": 5, "t": "அதில் மிக அழகானதை"}, {"w": 6, "t": "அவர்கள்தான்"}, {"w": 7, "t": "எவர்கள்/நேர்வழிகாட்டினான்/அவர்களுக்கு"}, {"w": 8, "t": "Allah has guided them"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "இன்னும் அவர்கள்தான்"}, {"w": 11, "t": "are [they]"}, {"w": 12, "t": "அறிவாளிகள்"}, {"w": 13, "t": "the men of understanding"}, {"w": 14, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "எவர்?"}, {"w": 2, "t": "உறுதியாகிவிட்டது"}, {"w": 3, "t": "அவர் மீது"}, {"w": 4, "t": "வாக்கு"}, {"w": 5, "t": "வேதனையின்"}, {"w": 6, "t": "நீர் பாதுகாப்பீரா?"}, {"w": 7, "t": "save"}, {"w": 8, "t": "நரகத்தில் இருப்பவரை"}, {"w": 9, "t": "(is) in"}, {"w": 10, "t": "the Fire"}, {"w": 11, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "எனினும்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "அஞ்சினார்களோ"}, {"w": 4, "t": "தங்கள் இறைவனை"}, {"w": 5, "t": "அவர்களுக்கு"}, {"w": 6, "t": "மாடி அறைகள்"}, {"w": 7, "t": "அவற்றுக்கு மேல்"}, {"w": 8, "t": "above them"}, {"w": 9, "t": "அறைகள்"}, {"w": 10, "t": "கட்டப்பட்ட(து)"}, {"w": 11, "t": "ஓடும்"}, {"w": 12, "t": "அவற்றைச் சுற்றி"}, {"w": 13, "t": "beneath it"}, {"w": 14, "t": "நதிகள்"}, {"w": 15, "t": "அல்லாஹ்வின்வாக்கு"}, {"w": 16, "t": "(of) Allah"}, {"w": 17, "t": "அல்லாஹ் மாற்றமாட்டான்"}, {"w": 18, "t": "Allah fails"}, {"w": 19, "t": "Allah fails"}, {"w": 20, "t": "வாக்கை"}, {"w": 21, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "இறக்கினான்"}, {"w": 6, "t": "வானத்திலிருந்து"}, {"w": 7, "t": "the sky"}, {"w": 8, "t": "மழையை"}, {"w": 9, "t": "அதை ஓடவைத்தான்"}, {"w": 10, "t": "பல ஊற்றுகளாக"}, {"w": 11, "t": "பூமியில்"}, {"w": 12, "t": "the earth"}, {"w": 13, "t": "பிறகு"}, {"w": 14, "t": "அவன் உற்பத்தி செய்கின்றான்"}, {"w": 15, "t": "அதன் மூலம்"}, {"w": 16, "t": "விளைச்சல்களை"}, {"w": 17, "t": "மாறுபட்ட(து)"}, {"w": 18, "t": "அதன் நிறங்கள்"}, {"w": 19, "t": "பிறகு"}, {"w": 20, "t": "அது காய்ந்து விடுகிறது"}, {"w": 21, "t": "அதை நீர் பார்க்கிறீர்"}, {"w": 22, "t": "மஞ்சளாக"}, {"w": 23, "t": "பிறகு"}, {"w": 24, "t": "அதை அவன் ஆக்கிவிடுகிறான்"}, {"w": 25, "t": "காய்ந்த சருகுகளாக"}, {"w": 26, "t": "நிச்சயமாக"}, {"w": 27, "t": "இதில்"}, {"w": 28, "t": "that"}, {"w": 29, "t": "ஓர் உபதேசம்"}, {"w": 30, "t": "அறிவுள்ளவர்களுக்கு"}, {"w": 31, "t": "for those of understanding"}, {"w": 32, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "எவர்?"}, {"w": 2, "t": "விரிவாக்கினான்"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "அவருடைய நெஞ்சை"}, {"w": 5, "t": "இஸ்லாமிற்கு"}, {"w": 6, "t": "அவர்/வெளிச்சத்தில்"}, {"w": 7, "t": "(is) upon"}, {"w": 8, "t": "a light"}, {"w": 9, "t": "தன் இறைவனின்"}, {"w": 10, "t": "his Lord"}, {"w": 11, "t": "நாசம் உண்டாகட்டும்"}, {"w": 12, "t": "இருகியவர்களுக்கு"}, {"w": 13, "t": "அவர்களுடைய உள்ளங்கள்"}, {"w": 14, "t": "நினைவை விட்டு"}, {"w": 15, "t": "(the) remembrance of Allah"}, {"w": 16, "t": "அல்லாஹ்வின்"}, {"w": 17, "t": "அவர்கள்"}, {"w": 18, "t": "வழிகேட்டில்"}, {"w": 19, "t": "error"}, {"w": 20, "t": "தெளிவான"}, {"w": 21, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "இறக்கினான்"}, {"w": 3, "t": "மிக அழகிய"}, {"w": 4, "t": "பேச்சை"}, {"w": 5, "t": "ஒரு வேதமாக"}, {"w": 6, "t": "ஒன்றுக்கொன்று ஒப்பான"}, {"w": 7, "t": "பலமுறை ஓதப்படுகின்ற"}, {"w": 8, "t": "சிலிர்க்கின்றன"}, {"w": 9, "t": "அதனால்/தோல்கள்"}, {"w": 10, "t": "(the) skins"}, {"w": 11, "t": "எவர்கள்"}, {"w": 12, "t": "பயப்படுவார்கள்"}, {"w": 13, "t": "தங்கள் இறைவனை"}, {"w": 14, "t": "பிறகு"}, {"w": 15, "t": "மென்மையாகின்றன"}, {"w": 16, "t": "அவர்களின் தோல்கள்"}, {"w": 17, "t": "இன்னும் அவர்களின் உள்ளங்களும்"}, {"w": 18, "t": "நினைவின் பக்கம்"}, {"w": 19, "t": "(the) remembrance"}, {"w": 20, "t": "அல்லாஹ்வின்"}, {"w": 21, "t": "இதுதான்"}, {"w": 22, "t": "நேர்வழியாகும்"}, {"w": 23, "t": "அல்லாஹ்வின்"}, {"w": 24, "t": "நேர்வழி செலுத்துகின்றான்"}, {"w": 25, "t": "இதன்மூலம்"}, {"w": 26, "t": "தான் நாடியவர்களை"}, {"w": 27, "t": "He wills"}, {"w": 28, "t": "எவரை"}, {"w": 29, "t": "வழிகெடுக்கின்றானோ"}, {"w": 30, "t": "அல்லாஹ்"}, {"w": 31, "t": "அவருக்கு இல்லை"}, {"w": 32, "t": "for him"}, {"w": 33, "t": "நேர்வழி காட்டுபவர் யாரும்"}, {"w": 34, "t": "guide"}, {"w": 35, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "?/எவர்"}, {"w": 2, "t": "தவிர்த்துக் கொள்கிறான்"}, {"w": 3, "t": "தனது முகத்தால்"}, {"w": 4, "t": "கெட்ட"}, {"w": 5, "t": "வேதனையை"}, {"w": 6, "t": "மறுமை நாளில்"}, {"w": 7, "t": "(of) the Resurrection"}, {"w": 8, "t": "கூறப்படும்"}, {"w": 9, "t": "அநியாயக்காரர்களுக்கு"}, {"w": 10, "t": "சுவையுங்கள்!"}, {"w": 11, "t": "நீங்கள் செய்து வந்ததை"}, {"w": 12, "t": "you used to"}, {"w": 13, "t": "earn"}, {"w": 14, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "பொய்ப்பித்தனர்"}, {"w": 2, "t": "இவர்களுக்கு முன்னர் உள்ளவர்களும்"}, {"w": 