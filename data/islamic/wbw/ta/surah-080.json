{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "கடுகடுத்தார்"}, {"w": 2, "t": "இன்னும் புறக்கணித்தார்"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவரிடம் வந்ததற்காக"}, {"w": 2, "t": "came to him"}, {"w": 3, "t": "பார்வையற்றவர்"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் நீர் அறிவீரா?"}, {"w": 2, "t": "would make you know"}, {"w": 3, "t": "அவர் பரிசுத்தமடையலாம்"}, {"w": 4, "t": "purify himself"}, {"w": 5, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "அவர் அறிவுரை பெறுவார்"}, {"w": 3, "t": "அவருக்கு பலனளிக்கலாம்"}, {"w": 4, "t": "அறிவுரை"}, {"w": 5, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "ஆக, எவன்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "தேவையற்றவனாகக் கருதினானோ"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நீர்"}, {"w": 2, "t": "அவனை"}, {"w": 3, "t": "முன்னோக்குகிறீர்"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் இல்லை"}, {"w": 2, "t": "உம்மீது"}, {"w": 3, "t": "அவன் பரிசுத்தமடையாதது"}, {"w": 4, "t": "he purifies himself"}, {"w": 5, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஆக, எவர்"}, {"w": 2, "t": "(he) who"}, {"w": 3, "t": "வந்தாரோ உம்மிடம்"}, {"w": 4, "t": "விரைந்தவராக"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவரோ"}, {"w": 2, "t": "பயப்படுகிறவராக"}, {"w": 3, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நீர்"}, {"w": 2, "t": "அவரை"}, {"w": 3, "t": "அலட்சியப்படுத்துகிறீர்"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "நிச்சயமாக இது"}, {"w": 3, "t": "ஓர் அறிவுரை"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "ஆகவே, யார்"}, {"w": 2, "t": "நாடுகிறாரோ"}, {"w": 3, "t": "இதை நினைவில் வைப்பார்"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "ஏடுகளில்"}, {"w": 2, "t": "sheets"}, {"w": 3, "t": "கண்ணி யப்படுத்தப்பட்ட"}, {"w": 4, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "உயர்வாக்கப்பட்ட"}, {"w": 2, "t": "தூய்மையாக்கப்பட்ட"}, {"w": 3, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "கைகளில்"}, {"w": 2, "t": "எழுதுபவர்களின்"}, {"w": 3, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "கண்ணிய மானவர்களான"}, {"w": 2, "t": "நல்லவர்களான"}, {"w": 3, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அழியட்டும்"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "அவன் எவ்வளவு நன்றி கெட்டவன்"}, {"w": 4, "t": "ungrateful is he"}, {"w": 5, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "எந்த பொருளிலிருந்து"}, {"w": 2, "t": "what"}, {"w": 3, "t": "thing"}, {"w": 4, "t": "அவனைப் படைத்தான்"}, {"w": 5, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "விந்திலிருந்து"}, {"w": 2, "t": "a semen-drop"}, {"w": 3, "t": "அவனைப் படைத்தான்"}, {"w": 4, "t": "அவனை அமைத்தான்"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "பாதையை"}, {"w": 3, "t": "அதை எளிதாக்கினான்"}, {"w": 4, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "பிறகு அவனை மரணிக்கச் செய்தான்"}, {"w": 2, "t": "He causes him to die"}, {"w": 3, "t": "அவனைப் புதைக்குழியில் தள்ளினான்"}, {"w": 4, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "அவன் நாடியபோது"}, {"w": 3, "t": "He wills"}, {"w": 4, "t": "அவனை உயிர்ப்பிப்பான்"}, {"w": 5, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "அவன் நிறைவேற்றவில்லை"}, {"w": 3, "t": "he has accomplished"}, {"w": 4, "t": "எதை/கட்டளையிட்டான்/அவனுக்கு"}, {"w": 5, "t": "He commanded him"}, {"w": 6, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "ஆகவே பார்க்கட்டும்"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "பக்கம்"}, {"w": 4, "t": "தன் உணவின்"}, {"w": 5, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "பொழிந்தோம்"}, {"w": 3, "t": "நீரை"}, {"w": 4, "t": "பொழிதல்"}, {"w": 5, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "பிளந்தோம்"}, {"w": 3, "t": "பூமியை"}, {"w": 4, "t": "பிளத்தல்"}, {"w": 5, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "இன்னும் முளைக்க வைத்தோம்"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "தானியம்"}, {"w": 4, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இன்னும் திராட்சை"}, {"w": 2, "t": "இன்னும் காய்கறி"}, {"w": 3, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "இன்னும் ஸைத்தூன்"}, {"w": 2, "t": "இன்னும் பேரிச்சை மரம்"}, {"w": 3, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "இன்னும் தோட்டங்கள்"}, {"w": 2, "t": "அடர்ந்த"}, {"w": 3, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "இன்னும் கனி"}, {"w": 2, "t": "இன்னும் புற்பூண்டு"}, {"w": 3, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "பலன் தருவதற்காக"}, {"w": 2, "t": "உங்களுக்கும்"}, {"w": 3, "t": "உங்கள் கால்நடைகளுக்கும்"}, {"w": 4, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "ஆகவே, வந்தால்"}, {"w": 2, "t": "comes"}, {"w": 3, "t": "செவிடாக்கும் சப்தம்"}, {"w": 4, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "விரண்டோடுவான்"}, {"w": 3, "t": "மனிதன்"}, {"w": 4, "t": "விட்டும்"}, {"w": 5, "t": "தன் சகோதரன்"}, {"w": 6, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இன்னும் தன் தாய்"}, {"w": 2, "t": "இன்னும் தன் தந்தை"}, {"w": 3, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "இன்னும் தன் மனைவி"}, {"w": 2, "t": "இன்னும் தான் பிள்ளைகள்"}, {"w": 3, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "ஒவ்வொரு மனிதனுக்கும்"}, {"w": 2, "t": "man"}, {"w": 3, "t": "அவர்களில்"}, {"w": 4, "t": "அந்நாளில்"}, {"w": 5, "t": "நிலைமை"}, {"w": 6, "t": "அவனைத் திருப்பிவிடுகின்ற"}, {"w": 7, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "(சில) முகங்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "ஒளிரக்கூடியதாக"}, {"w": 4, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "சிரித்தவையாக"}, {"w": 2, "t": "நற்செய்தி பெற்றவையாக"}, {"w": 3, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "இன்னும் (சில) முகங்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "அவற்றின் மீது"}, {"w": 4, "t": "புழுதி"}, {"w": 5, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவற்றை மூடிக்கொள்ளும்"}, {"w": 2, "t": "கருமை"}, {"w": 3, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "இவர்கள்தான்"}, {"w": 2, "t": "நிராகரிப்பாளர்கள்"}, {"w": 3, "t": "பெரும் பாவிகளான"}, {"w": 4, "t": "the wicked ones"}, {"w": 5, "t": "(42)"}]}]}