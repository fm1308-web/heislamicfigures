{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "ஹா மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "வேதத்தின் மீது சத்தியமாக!"}, {"w": 2, "t": "தெளிவான"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இதை ஆக்கினோம்"}, {"w": 3, "t": "குர்ஆனாக"}, {"w": 4, "t": "அரபி மொழி"}, {"w": 5, "t": "நீங்கள் சிந்தித்து புரிய வேண்டும் என்பதற்காக"}, {"w": 6, "t": "understand"}, {"w": 7, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக இது"}, {"w": 2, "t": "தாய் புத்தகத்தில் உள்ளதும்"}, {"w": 3, "t": "(the) Mother"}, {"w": 4, "t": "(of) the Book"}, {"w": 5, "t": "நம்மிடம் உள்ள"}, {"w": 6, "t": "மிக உயர்ந்ததும்"}, {"w": 7, "t": "மகா ஞானமுடையதும்"}, {"w": 8, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "விட்டுவிடுவோமா/உங்களைப் பற்றி/கூறுவதை"}, {"w": 2, "t": "from you"}, {"w": 3, "t": "the Reminder"}, {"w": 4, "t": "மன்னித்து"}, {"w": 5, "t": "நீங்களோ இருக்க"}, {"w": 6, "t": "you are"}, {"w": 7, "t": "மக்களாக"}, {"w": 8, "t": "வரம்பு மீறுகின்ற(வர்கள்)"}, {"w": 9, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "நபிமார்களை"}, {"w": 4, "t": "a Prophet"}, {"w": 5, "t": "முந்தியவர்களில்"}, {"w": 6, "t": "the former (people)"}, {"w": 7, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவர்களிடம் வருவதில்லை"}, {"w": 2, "t": "came to them"}, {"w": 3, "t": "எந்த ஒரு நபியும்"}, {"w": 4, "t": "any Prophet"}, {"w": 5, "t": "தவிர"}, {"w": 6, "t": "அவர்கள் இருந்தே"}, {"w": 7, "t": "அவரை"}, {"w": 8, "t": "அவர்கள் பரிகாசம் செய்கின்றவர்களாக"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஆகவேஅழித்தோம்"}, {"w": 2, "t": "மிக பலமானவர்களை"}, {"w": 3, "t": "இவர்களைவிட"}, {"w": 4, "t": "வலிமையால்"}, {"w": 5, "t": "சென்றிருக்கிறது"}, {"w": 6, "t": "உதாரணம்"}, {"w": 7, "t": "முந்தியவர்களின்"}, {"w": 8, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நீர் அவர்களிடம் கேட்டால்"}, {"w": 2, "t": "யார் படைத்தான்"}, {"w": 3, "t": "Who"}, {"w": 4, "t": "வானங்களையும்"}, {"w": 5, "t": "பூமியையும்"}, {"w": 6, "t": "நிச்சயமாக கூறுவார்கள்"}, {"w": 7, "t": "அவற்றைப் படைத்தான்"}, {"w": 8, "t": "மிகைத்தவன்"}, {"w": 9, "t": "நன்கறிந்தவன்"}, {"w": 10, "t": "the All-Knower"}, {"w": 11, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "எப்படிப்பட்டவன்/அவன் ஆக்கினான்"}, {"w": 2, "t": "made"}, {"w": 3, "t": "உங்களுக்கு"}, {"w": 4, "t": "பூமியை"}, {"w": 5, "t": "விரிப்பாக"}, {"w": 6, "t": "இன்னும் ஏற்படுத்தினான்"}, {"w": 7, "t": "உங்களுக்கு"}, {"w": 8, "t": "அதில்"}, {"w": 9, "t": "பாதைகளை"}, {"w": 10, "t": "நீங்கள் சரியான பாதையில் செல்வதற்காக"}, {"w": 11, "t": "(be) guided"}, {"w": 12, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "இன்னும் எப்படிப்பட்டவன்"}, {"w": 2, "t": "இறக்கினான்"}, {"w": 3, "t": "வானத்திலிருந்து"}, {"w": 4, "t": "the sky"}, {"w": 5, "t": "மழையை"}, {"w": 6, "t": "ஓர் அளவோடு"}, {"w": 7, "t": "ஆக, நாம் உயிர்ப்பிக்கின்றோம்"}, {"w": 8, "t": "அதன் மூலம்/பூமியை"}, {"w": 9, "t": "a land"}, {"w": 10, "t": "இறந்து போன"}, {"w": 11, "t": "இவ்வாறுதான்"}, {"w": 12, "t": "நீங்கள் வெளியாக்கப்படுவீர்கள்"}, {"w": 13, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் எப்படிப்பட்டவன்/ அவன் படைத்தான்"}, {"w": 2, "t": "created"}, {"w": 3, "t": "ஜோடிகள்"}, {"w": 4, "t": "எல்லாவற்றையும்"}, {"w": 5, "t": "இன்னும் ஏற்படுத்தினான்"}, {"w": 6, "t": "உங்களுக்கு"}, {"w": 7, "t": "கப்பல்களிலும்"}, {"w": 8, "t": "the ships"}, {"w": 9, "t": "கால்நடைகளிலும்"}, {"w": 10, "t": "நீங்கள் பயணம் செய்கின்றவற்றை"}, {"w": 11, "t": "you ride"}, {"w": 12, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நீங்கள் ஸ்திரமாக அமர்வதற்காகவும்"}, {"w": 2, "t": "அவற்றின்முதுகுகளில்"}, {"w": 3, "t": "their backs"}, {"w": 4, "t": "பிறகு"}, {"w": 5, "t": "நீங்கள் நினைவு கூர்வதற்காகவும்"}, {"w": 6, "t": "அருட்கொடையை"}, {"w": 7, "t": "உங்கள் இறைவனின்"}, {"w": 8, "t": "நீங்கள் ஸ்திரமாக அமரும்போது"}, {"w": 9, "t": "you sit firmly"}, {"w": 10, "t": "அவற்றின் மீது"}, {"w": 11, "t": "இன்னும் நீங்கள் கூறுவதற்காக"}, {"w": 12, "t": "மகா தூயவன்"}, {"w": 13, "t": "வசப்படுத்தி தந்தவன்"}, {"w": 14, "t": "(has) subjected"}, {"w": 15, "t": "எங்களுக்கு"}, {"w": 16, "t": "இதை"}, {"w": 17, "t": "நாங்கள் இருக்கவில்லை"}, {"w": 18, "t": "we were"}, {"w": 19, "t": "இதை"}, {"w": 20, "t": "கட்டுப்படுத்தும் ஆற்றல் உள்ளவர்களாக"}, {"w": 21, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "பக்கம்"}, {"w": 3, "t": "எங்கள் இறைவனின்"}, {"w": 4, "t": "திரும்புகின்றவர்கள்"}, {"w": 5, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவர்கள் ஆக்கிவிட்டனர்"}, {"w": 2, "t": "அவனுக்கு"}, {"w": 3, "t": "அவனது அடியார்களில்"}, {"w": 4, "t": "His slaves"}, {"w": 5, "t": "சிலரை"}, {"w": 6, "t": "நிச்சயமாக மனிதன்"}, {"w": 7, "t": "man"}, {"w": 8, "t": "மகா நன்றி கெட்டவன்"}, {"w": 9, "t": "மிகத் தெளிவான"}, {"w": 10, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "எடுத்துக்கொண்டானா"}, {"w": 2, "t": "has He taken"}, {"w": 3, "t": "தான் படைத்தவற்றில்"}, {"w": 4, "t": "He has created"}, {"w": 5, "t": "பெண் பிள்ளைகளை"}, {"w": 6, "t": "இன்னும் உங்களுக்கு தேர்தெடுத்(துக் கொடுத்)தானா?"}, {"w": 7, "t": "ஆண் பிள்ளைகளை"}, {"w": 8, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நற்செய்தி கூறப்பட்டால்"}, {"w": 2, "t": "is given good news"}, {"w": 3, "t": "ஒருவருக்கு அவர்களில்"}, {"w": 4, "t": "எதை/அவர் விவரித்தாரோ"}, {"w": 5, "t": "he sets up"}, {"w": 6, "t": "ரஹ்மானுக்கு"}, {"w": 7, "t": "தன்மையாக"}, {"w": 8, "t": "மாறிவிடுகிறது"}, {"w": 9, "t": "அவரது முகம்"}, {"w": 10, "t": "கருப்பாக"}, {"w": 11, "t": "அவர்/துக்கப்படுகிறார்"}, {"w": 12, "t": "(is) filled with grief"}, {"w": 13, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "?/யார் வளர்க்கப்படுகிறாரோ"}, {"w": 2, "t": "is brought up"}, {"w": 3, "t": "ஆபரணங்களில்"}, {"w": 4, "t": "ornaments"}, {"w": 5, "t": "இன்னும் அவர்"}, {"w": 6, "t": "வாதிப்பதில்"}, {"w": 7, "t": "the dispute"}, {"w": 8, "t": "தெளிவற்றவராக"}, {"w": 9, "t": "clear"}, {"w": 10, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இவர்கள் ஆக்கிவிட்டனர்"}, {"w": 2, "t": "வானவர்களை"}, {"w": 3, "t": "எவர்கள்/அவர்கள்"}, {"w": 4, "t": "themselves"}, {"w": 5, "t": "அடியார்களாகிய"}, {"w": 6, "t": "பேரருளாளனின்"}, {"w": 7, "t": "பெண்களாக"}, {"w": 8, "t": "பார்த்தார்களா?"}, {"w": 9, "t": "அவர்கள் படைக்கப்பட்டதை"}, {"w": 10, "t": "பதியப்படும்"}, {"w": 11, "t": "இவர்களின் சாட்சி"}, {"w": 12, "t": "இன்னும் இவர்கள் விசாரிக்கப்படுவார்கள்"}, {"w": 13, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இன்னும் கூறுகின்றனர்"}, {"w": 2, "t": "நாடியிருந்தால்"}, {"w": 3, "t": "had willed"}, {"w": 4, "t": "பேரருளாளன்"}, {"w": 5, "t": "நாம் அவர்களை வணங்கியிருக்க மாட்டோம்."}, {"w": 6, "t": "we would not have worshipped them"}, {"w": 7, "t": "இவர்களுக்கு இல்லை"}, {"w": 8, "t": "they have"}, {"w": 9, "t": "இதைப் பற்றி"}, {"w": 10, "t": "எந்த அறிவும்"}, {"w": 11, "t": "knowledge"}, {"w": 12, "t": "இவர்கள் இல்லை"}, {"w": 13, "t": "they (do)"}, {"w": 14, "t": "தவிர/கற்பனை செய்கின்றவர்களே"}, {"w": 15, "t": "lie"}, {"w": 16, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "?/நாம் அவர்களுக்குக் கொடுத்தோம்"}, {"w": 2, "t": "have We given them"}, {"w": 3, "t": "ஒரு வேதத்தை"}, {"w": 4, "t": "இதற்கு முன்னர்"}, {"w": 5, "t": "before it"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "அதை"}, {"w": 8, "t": "பற்றிப் பிடித்திருக்கின்றார்கள்"}, {"w": 9, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "அவர்கள் கூறுகின்றனர்"}, {"w": 3, "t": "நிச்சயமாக நாம்"}, {"w": 4, "t": "கண்டோம்"}, {"w": 5, "t": "எங்கள் மூதாதைகளை"}, {"w": 6, "t": "ஒரு கொள்கையில்"}, {"w": 7, "t": "a religion"}, {"w": 8, "t": "நிச்சயமாக நாங்கள்"}, {"w": 9, "t": "அவர்களின் அடிச்சுவடுகள் மீதே"}, {"w": 10, "t": "their footsteps"}, {"w": 11, "t": "நேர்வழி நடப்போம்"}, {"w": 12, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "இவ்வாறு"}, {"w": 2, "t": "நாம் அனுப்பியதில்லை"}, {"w": 3, "t": "We sent"}, {"w": 4, "t": "உமக்கு முன்னர்"}, {"w": 5, "t": "before you"}, {"w": 6, "t": "ஓர் ஊரில்"}, {"w": 7, "t": "a town"}, {"w": 8, "t": "எந்த ஓர் எச்சரிப்பாளரையும்"}, {"w": 9, "t": "warner"}, {"w": 10, "t": "கூறியே தவிர"}, {"w": 11, "t": "said"}, {"w": 12, "t": "அதன் செல்வந்தர்கள்"}, {"w": 13, "t": "நிச்சயமாக நாம் கண்டோம்"}, {"w": 14, "t": "[we] found"}, {"w": 15, "t": "எங்கள் மூதாதைகளை"}, {"w": 16, "t": "ஒரு கொள்கையில்"}, {"w": 17, "t": "a religion"}, {"w": 18, "t": "நிச்சயமாக நாங்கள்"}, {"w": 19, "t": "அவர்களின் அடிச்சுவடுகளை"}, {"w": 20, "t": "their footsteps"}, {"w": 21, "t": "பின்பற்றி நடப்போம்"}, {"w": 22, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "நான் உங்களிடம் கொண்டு வந்தாலுமா"}, {"w": 3, "t": "I brought you"}, {"w": 4, "t": "மிகச் சிறந்த நேர்வழியை"}, {"w": 5, "t": "எதைவிட/ கண்டீர்களோ"}, {"w": 6, "t": "you found"}, {"w": 7, "t": "அதன் மீது"}, {"w": 8, "t": "உங்கள் மூதாதைகளை"}, {"w": 9, "t": "அவர்கள் கூறினார்கள்"}, {"w": 10, "t": "நிச்சயமாக நாங்கள்"}, {"w": 11, "t": "நீங்கள் எதைக் கொடுத்து அனுப்பப்பட்டீர்களோ"}, {"w": 12, "t": "you are sent"}, {"w": 13, "t": "அதை/ நிராகரிப்பவர்கள்"}, {"w": 14, "t": "(are) disbelievers"}, {"w": 15, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "ஆகவே, நாம் பழிவாங்கினோம்"}, {"w": 2, "t": "அவர்களிடம்"}, {"w": 3, "t": "ஆக, நீர் கவனிப்பீராக!"}, {"w": 4, "t": "எப்படி"}, {"w": 5, "t": "இருந்தது"}, {"w": 6, "t": "முடிவு"}, {"w": 7, "t": "பொய்ப்பித்தவர்களின்"}, {"w": 8, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூறிய சமயத்தை நினைவு கூர்வீராக!"}, {"w": 2, "t": "Ibrahim Said"}, {"w": 3, "t": "இப்ராஹீம்"}, {"w": 4, "t": "தனது தந்தைக்கு(ம்)"}, {"w": 5, "t": "தனது மக்களுக்கும்"}, {"w": 6, "t": "நிச்சயமாக நான் முற்றிலும் நீங்கியவன்"}, {"w": 7, "t": "disassociated"}, {"w": 8, "t": "நீங்கள் வணங்குகின்ற அனைத்தையும் விட்டும்"}, {"w": 9, "t": "you worship"}, {"w": 10, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "என்னைப் படைத்தவனைத் தவிர"}, {"w": 2, "t": "the One Who"}, {"w": 3, "t": "created me"}, {"w": 4, "t": "நிச்சயமாக அவன்"}, {"w": 5, "t": "எனக்கு நேர்வழி காட்டுவான்"}, {"w": 6, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இதை ஆக்கினார்"}, {"w": 2, "t": "ஒரு வாக்கியமாக"}, {"w": 3, "t": "நீடித்து இருக்கின்ற(து)"}, {"w": 4, "t": "தனது சந்ததிகளில்"}, {"w": 5, "t": "his descendents"}, {"w": 6, "t": "அவர்கள் திரும்ப வேண்டும் என்பதற்காக"}, {"w": 7, "t": "return"}, {"w": 8, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "நாம் சுகமான வாழ்க்கையைக் கொடுத்தோம்"}, {"w": 3, "t": "இவர்களுக்கு(ம்)"}, {"w": 4, "t": "மூதாதைகளுக்கும் இவர்களின்"}, {"w": 5, "t": "இறுதியாக"}, {"w": 6, "t": "வந்தது அவர்களிடம்"}, {"w": 7, "t": "உண்மையான வேதம்"}, {"w": 8, "t": "தூதரும்"}, {"w": 9, "t": "தெளிவான"}, {"w": 10, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "வந்த போது"}, {"w": 2, "t": "அவர்களிடம்"}, {"w": 3, "t": "உண்மையான வேதம்"}, {"w": 4, "t": "கூறினார்கள்"}, {"w": 5, "t": "இது சூனியம்"}, {"w": 6, "t": "(is) magic"}, {"w": 7, "t": "நிச்சயமாக நாங்கள்"}, {"w": 8, "t": "இதை"}, {"w": 9, "t": "நிராகரிப்பவர்கள்"}, {"w": 10, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "அவர்கள் கூறுகின்றனர்"}, {"w": 2, "t": "இறக்கப்பட வேண்டாமா!"}, {"w": 3, "t": "was sent down"}, {"w": 4, "t": "இந்த குர்ஆன்"}, {"w": 5, "t": "the Quran"}, {"w": 6, "t": "மனிதர் மீது"}, {"w": 7, "t": "a man"}, {"w": 8, "t": "இந்த இரண்டு ஊர்களில் உள்ள"}, {"w": 9, "t": "the two towns"}, {"w": 10, "t": "ஒரு பெரிய(வர்)"}, {"w": 11, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அவர்கள் பங்கு வைக்கின்றனரா?"}, {"w": 2, "t": "distribute"}, {"w": 3, "t": "அருளை"}, {"w": 4, "t": "உமது இறைவனின்"}, {"w": 5, "t": "நாம்தான்"}, {"w": 6, "t": "பங்குவைத்தோம்."}, {"w": 7, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 8, "t": "அவர்களது வாழ்க்கையை"}, {"w": 9, "t": "இவ்வுலக வாழ்வில்"}, {"w": 10, "t": "the life"}, {"w": 11, "t": "(of) the world"}, {"w": 12, "t": "இன்னும் உயர்வாக்கினோம்"}, {"w": 13, "t": "அவர்களில் சிலரை"}, {"w": 14, "t": "மேலாக"}, {"w": 15, "t": "சிலருக்கு"}, {"w": 16, "t": "தகுதிகளால்"}, {"w": 17, "t": "எடுத்துக் கொள்வதற்காக"}, {"w": 18, "t": "அவர்களில் சிலர்"}, {"w": 19, "t": "சிலரை"}, {"w": 20, "t": "பணியாளராக"}, {"w": 21, "t": "அருள்தான்"}, {"w": 22, "t": "உமது இறைவனின்"}, {"w": 23, "t": "மிகச் சிறந்ததாகும்"}, {"w": 24, "t": "அவர்கள் சேகரிப்பதைவிட"}, {"w": 25, "t": "they accumulate"}, {"w": 26, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "இல்லையெனில்"}, {"w": 2, "t": "ஆகிவிடுவார்கள் என்று"}, {"w": 3, "t": "(would) become"}, {"w": 4, "t": "மக்கள்"}, {"w": 5, "t": "சமுதாயமாக"}, {"w": 6, "t": "ஒரே ஒரு"}, {"w": 7, "t": "ஆக்கியிருப்போம்"}, {"w": 8, "t": "நிராகரிப்பவர்களுக்கு"}, {"w": 9, "t": "disbelieves"}, {"w": 10, "t": "ரஹ்மானை"}, {"w": 11, "t": "அவர்களின் வீடுகளுக்கு"}, {"w": 12, "t": "முகடுகளை(யும்)"}, {"w": 13, "t": "வெள்ளியினால் ஆன"}, {"w": 14, "t": "silver"}, {"w": 15, "t": "ஏணிகளையும்"}, {"w": 16, "t": "அவற்றின் மீது"}, {"w": 17, "t": "ஏறுவார்கள்"}, {"w": 18, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இன்னும் அவர்களின் வீடுகளுக்கு"}, {"w": 2, "t": "கதவுகளையும்"}, {"w": 3, "t": "கட்டில்களையும்"}, {"w": 4, "t": "அவற்றின் மீது"}, {"w": 5, "t": "அவர்கள் சாய்ந்து படுப்பார்கள்"}, {"w": 6, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இன்னும் தங்கத்தையும்"}, {"w": 2, "t": "எல்லாம் இல்லை"}, {"w": 3, "t": "all"}, {"w": 4, "t": "இவை"}, {"w": 5, "t": "இன்பங்களே தவிர"}, {"w": 6, "t": "an enjoyment"}, {"w": 7, "t": "உலக வாழ்க்கையின்"}, {"w": 8, "t": "(of) the world"}, {"w": 9, "t": "மறுமை"}, {"w": 10, "t": "உமது இறைவனிடம்"}, {"w": 11, "t": "your Lord"}, {"w": 12, "t": "இறையச்சமுள்ளவர்களுக்கு"}, {"w": 13, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "யார் புறக்கணிப்பாரோ"}, {"w": 2, "t": "turns away"}, {"w": 3, "t": "நினைவு கூர்வதை"}, {"w": 4, "t": "(the) remembrance"}, {"w": 5, "t": "பேரருளாளனை"}, {"w": 6, "t": "நாம் சாட்டிவிடுவோம்"}, {"w": 7, "t": "அவருக்கு"}, {"w": 8, "t": "ஒரு ஷைத்தானை"}, {"w": 9, "t": "அவன் அவருக்கு"}, {"w": 10, "t": "(is) to him"}, {"w": 11, "t": "நண்பனாக"}, {"w": 12, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "நிச்சயமாக இவர்கள்"}, {"w": 2, "t": "அவர்களை தடுக்கின்றனர்"}, {"w": 3, "t": "பாதையிலிருந்து"}, {"w": 4, "t": "the Path"}, {"w": 5, "t": "இன்னும் எண்ணுகிறார்கள்"}, {"w": 6, "t": "நிச்சயமாக தாங்கள்"}, {"w": 7, "t": "நேர்வழி நடப்பவர்கள்தான்"}, {"w": 8, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "இறுதியாக"}, {"w": 2, "t": "அவன் வரும் போது"}, {"w": 3, "t": "அவன் வரும் போது நம்மிடம்"}, {"w": 4, "t": "கூறுவான்"}, {"w": 5, "t": "இருக்க வேண்டுமே!"}, {"w": 6, "t": "எனக்கு மத்தியிலும்"}, {"w": 7, "t": "உனக்கு மத்தியிலும்"}, {"w": 8, "t": "இடைப்பட்ட தூரம்"}, {"w": 9, "t": "கிழக்கிற்கும் மேற்கிற்கும்"}, {"w": 10, "t": "அவன் மிகக் கெட்ட நண்பன்"}, {"w": 11, "t": "the companion"}, {"w": 12, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "உங்களுக்கு அறவே பலனளிக்காது"}, {"w": 2, "t": "will benefit you"}, {"w": 3, "t": "இன்றைய தினம்"}, {"w": 4, "t": "நீங்கள் அநியாயம் செய்த காரணத்தால்"}, {"w": 5, "t": "you have wronged"}, {"w": 6, "t": "நிச்சயமாக நீங்கள்"}, {"w": 7, "t": "வேதனையில்"}, {"w": 8, "t": "the punishment"}, {"w": 9, "t": "இணைந்திருப்பது"}, {"w": 10, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நீர் செவி ஏற்க வைக்க முடியுமா?"}, {"w": 2, "t": "cause to hear"}, {"w": 3, "t": "அந்த செவிடர்களை"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "நீர் நேர்வழி நடத்திட முடியுமா?"}, {"w": 6, "t": "அந்த குருடர்களை"}, {"w": 7, "t": "இன்னும் இருப்பவர்களை"}, {"w": 8, "t": "is"}, {"w": 9, "t": "வழிகேட்டில்"}, {"w": 10, "t": "an error"}, {"w": 11, "t": "தெளிவான"}, {"w": 12, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "ஆகவே, ஒன்று"}, {"w": 2, "t": "நிச்சயமாக நாம் மரணிக்கச் செய்வோம்"}, {"w": 3, "t": "உம்மை"}, {"w": 4, "t": "நிச்சயமாக நாம்"}, {"w": 5, "t": "அவர்களிடம்"}, {"w": 6, "t": "பழிவாங்குவோம்"}, {"w": 7, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "அல்லது/நாம் உமக்கு காண்பிப்போம்"}, {"w": 2, "t": "We show you"}, {"w": 3, "t": "அவர்களுக்கு நாம் வாக்களித்ததை"}, {"w": 4, "t": "We have promised them"}, {"w": 5, "t": "நிச்சயமாக நாம்"}, {"w": 6, "t": "அவர்கள் மீது"}, {"w": 7, "t": "முழு ஆற்றல் உள்ளவர்கள்"}, {"w": 8, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "ஆகவே, உறுதியாக பற்றிப்பிடிப்பீராக!"}, {"w": 2, "t": "வஹீ  அறிவிக்கப்பட்டதை"}, {"w": 3, "t": "is revealed"}, {"w": 4, "t": "உமக்கு"}, {"w": 5, "t": "நிச்சயமாக நீர்"}, {"w": 6, "t": "பாதையில்"}, {"w": 7, "t": "a Path"}, {"w": 8, "t": "நேரான(து)"}, {"w": 9, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "நிச்சயமாக இது"}, {"w": 2, "t": "ஒரு சிறப்பாகும்"}, {"w": 3, "t": "உமக்கு(ம்)"}, {"w": 4, "t": "உமது மக்களுக்கும்"}, {"w": 5, "t": "உங்களிடம் விரைவில் விசாரிக்கப்படும்"}, {"w": 6, "t": "you will be questioned"}, {"w": 7, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "இன்னும் நீர் விசாரிப்பீராக!"}, {"w": 2, "t": "நாம் அனுப்பியவர்களை"}, {"w": 3, "t": "We sent"}, {"w": 4, "t": "உமக்கு முன்னர்"}, {"w": 5, "t": "before you"}, {"w": 6, "t": "நமது தூதர்களில்"}, {"w": 7, "t": "Our Messengers"}, {"w": 8, "t": "ஏற்படுத்தி இருக்கின்றோமா?"}, {"w": 9, "t": "ரஹ்மானை அன்றி"}, {"w": 10, "t": "besides"}, {"w": 11, "t": "the Most Gracious"}, {"w": 12, "t": "கடவுள்களை"}, {"w": 13, "t": "வணங்கப்படுகின்ற(னர்)"}, {"w": 14, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "மூசாவை"}, {"w": 4, "t": "நமது அத்தாட்சிகளுடன்"}, {"w": 5, "t": "ஃபிர்அவ்னிடம்"}, {"w": 6, "t": "Firaun"}, {"w": 7, "t": "இன்னும் அவனது பிரமுகர்களிடம்"}, {"w": 8, "t": "அவர் கூறினார்"}, {"w": 9, "t": "நிச்சயமாக நான்"}, {"w": 10, "t": "தூதர் ஆவேன்"}, {"w": 11, "t": "இறைவனுடைய"}, {"w": 12, "t": "அகிலங்களின்"}, {"w": 13, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "அவர் வந்த போது"}, {"w": 2, "t": "அவர்களிடம்"}, {"w": 3, "t": "நமது அத்தாட்சிகளுடன்"}, {"w": 4, "t": "அப்போது"}, {"w": 5, "t": "அவர்கள்"}, {"w": 6, "t": "அவற்றைப் பார்த்து"}, {"w": 7, "t": "சிரித்தார்கள்"}, {"w": 8, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "அவர்களுக்கு நாம் காண்பிக்க மாட்டோம்"}, {"w": 2, "t": "We showed them"}, {"w": 3, "t": "ஓர் அத்தாட்சியை"}, {"w": 4, "t": "a Sign"}, {"w": 5, "t": "தவிர"}, {"w": 6, "t": "அது"}, {"w": 7, "t": "பெரியதாக இருந்தே"}, {"w": 8, "t": "அதன் சகோதரியை விட"}, {"w": 9, "t": "its sister"}, {"w": 10, "t": "இன்னும் நாம் அவர்களைப் பிடித்தோம்"}, {"w": 11, "t": "வேதனையால்"}, {"w": 12, "t": "அல்லது திரும்புவதற்காக"}, {"w": 13, "t": "return"}, {"w": 14, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "ஓ சூனியக்காரரே!"}, {"w": 3, "t": "[the] magician"}, {"w": 4, "t": "நீர் பிரார்த்திப்பீராக!"}, {"w": 5, "t": "எங்களுக்காக"}, {"w": 6, "t": "உமது இறைவனிடம்"}, {"w": 7, "t": "அவன் வாக்களித்ததை"}, {"w": 8, "t": "He has made covenant"}, {"w": 9, "t": "உம்மிடம்/நிச்சயமாக நாங்கள்"}, {"w": 10, "t": "Indeed, we"}, {"w": 11, "t": "நேர்வழி பெறுவோம்"}, {"w": 12, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "நாம் அகற்றும்போது"}, {"w": 2, "t": "We removed"}, {"w": 3, "t": "அவர்களை விட்டும்"}, {"w": 4, "t": "வேதனையை"}, {"w": 5, "t": "அப்போது அவர்கள்"}, {"w": 6, "t": "They"}, {"w": 7, "t": "முறித்து விடுகின்றனர்"}, {"w": 8, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "அழைத்தான்"}, {"w": 2, "t": "ஃபிர்அவ்ன்"}, {"w": 3, "t": "தனது மக்களை"}, {"w": 4, "t": "his people"}, {"w": 5, "t": "கூறினான்"}, {"w": 6, "t": "என் மக்களே!"}, {"w": 7, "t": "இல்லையா?"}, {"w": 8, "t": "எனக்கு சொந்தமானது"}, {"w": 9, "t": "ஆட்சி"}, {"w": 10, "t": "எகிப்துடைய"}, {"w": 11, "t": "இந்த"}, {"w": 12, "t": "ஆறுகள்"}, {"w": 13, "t": "ஓடுகின்றன"}, {"w": 14, "t": "எனக்கு முன்னால்"}, {"w": 15, "t": "underneath me"}, {"w": 16, "t": "நீங்கள் உற்று நோக்கவில்லையா?"}, {"w": 17, "t": "you see"}, {"w": 18, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "?"}, {"w": 2, "t": "நான்"}, {"w": 3, "t": "சிறந்தவன்"}, {"w": 4, "t": "இவரை விட"}, {"w": 5, "t": "this"}, {"w": 6, "t": "எவர்/அவர்/பலவீனமானவர்"}, {"w": 7, "t": "he"}, {"w": 8, "t": "(is) insignificant"}, {"w": 9, "t": "இன்னும் தெளிவாகப் பேசமாட்டார்"}, {"w": 10, "t": "and hardly"}, {"w": 11, "t": "clear"}, {"w": 12, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "போடப்பட வேண்டாமா?"}, {"w": 2, "t": "are placed"}, {"w": 3, "t": "அவர் மீது"}, {"w": 4, "t": "காப்புகள்"}, {"w": 5, "t": "தங்கத்தின்"}, {"w": 6, "t": "gold"}, {"w": 7, "t": "அல்லது"}, {"w": 8, "t": "வர வேண்டாமா!"}, {"w": 9, "t": "அவருடன்"}, {"w": 10, "t": "வானவர்கள்"}, {"w": 11, "t": "சேர்ந்தவர்களாக"}, {"w": 12, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "அற்பமாகக் கருதினான்"}, {"w": 2, "t": "தனது மக்களை"}, {"w": 3, "t": "ஆக, அவர்கள் அவனுக்கு கீழ்ப்படிந்தனர்"}, {"w": 4, "t": "நிச்சயமாக அவர்கள்"}, {"w": 5, "t": "இருந்தனர்"}, {"w": 6, "t": "மக்களாக"}, {"w": 7, "t": "பாவிகளான"}, {"w": 8, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "அவர்கள் நமக்கு கோபமூட்டவே"}, {"w": 2, "t": "they angered Us"}, {"w": 3, "t": "நாம் பழிவாங்கினோம்"}, {"w": 4, "t": "அவர்களிடம்"}, {"w": 5, "t": "மூழ்கடித்தோம்/அவர்கள்"}, {"w": 6, "t": "அனைவரையும்"}, {"w": 7, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "நாம் ஆக்கினோம்"}, {"w": 2, "t": "முன்னோடிகளாக(வும்)"}, {"w": 3, "t": "படிப்பினையாகவும்"}, {"w": 4, "t": "மற்றவர்களுக்கு"}, {"w": 5, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "விவரிக்கப்பட்டபோது"}, {"w": 2, "t": "is presented"}, {"w": 3, "t": "மகன்"}, {"w": 4, "t": "மர்யமின்"}, {"w": 5, "t": "ஓர் உதாரணமாக"}, {"w": 6, "t": "அப்போது உமது மக்கள்"}, {"w": 7, "t": "Your people"}, {"w": 8, "t": "அதனால்"}, {"w": 9, "t": "கூச்சல்போடுகின்றனர்"}, {"w": 10, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "அவர்கள் கூறினார்கள்"}, {"w": 2, "t": "?/எங்கள் கடவுள்கள்"}, {"w": 3, "t": "சிறந்த(வர்களா)"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "அவர்"}, {"w": 6, "t": "அவரை உதாரணமாக அவர்கள் பேசவில்லை"}, {"w": 7, "t": "they present it"}, {"w": 8, "t": "உமக்கு"}, {"w": 9, "t": "தவிர"}, {"w": 10, "t": "தர்க்கம் செய்வதற்காகவே"}, {"w": 11, "t": "மாறாக/அவர்கள்"}, {"w": 12, "t": "they"}, {"w": 13, "t": "மக்கள்"}, {"w": 14, "t": "தர்க்கம் செய்கின்ற(வர்கள்)"}, {"w": 15, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "அவர் இல்லை"}, {"w": 2, "t": "he"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "ஓர் அடியாராகவே"}, {"w": 5, "t": "அருள் புரிந்தோம்"}, {"w": 6, "t": "அவர்மீது"}, {"w": 7, "t": "அவரை ஆக்கினோம்"}, {"w": 8, "t": "ஓர் அத்தாட்சியாக"}, {"w": 9, "t": "இஸ்ரவேலர்களுக்கு"}, {"w": 10, "t": "for (the) Children of Israel"}, {"w": 11, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "நாம் நாடினால்"}, {"w": 2, "t": "We willed"}, {"w": 3, "t": "ஆக்கியிருப்போம்"}, {"w": 4, "t": "உங்களுக்குப் பதிலாக"}, {"w": 5, "t": "வானவர்களை"}, {"w": 6, "t": "இந்த பூமியில்"}, {"w": 7, "t": "the earth"}, {"w": 8, "t": "வழித்தோன்றி வருவார்கள்"}, {"w": 9, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "நிச்சயமாக அவர்"}, {"w": 2, "t": "அடையாளமாவார்"}, {"w": 3, "t": "மறுமையின்"}, {"w": 4, "t": "ஆகவே அதில் நீங்கள் அறவே சந்தேகிக்காதீர்கள்"}, {"w": 5, "t": "(be) doubtful"}, {"w": 6, "t": "about it"}, {"w": 7, "t": "இன்னும் என்னை பின்பற்றுங்கள்!"}, {"w": 8, "t": "இதுதான்"}, {"w": 9, "t": "நேரான(து)"}, {"w": 10, "t": "பாதையாகும்"}, {"w": 11, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "உங்களை தடுத்துவிட வேண்டாம்"}, {"w": 2, "t": "avert you"}, {"w": 3, "t": "ஷைத்தான்"}, {"w": 4, "t": "நிச்சயமாக அவன்"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "எதிரி"}, {"w": 7, "t": "தெளிவான"}, {"w": 8, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "வந்த போது"}, {"w": 2, "t": "came"}, {"w": 3, "t": "ஈஸா"}, {"w": 4, "t": "தெளிவான அத்தாட்சிகளுடன்"}, {"w": 5, "t": "அவர் கூறினார்"}, {"w": 6, "t": "திட்டமாக நான் உங்களிடம் வந்துள்ளேன்"}, {"w": 7, "t": "I have come to you"}, {"w": 8, "t": "ஞானத்துடன்"}, {"w": 9, "t": "விவரிப்பதற்காகவும்"}, {"w": 10, "t": "உங்களுக்கு/சிலவற்றை"}, {"w": 11, "t": "some"}, {"w": 12, "t": "எதில்/கருத்து வேற்றுமை கொள்கிறீர்களோ"}, {"w": 13, "t": "you differ"}, {"w": 14, "t": "அதில்"}, {"w": 15, "t": "ஆகவே அல்லாஹ்வை பயந்து கொள்ளுங்கள்!"}, {"w": 16, "t": "Allah"}, {"w": 17, "t": "இன்னும் எனக்கு கீழ்ப்படிந்து நடங்கள்!"}, {"w": 18, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "அல்லாஹ்தான்"}, {"w": 3, "t": "He"}, {"w": 4, "t": "எனது இறைவனும்"}, {"w": 5, "t": "உங்கள் இறைவனும்"}, {"w": 6, "t": "ஆக