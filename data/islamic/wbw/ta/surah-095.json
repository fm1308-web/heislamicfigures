{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அத்தி மரத்தின் மீது சத்தியமாக"}, {"w": 2, "t": "ஜைதூன் மரத்தின் மீது சத்தியமாக"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "மலையின் மீது சத்தியமாக"}, {"w": 2, "t": "சினாய்"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "சத்தியமாக இந்த"}, {"w": 2, "t": "நகரம்"}, {"w": 3, "t": "அபயமளிக்கக்கூடிய"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "திட்டமாக படைத்தோம்"}, {"w": 2, "t": "We created"}, {"w": 3, "t": "மனிதனை"}, {"w": 4, "t": "மிக அழகிய/இல்"}, {"w": 5, "t": "(the) best"}, {"w": 6, "t": "அமைப்பு"}, {"w": 7, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "பிறகு/அவனைத் திருப்பினோம்"}, {"w": 2, "t": "We returned him"}, {"w": 3, "t": "மிகத் தாழ்ந்தவனாக"}, {"w": 4, "t": "தாழ்ந்தோரில்"}, {"w": 5, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நற்செயல்களை"}, {"w": 6, "t": "ஆகவே அவர்களுக்கு"}, {"w": 7, "t": "நன்மை"}, {"w": 8, "t": "முடிவுறாத"}, {"w": 9, "t": "ending"}, {"w": 10, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "ஆகவே யார்தான் உம்மை பொய்ப்பிப்பார்"}, {"w": 2, "t": "causes you to deny"}, {"w": 3, "t": "(இதற்குப்) பின்னர்"}, {"w": 4, "t": "மார்க்கத்தில்"}, {"w": 5, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இல்லையா?"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "மிக மேலான தீர்ப்பளிப்பவனாக"}, {"w": 4, "t": "தீர்ப்பளிப்பவர்களில்"}, {"w": 5, "t": "(8)"}]}]}