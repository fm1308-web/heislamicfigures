{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "முற்பகலின் மீது சத்தியமாக"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இரவின் மீது சத்தியமாக"}, {"w": 2, "t": "அது நிசப்தமாகும்போது"}, {"w": 3, "t": "it covers with darkness"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "உம்மை விடவில்லை"}, {"w": 2, "t": "has forsaken you"}, {"w": 3, "t": "உம் இறைவன்"}, {"w": 4, "t": "இன்னும் வெறுக்கவில்லை"}, {"w": 5, "t": "He is displeased"}, {"w": 6, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் மறுமைதான்"}, {"w": 2, "t": "மிகச் சிறந்தது"}, {"w": 3, "t": "உமக்கு"}, {"w": 4, "t": "இம்மையைவிட"}, {"w": 5, "t": "the first"}, {"w": 6, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இன்னும் திட்டமாக உமக்குக் கொடுப்பான்"}, {"w": 2, "t": "will give you"}, {"w": 3, "t": "உம் இறைவன்"}, {"w": 4, "t": "ஆகவே நீர் திருப்தியடைவீர்"}, {"w": 5, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "உம்மை அவன் காணவில்லையா?"}, {"w": 2, "t": "He find you"}, {"w": 3, "t": "அநாதையாக"}, {"w": 4, "t": "ஆகவே ஆதரித்தான்"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் உம்மைக் கண்டான்"}, {"w": 2, "t": "வழி அறியாதவராக"}, {"w": 3, "t": "ஆகவே அவன் நேர்வழி செலுத்தினான்"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் உம்மைக் கண்டான்"}, {"w": 2, "t": "வறியவராக"}, {"w": 3, "t": "ஆகவே செல்வந்தராக்கினான்"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "அநாதைக்கு"}, {"w": 3, "t": "அநீதி செய்யாதீர்"}, {"w": 4, "t": "oppress"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "யாசகரை"}, {"w": 3, "t": "கடிந்து கொள்ளாதீர்"}, {"w": 4, "t": "repel"}, {"w": 5, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "அருளை"}, {"w": 3, "t": "உம் இறைவனின்"}, {"w": 4, "t": "அறிவிப்பீராக"}, {"w": 5, "t": "(11)"}]}]}