{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "இது ஒரு அத்தியாயமாகும்"}, {"w": 2, "t": "இதை நாம் இறக்கினோம்"}, {"w": 3, "t": "இதை நாம் கடமையாக்கினோம்"}, {"w": 4, "t": "இன்னும் நாம் இறக்கினோம்"}, {"w": 5, "t": "இதில்"}, {"w": 6, "t": "அத்தாட்சிகளை"}, {"w": 7, "t": "தெளிவான"}, {"w": 8, "t": "நீங்கள் நல்லறிவு பெறுவதற்காக"}, {"w": 9, "t": "take heed"}, {"w": 10, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "விபச்சாரி"}, {"w": 2, "t": "இன்னும் விபசாரன்"}, {"w": 3, "t": "அடியுங்கள்"}, {"w": 4, "t": "ஒவ்வொருவரையும்"}, {"w": 5, "t": "one"}, {"w": 6, "t": "அவ்விருவரில்"}, {"w": 7, "t": "நூறு"}, {"w": 8, "t": "அடி"}, {"w": 9, "t": "பிடித்துவிட வேண்டாம்"}, {"w": 10, "t": "பிடித்துவிட வேண்டாம் உங்களை"}, {"w": 11, "t": "அந்த இருவர் மீது"}, {"w": 12, "t": "இரக்கம்"}, {"w": 13, "t": "மார்க்கத்தில்"}, {"w": 14, "t": "(the) religion of Allah"}, {"w": 15, "t": "அல்லாஹ்வின்"}, {"w": 16, "t": "நீங்கள் இருந்தால்"}, {"w": 17, "t": "you"}, {"w": 18, "t": "நம்பிக்கை கொண்டவர்களாக"}, {"w": 19, "t": "அல்லாஹ்வையும்"}, {"w": 20, "t": "மறுமை நாளையும்"}, {"w": 21, "t": "the Last"}, {"w": 22, "t": "ஆஜராகட்டும்"}, {"w": 23, "t": "அவ்விருவரின் தண்டனைக்கு"}, {"w": 24, "t": "ஒரு கூட்டம்"}, {"w": 25, "t": "நம்பிக்கையாளர்களில்"}, {"w": 26, "t": "the believers"}, {"w": 27, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "ஒரு விபசாரன்"}, {"w": 2, "t": "உ(டலு)றவு வைக்க மாட்டான்"}, {"w": 3, "t": "marry"}, {"w": 4, "t": "தவிர/ஒரு விபசாரி"}, {"w": 5, "t": "a fornicatress"}, {"w": 6, "t": "அல்லது"}, {"w": 7, "t": "இணைவைப்பவள்"}, {"w": 8, "t": "இன்னும் விபசாரி"}, {"w": 9, "t": "அவளுடன் உ(டலு)றவு வைக்கமாட்டான்"}, {"w": 10, "t": "marry her"}, {"w": 11, "t": "தவிர"}, {"w": 12, "t": "ஒரு விபசாரன்"}, {"w": 13, "t": "அல்லது"}, {"w": 14, "t": "இணைவைப்பவன்"}, {"w": 15, "t": "தடுக்கப்பட்டுள்ளது"}, {"w": 16, "t": "இது"}, {"w": 17, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 18, "t": "the believers"}, {"w": 19, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "ஏசுவார்களோ"}, {"w": 3, "t": "பத்தினிகளை"}, {"w": 4, "t": "பிறகு"}, {"w": 5, "t": "அவர்கள் கொண்டுவரவில்லை என்றால்"}, {"w": 6, "t": "they bring"}, {"w": 7, "t": "நான்கு"}, {"w": 8, "t": "சாட்சிகளை"}, {"w": 9, "t": "அடியுங்கள் அவர்களை"}, {"w": 10, "t": "எண்பது"}, {"w": 11, "t": "அடி"}, {"w": 12, "t": "ஏற்காதீர்கள்"}, {"w": 13, "t": "accept"}, {"w": 14, "t": "அவர்களின்"}, {"w": 15, "t": "சாட்சியத்தை"}, {"w": 16, "t": "ஒருபோதும்"}, {"w": 17, "t": "அவர்கள்தான்"}, {"w": 18, "t": "they"}, {"w": 19, "t": "பாவிகள்"}, {"w": 20, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "திருந்தினார்கள்"}, {"w": 4, "t": "பின்னர்"}, {"w": 5, "t": "after"}, {"w": 6, "t": "அதற்குப்"}, {"w": 7, "t": "இன்னும் சீர்படுத்திக் கொண்டார்கள்"}, {"w": 8, "t": "நிச்சயமாக"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "மகா மன்னிப்பாளன்"}, {"w": 11, "t": "மகா கருணையாளன்"}, {"w": 12, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "ஏசுகிறார்களோ"}, {"w": 3, "t": "தங்களது மனைவிகளை"}, {"w": 4, "t": "இல்லையோ"}, {"w": 5, "t": "have"}, {"w": 6, "t": "அவர்களிடம்"}, {"w": 7, "t": "சாட்சிகள்"}, {"w": 8, "t": "தவிர"}, {"w": 9, "t": "அவர்களை"}, {"w": 10, "t": "சாட்சிகள் சொல்ல வேண்டும்"}, {"w": 11, "t": "அவர்களில் ஒருவர்"}, {"w": 12, "t": "நான்கு முறை சாட்சி சொல்வது"}, {"w": 13, "t": "testimonies"}, {"w": 14, "t": "அல்லாஹ்வின் மீது சத்தியமாக"}, {"w": 15, "t": "நிச்சயமாக தான்"}, {"w": 16, "t": "உண்மை கூறுபவர்களில்"}, {"w": 17, "t": "the truthful"}, {"w": 18, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "ஐந்தாவது முறை"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "சாபம் உண்டாகட்டும்"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "தன் மீது"}, {"w": 6, "t": "ஒருவனாக இருந்தால்"}, {"w": 7, "t": "he is"}, {"w": 8, "t": "பொய் கூறுபவர்களில்"}, {"w": 9, "t": "the liars"}, {"w": 10, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "தடுக்கும்"}, {"w": 2, "t": "அவளை விட்டும்"}, {"w": 3, "t": "தண்டனையை"}, {"w": 4, "t": "அவள் சாட்சி சொல்வது"}, {"w": 5, "t": "she bears witness"}, {"w": 6, "t": "நான்கு முறை சாட்சி சொல்வது"}, {"w": 7, "t": "testimonies"}, {"w": 8, "t": "அல்லாஹ்வின் மீது சத்தியமாக"}, {"w": 9, "t": "நிச்சயமாக அவர்"}, {"w": 10, "t": "பொய் கூறுபவர்களில் உள்ளவர்"}, {"w": 11, "t": "the liars"}, {"w": 12, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "ஐந்தாவது முறை"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "சாபம் உண்டாகட்டும்"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "தன் மீது"}, {"w": 6, "t": "அவர் இருந்தால்"}, {"w": 7, "t": "he is"}, {"w": 8, "t": "உண்மை கூறுபவர்களில்"}, {"w": 9, "t": "the truthful"}, {"w": 10, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அருளும் இல்லாதிருந்தால்"}, {"w": 2, "t": "(for) the Grace of Allah"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "உங்கள் மீது"}, {"w": 5, "t": "இன்னும் அவனது கருணையும்"}, {"w": 6, "t": "இன்னும் நிச்சயமாக"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "பிழை பொறுப்பவனாகவும்"}, {"w": 9, "t": "ஞானவானாகவும்"}, {"w": 10, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "இட்டுக்கட்டியவர்கள்"}, {"w": 4, "t": "the lie"}, {"w": 5, "t": "ஒரு குழுவினர்தான்"}, {"w": 6, "t": "உங்களில் உள்ள"}, {"w": 7, "t": "அதை கருதாதீர்கள்"}, {"w": 8, "t": "think it"}, {"w": 9, "t": "தீமையாக"}, {"w": 10, "t": "உங்களுக்கு"}, {"w": 11, "t": "மாறாக"}, {"w": 12, "t": "அது"}, {"w": 13, "t": "நன்மைதான்"}, {"w": 14, "t": "உங்களுக்கு"}, {"w": 15, "t": "ஒவ்வொருவருக்கும்"}, {"w": 16, "t": "person"}, {"w": 17, "t": "அவர்களில்"}, {"w": 18, "t": "அவர் செய்தது"}, {"w": 19, "t": "he earned"}, {"w": 20, "t": "பாவத்தில்"}, {"w": 21, "t": "the sin"}, {"w": 22, "t": "செய்தவர்கள்"}, {"w": 23, "t": "took upon himself a greater share of it"}, {"w": 24, "t": "பெரியதை"}, {"w": 25, "t": "அதில்"}, {"w": 26, "t": "அவருக்கு"}, {"w": 27, "t": "தண்டனை உண்டு"}, {"w": 28, "t": "பெரும்"}, {"w": 29, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நீங்கள் அதைக் கேட்டபோது"}, {"w": 2, "t": "when"}, {"w": 3, "t": "you heard it"}, {"w": 4, "t": "எண்ணியிருக்க"}, {"w": 5, "t": "நம்பிக்கை கொண்ட ஆண்களும்"}, {"w": 6, "t": "நம்பிக்கை கொண்ட பெண்களும்"}, {"w": 7, "t": "தங்களைப் பற்றி"}, {"w": 8, "t": "நல்லதை"}, {"w": 9, "t": "இன்னும் அவர்கள் சொல்லியிருக்க வேண்டாமா"}, {"w": 10, "t": "இது"}, {"w": 11, "t": "இட்டுக்கட்டு"}, {"w": 12, "t": "தெளிவான"}, {"w": 13, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "கொண்டு வந்திருக்க வேண்டாமா!"}, {"w": 2, "t": "they bring"}, {"w": 3, "t": "அதற்கு"}, {"w": 4, "t": "நான்கு"}, {"w": 5, "t": "சாட்சிகளை"}, {"w": 6, "t": "ஆகவே அவர்கள் வராததால்"}, {"w": 7, "t": "not"}, {"w": 8, "t": "they brought"}, {"w": 9, "t": "சாட்சிகளைக்கொண்டு"}, {"w": 10, "t": "அவர்கள்தான்"}, {"w": 11, "t": "அல்லாஹ்விடம்"}, {"w": 12, "t": "near Allah"}, {"w": 13, "t": "அவர்கள்தான்"}, {"w": 14, "t": "பொய்யர்கள்"}, {"w": 15, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அருளும் இல்லாதிருந்தால்"}, {"w": 2, "t": "(for the) Grace"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "உங்கள் மீது"}, {"w": 5, "t": "கருணையும்"}, {"w": 6, "t": "இம்மையிலும்"}, {"w": 7, "t": "the world"}, {"w": 8, "t": "மறுமையிலும்"}, {"w": 9, "t": "உங்களுக்கு கிடைத்திருக்கும்"}, {"w": 10, "t": "நீங்கள் ஈடுபட்ட விஷயத்தில்"}, {"w": 11, "t": "what"}, {"w": 12, "t": "you had rushed glibly"}, {"w": 13, "t": "concerning it"}, {"w": 14, "t": "பெரிய தண்டனை"}, {"w": 15, "t": "great"}, {"w": 16, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஏனெனில்"}, {"w": 2, "t": "அதை உங்களுக்குள் அறிவித்துக் கொண்டீர்கள்"}, {"w": 3, "t": "நீங்கள்உங்கள் நாவுகளால்"}, {"w": 4, "t": "இன்னும் அதை கூறுகிறீர்கள்"}, {"w": 5, "t": "உங்கள் வாய்களால்"}, {"w": 6, "t": "எதைப் பற்றி"}, {"w": 7, "t": "உங்களுக்கு இல்லையோ"}, {"w": 8, "t": "for you"}, {"w": 9, "t": "அதைக் கொண்டு"}, {"w": 10, "t": "அறிவு"}, {"w": 11, "t": "அதை கருதுகிறீர்கள்"}, {"w": 12, "t": "மிக இலகுவாக"}, {"w": 13, "t": "அதுவோ இருக்கிறது"}, {"w": 14, "t": "அல்லாஹ்விடம்"}, {"w": 15, "t": "(was) near Allah"}, {"w": 16, "t": "மிகப்பெரியதாக"}, {"w": 17, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "வேண்டாமா"}, {"w": 2, "t": "அதை நீங்கள் கேட்டபோது"}, {"w": 3, "t": "you heard it"}, {"w": 4, "t": "நீங்கள் சொல்லியிருக்க"}, {"w": 5, "t": "தகாது"}, {"w": 6, "t": "it is"}, {"w": 7, "t": "எங்களுக்கு"}, {"w": 8, "t": "நாங்கள் பேசுவது"}, {"w": 9, "t": "we speak"}, {"w": 10, "t": "இதை"}, {"w": 11, "t": "அல்லாஹ் மிகப் பரிசுத்தமானவன் / இது"}, {"w": 12, "t": "This"}, {"w": 13, "t": "அபாண்டமான பேச்சு"}, {"w": 14, "t": "பெரிய"}, {"w": 15, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அல்லாஹ் உங்களுக்கு உபதேசிக்கிறான்"}, {"w": 2, "t": "Allah warns you"}, {"w": 3, "t": "நீங்கள் மீண்டும் வரக்கூடாது என்று"}, {"w": 4, "t": "you return"}, {"w": 5, "t": "இது போன்றதற்கு"}, {"w": 6, "t": "ஒரு போதும்"}, {"w": 7, "t": "நீங்கள் இருந்தால்"}, {"w": 8, "t": "you are"}, {"w": 9, "t": "நம்பிக்கையாளர்களாக"}, {"w": 10, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இன்னும் விவரிக்கிறான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "உங்களுக்கு"}, {"w": 4, "t": "வசனங்களை"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "நன்கறிந்தவன்"}, {"w": 7, "t": "மகா ஞானவான்"}, {"w": 8, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "விரும்பக்கூடியவர்கள்"}, {"w": 3, "t": "like"}, {"w": 4, "t": "பரவுவதை"}, {"w": 5, "t": "(should) spread"}, {"w": 6, "t": "அசிங்கமான செயல்"}, {"w": 7, "t": "நம்பிக்கையாளர்களுக்கிடையில்"}, {"w": 8, "t": "those who"}, {"w": 9, "t": "believe"}, {"w": 10, "t": "அவர்களுக்கு"}, {"w": 11, "t": "தண்டனை"}, {"w": 12, "t": "வலி தரக்கூடிய"}, {"w": 13, "t": "இம்மையிலும்"}, {"w": 14, "t": "the world"}, {"w": 15, "t": "மறுமையிலும்"}, {"w": 16, "t": "அல்லாஹ்தான்"}, {"w": 17, "t": "அறிவான்"}, {"w": 18, "t": "நீங்கள்"}, {"w": 19, "t": "அறியமாட்டீர்கள்"}, {"w": 20, "t": "know"}, {"w": 21, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இல்லாதிருந்தால்"}, {"w": 2, "t": "அருளும்"}, {"w": 3, "t": "அல்லாஹ்வுடைய"}, {"w": 4, "t": "உங்கள் மீது"}, {"w": 5, "t": "அவனது கருணையும்"}, {"w": 6, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "மிக்க இரக்கமுள்ளவன்"}, {"w": 9, "t": "மகா கருணையுள்ளவன்"}, {"w": 10, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "பின்பற்றாதீர்கள்"}, {"w": 5, "t": "follow"}, {"w": 6, "t": "அடிச்சுவடுகளை"}, {"w": 7, "t": "ஷைத்தானின்"}, {"w": 8, "t": "யார்"}, {"w": 9, "t": "பின்பற்றுகிறானோ"}, {"w": 10, "t": "அடிச்சுவடுகளை"}, {"w": 11, "t": "ஷைத்தானின்"}, {"w": 12, "t": "நிச்சயமாக அவன்"}, {"w": 13, "t": "ஏவுகிறான்"}, {"w": 14, "t": "அசிங்கத்தையும்"}, {"w": 15, "t": "கெட்டதையும்"}, {"w": 16, "t": "இல்லாதிருந்தால்"}, {"w": 17, "t": "அருளும்"}, {"w": 18, "t": "அல்லாஹ்வுடைய"}, {"w": 19, "t": "உங்கள் மீது"}, {"w": 20, "t": "அவனது கருணையும்"}, {"w": 21, "t": "தூய்மை அடைந்திருக்க மாட்டார்"}, {"w": 22, "t": "(would) have been pure"}, {"w": 23, "t": "உங்களில்"}, {"w": 24, "t": "எவரும்"}, {"w": 25, "t": "anyone"}, {"w": 26, "t": "ஒரு போதும்"}, {"w": 27, "t": "எனினும் அல்லாஹ்"}, {"w": 28, "t": "Allah"}, {"w": 29, "t": "பரிசுத்தப்படுத்துகிறான்"}, {"w": 30, "t": "தான் நாடியவரை"}, {"w": 31, "t": "He wills"}, {"w": 32, "t": "அல்லாஹ்"}, {"w": 33, "t": "நன்கு செவியுறுபவன்"}, {"w": 34, "t": "நன்கறிந்தவன்"}, {"w": 35, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "சத்தியம் செய்ய வேண்டாம்"}, {"w": 2, "t": "let swear"}, {"w": 3, "t": "செல்வம் உடையவர்கள்"}, {"w": 4, "t": "those of virtue"}, {"w": 5, "t": "உங்களில்"}, {"w": 6, "t": "இன்னும் வசதி"}, {"w": 7, "t": "அவர்கள் கொடுக்க"}, {"w": 8, "t": "they give"}, {"w": 9, "t": "உறவினர்களுக்கு"}, {"w": 10, "t": "(to) the near of kin"}, {"w": 11, "t": "இன்னும் வறியவர்களுக்கு"}, {"w": 12, "t": "இன்னும் ஹிஜ்ரா சென்றவர்களுக்கு"}, {"w": 13, "t": "பாதையில்"}, {"w": 14, "t": "(the) way"}, {"w": 15, "t": "அல்லாஹ்வின்"}, {"w": 16, "t": "அவர்கள் மன்னிக்கட்டும்"}, {"w": 17, "t": "பெருந்தன்மையுடன் விட்டு விடட்டும்"}, {"w": 18, "t": "விரும்ப மாட்டீர்களா?"}, {"w": 19, "t": "you like"}, {"w": 20, "t": "மன்னிப்பதை"}, {"w": 21, "t": "Allah should forgive"}, {"w": 22, "t": "அல்லாஹ்"}, {"w": 23, "t": "உங்களை"}, {"w": 24, "t": "அல்லாஹ்"}, {"w": 25, "t": "மகா மன்னிப்பாளன்"}, {"w": 26, "t": "மகா கருணையுடையவன்"}, {"w": 27, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "குற்றம் சுமத்துகிறார்களோ"}, {"w": 3, "t": "accuse"}, {"w": 4, "t": "பத்தினிகள்"}, {"w": 5, "t": "அறியாத பெண்கள்"}, {"w": 6, "t": "நம்பிக்கைகொண்ட பெண்கள்"}, {"w": 7, "t": "சபிக்கப்பட்டார்கள்"}, {"w": 8, "t": "உலகத்திலும்"}, {"w": 9, "t": "the world"}, {"w": 10, "t": "மறுமையிலும்"}, {"w": 11, "t": "இன்னும் அவர்களுக்கு உண்டு"}, {"w": 12, "t": "தண்டனை"}, {"w": 13, "t": "பெரிய"}, {"w": 14, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "சாட்சி பகரும்"}, {"w": 3, "t": "அவர்களுக்கு எதிராக"}, {"w": 4, "t": "அவர்களது நாவுகளும்"}, {"w": 5, "t": "அவர்களதுகரங்களும்"}, {"w": 6, "t": "அவர்களதுகால்களும்"}, {"w": 7, "t": "எதை/இருந்தனர்"}, {"w": 8, "t": "they used"}, {"w": 9, "t": "செய்கின்றார்கள்"}, {"w": 10, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அந்நாளில்"}, {"w": 2, "t": "அவர்களுக்கு முழுமையாக தருவான்"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "அவர்களுடைய கூலியை"}, {"w": 5, "t": "உண்மையான"}, {"w": 6, "t": "இன்னும் அவர்கள் அறிந்து கொள்வார்கள்"}, {"w": 7, "t": "நிச்சயமாக"}, {"w": 8, "t": "அல்லாஹ்தான்"}, {"w": 9, "t": "உண்மையானவன்"}, {"w": 10, "t": "(is) the Truth"}, {"w": 11, "t": "தெளிவானவன்"}, {"w": 12, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கெட்ட சொற்கள்"}, {"w": 2, "t": "கெட்டவர்களுக்கு உரியன"}, {"w": 3, "t": "இன்னும் கெட்டவர்கள்"}, {"w": 4, "t": "கெட்ட சொற்களுக்கு உரியவர்கள்"}, {"w": 5, "t": "இன்னும் நல்ல சொற்கள்"}, {"w": 6, "t": "நல்லவர்களுக்கு உரியன"}, {"w": 7, "t": "இன்னும் நல்லவர்கள்"}, {"w": 8, "t": "நல்ல சொற்களுக்கு உரியவர்கள்"}, {"w": 9, "t": "அவர்கள்"}, {"w": 10, "t": "நீக்கப்பட்டவர்கள்"}, {"w": 11, "t": "இவர்கள் சொல்வதிலிருந்து"}, {"w": 12, "t": "they say"}, {"w": 13, "t": "அவர்களுக்கு"}, {"w": 14, "t": "மன்னிப்பும்"}, {"w": 15, "t": "அருட்கொடையும்"}, {"w": 16, "t": "கண்ணியமான"}, {"w": 17, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "நீங்கள் நுழையாதீர்கள்"}, {"w": 5, "t": "enter"}, {"w": 6, "t": "வீடுகளில்"}, {"w": 7, "t": "உங்கள் வீடுகள் அல்லாத"}, {"w": 8, "t": "your houses"}, {"w": 9, "t": "வரை"}, {"w": 10, "t": "நீங்கள் அனுமதி பெறுகின்ற"}, {"w": 11, "t": "இன்னும் நீங்கள் ஸலாம் கூறி"}, {"w": 12, "t": "அவ்வீட்டார்களுக்கு"}, {"w": 13, "t": "its inhabitants"}, {"w": 14, "t": "அதுதான்"}, {"w": 15, "t": "சிறந்தது"}, {"w": 16, "t": "உங்களுக்கு"}, {"w": 17, "t": "நீங்கள் நல்லறிவு பெறுவதற்காக"}, {"w": 18, "t": "pay heed"}, {"w": 19, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நீங்கள் காணவில்லையெனில்"}, {"w": 2, "t": "not"}, {"w": 3, "t": "you find"}, {"w": 4, "t": "அவற்றில்"}, {"w": 5, "t": "ஒருவரையும்"}, {"w": 6, "t": "அவற்றில் நீங்கள் நுழையாதீர்கள்"}, {"w": 7, "t": "enter it"}, {"w": 8, "t": "அனுமதி கொடுக்கப்படுகின்ற வரை"}, {"w": 9, "t": "permission has been given"}, {"w": 10, "t": "உங்களுக்கு"}, {"w": 11, "t": "சொல்லப்பட்டால்"}, {"w": 12, "t": "it is said"}, {"w": 13, "t": "உங்களுக்கு"}, {"w": 14, "t": "திரும்பி விடுங்கள்"}, {"w": 15, "t": "திரும்பி விடுங்கள்"}, {"w": 16, "t": "அது"}, {"w": 17, "t": "மிக சுத்தமானது"}, {"w": 18, "t": "உங்களுக்கு"}, {"w": 19, "t": "அல்லாஹ்"}, {"w": 20, "t": "நீங்கள் செய்வதை"}, {"w": 21, "t": "you do"}, {"w": 22, "t": "நன்கறிந்தவன்"}, {"w": 23, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "உங்கள் மீது இல்லை"}, {"w": 2, "t": "upon you"}, {"w": 3, "t": "குற்றம்"}, {"w": 4, "t": "நீங்கள் நுழைவது"}, {"w": 5, "t": "you enter"}, {"w": 6, "t": "வீடுகளில்"}, {"w": 7, "t": "வசிக்கப்படாத"}, {"w": 8, "t": "inhabited"}, {"w": 9, "t": "அவற்றில்"}, {"w": 10, "t": "பொருள்"}, {"w": 11, "t": "உங்களுக்கு"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "நன்கறிவான்"}, {"w": 14, "t": "நீங்கள்வெளிப்படுத்துவதை"}, {"w": 15, "t": "you reveal"}, {"w": 16, "t": "நீங்கள் மறைப்பதை"}, {"w": 17, "t": "you conceal"}, {"w": 18, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "கூறுங்கள்"}, {"w": 2, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 3, "t": "அவர்கள் தடுத்துக் கொள்ளட்டும்"}, {"w": 4, "t": "தங்கள் பார்வைகளை"}, {"w": 5, "t": "their gaze"}, {"w": 6, "t": "இன்னும் அவர்கள் பாதுகாத்துக் கொள்ளட்டும்"}, {"w": 7, "t": "தங்கள் மறைவிடங்களை"}, {"w": 8, "t": "அது"}, {"w": 9, "t": "மிக சுத்தமானது"}, {"w": 10, "t": "அவர்களுக்கு"}, {"w": 11, "t": "நிச்சயமாக"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "ஆழ்ந்தறிந்தவன்"}, {"w": 14, "t": "அவர்கள் செய்வதை"}, {"w": 15, "t": "they do"}, {"w": 16, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "கூறுங்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்ட பெண்களுக்கு"}, {"w": 3, "t": "அவர்கள் தடுத்துக் கொள்ளட்டும்"}, {"w": 4, "t": "பார்வைகளை"}, {"w": 5, "t": "பார்வைகளை தங்கள்"}, {"w": 6, "t": "இன்னும் அவர்கள் பாதுகாத்துக் கொள்ளட்டும்"}, {"w": 7, "t": "தங்கள் மறைவிடங்களை"}, {"w": 8, "t": "இன்னும் அவர்கள் வெளிப்படுத்த வேண்டாம்"}, {"w": 9, "t": "(to) display"}, {"w": 10, "t": "தங்கள் அலங்காரங்களை"}, {"w": 11, "t": "வெளியில் தெரிபவற்றை தவிர"}, {"w": 12, "t": "what"}, {"w": 13, "t": "is apparent"}, {"w": 14, "t": "அதிலிருந்து"}, {"w": 15, "t": "இன்னும் அவர்கள் போர்த்திக் கொள்ளட்டும்"}, {"w": 16, "t": "தங்கள் முந்தானைகளை"}, {"w": 17, "t": "தங்கள் நெஞ்சுப் பகுதிகள் மீது"}, {"w": 18, "t": "their bosoms"}, {"w": 19, "t": "இன்னும் அவர்கள் வெளிப்படுத்த வேண்டாம்"}, {"w": 20, "t": "(to) display"}, {"w": 21, "t": "தங்கள் அலங்காரங்களை"}, {"w": 22, "t": "தங்கள் கணவர்களுக்கு தவிர"}, {"w": 23, "t": "to their husbands"}, {"w": 24, "t": "அல்லது"}, {"w": 25, "t": "தங்கள்தந்தைகளுக்கு"}, {"w": 26, "t": "அல்லது"}, {"w": 27, "t": "தந்தைகளுக்கு"}, {"w": 28, "t": "தங்கள் கணவர்களின்"}, {"w": 29, "t": "அல்லது"}, {"w": 30, "t": "தங்கள் ஆண் பிள்ளைகளுக்கு"}, {"w": 31, "t": "அல்லது"}, {"w": 32, "t": "ஆண் பிள்ளைகளுக்கு"}, {"w": 33, "t": "தங்கள் கணவர்களின்"}, {"w": 34, "t": "அல்லது"}, {"w": 35, "t": "தங்கள் சகோதரர்களுக்கு"}, {"w": 36, "t": "அல்லது"}, {"w": 37, "t": "ஆண் பிள்ளைகளுக்கு"}, {"w": 38, "t": "தங்கள் சகோதரர்கள