{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "ஹா மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இறக்கப்பட்டது"}, {"w": 2, "t": "இந்த வேதம்"}, {"w": 3, "t": "அல்லாஹ்வின் புறத்தில் இருந்து"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "மிகைத்தவன்"}, {"w": 6, "t": "நன்கறிந்தவன்"}, {"w": 7, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "மன்னிப்பவன்"}, {"w": 2, "t": "பாவங்களை"}, {"w": 3, "t": "இன்னும் அங்கீகரிப்பவன்"}, {"w": 4, "t": "திருந்தி மன்னிப்புக் கோருவதை"}, {"w": 5, "t": "கடுமையானவன்"}, {"w": 6, "t": "தண்டிப்பதில்"}, {"w": 7, "t": "அருள் உடையவன்"}, {"w": 8, "t": "Owner (of) the abundance"}, {"w": 9, "t": "அறவே இல்லை"}, {"w": 10, "t": "வணக்கத்திற்குரியவன்"}, {"w": 11, "t": "அவனைத் தவிர"}, {"w": 12, "t": "Him"}, {"w": 13, "t": "அவன் பக்கமே"}, {"w": 14, "t": "மீளுமிடம்"}, {"w": 15, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "விவாதம் செய்ய மாட்டார்(கள்)"}, {"w": 2, "t": "dispute"}, {"w": 3, "t": "அத்தாட்சிகளில்"}, {"w": 4, "t": "(the) Verses"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "தவிர"}, {"w": 7, "t": "நிராகரித்தவர்களை"}, {"w": 8, "t": "disbelieve"}, {"w": 9, "t": "ஆகவே, உம்மை மயக்கிவிட வேண்டாம்"}, {"w": 10, "t": "deceive you"}, {"w": 11, "t": "அவர்கள் சுற்றித்திரிவது"}, {"w": 12, "t": "நகரங்களில்"}, {"w": 13, "t": "the cities"}, {"w": 14, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "பொய்ப்பித்தனர்"}, {"w": 2, "t": "இவர்களுக்கு முன்னர்"}, {"w": 3, "t": "மக்களும்"}, {"w": 4, "t": "நூஹூடைய"}, {"w": 5, "t": "இராணுவங்களும்"}, {"w": 6, "t": "அவர்களுக்குப் பின்னர்"}, {"w": 7, "t": "after them"}, {"w": 8, "t": "இன்னும் நாடினார்கள்"}, {"w": 9, "t": "எல்லா"}, {"w": 10, "t": "சமுதாயத்தினரும்"}, {"w": 11, "t": "தங்களது தூதரை"}, {"w": 12, "t": "அவரைதண்டிப்பதற்கு"}, {"w": 13, "t": "இன்னும் தர்க்கம் செய்தனர்"}, {"w": 14, "t": "அசத்தியத்தைக் கொண்டு"}, {"w": 15, "t": "அவர்கள் அழிப்பதற்காக"}, {"w": 16, "t": "அதன் மூலம்"}, {"w": 17, "t": "சத்தியத்தை"}, {"w": 18, "t": "ஆகவே, நான் அவர்களைப் பிடித்தேன்"}, {"w": 19, "t": "எப்படி?"}, {"w": 20, "t": "இருந்தது"}, {"w": 21, "t": "எனது தண்டனை"}, {"w": 22, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "உறுதியாகி விட்டது"}, {"w": 3, "t": "வாக்கு"}, {"w": 4, "t": "உமது இறைவனின்"}, {"w": 5, "t": "நிராகரித்தவர்கள் மீது"}, {"w": 6, "t": "those who"}, {"w": 7, "t": "disbelieved"}, {"w": 8, "t": "நிச்சயமாக அவர்கள்"}, {"w": 9, "t": "நரகவாசிகள்"}, {"w": 10, "t": "(of) the Fire"}, {"w": 11, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "சுமப்பவர்களும்"}, {"w": 2, "t": "bear"}, {"w": 3, "t": "அர்ஷை"}, {"w": 4, "t": "அதைச் சுற்றி இருப்பவர்களும்"}, {"w": 5, "t": "(are) around it"}, {"w": 6, "t": "துதிக்கின்றனர்"}, {"w": 7, "t": "புகழை"}, {"w": 8, "t": "தங்கள் இறைவனின்"}, {"w": 9, "t": "இன்னும் அவனை நம்பிக்கை கொள்கின்றனர்"}, {"w": 10, "t": "in Him"}, {"w": 11, "t": "இன்னும் பாவமன்னிப்புக் கோருகின்றனர்"}, {"w": 12, "t": "நம்பிக்கை கொண்டவர்களுக்காக"}, {"w": 13, "t": "believe"}, {"w": 14, "t": "எங்கள் இறைவா"}, {"w": 15, "t": "நீ விசாலமடைந்து இருக்கின்றாய்"}, {"w": 16, "t": "எல்லாவற்றையும்"}, {"w": 17, "t": "things"}, {"w": 18, "t": "கருணையாலும்"}, {"w": 19, "t": "இன்னும் கல்வியாலும்"}, {"w": 20, "t": "ஆகவே மன்னிப்பாயாக!"}, {"w": 21, "t": "திருந்தி மன்னிப்புக் கோரியவர்களை"}, {"w": 22, "t": "repent"}, {"w": 23, "t": "இன்னும் பின்பற்றினார்கள்"}, {"w": 24, "t": "உனது பாதையை"}, {"w": 25, "t": "இன்னும் அவர்களை பாதுகாப்பாயாக!"}, {"w": 26, "t": "வேதனையை விட்டு"}, {"w": 27, "t": "நரகத்தின்"}, {"w": 28, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "எங்கள் இறைவா!"}, {"w": 2, "t": "இன்னும் அவர்களை நுழைப்பாயாக!"}, {"w": 3, "t": "சொர்க்கங்களில்"}, {"w": 4, "t": "அத்ன்"}, {"w": 5, "t": "எதை/அவர்களுக்கு வாக்களித்திருக்கின்றாய்"}, {"w": 6, "t": "You have promised them"}, {"w": 7, "t": "நல்லவர்களாக இருந்தவர்களை"}, {"w": 8, "t": "(was) righteous"}, {"w": 9, "t": "அவர்களின் பெற்றோர்கள்"}, {"w": 10, "t": "their fathers"}, {"w": 11, "t": "அவர்களின் மனைவிகள்"}, {"w": 12, "t": "அவர்களின் சந்ததிகளில்"}, {"w": 13, "t": "நிச்சயமாக நீதான்"}, {"w": 14, "t": "You"}, {"w": 15, "t": "மிகைத்தவன்"}, {"w": 16, "t": "மகா ஞானவான்"}, {"w": 17, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் அவர்களை பாதுகாப்பாயாக!"}, {"w": 2, "t": "தீமைகளை விட்டு"}, {"w": 3, "t": "நீங்கள் எவரை பாதுகாப்பாயோ"}, {"w": 4, "t": "you protect"}, {"w": 5, "t": "தீமைகளை விட்டு"}, {"w": 6, "t": "அன்றைய தினம்"}, {"w": 7, "t": "திட்டமாக"}, {"w": 8, "t": "அவர் மீது நீ கருணை புரிந்துவிட்டாய்"}, {"w": 9, "t": "அதுதான்"}, {"w": 10, "t": "[it]"}, {"w": 11, "t": "வெற்றியாகும்"}, {"w": 12, "t": "மகத்தான"}, {"w": 13, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நிராகரிப்பவர்கள்"}, {"w": 3, "t": "disbelieved"}, {"w": 4, "t": "அழைக்கப்படுவார்கள்"}, {"w": 5, "t": "கோபிப்பது"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "மிகப் பெரியது"}, {"w": 8, "t": "நீங்கள் கோபிப்பதை விட"}, {"w": 9, "t": "your hatred"}, {"w": 10, "t": "உங்களை"}, {"w": 11, "t": "நீங்கள் அழைக்கப்பட்டபோது"}, {"w": 12, "t": "you were called"}, {"w": 13, "t": "நம்பிக்கை கொள்வதற்கு"}, {"w": 14, "t": "the faith"}, {"w": 15, "t": "நிராகரித்தீர்கள்"}, {"w": 16, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "எங்கள் இறைவா!"}, {"w": 3, "t": "நீ எங்களுக்கு மரணத்தைக் கொடுத்தாய்"}, {"w": 4, "t": "இருமுறை"}, {"w": 5, "t": "எங்களுக்கு வாழ்க்கையைக் கொடுத்தாய்"}, {"w": 6, "t": "இருமுறை"}, {"w": 7, "t": "நாங்கள் ஒப்புக் கொண்டோம்"}, {"w": 8, "t": "எங்கள் பாவங்களை"}, {"w": 9, "t": "வெளியேறுவதற்கு ஏதேனும் உண்டா?"}, {"w": 10, "t": "to"}, {"w": 11, "t": "get out"}, {"w": 12, "t": "வழி"}, {"w": 13, "t": "way"}, {"w": 14, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "ஏனென்றால் நிச்சயமாக"}, {"w": 3, "t": "அழைக்கப்பட்டால்"}, {"w": 4, "t": "Allah was invoked"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "அவன் ஒருவனை மட்டும்"}, {"w": 7, "t": "நீங்கள் நிராகரித்தீர்கள்"}, {"w": 8, "t": "இணை வைக்கப்பட்டால்"}, {"w": 9, "t": "(others) were associated"}, {"w": 10, "t": "அவனுக்கு"}, {"w": 11, "t": "நம்பிக்கை கொள்கிறீர்கள்"}, {"w": 12, "t": "எல்லா அதிகாரமும்"}, {"w": 13, "t": "அல்லாஹ்வுக்கே"}, {"w": 14, "t": "மிக உயர்ந்தவனும்"}, {"w": 15, "t": "மிகப் பெரியவனுமாகிய"}, {"w": 16, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "உங்களுக்கு காண்பிக்கின்றான்"}, {"w": 4, "t": "தனது அத்தாட்சிகளை"}, {"w": 5, "t": "இறக்குகின்றான்"}, {"w": 6, "t": "உங்களுக்கு"}, {"w": 7, "t": "வானத்திலிருந்து"}, {"w": 8, "t": "the sky"}, {"w": 9, "t": "உணவை"}, {"w": 10, "t": "நல்லுபதேசம் பெற மாட்டார்கள்"}, {"w": 11, "t": "take heed"}, {"w": 12, "t": "திரும்புகின்றவர்களைத் தவிர"}, {"w": 13, "t": "(one) who"}, {"w": 14, "t": "turns"}, {"w": 15, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "ஆகவே அழையுங்கள்"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "அவனுக்கு பரிசுத்தமாக்கியவர்களாக"}, {"w": 4, "t": "to Him"}, {"w": 5, "t": "வழிபாடுகளை"}, {"w": 6, "t": "வெறுத்தாலும் சரியே!"}, {"w": 7, "t": "dislike (it)"}, {"w": 8, "t": "நிராகரிப்பவர்கள்"}, {"w": 9, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "உயர்த்தக்கூடியவன்"}, {"w": 2, "t": "அந்தஸ்துகளை"}, {"w": 3, "t": "அர்ஷுடையவன்"}, {"w": 4, "t": "Owner (of) the Throne"}, {"w": 5, "t": "இறக்கினான்"}, {"w": 6, "t": "வஹ்யை"}, {"w": 7, "t": "தனது கட்டளையை உள்ளடக்கிய"}, {"w": 8, "t": "His Command"}, {"w": 9, "t": "தான் நாடியவர் மீது"}, {"w": 10, "t": "whom"}, {"w": 11, "t": "He wills"}, {"w": 12, "t": "தனது அடியார்களில்"}, {"w": 13, "t": "His slaves"}, {"w": 14, "t": "அவர்எச்சரிப்பதற்காக"}, {"w": 15, "t": "சந்திக்கின்ற நாளைப் பற்றி"}, {"w": 16, "t": "(of) the Meeting"}, {"w": 17, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "நாளை(ப் பற்றி)"}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "வெளிப்பட்டு நிற்பார்கள்"}, {"w": 4, "t": "மறைந்துவிடாது"}, {"w": 5, "t": "is hidden"}, {"w": 6, "t": "முன்னால்"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "அவர்களில்"}, {"w": 9, "t": "எதுவும்"}, {"w": 10, "t": "யாருக்கு உரியது?"}, {"w": 11, "t": "ஆட்சி"}, {"w": 12, "t": "இன்று"}, {"w": 13, "t": "அல்லாஹ்விற்கே உரியது"}, {"w": 14, "t": "ஒருவனும்/அடக்கி ஆள்பவனுமாகிய"}, {"w": 15, "t": "the Irresistible"}, {"w": 16, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இன்று"}, {"w": 2, "t": "கூலி கொடுக்கப்படும்"}, {"w": 3, "t": "எல்லா"}, {"w": 4, "t": "ஆன்மாவுக்கும்"}, {"w": 5, "t": "அவைசெய்தவற்றுக்கு"}, {"w": 6, "t": "it earned"}, {"w": 7, "t": "எவ்வித அநியாயமும் இருக்காது"}, {"w": 8, "t": "injustice"}, {"w": 9, "t": "இன்று"}, {"w": 10, "t": "நிச்சயமாக"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "மிக விரைவானவன்"}, {"w": 13, "t": "விசாரிப்பதில்"}, {"w": 14, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவர்களை நீர் எச்சரிப்பீராக!"}, {"w": 2, "t": "நெருங்கி வரக்கூடிய நாளைப் பற்றி"}, {"w": 3, "t": "the Approaching"}, {"w": 4, "t": "போது/உள்ளங்கள்"}, {"w": 5, "t": "the hearts"}, {"w": 6, "t": "தொண்டைகளுக்கு அருகில்"}, {"w": 7, "t": "the throats"}, {"w": 8, "t": "துக்கம் நிறைந்தவர்களாக"}, {"w": 9, "t": "அந்த அநியாயக்காரர்களுக்கு இருக்கமாட்டார்"}, {"w": 10, "t": "for the wrongdoers"}, {"w": 11, "t": "நண்பர் எவரும்"}, {"w": 12, "t": "intimate friend"}, {"w": 13, "t": "இன்னும் ஒரு பரிந்துரையாளரும் இருக்க மாட்டார்"}, {"w": 14, "t": "intercessor"}, {"w": 15, "t": "ஏற்றுக்கொள்ளப்படுகின்றார்"}, {"w": 16, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவன் நன்கறிவான்"}, {"w": 2, "t": "மோசடிகளையும்"}, {"w": 3, "t": "கண்களின்"}, {"w": 4, "t": "மறைப்பதையும்"}, {"w": 5, "t": "conceal"}, {"w": 6, "t": "நெஞ்சங்கள்"}, {"w": 7, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "தீர்ப்பளிக்கின்றான்"}, {"w": 3, "t": "உண்மையைத்தான்"}, {"w": 4, "t": "எவர்களை"}, {"w": 5, "t": "அவர்கள் அழைக்கின்றார்களோ"}, {"w": 6, "t": "அவனையன்றி"}, {"w": 7, "t": "besides Him"}, {"w": 8, "t": "அவர்கள் தீர்ப்பளிக்க மாட்டார்கள்"}, {"w": 9, "t": "they judge"}, {"w": 10, "t": "எதையும்"}, {"w": 11, "t": "நிச்சயமாக"}, {"w": 12, "t": "அல்லாஹ்தான்"}, {"w": 13, "t": "He"}, {"w": 14, "t": "நன்கு செவிமடுப்பவன்"}, {"w": 15, "t": "உற்று நோக்குபவன்"}, {"w": 16, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அவர்கள் சுற்றுப் பயணம் செய்யவி்ல்லையா?"}, {"w": 2, "t": "they travel"}, {"w": 3, "t": "பூமியில்"}, {"w": 4, "t": "the earth"}, {"w": 5, "t": "பார்த்திருப்பார்களே!"}, {"w": 6, "t": "எப்படி இருந்தது"}, {"w": 7, "t": "was"}, {"w": 8, "t": "முடிவு"}, {"w": 9, "t": "தங்களுக்கு முன்னுள்ளவர்களின்"}, {"w": 10, "t": "were"}, {"w": 11, "t": "before them"}, {"w": 12, "t": "before them"}, {"w": 13, "t": "இருந்தார்கள்"}, {"w": 14, "t": "அவர்கள்"}, {"w": 15, "t": "மிகபலசாலிகளாகவும்"}, {"w": 16, "t": "இவர்களை விட"}, {"w": 17, "t": "(உடல்) வலிமையால்"}, {"w": 18, "t": "இன்னும் அடையாளங்களால்"}, {"w": 19, "t": "பூமியில்"}, {"w": 20, "t": "the land"}, {"w": 21, "t": "தண்டித்தான் அவர்களை"}, {"w": 22, "t": "அல்லாஹ்"}, {"w": 23, "t": "அவர்களின் பாவங்களினால்"}, {"w": 24, "t": "இருக்கவில்லை"}, {"w": 25, "t": "was"}, {"w": 26, "t": "அவர்களை"}, {"w": 27, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 28, "t": "Allah"}, {"w": 29, "t": "பாதுகாப்பவர் எவரும்"}, {"w": 30, "t": "protector"}, {"w": 31, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "அதற்கு காரணம் நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "(was) because [they]"}, {"w": 3, "t": "அவர்களிடம் வந்து கொண்டிருந்தார்கள்"}, {"w": 4, "t": "used to come to them"}, {"w": 5, "t": "அவர்களின் தூதர்கள்"}, {"w": 6, "t": "தெளிவான அத்தாட்சிகளுடன்"}, {"w": 7, "t": "ஆனால், அவர்கள் நிராகரித்தார்கள்"}, {"w": 8, "t": "ஆகவே தண்டித்தான் அவர்களை"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "நிச்சயமாக அவன்"}, {"w": 11, "t": "வலிமை மிக்கவன்"}, {"w": 12, "t": "தண்டிப்பதில் கடுமையானவன்"}, {"w": 13, "t": "(in) punishment"}, {"w": 14, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அனுப்பினோம்"}, {"w": 3, "t": "மூஸாவை"}, {"w": 4, "t": "நமது அத்தாட்சிகளுடன்"}, {"w": 5, "t": "இன்னும் ஆதாரத்துடன்"}, {"w": 6, "t": "தெளிவான"}, {"w": 7, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "ஃபிர்அவ்னிடம்"}, {"w": 2, "t": "Firaun"}, {"w": 3, "t": "இன்னும் ஹாமான்"}, {"w": 4, "t": "இன்னும் காரூன்"}, {"w": 5, "t": "அவர்கள் கூறினார்கள்"}, {"w": 6, "t": "சூனியக்காரர்"}, {"w": 7, "t": "பொய்யர்"}, {"w": 8, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவர் வந்த போது"}, {"w": 2, "t": "அவர்களிடம்"}, {"w": 3, "t": "சத்தியத்தைக்கொண்டு"}, {"w": 4, "t": "நம்மிடமிருந்து"}, {"w": 5, "t": "Us"}, {"w": 6, "t": "அவர்கள் கூறினார்கள்"}, {"w": 7, "t": "கொன்று விடுங்கள்!"}, {"w": 8, "t": "ஆண் பிள்ளைகளை"}, {"w": 9, "t": "நம்பிக்கை கொண்டவர்களின்"}, {"w": 10, "t": "believe"}, {"w": 11, "t": "இவருடன்"}, {"w": 12, "t": "இன்னும் வாழவிடுங்கள்!"}, {"w": 13, "t": "பெண்களை அவர்களின்"}, {"w": 14, "t": "சூழ்ச்சி இல்லை"}, {"w": 15, "t": "(is the) plot"}, {"w": 16, "t": "நிராகரிப்பவர்களின்"}, {"w": 17, "t": "தவிர"}, {"w": 18, "t": "வழிகேட்டில்"}, {"w": 19, "t": "error"}, {"w": 20, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "ஃபிர்அவ்ன்"}, {"w": 3, "t": "என்னை விடுங்கள்"}, {"w": 4, "t": "கொன்று விடுகிறேன்"}, {"w": 5, "t": "மூஸாவை"}, {"w": 6, "t": "அவர் அழைக்கட்டும்"}, {"w": 7, "t": "தன் இறைவனை"}, {"w": 8, "t": "நிச்சயமாக நான்"}, {"w": 9, "t": "பயப்படுகிறேன்"}, {"w": 10, "t": "அவர் மாற்றிவிடுவார் என்று"}, {"w": 11, "t": "he will change"}, {"w": 12, "t": "உங்கள் மார்க்கத்தை"}, {"w": 13, "t": "அல்லது"}, {"w": 14, "t": "உருவாக்கி விடுவார் என்று"}, {"w": 15, "t": "he may cause to appear"}, {"w": 16, "t": "இந்த பூமியில்"}, {"w": 17, "t": "the land"}, {"w": 18, "t": "குழப்பத்தை"}, {"w": 19, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "மூஸா"}, {"w": 3, "t": "நிச்சயமாக நான்"}, {"w": 4, "t": "பாதுகாவல் தேடுகிறேன்"}, {"w": 5, "t": "எனது இறைவனிடம்"}, {"w": 6, "t": "இன்னும் உங்கள் இறைவனிடம்"}, {"w": 7, "t": "எல்லோரை விட்டும்"}, {"w": 8, "t": "every"}, {"w": 9, "t": "பெருமை அடிக்கின்றவன்"}, {"w": 10, "t": "நம்பிக்கைகொள்ள மாட்டான்"}, {"w": 11, "t": "who believes"}, {"w": 12, "t": "விசாரணை நாளை"}, {"w": 13, "t": "(of) the Account"}, {"w": 14, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "ஓர் ஆடவர்"}, {"w": 3, "t": "நம்பிக்கைகொண்டவர்"}, {"w": 4, "t": "குடும்பத்தாரில்"}, {"w": 5, "t": "(the) family"}, {"w": 6, "t": "ஃபிர்அவ்னுடைய"}, {"w": 7, "t": "மறைத்தவராக"}, {"w": 8, "t": "தனது நம்பிக்கையை"}, {"w": 9, "t": "நீங்கள்கொல்கின்றீர்களா?"}, {"w": 10, "t": "ஒரு மனிதரை"}, {"w": 11, "t": "கூறியதற்காக"}, {"w": 12, "t": "he says"}, {"w": 13, "t": "என் இறைவன் என்று"}, {"w": 14, "t": "அல்லாஹ்தான்"}, {"w": 15, "t": "திட்டமாக"}, {"w": 16, "t": "அவர் கொண்டு வந்திருக்கிறார் உங்களுக்கு"}, {"w": 17, "t": "தெளிவான அத்தாட்சிகளை"}, {"w": 18, "t": "உங்கள் இறைவனிடமிருந்து"}, {"w": 19, "t": "your Lord"}, {"w": 20, "t": "அவர் இருந்தால்"}, {"w": 21, "t": "he is"}, {"w": 22, "t": "பொய்யராக"}, {"w": 23, "t": "அவருக்குத்தான் கேடாக அமையும்"}, {"w": 24, "t": "அவருடைய பொய்"}, {"w": 25, "t": "அவர் இருந்தால்"}, {"w": 26, "t": "he is"}, {"w": 27, "t": "உண்மையாளராக"}, {"w": 28, "t": "உங்களைவந்தடையும்"}, {"w": 29, "t": "சில"}, {"w": 30, "t": "அவர் எச்சரிப்பதில்"}, {"w": 31, "t": "அவர் எச்சரிப்பதில் உங்களை"}, {"w": 32, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 33, "t": "Allah"}, {"w": 34, "t": "நேர்வழி செலுத்தமாட்டான்/எவரை/அவர்"}, {"w": 35, "t": "guide"}, {"w": 36, "t": "(one) who"}, {"w": 37, "t": "[he]"}, {"w": 38, "t": "வரம்புமீறுபவராக(வும்)"}, {"w": 39, "t": "பெரும் பொய்யராக(வும்)"}, {"w": 40, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "எனது மக்களே!"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "ஆட்சி"}, {"w": 4, "t": "இன்றைய தினம்"}, {"w": 5, "t": "நீங்கள் மிகைத்திருக்கிறீர்கள்"}, {"w": 6, "t": "பூமியில்"}, {"w": 7, "t": "the land"}, {"w": 8, "t": "யார்?"}, {"w": 9, "t": "நமக்கு உதவுவார்"}, {"w": 10, "t": "தண்டனையில்இருந்து"}, {"w": 11, "t": "(the) punishment"}, {"w": 12, "t": "அல்லாஹ்வின்"}, {"w": 13, "t": "நம்மிடம்அதுவந்தால்"}, {"w": 14, "t": "it came to us"}, {"w": 15, "t": "ஃபிர்அவ்ன் கூறினான்"}, {"w": 16, "t": "Firaun"}, {"w": 17, "t": "உங்களுக்கு நான் காண்பிக்க மாட்டேன்"}, {"w": 18, "t": "I show you"}, {"w": 19, "t": "தவிர"}, {"w": 20, "t": "நான் கருதுவதையே"}, {"w": 21, "t": "I see"}, {"w": 22, "t": "உங்களுக்கு நான் வழிகாட்ட மாட்டேன்"}, {"w": 23, "t": "I guide you"}, {"w": 24, "t": "பாதையைத் தவிர"}, {"w": 25, "t": "(to the) path"}, {"w": 26, "t": "நேரான"}, {"w": 27, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்"}, {"w": 3, "t": "believed"}, {"w": 4, "t": "என் மக்களே!"}, {"w": 5, "t": "நிச்சயமாக நான்"}, {"w": 6, "t": "பயப்படுகிறேன்"}, {"w": 7, "t": "உங்கள் மீது"}, {"w": 8, "t": "போன்றதை"}, {"w": 9, "t": "நாளை"}, {"w": 10, "t": "ராணுவங்களின்"}, {"w": 11, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "போன்று"}, {"w": 2, "t": "வழமையான வேதனையை"}, {"w": 3, "t": "மக்கள்"}, {"w": 4, "t": "நூஹூடைய"}, {"w": 5, "t": "இன்னும் ஆது"}, {"w": 6, "t": "இன்னும் ஸமூது"}, {"w": 7, "t": "இன்னும் அவர்களுக்குப் பின்னர் வந்தவர்களுக்கு ஏற்பட்ட"}, {"w": 8, "t": "after them"}, {"w": 9, "t": "after them"}, {"w": 10, "t": "அல்லாஹ் இல்லை"}, {"w": 11, "t": "And Allah (does) not"}, {"w": 12, "t": "நாடுகின்றவனாக"}, {"w": 13, "t": "அநியாயத்தை"}, {"w": 14, "t": "அடியார்களுக்கு"}, {"w": 15, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "என் மக்களே"}, {"w": 2, "t": "நிச்சயமாக பயப்படுகிறேன்"}, {"w": 3, "t": "[I] fear"}, {"w": 4, "t": "உங்கள் மீது"}, {"w": 5, "t": "கூவி அழைக்கின்ற நாளை"}, {"w": 6, "t": "(of) Calling"}, {"w": 7, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "நீங்கள் திரும்புகின்றீர்கள்"}, {"w": 3, "t": "புறமுதுகிட்டவர்களாக"}, {"w": 4, "t": "உங்களுக்கு இருக்க மாட்டார்"}, {"w": 5, "t": "for you"}, {"w": 6, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "எவரும்/ பாதுகாக்கக்கூடியவர்"}, {"w": 9, "t": "protector"}, {"w": 10, "t": "எவரை"}, {"w": 11, "t": "வழிகெடுத்தானோ"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "அவருக்கு இல்லை"}, {"w": 14, "t": "for him"}, {"w": 15, "t": "நேர்வழி காட்டுபவர் யாரும்"}, {"w": 16, "t": "guide"}, {"w": 17, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "உங்களிடம் வந்தார்"}, {"w": 3, "t": "யூஸுஃப்"}, {"w": 4, "t": "இதற்கு முன்னர்"}, {"w": 5, "t": "before"}, {"w": 6, "t": "தெளிவான அத்தாட்சிகளுடன்"}, {"w": 7, "t": "ஆனால், நீங்கள் சந்தேகத்தில்தான் தொடர்ந்து இருந்தீர்கள்"}, {"w": 8, "t": "you ceased"}, {"w": 9, "t": "in"}, {"w": 10, "t": "doubt"}, {"w": 11, "t": "எதில்"}, {"w": 12, "t": "உங்களிடம் வந்தார்"}, {"w": 13, "t": "அதைக் கொண்டு"}, {"w": 14, "t": "இறுதியாக"}, {"w": 15, "t": "அவர் இறந்துவிட்ட போது"}, {"w": 16, "t": "he died"}, {"w": 17, "t": "கூறினீர்கள்"}, {"w": 18, "t": "அனுப்பவே மாட்டான்"}, {"w": 19, "t": "will Allah raise"}, {"w": 20, "t": "அல்லாஹ்"}, {"w": 21, "t": "அவருக்குப் பின்னர்"}, {"w": 22, "t": "after him"}, {"w": 23, "t": "ஒரு தூதரை"}, {"w": 24, "t": "இவ்வாறுதான்"}, {"w": 25, "t": "வழிகெடுப்பான்"}, {"w": 26, "t": "அல்லாஹ்/எவர்/அவர்/ வரம்புமீறுபவராக(வும்)"}, {"w": 27, "t": "who"}, {"w": 28, "t": "[he]"}, {"w": 29, "t": "(is) a transgressor"}, {"w": 30, "t": "சந்தேகம் கொள்பவராக(வும்)"}, {"w": 31, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "எவர்கள்/தர்க்கம் செய்கின்றார்கள்"}, {"w": 2, "t": "dispute"}, {"w": 3, "t": "அத்தாட்சிகளில்"}, {"w": 4, "t": "(the) Signs"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "எவ்வித ஆதாரமின்றி"}, {"w": 7, "t": "any authority"}, {"w": 8, "t": "தங்களிடம் வந்த(து)"}, {"w": 9, "t": "மிகப் பெரிய(து)"}, {"w": 10, "t": "கோபத்திற்குரியது"}, {"w": 11, "t": "அல்லாஹ்விட(மு)ம்"}, {"w": 12, "t": "near Allah"}, {"w": 13, "t": "நம்பிக்கையாளர்களிடமும்"}, {"w": 14, "t": "those"}, {"w": 15, "t": "who believe"}, {"w": 16, "t": "இவ்வாறுதான்"}, {"w": 17, "t": "முத்திரையிடுகிறான்"}, {"w": 18, "t": "அல்லாஹ்"}, {"w": 19, "t": "எல்லோருடைய உள்ளத்திலும்"}, {"w": 20, "t": "every"}, {"w": 21, "t": "heart"}, {"w": 22, "t": "பெருமை அடிக்கின்றவர்கள்"}, {"w": 23, "t": "அநியாயக்காரர்கள்"}, {"w": 24, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "ஃபிர்அவ்ன்"}, {"w": 3, "t": "ஹாமானே!"}, {"w": 4, "t": "கட்டு"}, {"w": 5, "t": "எனக்காக"}, {"w": 6, "t": "ஒரு கோபுரத்தை"}, {"w": 7, "t": "நான் ஏற வேண்டும்"}, {"w": 8, "t": "reach"}, {"w": 9, "t": "வாசல்களில்"}, {"w": 10, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "வாசல்களில்"}, {"w": 2, "t": "வானங்களின்"}, {"w": 3, "t": "நான் எட்டிப்பார்க்க வேண்டும்"}, {"w": 4, "t": "கடவுளை"}, {"w": 5, "t": "(the) God"}, {"w": 6, "t": "மூஸாவின்"}, {"w": 7, "t": "நிச்சயமாக நான்"}, {"w": 8, "t": "அவரைக்கருதுகிறேன்"}, {"w": 9, "t": "பொய்யராகவே"}, {"w": 10, "t": "இவ்வாறுதான்"}, {"w": 11, "t": "அலங்காரமாக்கப் பட்டது"}, {"w": 12, "t": "ஃபிர்அவ்னுக்கு"}, {"w": 13, "t": "தீய/அவனது செயல்"}, {"w": 14, "t": "(of) his deed"}, {"w": 15, "t": "இன்னும் அவன் தடுக்கப்பட்டான்"}, {"w": 16, "t": "நேரான பாதையை விட்டு"}, {"w": 17, "t": "the way"}, {"w": 18, "t": "சூழ்ச்சி இல்லை"}, {"w": 19, "t": "(was the) plot"}, {"w": 20, "t": "ஃபிர்அவ்னின்"}, {"w": 21, "t": "தவிர"}, {"w": 22, "t": "அழிவில்"}, {"w": 23, "t": "ruin"}, {"w": 24, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்"}, {"w": 3, "t": "believed"}, {"w": 4, "t": "என் மக்களே!"}, {"w": 5, "t": "என்னை பின்பற்றுங்கள்!"}, {"w": 6, "t": "நான் உங்களுக்கு வழி காட்டுகிறேன்"}, {"w": 7, "t": "பாதையை"}, {"w": 8, "t": "நேரான"}, {"w": 9, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "என் மக்களே!"}, {"w": 2, "t": "இந்த வாழ்க்கை எல்லாம்"}, {"w": 3, "t": "this"}, {"w": 4, "t": "the life"}, {"w": 5, "t": "உலக"}, {"w": 6, "t": "அற்ப இன்பம்தான்"}, {"w": 7, "t": "இன்னும் நிச்சயமாக"}, {"w": 8, "t": "மறுமைதான்"}, {"w": 9, "t": "it"}, {"w": 10, "t": "நிரந்தரமான இல்லம்"}, {"w": 11, "t": "(of) settlement"}, {"w": 12, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "யார் செய்வாரோ"}, {"w": 2, "t": "does"}, {"w": 3, "t": "ஒரு தீமையை"}, {"w": 4, "t": "அவர் கூலி கொடுக்கப்பட மாட்டார்"}, {"w": 5, "t": "he will be recompensed"}, {"w": 6, "t": "தவிர"}, {"w": 7, "t": "அது போன்றதே"}, {"w": 8, "t": "யார் ஒருவர்"}, {"w": 9, "t": "செய்வாரோ"}, {"w": 10, "t": "நன்மையை"}, {"w": 11, "t": "இல்/ஆண்(கள்)"}, {"w": 12, "t": "male"}, {"w": 13, "t": "அல்லது"}, {"w": 14, "t": "பெண்(கள்)"}, {"w": 15, "