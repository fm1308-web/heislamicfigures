{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "போது"}, {"w": 2, "t": "சூரியன்"}, {"w": 3, "t": "மங்க வைக்கப்படும்"}, {"w": 4, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "நட்சத்திரங்கள்"}, {"w": 3, "t": "உதிர்ந்துவிடும்"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "மலைகள்"}, {"w": 3, "t": "அகற்றப்படும்"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் போது/நிறைமாத ஒட்டகங்கள்"}, {"w": 2, "t": "the full-term she-camels"}, {"w": 3, "t": "கவனிப்பற்று விடப்படும்"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "காட்டு மிருகங்கள்"}, {"w": 3, "t": "ஒன்று சேர்க்கப்படும்"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "கடல்கள்"}, {"w": 3, "t": "தீ மூட்டப்படும்"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "உயிர்கள்"}, {"w": 3, "t": "இணைக்கப்படும்"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் போது/ புதைக்கப்பட்ட பெண் குழந்தை"}, {"w": 2, "t": "the female infant buried alive"}, {"w": 3, "t": "விசாரிக்கப்படும்"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "எந்தக் குற்றத்திற்காக"}, {"w": 2, "t": "sin"}, {"w": 3, "t": "கொல்லப்பட்டாள்"}, {"w": 4, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "ஏடுகள்"}, {"w": 3, "t": "விரிக்கப்படும்"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "வானம்"}, {"w": 3, "t": "அகற்றப்படும்"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "நரகம்"}, {"w": 3, "t": "கடுமையாக எரிக்கப்படும்"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "சொர்க்கம்"}, {"w": 3, "t": "சமீபமாக்கப்படும்"}, {"w": 4, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அறியும்"}, {"w": 2, "t": "ஓர் ஆன்மா"}, {"w": 3, "t": "எதை/தான் கொண்டு வந்தது"}, {"w": 4, "t": "it has brought"}, {"w": 5, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "சத்தியம் செய்கிறேன்!"}, {"w": 2, "t": "I swear"}, {"w": 3, "t": "மறைகின்ற நட்சத்திரங்கள் மீது"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "வேகமாகச் செல்கின்ற நட்சத்திரங்கள்"}, {"w": 2, "t": "தோன்றுகின்ற"}, {"w": 3, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இரவின் மீது சத்தியமாக"}, {"w": 2, "t": "பின்செல்லும் போது"}, {"w": 3, "t": "it departs"}, {"w": 4, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "காலைப் பொழுதின் மீது சத்தியமாக"}, {"w": 2, "t": "அது தெளிவாகிவிடும் போது"}, {"w": 3, "t": "it breathes"}, {"w": 4, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நிச்சயாக இது"}, {"w": 2, "t": "கூற்றாகும்"}, {"w": 3, "t": "தூதர்"}, {"w": 4, "t": "கண்ணியத்திற்குரியவர்"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "பலமுடையவர்"}, {"w": 2, "t": "power"}, {"w": 3, "t": "அர்ஷுடையவனிடம்"}, {"w": 4, "t": "(the) Owner of"}, {"w": 5, "t": "the Throne"}, {"w": 6, "t": "பதவியாளர்"}, {"w": 7, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "கீழ்ப்படியப்படுகிறவர்"}, {"w": 2, "t": "அங்கு"}, {"w": 3, "t": "நம்பிக்கைக்குரியவர்"}, {"w": 4, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "இன்னும் உங்கள் தோழர் இல்லை"}, {"w": 2, "t": "(is) your companion"}, {"w": 3, "t": "பைத்தியக்காரராக"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "இன்னும் திட்டவட்டமாக"}, {"w": 2, "t": "அவர் அவரைக் கண்டார்"}, {"w": 3, "t": "கோடியில்"}, {"w": 4, "t": "தெளிவான"}, {"w": 5, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "இன்னும் அவர் இல்லை"}, {"w": 2, "t": "he (is)"}, {"w": 3, "t": "மறைவானவற்றில்"}, {"w": 4, "t": "the unseen"}, {"w": 5, "t": "கஞ்சனாக"}, {"w": 6, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இன்னும் அது இல்லை"}, {"w": 2, "t": "it"}, {"w": 3, "t": "கூற்றாக"}, {"w": 4, "t": "ஷைத்தானின்"}, {"w": 5, "t": "எறியப்பட்ட"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "ஆகவே எங்கே?"}, {"w": 2, "t": "நீங்கள் செல்கிறீர்கள்"}, {"w": 3, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அது இல்லை"}, {"w": 2, "t": "it"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "ஓர் அறிவுரையாகவே"}, {"w": 5, "t": "அகிலத்தார்களுக்கு"}, {"w": 6, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நாடியவருக்கு"}, {"w": 2, "t": "wills"}, {"w": 3, "t": "உங்களில்"}, {"w": 4, "t": "நேர்வழி நடக்க"}, {"w": 5, "t": "take a straight way"}, {"w": 6, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "இன்னும் நாடமாட்டீர்கள்"}, {"w": 2, "t": "you will"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "நாடினால்"}, {"w": 5, "t": "wills"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "இறைவனான"}, {"w": 8, "t": "அகிலத்தார்களின்"}, {"w": 9, "t": "(29)"}]}]}