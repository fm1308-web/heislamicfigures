{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "போர்வை போர்த்தியவரே!"}, {"w": 2, "t": "who covers himself"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "எழுவீராக!"}, {"w": 2, "t": "எச்சரிப்பீராக!"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் உமது இறைவனை"}, {"w": 2, "t": "பெருமைப்படுத்துவீராக!"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் உமது ஆடையை"}, {"w": 2, "t": "சுத்தப்படுத்துவீராக!"}, {"w": 3, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "சிலைகளை"}, {"w": 2, "t": "விட்டு விலகுவீராக!"}, {"w": 3, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "சொல்லிக் காண்பிக்காதீர்!"}, {"w": 2, "t": "confer favor"}, {"w": 3, "t": "நீர் பெரிதாக கருதி(யவராக)"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் உமது இறைவனுக்காக"}, {"w": 2, "t": "நீர் பொறுமையாக இருப்பீராக!"}, {"w": 3, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஊதப்பட்டால்"}, {"w": 2, "t": "is blown"}, {"w": 3, "t": "எக்காளத்தில்"}, {"w": 4, "t": "the trumpet"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அது"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "ஒரு நாள்"}, {"w": 4, "t": "மிக சிரமமான"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 2, "t": "the disbelievers "}, {"w": 3, "t": "இலகுவானதல்ல"}, {"w": 4, "t": "easy"}, {"w": 5, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "என்னை(யும்) விட்டு விடுவீராக!/இன்னும் எவனை"}, {"w": 2, "t": "and whom"}, {"w": 3, "t": "படைத்தேனோ"}, {"w": 4, "t": "தனியாக"}, {"w": 5, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் ஏற்படுத்திக் கொடுத்தேன் / அவனுக்கு"}, {"w": 2, "t": "to him"}, {"w": 3, "t": "செல்வத்தை"}, {"w": 4, "t": "விசாலமான"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இன்னும் ஆண் பிள்ளைகளை"}, {"w": 2, "t": "ஆஜராகி இருக்கக் கூடிய(வர்கள்)"}, {"w": 3, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் வசதிகளை ஏற்படுத்தினோம்"}, {"w": 2, "t": "அவனுக்கு"}, {"w": 3, "t": "மிகுந்த வசதிகளை"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "ஆசைப்படுகின்றான்"}, {"w": 3, "t": "நான் அதிகப்படுத்த வேண்டுமென்று"}, {"w": 4, "t": "I (should) add more"}, {"w": 5, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "நிச்சயமாக அவன்"}, {"w": 3, "t": "இருந்தான்"}, {"w": 4, "t": "நமது வசனங்களுக்கு"}, {"w": 5, "t": "முரண்படக்கூடியவனாக"}, {"w": 6, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "விரைவில் நிர்ப்பந்தித்து விடுவேன்"}, {"w": 2, "t": "மிகப் பெரிய சிரமத்திற்கு"}, {"w": 3, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நிச்சயமாக அவன்"}, {"w": 2, "t": "யோசித்தான்"}, {"w": 3, "t": "இன்னும் திட்டமிட்டான்"}, {"w": 4, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவன் அழியட்டும்"}, {"w": 2, "t": "எப்படி"}, {"w": 3, "t": "திட்டமிட்டான்"}, {"w": 4, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "அவன் அழியட்டும்"}, {"w": 3, "t": "எப்படி"}, {"w": 4, "t": "திட்டமிட்டான்"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "தாமதித்தான்"}, {"w": 3, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "முகம் சுளித்தான்"}, {"w": 3, "t": "இன்னும் கடுகடுத்தான்"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "புறக்கணித்தான்"}, {"w": 3, "t": "இன்னும் பெருமையடித்தான்"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவன் கூறினான்"}, {"w": 2, "t": "இது இல்லை"}, {"w": 3, "t": "(is) this"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "சூனியமே"}, {"w": 6, "t": "கற்றுக்கொள்ளப்பட்ட"}, {"w": 7, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இது இல்லை"}, {"w": 2, "t": "(is) this"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "சொல்லே"}, {"w": 5, "t": "மனிதர்களின்"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "நான் விரைவில் பொசுக்குவேன்/அவனை/சகர்"}, {"w": 2, "t": "(into) Hell"}, {"w": 3, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "உமக்குத் தெரியுமா?"}, {"w": 2, "t": "can make you know"}, {"w": 3, "t": "சகர் என்றால் என்ன"}, {"w": 4, "t": "(is) Hell"}, {"w": 5, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "வாழவைக்காது"}, {"w": 2, "t": "it lets remain"}, {"w": 3, "t": "இன்னும் விட்டுவிடாது"}, {"w": 4, "t": "it leaves"}, {"w": 5, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "கரித்துவிடும்"}, {"w": 2, "t": "தோல்களை"}, {"w": 3, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "அதன் மீது"}, {"w": 2, "t": "பத்தொன்பது வானவர்கள்"}, {"w": 3, "t": "teen"}, {"w": 4, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நாம் ஆக்கவில்லை"}, {"w": 2, "t": "We have made"}, {"w": 3, "t": "நரகத்தின் காவலாளிகளை"}, {"w": 4, "t": "(of) the Fire"}, {"w": 5, "t": "தவிர/வானவர்களாக"}, {"w": 6, "t": "Angels"}, {"w": 7, "t": "இன்னும் நாம் ஆக்கவில்லை"}, {"w": 8, "t": "We have made"}, {"w": 9, "t": "அவர்களின் எண்ணிக்கையை"}, {"w": 10, "t": "தவிர"}, {"w": 11, "t": "ஒரு குழப்பமாகவே"}, {"w": 12, "t": "நிராகரித்தவர்களுக்கு"}, {"w": 13, "t": "disbelieve "}, {"w": 14, "t": "உறுதி கொள்ளவேண்டும் என்பதற்காக(வும்)"}, {"w": 15, "t": "வேதம் கொடுக்கப்பட்டவர்கள்"}, {"w": 16, "t": "were given"}, {"w": 17, "t": "the Scripture"}, {"w": 18, "t": "அதிகரிப்பதற்காகவும்"}, {"w": 19, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 20, "t": "believe"}, {"w": 21, "t": "நம்பிக்கையால்"}, {"w": 22, "t": "சந்தேகிக்காமல் இருப்பதற்காகவும்"}, {"w": 23, "t": "may doubt"}, {"w": 24, "t": "வேதம் கொடுக்கப்பட்டவர்களும்"}, {"w": 25, "t": "were given"}, {"w": 26, "t": "the Scripture"}, {"w": 27, "t": "நம்பிக்கையாளர்களும்"}, {"w": 28, "t": "கூறுவதற்காகவும்"}, {"w": 29, "t": "எவர்கள்"}, {"w": 30, "t": "தங்கள் உள்ளங்களில்"}, {"w": 31, "t": "their hearts"}, {"w": 32, "t": "நோய்"}, {"w": 33, "t": "நிராகரிப்பாளர்களும்"}, {"w": 34, "t": "என்ன"}, {"w": 35, "t": "நாடுகின்றான்"}, {"w": 36, "t": "அல்லாஹ்"}, {"w": 37, "t": "இதன் மூலம்"}, {"w": 38, "t": "உதாரணத்தை"}, {"w": 39, "t": "இவ்வாறுதான்"}, {"w": 40, "t": "வழிகெடுக்கின்றான்"}, {"w": 41, "t": "அல்லாஹ்"}, {"w": 42, "t": "தான் நாடுகின்றவர்களை"}, {"w": 43, "t": "He wills"}, {"w": 44, "t": "நேர்வழி செலுத்துகின்றான்"}, {"w": 45, "t": "தான் நாடுகின்றவர்களை"}, {"w": 46, "t": "He wills"}, {"w": 47, "t": "அறிய மாட்டார்(கள்)"}, {"w": 48, "t": "knows"}, {"w": 49, "t": "இராணுவங்களை"}, {"w": 50, "t": "உமது இறைவனின்"}, {"w": 51, "t": "தவிர"}, {"w": 52, "t": "அவனை"}, {"w": 53, "t": "இல்லை/இது"}, {"w": 54, "t": "it"}, {"w": 55, "t": "தவிர"}, {"w": 56, "t": "ஒரு நினைவூட்டலே"}, {"w": 57, "t": "மனிதர்களுக்கு"}, {"w": 58, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அவ்வாறல்ல/சந்திரன் மீது சத்தியமாக!"}, {"w": 2, "t": "By the moon"}, {"w": 3, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "இரவின் மீது சத்தியமாக"}, {"w": 2, "t": "அது முடியும் போது!"}, {"w": 3, "t": "it departs"}, {"w": 4, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "அதிகாலை மீது சத்தியமாக"}, {"w": 2, "t": "அது ஒளி வீசும் போது!"}, {"w": 3, "t": "it brightens"}, {"w": 4, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "நிச்சயமாக அது"}, {"w": 2, "t": "மிகப் பெரிய விஷயங்களில் ஒன்றாகும்"}, {"w": 3, "t": "(of) the greatest"}, {"w": 4, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "எச்சரிக்கை செய்யக்கூடியதாகும்"}, {"w": 2, "t": "மனிதர்களுக்கு"}, {"w": 3, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "யார்/நாடினாரோ"}, {"w": 2, "t": "wills"}, {"w": 3, "t": "உங்களில்"}, {"w": 4, "t": "முன்னேறுவதற்கு"}, {"w": 5, "t": "proceed"}, {"w": 6, "t": "அல்லது"}, {"w": 7, "t": "பின் தங்கிவிடுவதற்கு"}, {"w": 8, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "ஒவ்வொரு"}, {"w": 2, "t": "ஆன்மாவும்"}, {"w": 3, "t": "தான் செய்ததற்காக"}, {"w": 4, "t": "it has earned"}, {"w": 5, "t": "பிடிக்கப்படும்"}, {"w": 6, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "வலது பக்கம் உள்ளவர்களைத் தவிர"}, {"w": 2, "t": "(the) companions"}, {"w": 3, "t": "(of) the right"}, {"w": 4, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "சொர்க்கங்களில்"}, {"w": 2, "t": "Gardens"}, {"w": 3, "t": "தங்களுக்குள் கேட்டுக்கொள்வார்கள்"}, {"w": 4, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "பாவிகளைப் பற்றி"}, {"w": 2, "t": "the criminals"}, {"w": 3, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "உங்களை நுழைத்தது எது?"}, {"w": 2, "t": "led you"}, {"w": 3, "t": "சகர் நரகத்தில்"}, {"w": 4, "t": "Hell"}, {"w": 5, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "நாங்கள் இருக்கவில்லை"}, {"w": 3, "t": "we were"}, {"w": 4, "t": "தொழுகையாளிகளில்"}, {"w": 5, "t": "those who prayed"}, {"w": 6, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "இன்னும் நாங்கள் இருக்கவில்லை"}, {"w": 2, "t": "we used to"}, {"w": 3, "t": "உணவளிப்பவர்களாக"}, {"w": 4, "t": "ஏழைகளுக்கு"}, {"w": 5, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நாங்கள் இருந்தோம்"}, {"w": 2, "t": "ஈடுபடுபவர்களாக"}, {"w": 3, "t": "வீணான காரியங்களில் ஈடுபடுவோருடன்"}, {"w": 4, "t": "the vain talkers"}, {"w": 5, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "நாங்கள் இருந்தோம்"}, {"w": 2, "t": "பொய்ப்பிப்பவர்களாக"}, {"w": 3, "t": "நாளை"}, {"w": 4, "t": "கூலி"}, {"w": 5, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "இறுதியாக"}, {"w": 2, "t": "எங்களுக்கு வந்தது"}, {"w": 3, "t": "மரணம்"}, {"w": 4, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "அவர்களுக்கு பலனளிக்காது"}, {"w": 2, "t": "will benefit them"}, {"w": 3, "t": "பரிந்துரை"}, {"w": 4, "t": "பரிந்துரை செய்பவர்களின்"}, {"w": 5, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அவர்களுக்கு என்ன ஆனது"}, {"w": 2, "t": "(is) for them"}, {"w": 3, "t": "இந்த அறிவுரையை விட்டு"}, {"w": 4, "t": "the Reminder"}, {"w": 5, "t": "புறக்கணித்து செல்கிறார்கள்"}, {"w": 6, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "போல்/அவர்கள்"}, {"w": 2, "t": "கழுதைகளை"}, {"w": 3, "t": "பயந்துபோன"}, {"w": 4, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "விரண்டோடுகின்ற(து)"}, {"w": 2, "t": "சிங்கத்தைப் பார்த்து"}, {"w": 3, "t": "a lion"}, {"w": 4, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "நாடுகின்றனர்"}, {"w": 3, "t": "ஒவ்வொரு மனிதனும்"}, {"w": 4, "t": "person"}, {"w": 5, "t": "அவர்களில்"}, {"w": 6, "t": "தனக்கு தரப்பட வேண்டும் என்று"}, {"w": 7, "t": "he may be given"}, {"w": 8, "t": "ஏடுகள்"}, {"w": 9, "t": "விரிக்கப்பட்ட"}, {"w": 10, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "மாறாக"}, {"w": 3, "t": "அவர்கள் பயப்படுவதில்லை"}, {"w": 4, "t": "they fear"}, {"w": 5, "t": "மறுமையை"}, {"w": 6, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "நிச்சயமாக இது"}, {"w": 3, "t": "ஒரு நல்லுபதேசமாகும்"}, {"w": 4, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "யார் நாடுகின்றாரோ"}, {"w": 2, "t": "wills"}, {"w": 3, "t": "இதன் மூலம் உபதேசம் பெறுவார்"}, {"w": 4, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "உபதேசம் பெறமாட்டார்கள்/தவிர"}, {"w": 2, "t": "will pay heed"}, {"w": 3, "t": "except"}, {"w": 4, "t": "அல்லாஹ் நாடினால்"}, {"w": 5, "t": "wills"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "அவன்தான்"}, {"w": 8, "t": "அஞ்சுவதற்கு(ம்) மிகத் தகுதியானவன்"}, {"w": 9, "t": "to be feared"}, {"w": 10, "t": "மன்னிப்பதற்கும் மிகத் தகுதியானவன்"}, {"w": 11, "t": "to forgive"}, {"w": 12, "t": "(56)"}]}]}