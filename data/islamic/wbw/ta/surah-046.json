{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "ஹா மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இறக்கப்படுகிறது"}, {"w": 2, "t": "இந்த வேதம்"}, {"w": 3, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "மிகைத்தவன்"}, {"w": 6, "t": "மகா ஞானவான்"}, {"w": 7, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நாம் படைக்கவில்லை"}, {"w": 2, "t": "We created"}, {"w": 3, "t": "வானங்களை(யும்)"}, {"w": 4, "t": "பூமியையும்"}, {"w": 5, "t": "அவை இரண்டிற்குமிடையில் உள்ளவற்றையும்"}, {"w": 6, "t": "(is) between both of them"}, {"w": 7, "t": "தவிர/உண்மையான காரணத்திற்கு(ம்)"}, {"w": 8, "t": "in truth"}, {"w": 9, "t": "ஒரு குறிப்பிட்ட தவணைக்கும்"}, {"w": 10, "t": "appointed"}, {"w": 11, "t": "நிராகரிப்பவர்கள்"}, {"w": 12, "t": "disbelieve"}, {"w": 13, "t": "அவர்கள் எச்சரிக்கப்பட்டதை"}, {"w": 14, "t": "they are warned"}, {"w": 15, "t": "புறக்கணிக்கின்றார்கள்"}, {"w": 16, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நீர் கூறுவீராக!"}, {"w": 2, "t": "அறிவியுங்கள்!"}, {"w": 3, "t": "நீங்கள் அழைக்கின்றவற்றை குறித்து"}, {"w": 4, "t": "you call"}, {"w": 5, "t": "அல்லாஹ்வையன்றி"}, {"w": 6, "t": "besides"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "எனக்கு காண்பியுங்கள்"}, {"w": 9, "t": "எதை"}, {"w": 10, "t": "படைத்தார்கள்"}, {"w": 11, "t": "பூமியில்"}, {"w": 12, "t": "the earth"}, {"w": 13, "t": "அல்லது"}, {"w": 14, "t": "அவர்களுக்கு"}, {"w": 15, "t": "பங்கு"}, {"w": 16, "t": "வானங்களில்"}, {"w": 17, "t": "the heavens"}, {"w": 18, "t": "ஒரு வேதத்தை என்னிடம் கொண்டு வாருங்கள்"}, {"w": 19, "t": "a book"}, {"w": 20, "t": "இதற்கு முன்னுள்ள"}, {"w": 21, "t": "before"}, {"w": 22, "t": "this"}, {"w": 23, "t": "அல்லது"}, {"w": 24, "t": "மீதமிருப்பதை"}, {"w": 25, "t": "கல்வியில்"}, {"w": 26, "t": "knowledge"}, {"w": 27, "t": "நீங்கள் இருந்தால்"}, {"w": 28, "t": "you are"}, {"w": 29, "t": "உண்மையாளர்களாக"}, {"w": 30, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "யார்?"}, {"w": 2, "t": "மிகப் பெரிய வழிகேடர்கள்"}, {"w": 3, "t": "அழைக்கின்ற வர்களை விட"}, {"w": 4, "t": "calls"}, {"w": 5, "t": "அல்லாஹ்வையன்றி"}, {"w": 6, "t": "besides"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "பதில் அளிக்க மாட்டார்கள்"}, {"w": 9, "t": "will not respond"}, {"w": 10, "t": "will not respond"}, {"w": 11, "t": "அவர்களுக்கு"}, {"w": 12, "t": "மறுமை நாள் வரை"}, {"w": 13, "t": "(the) Day"}, {"w": 14, "t": "(of) Resurrection"}, {"w": 15, "t": "அவர்கள்"}, {"w": 16, "t": "அவர்களின்துஆவை"}, {"w": 17, "t": "their calls"}, {"w": 18, "t": "அறியமாட்டார்கள்"}, {"w": 19, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "எழுப்பப்படும் போது"}, {"w": 2, "t": "are gathered"}, {"w": 3, "t": "மக்கள்"}, {"w": 4, "t": "ஆகிவிடுவார்கள்"}, {"w": 5, "t": "அவர்களுக்கு"}, {"w": 6, "t": "எதிரிகளாக"}, {"w": 7, "t": "இன்னும் ஆகிவிடுவார்கள்"}, {"w": 8, "t": "அவர்கள் தங்களை வணங்கியதை"}, {"w": 9, "t": "மறுப்பவர்களாக"}, {"w": 10, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "ஓதிக் காண்பிக்கப்பட்டால்"}, {"w": 2, "t": "are recited"}, {"w": 3, "t": "இவர்கள் மீது"}, {"w": 4, "t": "நமது வசனங்கள்"}, {"w": 5, "t": "தெளிவான அத்தாட்சிகளாக"}, {"w": 6, "t": "கூறினார்கள்"}, {"w": 7, "t": "நிராகரித்தவர்கள்"}, {"w": 8, "t": "disbelieve"}, {"w": 9, "t": "சத்தியத்தைப் பார்த்து"}, {"w": 10, "t": "அது வந்த போது"}, {"w": 11, "t": "அவர்களிடம்"}, {"w": 12, "t": "இது"}, {"w": 13, "t": "சூனியமாகும்"}, {"w": 14, "t": "தெளிவான"}, {"w": 15, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "கூறுகிறார்களா?"}, {"w": 2, "t": "they say"}, {"w": 3, "t": "இவர் இதை இட்டுக்கட்டினார்"}, {"w": 4, "t": "கூறுவீராக!"}, {"w": 5, "t": "நான் இதை இட்டுக்கட்டி இருந்தால்"}, {"w": 6, "t": "I have invented it"}, {"w": 7, "t": "நீங்கள் ஆற்றல் பெற மாட்டீர்கள்"}, {"w": 8, "t": "you have power"}, {"w": 9, "t": "எனக்காக"}, {"w": 10, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 11, "t": "Allah"}, {"w": 12, "t": "எதையும்"}, {"w": 13, "t": "அவன்"}, {"w": 14, "t": "மிக அறிந்தவன்"}, {"w": 15, "t": "எதை/நீங்கள் ஈடுபடுகிறீர்களோ"}, {"w": 16, "t": "you utter"}, {"w": 17, "t": "அதில்"}, {"w": 18, "t": "போதுமானவன்"}, {"w": 19, "t": "அவனே"}, {"w": 20, "t": "சாட்சியால்"}, {"w": 21, "t": "எனக்கு மத்தியிலும்"}, {"w": 22, "t": "உங்களுக்கு மத்தியிலும்"}, {"w": 23, "t": "அவன்தான்"}, {"w": 24, "t": "மகா மன்னிப்பாளன்"}, {"w": 25, "t": "மகா கருணையாளன்"}, {"w": 26, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் இருக்கவில்லை"}, {"w": 3, "t": "I am"}, {"w": 4, "t": "புதுமையானவனாக"}, {"w": 5, "t": "தூதர்களில்"}, {"w": 6, "t": "the Messengers"}, {"w": 7, "t": "அறியமாட்டேன்"}, {"w": 8, "t": "I know"}, {"w": 9, "t": "என்ன செய்யப்படும்"}, {"w": 10, "t": "will be done"}, {"w": 11, "t": "எனக்கு"}, {"w": 12, "t": "இன்னும் உங்களுக்கு"}, {"w": 13, "t": "with you"}, {"w": 14, "t": "பின்பற்ற மாட்டேன்"}, {"w": 15, "t": "I follow"}, {"w": 16, "t": "தவிர"}, {"w": 17, "t": "எது/வஹீ  அறிவிக்கப்படுகின்றது"}, {"w": 18, "t": "is revealed"}, {"w": 19, "t": "எனக்கு"}, {"w": 20, "t": "நான் இல்லை/தவிர"}, {"w": 21, "t": "I am"}, {"w": 22, "t": "but"}, {"w": 23, "t": "எச்சரிப்பாளராகவே"}, {"w": 24, "t": "தெளிவான"}, {"w": 25, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அறிவியுங்கள்"}, {"w": 3, "t": "இது இருந்தால்"}, {"w": 4, "t": "it is"}, {"w": 5, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 6, "t": "from Allah"}, {"w": 7, "t": "from Allah"}, {"w": 8, "t": "இன்னும் நீங்கள் நிராகரித்து விட்டால்/இதை"}, {"w": 9, "t": "in it"}, {"w": 10, "t": "இன்னும் சாட்சியும் கூறினார்"}, {"w": 11, "t": "ஒரு சாட்சியாளர்"}, {"w": 12, "t": "இஸ்ரவேலர்களில் உள்ள"}, {"w": 13, "t": "(the) Children of Israel"}, {"w": 14, "t": "(the) Children of Israel"}, {"w": 15, "t": "இதுபோன்ற ஒன்றுக்கு"}, {"w": 16, "t": "(the) like thereof"}, {"w": 17, "t": "அவர் நம்பிக்கை கொண்டிருக்க"}, {"w": 18, "t": "நீங்களோ பெருமை அடித்தீர்கள்"}, {"w": 19, "t": "நிச்சயமாக"}, {"w": 20, "t": "அல்லாஹ்"}, {"w": 21, "t": "நேர்வழி காட்ட மாட்டான்"}, {"w": 22, "t": "guide"}, {"w": 23, "t": "மக்களுக்கு"}, {"w": 24, "t": "அநியாயக்கார(ர்கள்)"}, {"w": 25, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "நிராகரித்தவர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "நம்பிக்கை கொண்டவர்களை நோக்கி"}, {"w": 5, "t": "believe"}, {"w": 6, "t": "இது சிறந்ததாக இருந்தால்"}, {"w": 7, "t": "it had been"}, {"w": 8, "t": "good"}, {"w": 9, "t": "இவர்கள் நம்மை முந்தியிருக்க மாட்டார்கள்"}, {"w": 10, "t": "they (would) have preceded us"}, {"w": 11, "t": "இதனளவில்"}, {"w": 12, "t": "அவர்கள் நேர்வழி பெறாமல் போனபோது"}, {"w": 13, "t": "not"}, {"w": 14, "t": "they (are) guided"}, {"w": 15, "t": "இதன் மூலம்"}, {"w": 16, "t": "கூறுகின்றனர்"}, {"w": 17, "t": "இது"}, {"w": 18, "t": "பொய்யாகும்"}, {"w": 19, "t": "பழைய(து)"}, {"w": 20, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இதற்கு முன்னர்"}, {"w": 2, "t": "And before it"}, {"w": 3, "t": "மூஸாவின் வேதம்"}, {"w": 4, "t": "(of) Musa"}, {"w": 5, "t": "ஒரு முன்னோடியாக(வும்)"}, {"w": 6, "t": "அருளாகவும்"}, {"w": 7, "t": "இதுவோ"}, {"w": 8, "t": "ஒரு வேதமாகும்"}, {"w": 9, "t": "மெய்ப்பிக்கக்கூடிய(து)"}, {"w": 10, "t": "அரபி மொழியில்"}, {"w": 11, "t": "Arabic"}, {"w": 12, "t": "எச்சரிப்பதற்காக(வும்)"}, {"w": 13, "t": "அநியாயக்காரர்களை"}, {"w": 14, "t": "do wrong"}, {"w": 15, "t": "நற்செய்தியாகவும்"}, {"w": 16, "t": "நல்லவர்களுக்கு"}, {"w": 17, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "கூறினார்கள்"}, {"w": 4, "t": "எங்கள் இறைவன்"}, {"w": 5, "t": "அல்லாஹ்தான்"}, {"w": 6, "t": "பிறகு"}, {"w": 7, "t": "உறுதியாக இருந்தார்களோ"}, {"w": 8, "t": "பயமில்லை"}, {"w": 9, "t": "fear"}, {"w": 10, "t": "அவர்கள் மீது"}, {"w": 11, "t": "இன்னும் அவர்கள் கவலைப்பட மாட்டார்கள்"}, {"w": 12, "t": "they"}, {"w": 13, "t": "will grieve"}, {"w": 14, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவர்கள்"}, {"w": 2, "t": "சொர்க்கவாசிகள்"}, {"w": 3, "t": "(of) Paradise"}, {"w": 4, "t": "நிரந்தரமாக இருப்பார்கள்"}, {"w": 5, "t": "அதில்"}, {"w": 6, "t": "கூலியாக"}, {"w": 7, "t": "அவர்கள் செய்து கொண்டிருந்தவற்றிற்கு"}, {"w": 8, "t": "they used to"}, {"w": 9, "t": "do"}, {"w": 10, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நாம் உபதேசித்தோம்"}, {"w": 2, "t": "மனிதனுக்கு"}, {"w": 3, "t": "தன் பெற்றோருக்கு"}, {"w": 4, "t": "நன்மை செய்வதற்கு"}, {"w": 5, "t": "அவனை சுமந்தாள்"}, {"w": 6, "t": "அவனது தாய்"}, {"w": 7, "t": "சிரமத்துடன்"}, {"w": 8, "t": "இன்னும் அவனை ஈன்றெடுத்தாள்"}, {"w": 9, "t": "சிரமத்துடன்"}, {"w": 10, "t": "அவனை சுமந்ததும்"}, {"w": 11, "t": "இன்னும் அவனுக்கு பால்குடி மறக்கச் செய்ததும்"}, {"w": 12, "t": "முப்பது"}, {"w": 13, "t": "மாதங்களாகும்"}, {"w": 14, "t": "இறுதியாக"}, {"w": 15, "t": "அவன் அடைந்து (விட்டால்)"}, {"w": 16, "t": "he reaches"}, {"w": 17, "t": "தனது வாலிபத்தை"}, {"w": 18, "t": "இன்னும் அடைந்து(விட்டால்)"}, {"w": 19, "t": "நாற்பது"}, {"w": 20, "t": "வயதை"}, {"w": 21, "t": "அவன் கூறுகிறான்"}, {"w": 22, "t": "என் இறைவா"}, {"w": 23, "t": "என்னை தூண்டுவாயாக"}, {"w": 24, "t": "நான் நன்றி செலுத்துவதற்கு(ம்)"}, {"w": 25, "t": "I may be grateful"}, {"w": 26, "t": "உனது அருளுக்கு"}, {"w": 27, "t": "எது"}, {"w": 28, "t": "நீ அருள் புரிந்தாய்"}, {"w": 29, "t": "என்மீது(ம்)"}, {"w": 30, "t": "மீதும்"}, {"w": 31, "t": "என் பெற்றோர்"}, {"w": 32, "t": "நான் செய்வதற்கும்"}, {"w": 33, "t": "I do"}, {"w": 34, "t": "நல்ல அமலை"}, {"w": 35, "t": "அதை நீ திருப்திபடுகின்றாய்"}, {"w": 36, "t": "இன்னும் சீர்திருத்தம் செய்"}, {"w": 37, "t": "எனக்கு"}, {"w": 38, "t": "என் சந்ததியில்"}, {"w": 39, "t": "my offspring"}, {"w": 40, "t": "நிச்சயமாக நான்"}, {"w": 41, "t": "திரும்பி விட்டேன்"}, {"w": 42, "t": "உன் பக்கம்"}, {"w": 43, "t": "இன்னும் நிச்சயமாக நான்"}, {"w": 44, "t": "முஸ்லிம்களில் ஒருவனாவேன்"}, {"w": 45, "t": "those who submit"}, {"w": 46, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இவர்கள்"}, {"w": 2, "t": "எப்படிப்பட்டவர்கள்"}, {"w": 3, "t": "ஏற்றுக் கொள்வோம்"}, {"w": 4, "t": "இவர்களிடமிருந்து"}, {"w": 5, "t": "மிக அழகானதை"}, {"w": 6, "t": "இவர்கள் செய்தவற்றில்"}, {"w": 7, "t": "they did"}, {"w": 8, "t": "இன்னும் மன்னித்து விடுவோம்"}, {"w": 9, "t": "இவர்களின் பாவங்களை"}, {"w": 10, "t": "their evil deeds"}, {"w": 11, "t": "சொர்க்க வாசிகளில்"}, {"w": 12, "t": "(the) companions"}, {"w": 13, "t": "(of) Paradise"}, {"w": 14, "t": "உண்மையான வாக்காகும்"}, {"w": 15, "t": "true"}, {"w": 16, "t": "எது/வாக்களிக்கப்பட்டுக் கொண்டிருந்தார்கள்"}, {"w": 17, "t": "they were"}, {"w": 18, "t": "promised"}, {"w": 19, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "எவர்/கூறினார்"}, {"w": 2, "t": "says"}, {"w": 3, "t": "தனது பெற்றோரை நோக்கி"}, {"w": 4, "t": "“சீ”"}, {"w": 5, "t": "உங்கள் இருவருக்கும்"}, {"w": 6, "t": "என்னை எச்சரிக்கிறீர்களா?"}, {"w": 7, "t": "நான் வெளியேற்றப்படுவேன்"}, {"w": 8, "t": "I will be brought forth"}, {"w": 9, "t": "திட்டமாக"}, {"w": 10, "t": "சென்றுள்ளனர்"}, {"w": 11, "t": "பல தலைமுறைகள்"}, {"w": 12, "t": "எனக்கு முன்னர்"}, {"w": 13, "t": "before me"}, {"w": 14, "t": "அவ்விருவரும்"}, {"w": 15, "t": "உதவி தேடுகின்றனர்"}, {"w": 16, "t": "அல்லாஹ்விடம்"}, {"w": 17, "t": "உனக்கு என்ன கேடு!"}, {"w": 18, "t": "நீ நம்பிக்கை கொள்!"}, {"w": 19, "t": "நிச்சயமாக வாக்கு"}, {"w": 20, "t": "(the) Promise"}, {"w": 21, "t": "அல்லாஹ்வின்"}, {"w": 22, "t": "உண்மையானதே!"}, {"w": 23, "t": "அவன் கூறுகிறான்"}, {"w": 24, "t": "இது இல்லை"}, {"w": 25, "t": "(is) this"}, {"w": 26, "t": "கதைகளே தவிர"}, {"w": 27, "t": "(the) stories"}, {"w": 28, "t": "முன்னோரின்"}, {"w": 29, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இவர்கள்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "உறுதியாகிவிட்டது"}, {"w": 4, "t": "இவர்கள் மீதும்"}, {"w": 5, "t": "வாக்கு"}, {"w": 6, "t": "சமுதாயங்களுடன்"}, {"w": 7, "t": "nations"}, {"w": 8, "t": "திட்டமாக"}, {"w": 9, "t": "சென்றுவிட்ட(னர்)"}, {"w": 10, "t": "இவர்களுக்கு முன்னர்"}, {"w": 11, "t": "before them"}, {"w": 12, "t": "ஜின்களில்"}, {"w": 13, "t": "(the) jinn"}, {"w": 14, "t": "மற்றும் மனித(ர்கள்)"}, {"w": 15, "t": "நிச்சயமாக இவர்கள்"}, {"w": 16, "t": "இருக்கின்றனர்"}, {"w": 17, "t": "நஷ்டவாளிகளாகவே"}, {"w": 18, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "எல்லோருக்கும்"}, {"w": 2, "t": "தகுதிகள் உண்டு"}, {"w": 3, "t": "அவர்கள் செய்தவற்றின் அடிப்படையில்"}, {"w": 4, "t": "they did"}, {"w": 5, "t": "இன்னும் இறுதியாக அவன் அவர்களுக்கு முழு கூலி கொடுப்பான்"}, {"w": 6, "t": "அவர்களுடைய செயல்களுக்கு"}, {"w": 7, "t": "இன்னும் அவர்கள்"}, {"w": 8, "t": "அநீதி இழைக்கப்பட மாட்டார்கள்"}, {"w": 9, "t": "will not be wronged"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "சமர்ப்பிக்கப்படுகின்ற நாளில்"}, {"w": 2, "t": "will be exposed"}, {"w": 3, "t": "நிராகரிப்பாளர்கள்"}, {"w": 4, "t": "disbelieved"}, {"w": 5, "t": "நரகத்தின் முன்"}, {"w": 6, "t": "the Fire"}, {"w": 7, "t": "நீங்கள் போக்கிக் கொண்டீர்கள்"}, {"w": 8, "t": "உங்கள் நன்மைகளை"}, {"w": 9, "t": "உங்கள் வாழ்க்கையிலே"}, {"w": 10, "t": "your life"}, {"w": 11, "t": "உலக"}, {"w": 12, "t": "இன்னும் இன்பம் அடைந்தீர்கள்"}, {"w": 13, "t": "அவற்றின் மூலம்"}, {"w": 14, "t": "ஆகவே இன்றைய தினம்"}, {"w": 15, "t": "கூலியாக கொடுக்கப்படுவீர்கள்"}, {"w": 16, "t": "தண்டனையை"}, {"w": 17, "t": "கேவலமான"}, {"w": 18, "t": "நீங்கள் இருந்த காரணத்தாலும்"}, {"w": 19, "t": "you were"}, {"w": 20, "t": "நீங்கள் பெருமையடிப்பவர்களாக"}, {"w": 21, "t": "பூமியில்"}, {"w": 22, "t": "the earth"}, {"w": 23, "t": "அநியாயமாக"}, {"w": 24, "t": "[the] right"}, {"w": 25, "t": "நீங்கள் இருந்த காரணத்தாலும்"}, {"w": 26, "t": "you were"}, {"w": 27, "t": "நீங்கள் பாவம் செய்பவர்களாக"}, {"w": 28, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "நினைவு கூர்வீராக"}, {"w": 2, "t": "சகோதரரை"}, {"w": 3, "t": "ஆது சமுதாயத்தின்"}, {"w": 4, "t": "அவர் எச்சரித்த சமயத்தை"}, {"w": 5, "t": "he warned"}, {"w": 6, "t": "தனது மக்களை"}, {"w": 7, "t": "மணல் பாங்கான இடத்தில்"}, {"w": 8, "t": "திட்டமாக"}, {"w": 9, "t": "சென்றுள்ளனர்"}, {"w": 10, "t": "எச்சரிப்பாளர்கள்"}, {"w": 11, "t": "இவருக்கு முன்னரும்"}, {"w": 12, "t": "before him"}, {"w": 13, "t": "before him"}, {"w": 14, "t": "இவருக்கு பின்னரும்"}, {"w": 15, "t": "and after him"}, {"w": 16, "t": "நீங்கள் வணங்காதீர்கள்"}, {"w": 17, "t": "you worship"}, {"w": 18, "t": "அல்லாஹ்வை அன்றி"}, {"w": 19, "t": "Allah"}, {"w": 20, "t": "நிச்சயமாக நான்"}, {"w": 21, "t": "பயப்படுகிறேன்"}, {"w": 22, "t": "உங்கள் மீது"}, {"w": 23, "t": "தண்டனையை"}, {"w": 24, "t": "நாளின்"}, {"w": 25, "t": "பெரிய(து)"}, {"w": 26, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "நீர் எங்களிடம் வந்தீரா?"}, {"w": 3, "t": "எங்களை திருப்புவதற்காக"}, {"w": 4, "t": "எங்கள் தெய்வங்களை விட்டு"}, {"w": 5, "t": "our gods"}, {"w": 6, "t": "எங்களுக்கு நீர் எச்சரிக்கை செய்வதை எங்களிடம் கொண்டு வருவீராக!"}, {"w": 7, "t": "what"}, {"w": 8, "t": "you threaten us"}, {"w": 9, "t": "நீர் இருந்தால்"}, {"w": 10, "t": "you are"}, {"w": 11, "t": "உண்மையாளர்களில்"}, {"w": 12, "t": "the truthful"}, {"w": 13, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "அறிவெல்லாம்"}, {"w": 3, "t": "the knowledge"}, {"w": 4, "t": "அல்லாஹ்விடம்தான் இருக்கிறது."}, {"w": 5, "t": "(is) with Allah"}, {"w": 6, "t": "உங்களுக்கு எடுத்துச் சொல்கிறேன்"}, {"w": 7, "t": "எதை/அனுப்பப்பட்டேன்"}, {"w": 8, "t": "I am sent"}, {"w": 9, "t": "அதைக் கொண்டு"}, {"w": 10, "t": "என்றாலும் நான்"}, {"w": 11, "t": "உங்களை கருதுகிறேன்"}, {"w": 12, "t": "மக்களாக"}, {"w": 13, "t": "நீங்கள் அறியாத(வர்கள்)"}, {"w": 14, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவர்கள் அதை பார்த்த போது"}, {"w": 2, "t": "they saw it"}, {"w": 3, "t": "அடர்த்தியான கார் மேகமாக"}, {"w": 4, "t": "முன்னோக்கி வரக்கூடிய(து)"}, {"w": 5, "t": "தங்களது பள்ளத்தாக்கை"}, {"w": 6, "t": "கூறினார்கள்"}, {"w": 7, "t": "இது"}, {"w": 8, "t": "அடர்த்தியான கார்மேகமாகும்"}, {"w": 9, "t": "நமக்கு மழை பொழிவிக்கும்"}, {"w": 10, "t": "மாறாக இது"}, {"w": 11, "t": "it"}, {"w": 12, "t": "எதை/நீங்கள் அவசரமாகத் தேடினீர்கள்"}, {"w": 13, "t": "you were asking it to be hastened"}, {"w": 14, "t": "அதை"}, {"w": 15, "t": "(இது) ஒரு காற்றாகும்"}, {"w": 16, "t": "இதில் உள்ளது"}, {"w": 17, "t": "தண்டனை"}, {"w": 18, "t": "வலி தரக்கூடிய(து)"}, {"w": 19, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இது சின்னா பின்னமாக்கிவிடும்"}, {"w": 2, "t": "எல்லாவற்றையும்"}, {"w": 3, "t": "thing"}, {"w": 4, "t": "கட்டளைப்படி"}, {"w": 5, "t": "தனது இறைவனின்"}, {"w": 6, "t": "ஆகிவிட்டனர்"}, {"w": 7, "t": "பார்க்க முடியாதபடி"}, {"w": 8, "t": "is seen"}, {"w": 9, "t": "தவிர"}, {"w": 10, "t": "அவர்களின் வசிப்பிடங்களை"}, {"w": 11, "t": "இவ்வாறுதான்"}, {"w": 12, "t": "கூலி கொடுப்போம்"}, {"w": 13, "t": "மக்களுக்கு"}, {"w": 14, "t": "குற்றவாளிகளான"}, {"w": 15, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அவர்களுக்கு நாம் வசதியளித்தோம்"}, {"w": 3, "t": "எதில்"}, {"w": 4, "t": "உங்களுக்கு நாம் வசதியளிக்கவில்லை(யோ)"}, {"w": 5, "t": "We have established you"}, {"w": 6, "t": "அதில்"}, {"w": 7, "t": "இன்னும் ஏற்படுத்தினோம்"}, {"w": 8, "t": "அவர்களுக்கு"}, {"w": 9, "t": "செவியை(யும்)"}, {"w": 10, "t": "பார்வைகளையும்"}, {"w": 11, "t": "உள்ளங்களையும்"}, {"w": 12, "t": "தடுக்கவில்லை"}, {"w": 13, "t": "availed"}, {"w": 14, "t": "அவர்களை விட்டும்"}, {"w": 15, "t": "அவர்களின் செவி(யும்)"}, {"w": 16, "t": "பார்வைகளும்"}, {"w": 17, "t": "பார்வைகளும் அவர்களின்"}, {"w": 18, "t": "அவர்களின் உள்ளங்களும்"}, {"w": 19, "t": "their hearts"}, {"w": 20, "t": "எதையும்"}, {"w": 21, "t": "thing"}, {"w": 22, "t": "அவர்கள் இருந்தபோது"}, {"w": 23, "t": "they were"}, {"w": 24, "t": "மறுப்பவர்களாக"}, {"w": 25, "t": "அத்தாட்சிகளை"}, {"w": 26, "t": "அல்லாஹ்வின்"}, {"w": 27, "t": "இன்னும் சூழ்ந்து கொண்டது"}, {"w": 28, "t": "அவர்களை"}, {"w": 29, "t": "எது/இருந்தார்கள்"}, {"w": 30, "t": "they used to"}, {"w": 31, "t": "அதை"}, {"w": 32, "t": "பரிகாசம் செய்பவர்களாக"}, {"w": 33, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் அழித்தோம்"}, {"w": 3, "t": "உங்களை சுற்றி உள்ளவற்றை"}, {"w": 4, "t": "surrounds you"}, {"w": 5, "t": "ஊர்களில்"}, {"w": 6, "t": "the towns"}, {"w": 7, "t": "இன்னும் நாம் விவரித்தோம்"}, {"w": 8, "t": "அத்தாட்சிகளை"}, {"w": 9, "t": "அவர்கள் திரும்புவதற்காக"}, {"w": 10, "t": "return"}, {"w": 11, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "(அவர்கள்) இவர்களுக்கு உதவி செய்திருக்க வேண்டாமா?"}, {"w": 2, "t": "help them"}, {"w": 3, "t": "எவர்களை/எடுத்துக் கொண்டார்கள்"}, {"w": 4, "t": "they had taken"}, {"w": 5, "t": "அல்லாஹ்வையன்றி"}, {"w": 6, "t": "besides"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "வழிபாட்டுக்காக"}, {"w": 9, "t": "தெய்வங்களாக"}, {"w": 10, "t": "மாறாக"}, {"w": 11, "t": "அவர்கள் மறைந்து விட்டனர்"}, {"w": 12, "t": "இவர்களை விட்டு"}, {"w": 13, "t": "இது"}, {"w": 14, "t": "இவர்களின்பொய்(யும்)"}, {"w": 15, "t": "இன்னும் எதை/இருந்தார்களோ"}, {"w": 16, "t": "they were"}, {"w": 17, "t": "இட்டுக் கட்டுபவர்களாக"}, {"w": 18, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "நாம் திருப்பிய சமயத்தை நினைவு கூர்வீராக!/உம் பக்கம்"}, {"w": 2, "t": "We directed"}, {"w": 3, "t": "to you"}, {"w": 4, "t": "சில நபர்களை"}, {"w": 5, "t": "ஜின்களின்"}, {"w": 6, "t": "the jinn"}, {"w": 7, "t": "செவிமடுக்கின்றனர்"}, {"w": 8, "t": "குர்ஆனை"}, {"w": 9, "t": "அவர்கள் அந்த இடத்திற்கு வந்தபோது"}, {"w": 10, "t": "they attended it"}, {"w": 11, "t": "கூறினார்கள்"}, {"w": 12, "t": "வாய்மூடி இருங்கள்!"}, {"w": 13, "t": "முடிக்கப்பட்ட போது"}, {"w": 14, "t": "it was concluded"}, {"w": 15, "t": "திரும்பினார்கள்"}, {"w": 16, "t": "தங்களது சமுதாயத்தினர் பக்கம்"}, {"w": 17, "t": "their people"}, {"w": 18, "t": "எச்சரிப்பவர்களாக"}, {"w": 19, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "எங்கள் சமுதாயமே!"}, {"w": 3, "t": "நிச்சயமாக நாங்கள் செவியுற்றோம்"}, {"w": 4, "t": "[we] have heard"}, {"w": 5, "t": "ஒரு வேதத்தை"}, {"w": 6, "t": "இறக்கப்பட்ட(து)"}, {"w": 7, "t": "பின்னர்"}, {"w": 8, "t": "after"}, {"w": 9, "t": "மூஸாவிற்கு"}, {"w": 10, "t": "உண்மைப்படுத்தக்கூடிய"}, {"w": 11, "t": "தனக்கு முந்தியவற்றை"}, {"w": 12, "t": "(was) before it"}, {"w": 13, "t": "(was) before it"}, {"w": 14, "t": "அது வழி காட்டுகிறது"}, {"w": 15, "t": "உண்மைக்கு(ம்)"}, {"w": 16, "t": "the truth"}, {"w": 17, "t": "பாதைக்கும்"}, {"w": 18, "t": "a Path"}, {"w": 19, "t": "மிக நேரான"}, {"w": 20, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "எங்கள் சமுதாயமே!"}, {"w": 2, "t": "பதில் தாருங்கள்!"}, {"w": 3, "t": "அழைப்பாளருக்கு"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "இன்னும் நம்பிக்கை கொள்ளுங்கள்"}, {"w": 6, "t": "அவரை"}, {"w": 7, "t": "அவன் மன்னிப்பான்"}, {"w": 8, "t": "உங்களுக்கு"}, {"w": 9, "t": "உங்கள் பாவங்களை"}, {"w": 10, "t": "your sins"}, {"w": 11, "t": "இன்னும் உங்களை பாதுகாப்பான்"}, {"w": 12, "t": "தண்டனையிலிருந்து"}, {"w": 13, "t": "a punishment"}, {"w": 14, "t": "வலி தரக்கூடிய(து)"}, {"w": 15, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "எவர்"}, {"w": 2, "t": "பதில் தரவில்லையோ"}, {"w": 3, "t": "respond"}, {"w": 4, "t": "அழைப்பாளருக்கு"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "அவர் தப்பித்துவிட மாட்டார்"}, {"w": 7, "t": "he can escape"}, {"w": 8, "t": "பூமியில்"}, {"w": 9, "t": "the earth"}, {"w": 10, "t": "இல்லை"}, {"w": 11, "t": "அவருக்கு"}, {"w": 12, "t": "அவனையன்றி"}, {"w": 13, "t": "besides Him"}, {"w": 14, "t": "பாதுகாவலர்கள்"}, {"w": 15, "t": "இப்படிப்பட்டவர்கள்"}, {"w": 16, "t": "வழிகேட்டில் இருக்கின்றனர்"}, {"w": 17, "t": "error"}, {"w": 18, "t": "மிகத் தெளிவான"}, {"w": 19, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "அவர்கள் கவனிக்கவில்லையா?"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "படைத்தவன்"}, {"w": 6, "t": "created"}, {"w": 7, "t": "வானங்களை(யும்)"}, {"w": 8, "t": "பூமியையும்"}, {"w": 9, "t": "கலைத்து விடாதவனுமாகிய"}, {"w": 10, "t": "tired"}, {"w": 11, "t": "அவற்றைபடைத்ததால்"}, {"w": 12, "t": "ஆற்றலுடையவன் (என்பதை)"}, {"w": 13, "t": "உயிர்ப்பிப்பதற்கு"}, {"w": 14, "t": "to give life"}, {"w": 15, "t": "இறந்தவர்களை"}, {"w": 16, "t": "ஏன் இல்லை"}, {"w": 17, "t": "நிச்சயமாக அவன்"}, {"w": 18, "t": "எல்லாவற்றின் மீதும்"}, {"w": 19, "t": "(is) on"}, {"w": 20, "t": "பேராற்றலுடையவன்"}, {"w": 21, "t": "thing"}, {"w": 22, "t": "Err"}, {"w": 23, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "கொண்டுவரப்படும்"}, {"w": 3, "t": "நிராகரித்தவர்கள்"}, {"w": 4, "t": "disbelieved"}, {"w": 5, "t": "நரகத்தின் முன்"}, {"w": 6, "t": "the Fire"}, {"w": 7, "t": "இல்லையா?"}, {"w": 8, "t": "இது"}, {"w": 9, "t": "உண்மையாக"}, {"w": 10, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 11, "t": "ஏன் இல்லை?"}, {"w": 12, "t": "எங்கள் இறைவன் மீது சத்தியமாக"}, {"w": 13, "t": "கூறுவான்"}, {"w": 14, "t": "நீங்கள் சுவையுங்கள்!"}, {"w": 15, "t": "இந்த வேதனையை"}, {"w": 16, "t": "நீங்கள் இருந்த காரணத்தால்"}, {"w": 17, "t": "you used to"}, {"w": 18, "t": "நிராகரிப்பவர்களாக"}, {"w": 19, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "பொறுமை காப்பீராக!"}, {"w": 2, "t": "பொறுத்தது போன்று"}, {"w": 3, "t": "had patience"}, {"w": 4, "t": "மிகவும் வீரமிக்கவர்கள்"}, {"w": 5, "t": "those of determination"}, {"w": 6, "t": "தூதர்களில்"}, {"w": 7, "t": "the Messengers"}, {"w": 8, "t": "அவர்களுக்காக அவசரமாகக் கேட்காதீர்!"}, {"w": 9, "t": "seek to hasten"}, {"w": 10, "t": "for them"}, {"w": 11, "t": "அவர்களுக்குத் தோன்றும்"}, {"w": 12, "t": "நாளில்"}, {"w": 13, "t": "அவர்கள் பார்க்கின்ற(னர்)"}, {"w": 14, "t": "அவர்கள் எச்சரிக்கப்பட்டதை"}, {"w": 15, "t": "they were promised"}, {"w": 16, "t": "அவர்கள் தங்கவில்லை"}, {"w": 17, "t": "remained"}, {"w": 18, "t": "சில மணிநேரம் தவிர"}, {"w": 19, "t": "an hour"}, {"w": 20, "t": "பகலின்"}, {"w": 21, "t": "a day"}, {"w": 22, "t": "இது எடுத்து சொல்லப்படும் செய்தியாகும்"}, {"w": 23, "t": "அழிக்கப்படுவார்களா?"}, {"w": 24, "t": "(any) be destroyed"}, {"w": 25, "t": "மக்களைத் தவிர"}, {"w": 26, "t": "the people "}, {"w": 27, "t": "பாவிகளான"}, {"w": 28, "t": "(35)"}]}]}