: "your houses"}, {"w": 4, "t": "அலங்காரங்களை வெளிப்படுத்தாதீர்கள்"}, {"w": 5, "t": "display yourselves"}, {"w": 6, "t": "அலங்காரங்களை வெளிப்படுத்தியதுபோன்று"}, {"w": 7, "t": "அறியாமைக்காலத்தில்"}, {"w": 8, "t": "முந்திய"}, {"w": 9, "t": "நிலைநிறுத்துங்கள்!"}, {"w": 10, "t": "தொழுகையை"}, {"w": 11, "t": "கொடுங்கள்!"}, {"w": 12, "t": "ஸகாத்தை"}, {"w": 13, "t": "கீழ்ப்படியுங்கள்!"}, {"w": 14, "t": "அல்லாஹ்விற்கும்"}, {"w": 15, "t": "அவனது தூதருக்கும்"}, {"w": 16, "t": "நாடுவதெல்லாம்"}, {"w": 17, "t": "Allah wishes"}, {"w": 18, "t": "அல்லாஹ்"}, {"w": 19, "t": "போக்குவதற்கும்"}, {"w": 20, "t": "உங்களை விட்டும்"}, {"w": 21, "t": "அசுத்தத்தை"}, {"w": 22, "t": "வீட்டார்களே!"}, {"w": 23, "t": "(of) the House"}, {"w": 24, "t": "முற்றிலும் உங்களை சுத்தப்படுத்துவதற்கும்தான்"}, {"w": 25, "t": "(with thorough) purification"}, {"w": 26, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இன்னும் மனனம் செய்யுங்கள்"}, {"w": 2, "t": "ஓதப்படுகின்றவற்றையும்"}, {"w": 3, "t": "is recited"}, {"w": 4, "t": "உங்கள் இல்லங்களில்"}, {"w": 5, "t": "your houses"}, {"w": 6, "t": "அதாவது,வசனங்களில்"}, {"w": 7, "t": "(the) Verses"}, {"w": 8, "t": "அல்லாஹ்வின்"}, {"w": 9, "t": "இன்னும் ஞானத்தை"}, {"w": 10, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 11, "t": "Allah"}, {"w": 12, "t": "இருக்கின்றான்"}, {"w": 13, "t": "மிக கருணையாளனாக"}, {"w": 14, "t": "ஆழ்ந்தறிபவனாக"}, {"w": 15, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "நிச்சயமாக முஸ்லிமான ஆண்கள்"}, {"w": 2, "t": "the Muslim men"}, {"w": 3, "t": "இன்னும் முஸ்லிமான பெண்கள்"}, {"w": 4, "t": "இன்னும் முஃமினான ஆண்கள்"}, {"w": 5, "t": "இன்னும் முஃமினான பெண்கள்"}, {"w": 6, "t": "இன்னும் பணிவான ஆண்கள்"}, {"w": 7, "t": "இன்னும் பணிவான பெண்கள்"}, {"w": 8, "t": "இன்னும் உண்மையான ஆண்கள்"}, {"w": 9, "t": "இன்னும் உண்மையான பெண்கள்"}, {"w": 10, "t": "இன்னும் பொறுமையான ஆண்கள்"}, {"w": 11, "t": "இன்னும் பொறுமையான பெண்கள்"}, {"w": 12, "t": "இன்னும் உள்ளச்சமுடைய ஆண்கள்"}, {"w": 13, "t": "இன்னும் உள்ளச்சமுடைய பெண்கள்"}, {"w": 14, "t": "இன்னும் தர்மம் செய்கின்ற ஆண்கள்"}, {"w": 15, "t": "இன்னும் தர்மம் செய்கின்ற பெண்கள்"}, {"w": 16, "t": "இன்னும் நோன்பாளியான ஆண்கள்"}, {"w": 17, "t": "இன்னும் நோன்பாளியான பெண்கள்"}, {"w": 18, "t": "இன்னும் பேணுகின்ற ஆண்கள்"}, {"w": 19, "t": "இன்னும் தங்கள் மறைவிடங்களை"}, {"w": 20, "t": "இன்னும் பேணுகின்ற பெண்கள்"}, {"w": 21, "t": "இன்னும் நினைவு கூரக்கூடிய ஆண்கள்"}, {"w": 22, "t": "அல்லாஹ்வை"}, {"w": 23, "t": "அதிகம்"}, {"w": 24, "t": "இன்னும் நினைவு கூரக்கூடிய பெண்கள்"}, {"w": 25, "t": "ஏற்படுத்தி இருக்கின்றான்/அல்லாஹ்"}, {"w": 26, "t": "Allah has prepared"}, {"w": 27, "t": "இவர்களுக்கு"}, {"w": 28, "t": "மன்னிப்பை(யும்)"}, {"w": 29, "t": "கூலியையும்"}, {"w": 30, "t": "மகத்தான"}, {"w": 31, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "ஆகுமானதல்ல"}, {"w": 2, "t": "(it) is"}, {"w": 3, "t": "நம்பிக்கையுடைய ஆணுக்கு(ம்)"}, {"w": 4, "t": "நம்பிக்கையுடைய பெண்ணுக்கும்"}, {"w": 5, "t": "(for) a believing woman"}, {"w": 6, "t": "முடிவுசெய்துவிட்டால்"}, {"w": 7, "t": "Allah has decided"}, {"w": 8, "t": "அல்லாஹ்வும்"}, {"w": 9, "t": "அவனது தூதரும்"}, {"w": 10, "t": "ஒரு காரியத்தை"}, {"w": 11, "t": "இருப்பது"}, {"w": 12, "t": "(there) should be"}, {"w": 13, "t": "அவர்களுக்கு"}, {"w": 14, "t": "ஒரு விருப்பம்"}, {"w": 15, "t": "தங்களது காரியத்தில்"}, {"w": 16, "t": "their affair"}, {"w": 17, "t": "யார்"}, {"w": 18, "t": "மாறு செய்வாரோ"}, {"w": 19, "t": "அல்லாஹ்வுக்கும்"}, {"w": 20, "t": "அவனது தூதருக்கும்"}, {"w": 21, "t": "திட்டமாக"}, {"w": 22, "t": "வழிகெட்டுவிட்டார்"}, {"w": 23, "t": "(into) error"}, {"w": 24, "t": "தெளிவாக"}, {"w": 25, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "நீர் கூறிய சமயத்தை நினைவு கூருவீராக!"}, {"w": 2, "t": "you said"}, {"w": 3, "t": "எவருக்கு"}, {"w": 4, "t": "அருள் புரிந்தான்"}, {"w": 5, "t": "அல்லாஹ்(வும்)"}, {"w": 6, "t": "அவர் மீது"}, {"w": 7, "t": "இன்னும் அருள் புரிந்தீர்"}, {"w": 8, "t": "அவர் மீது"}, {"w": 9, "t": "வைத்துக்கொள்!"}, {"w": 10, "t": "உன்னுடன்"}, {"w": 11, "t": "உன் மனைவியை"}, {"w": 12, "t": "இன்னும் அஞ்சிக்கொள் !"}, {"w": 13, "t": "அல்லாஹ்வை"}, {"w": 14, "t": "நீர் மறைக்கிறீர்"}, {"w": 15, "t": "உமது உள்ளத்தில்"}, {"w": 16, "t": "yourself"}, {"w": 17, "t": "ஒன்றை"}, {"w": 18, "t": "அல்லாஹ்"}, {"w": 19, "t": "அதை வெளிப்படுத்தக்கூடியவனாக"}, {"w": 20, "t": "இன்னும் பயப்படுகின்றீர்"}, {"w": 21, "t": "மக்களை"}, {"w": 22, "t": "அல்லாஹ்தான்"}, {"w": 23, "t": "மிகத் தகுதியானவன்"}, {"w": 24, "t": "அவனை நீர் பயப்படுவதற்கு"}, {"w": 25, "t": "you (should) fear Him"}, {"w": 26, "t": "முடித்துவிட்ட போது"}, {"w": 27, "t": "ended"}, {"w": 28, "t": "சைது"}, {"w": 29, "t": "அவளிடம்"}, {"w": 30, "t": "தேவையை"}, {"w": 31, "t": "அவளை உமக்கு நாம் மணமுடித்து வைத்தோம்"}, {"w": 32, "t": "இருக்கக்கூடாது என்பதற்காக"}, {"w": 33, "t": "not"}, {"w": 34, "t": "there be"}, {"w": 35, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 36, "t": "the believers"}, {"w": 37, "t": "சிரமம்"}, {"w": 38, "t": "மனைவிகள் விஷயத்தில்"}, {"w": 39, "t": "the wives"}, {"w": 40, "t": "அவர்களது வளர்ப்பு பிள்ளைகளின்"}, {"w": 41, "t": "அவர்கள் முடித்துவிட்டபோது"}, {"w": 42, "t": "they have ended"}, {"w": 43, "t": "அவர்களிடம்"}, {"w": 44, "t": "தேவையை"}, {"w": 45, "t": "இருக்கின்றது/காரியம்"}, {"w": 46, "t": "(the) Command"}, {"w": 47, "t": "அல்லாஹ்வின்"}, {"w": 48, "t": "நடக்கக்கூடியதாக"}, {"w": 49, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "இருக்கவில்லை"}, {"w": 2, "t": "(there can) be"}, {"w": 3, "t": "மீது"}, {"w": 4, "t": "நபியின்"}, {"w": 5, "t": "அறவே குற்றம்"}, {"w": 6, "t": "discomfort"}, {"w": 7, "t": "கடமையாக்கியதை"}, {"w": 8, "t": "Allah has imposed"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "தனக்கு"}, {"w": 11, "t": "வழிமுறையைத்தான்"}, {"w": 12, "t": "அல்லாஹ்வின்"}, {"w": 13, "t": "சென்றவர்களில்"}, {"w": 14, "t": "those who"}, {"w": 15, "t": "passed away"}, {"w": 16, "t": "இதற்கு முன்னர்"}, {"w": 17, "t": "before"}, {"w": 18, "t": "இருக்கின்றது"}, {"w": 19, "t": "செயல்"}, {"w": 20, "t": "அல்லாஹ்வின்"}, {"w": 21, "t": "தீர்ப்பாக"}, {"w": 22, "t": "நிறைவேற்றப்படுகின்ற"}, {"w": 23, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "அவர்கள் எடுத்த