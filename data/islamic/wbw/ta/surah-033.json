{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நபியே!"}, {"w": 2, "t": "O Prophet"}, {"w": 3, "t": "பயந்துகொள்ளுங்கள்!"}, {"w": 4, "t": "அல்லாஹ்வை"}, {"w": 5, "t": "கீழ்ப்படியாதீர்"}, {"w": 6, "t": "obey"}, {"w": 7, "t": "நிராகரிப்பவர்களுக்கும்"}, {"w": 8, "t": "நயவஞ்சகர்களுக்கும்"}, {"w": 9, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 10, "t": "Allah"}, {"w": 11, "t": "இருக்கின்றான்"}, {"w": 12, "t": "நன்கறிந்தவனாக"}, {"w": 13, "t": "மகா ஞானவானாக"}, {"w": 14, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இன்னும் பின்பற்றுவீராக"}, {"w": 2, "t": "வஹீ  அறிவிக்கப்படுவதை"}, {"w": 3, "t": "is inspired"}, {"w": 4, "t": "உமக்கு"}, {"w": 5, "t": "உமது இறைவனிடமிருந்து"}, {"w": 6, "t": "your Lord"}, {"w": 7, "t": "நிச்சயமாக"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "இருக்கின்றான்"}, {"w": 10, "t": "நீங்கள் செய்வதை"}, {"w": 11, "t": "you do"}, {"w": 12, "t": "ஆழ்ந்தறிந்தவனாக"}, {"w": 13, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் சார்ந்திருப்பீராக!"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "Allah"}, {"w": 4, "t": "போதுமானவன்"}, {"w": 5, "t": "அல்லாஹ்வே"}, {"w": 6, "t": "பொறுப்பாளனாக இருக்க"}, {"w": 7, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அமைக்கவில்லை"}, {"w": 2, "t": "Allah (has) made"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "ஒரு மனிதனுக்கு"}, {"w": 5, "t": "இரு உள்ளங்களை"}, {"w": 6, "t": "two hearts"}, {"w": 7, "t": "அவனது உடலில்"}, {"w": 8, "t": "his interior"}, {"w": 9, "t": "அவன்ஆக்கவில்லை"}, {"w": 10, "t": "He (has) made"}, {"w": 11, "t": "உங்கள்மனைவிகளை"}, {"w": 12, "t": "எவர்கள்"}, {"w": 13, "t": "ளிஹார்செய்கின்றீர்கள்"}, {"w": 14, "t": "அவர்களில்"}, {"w": 15, "t": "உங்கள் தாய்மார்களாக"}, {"w": 16, "t": "அவன்ஆக்கவில்லை"}, {"w": 17, "t": "He has made"}, {"w": 18, "t": "வளர்ப்புபிள்ளைகளை உங்கள்"}, {"w": 19, "t": "உங்கள் பிள்ளைகளாக"}, {"w": 20, "t": "அது"}, {"w": 21, "t": "நீங்கள் கூறுவதாகும்"}, {"w": 22, "t": "உங்கள் வாய்களால்"}, {"w": 23, "t": "அல்லாஹ்"}, {"w": 24, "t": "கூறுகின்றான்"}, {"w": 25, "t": "உண்மையை"}, {"w": 26, "t": "அவன்தான்"}, {"w": 27, "t": "வழிகாட்டுகின்றான்"}, {"w": 28, "t": "நல்ல பாதைக்கு"}, {"w": 29, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அழையுங்கள்! அவர்களை"}, {"w": 2, "t": "அவர்களது தந்தைகளுடன் (சேர்த்தே)"}, {"w": 3, "t": "அதுதான்"}, {"w": 4, "t": "மிக நீதமானது"}, {"w": 5, "t": "அல்லாஹ்விடம்"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "நீங்கள் அறியவில்லை என்றால்"}, {"w": 8, "t": "not"}, {"w": 9, "t": "you know"}, {"w": 10, "t": "தந்தைகளை அவர்களின்"}, {"w": 11, "t": "உங்கள் சகோதரர்கள்"}, {"w": 12, "t": "மார்க்கத்தில்"}, {"w": 13, "t": "[the] religion"}, {"w": 14, "t": "இன்னும் உங்கள் உதவியாளர்கள்"}, {"w": 15, "t": "இல்லை"}, {"w": 16, "t": "உங்கள் மீது"}, {"w": 17, "t": "குற்றம்"}, {"w": 18, "t": "எதில்"}, {"w": 19, "t": "நீங்கள் தவறு செய்தீர்களோ"}, {"w": 20, "t": "அதில்"}, {"w": 21, "t": "என்றாலும்"}, {"w": 22, "t": "எதை"}, {"w": 23, "t": "வேண்டுமென்று செய்தது"}, {"w": 24, "t": "உங்கள் உள்ளங்கள்"}, {"w": 25, "t": "இருக்கின்றான்"}, {"w": 26, "t": "அல்லாஹ்"}, {"w": 27, "t": "மகா மன்னிப்பாளனாக"}, {"w": 28, "t": "மகா கருணையாளனாக"}, {"w": 29, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நபிதான்"}, {"w": 2, "t": "மிக உரிமையாளர்"}, {"w": 3, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 4, "t": "அவர்களின் ஆன்மாக்களைவிட"}, {"w": 5, "t": "their own selves"}, {"w": 6, "t": "இன்னும் அவருடைய மனைவிமார்கள்"}, {"w": 7, "t": "அவர்களுக்கு தாய்மார்கள்"}, {"w": 8, "t": "இன்னும் இரத்தபந்தங்கள்"}, {"w": 9, "t": "(of) relationships"}, {"w": 10, "t": "அவர்களில் சிலர்"}, {"w": 11, "t": "உரிமையுள்ளவர்கள்"}, {"w": 12, "t": "சிலருக்கு"}, {"w": 13, "t": "வேதத்தின் படி"}, {"w": 14, "t": "(the) Decree"}, {"w": 15, "t": "அல்லாஹ்வின்"}, {"w": 16, "t": "நம்பிக்கையாளர்களை(யும்) விட"}, {"w": 17, "t": "the believers"}, {"w": 18, "t": "முஹாஜிர்களையும்"}, {"w": 19, "t": "தவிர"}, {"w": 20, "t": "நீங்கள்ஏதும்செய்தால்"}, {"w": 21, "t": "you do"}, {"w": 22, "t": "உங்கள் பொறுப்பாளர்களுக்கு"}, {"w": 23, "t": "your friends"}, {"w": 24, "t": "ஒரு நன்மையை"}, {"w": 25, "t": "இருக்கின்றது"}, {"w": 26, "t": "இது"}, {"w": 27, "t": "வேதத்தில்"}, {"w": 28, "t": "the Book"}, {"w": 29, "t": "எழுதப்பட்டதாக"}, {"w": 30, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நாம் வாங்கிய சமயத்தை நினைவு கூறுவீராக"}, {"w": 2, "t": "We took"}, {"w": 3, "t": "எல்லா நபிமார்களிடமும்"}, {"w": 4, "t": "the Prophets"}, {"w": 5, "t": "அவர்களின் ஒப்பந்தத்தை"}, {"w": 6, "t": "உம்மிடமும்"}, {"w": 7, "t": "இன்னும் நூஹிடம்"}, {"w": 8, "t": "Nuh"}, {"w": 9, "t": "இன்னும் இப்ராஹீம்"}, {"w": 10, "t": "இன்னும் மூஸா/இன்னும் ஈஸா"}, {"w": 11, "t": "and Isa"}, {"w": 12, "t": "மகன்"}, {"w": 13, "t": "மர்யமின்"}, {"w": 14, "t": "இன்னும் நாம் வாங்கினோம்"}, {"w": 15, "t": "அவர்களிடம்"}, {"w": 16, "t": "ஒப்பந்தத்தை"}, {"w": 17, "t": "உறுதியான"}, {"w": 18, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "விசாரிப்பதற்காக"}, {"w": 2, "t": "உண்மையாளர்களை"}, {"w": 3, "t": "அவர்களின் உண்மையைப் பற்றி"}, {"w": 4, "t": "their truth"}, {"w": 5, "t": "ஏற்படுத்திஇருக்கிறான்"}, {"w": 6, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 7, "t": "தண்டனையை"}, {"w": 8, "t": "வலிமிகுந்த(து)"}, {"w": 9, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "நினைத்துப் பாருங்கள்"}, {"w": 5, "t": "அருட்கொடையை"}, {"w": 6, "t": "அல்லாஹ்வின்"}, {"w": 7, "t": "உங்கள் மீதுள்ள"}, {"w": 8, "t": "உங்களிடம்வந்தபோது"}, {"w": 9, "t": "came to you"}, {"w": 10, "t": "பல ராணுவங்கள்"}, {"w": 11, "t": "நாம் அனுப்பினோம்"}, {"w": 12, "t": "அவர்களுக்கு எதிராக"}, {"w": 13, "t": "காற்றை(யும்)"}, {"w": 14, "t": "ராணுவங்களையும்"}, {"w": 15, "t": "நீங்கள் பார்க்கவில்லை/ அவர்களை"}, {"w": 16, "t": "you (could) see them"}, {"w": 17, "t": "இருக்கின்றான்"}, {"w": 18, "t": "அல்லாஹ்"}, {"w": 19, "t": "நீங்கள் செய்வதை"}, {"w": 20, "t": "you do"}, {"w": 21, "t": "உற்று நோக்கியவனாக"}, {"w": 22, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அவர்கள் வந்த சமயத்தில்"}, {"w": 2, "t": "உங்களிடம்"}, {"w": 3, "t": "உங்களுக்கு மேல் புறத்திலிருந்(தும்)"}, {"w": 4, "t": "above you"}, {"w": 5, "t": "கீழ்ப்புறத்திலிருந்தும்"}, {"w": 6, "t": "below"}, {"w": 7, "t": "உங்களுக்கு"}, {"w": 8, "t": "இன்னும் சமயத்தில்"}, {"w": 9, "t": "சொருகின"}, {"w": 10, "t": "பார்வைகள்"}, {"w": 11, "t": "இன்னும் எட்டின"}, {"w": 12, "t": "உள்ளங்கள்"}, {"w": 13, "t": "தொண்டைகளுக்கு"}, {"w": 14, "t": "நீங்கள் எண்ணினீர்கள்"}, {"w": 15, "t": "அல்லாஹ்வின் மீது"}, {"w": 16, "t": "பல எண்ணங்களை"}, {"w": 17, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அங்குதான்"}, {"w": 2, "t": "சோதிக்கப்பட்டார்கள்"}, {"w": 3, "t": "நம்பிக்கையாளர்கள்"}, {"w": 4, "t": "இன்னும் அச்சுறுத்தப்பட்டார்கள்"}, {"w": 5, "t": "(with a) shake"}, {"w": 6, "t": "கடுமையாக"}, {"w": 7, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் கூறிய சமயத்தை நினைவு கூறுங்கள்"}, {"w": 2, "t": "said"}, {"w": 3, "t": "நயவஞ்சகர்களும்"}, {"w": 4, "t": "இன்னும் எவர்கள்"}, {"w": 5, "t": "தங்கள் உள்ளங்களில்"}, {"w": 6, "t": "their hearts"}, {"w": 7, "t": "நோய்"}, {"w": 8, "t": "நமக்கு வாக்களிக்கவில்லை"}, {"w": 9, "t": "Allah promised us"}, {"w": 10, "t": "அல்லாஹ்(வும்)"}, {"w": 11, "t": "அவனது தூதரும்"}, {"w": 12, "t": "தவிர"}, {"w": 13, "t": "பொய்யை"}, {"w": 14, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "கூறிய சமயத்தை நினைவு கூறுங்கள்"}, {"w": 2, "t": "said"}, {"w": 3, "t": "ஒரு சாரார்"}, {"w": 4, "t": "அவர்களில்"}, {"w": 5, "t": "யஸ்ரிப் வாசிகளே!"}, {"w": 6, "t": "(of) Yathrib"}, {"w": 7, "t": "தங்குவது அறவே முடியாது"}, {"w": 8, "t": "stand"}, {"w": 9, "t": "உங்களுக்கு"}, {"w": 10, "t": "ஆகவே, திரும்பிவிடுங்கள்"}, {"w": 11, "t": "அனுமதிகேட்கின்றனர்"}, {"w": 12, "t": "ஒரு பிரிவினர்"}, {"w": 13, "t": "அவர்களில்"}, {"w": 14, "t": "நபியிடம்"}, {"w": 15, "t": "கூறியவர்களாக"}, {"w": 16, "t": "நிச்சயமாக"}, {"w": 17, "t": "எங்கள் இல்லங்கள்"}, {"w": 18, "t": "பாதுகாப்பு அற்றதாக இருக்கின்றன"}, {"w": 19, "t": "ஆனால் இல்லை."}, {"w": 20, "t": "அவை"}, {"w": 21, "t": "பாதுகாப்பு அற்றதாக"}, {"w": 22, "t": "அவர்கள் நாடவில்லை"}, {"w": 23, "t": "they wished"}, {"w": 24, "t": "தவிர"}, {"w": 25, "t": "விரண்டோடுவதை"}, {"w": 26, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நுழைந்தால்"}, {"w": 2, "t": "had been entered"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "சுற்றுப் புறங்களில் இருந்து"}, {"w": 5, "t": "சுற்றுப் புறங்களில் இருந்து அதன்"}, {"w": 6, "t": "பிறகு"}, {"w": 7, "t": "அவர்களிடம் கேட்கப்பட்டால்"}, {"w": 8, "t": "குழப்பத்தை"}, {"w": 9, "t": "அவர்கள் செய்திருப்பார்கள் அதை"}, {"w": 10, "t": "அவர்கள் தாமதித்திருக்க மாட்டார்கள்"}, {"w": 11, "t": "they (would) have hesitated"}, {"w": 12, "t": "அதற்கு"}, {"w": 13, "t": "கொஞ்சமே தவிர"}, {"w": 14, "t": "a little"}, {"w": 15, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "ஒப்பந்தம் செய்திருந்தனர்"}, {"w": 3, "t": "promised"}, {"w": 4, "t": "அல்லாஹ்விடம்"}, {"w": 5, "t": "இதற்கு முன்னர்"}, {"w": 6, "t": "before"}, {"w": 7, "t": "ஓடமாட்டார்கள்"}, {"w": 8, "t": "they would turn"}, {"w": 9, "t": "புறமுதுகிட்டு"}, {"w": 10, "t": "இருக்கின்றது"}, {"w": 11, "t": "ஒப்பந்தம்"}, {"w": 12, "t": "அல்லாஹ்வின்"}, {"w": 13, "t": "விசாரிக்கப்படுவதாக"}, {"w": 14, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "உங்களுக்கு அறவே பலனளிக்காது"}, {"w": 3, "t": "will benefit you"}, {"w": 4, "t": "விரண்டோடுவது"}, {"w": 5, "t": "நீங்கள் விரண்டோடினால்"}, {"w": 6, "t": "you flee"}, {"w": 7, "t": "மரணத்தைவிட்டு"}, {"w": 8, "t": "death"}, {"w": 9, "t": "அல்லது கொல்லப்படுவதை விட்டு"}, {"w": 10, "t": "killing"}, {"w": 11, "t": "அப்போதும்"}, {"w": 12, "t": "சுகமளிக்கப்பட மாட்டீர்கள்"}, {"w": 13, "t": "you will be allowed to enjoy"}, {"w": 14, "t": "கொஞ்சமே தவிர"}, {"w": 15, "t": "a little"}, {"w": 16, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "யார்?"}, {"w": 3, "t": "உங்களைப் பாதுகாக்கின்றவர்"}, {"w": 4, "t": "(is) it that"}, {"w": 5, "t": "(can) protect you"}, {"w": 6, "t": "அல்லாஹ்வைவிட்டும்"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "நாடினால்"}, {"w": 9, "t": "He intends"}, {"w": 10, "t": "உங்களுக்கு"}, {"w": 11, "t": "ஒரு தீங்கை"}, {"w": 12, "t": "அல்லது/அ