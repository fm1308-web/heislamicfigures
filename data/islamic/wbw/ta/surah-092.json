{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "இரவின் மீது சத்தியமாக"}, {"w": 2, "t": "மூடும் போது"}, {"w": 3, "t": "it covers"}, {"w": 4, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "பகலின் மீது சத்தியமாக"}, {"w": 2, "t": "அது வெளிப்படும் போது"}, {"w": 3, "t": "it shines in brightness"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "படைத்தவன் மீது சத்தியமாக"}, {"w": 2, "t": "created"}, {"w": 3, "t": "ஆணை"}, {"w": 4, "t": "இன்னும் பெண்ணை"}, {"w": 5, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உங்கள் முயற்சி"}, {"w": 3, "t": "பலதரப்பட்டதுதான்"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "ஆகவே, யார்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "தர்மம் புரிந்தார்"}, {"w": 4, "t": "இன்னும் அல்லாஹ்வை அஞ்சினார்"}, {"w": 5, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இன்னும் உண்மைப்படுத்தினார்"}, {"w": 2, "t": "மிக அழகியதை"}, {"w": 3, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவருக்கு இலகுவாக்குவோம்"}, {"w": 2, "t": "சொர்க்கப் பாதையை"}, {"w": 3, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஆக யார்?/கஞ்சத்தனம் செய்தான்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "withholds"}, {"w": 4, "t": "இன்னும் தேவையற்றவனாகக் கருதினான்"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் பொய்ப்பித்தான்"}, {"w": 2, "t": "மிக அழகியதை"}, {"w": 3, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அவனுக்கு இலகுவாக்குவோம்"}, {"w": 2, "t": "நரகத்தின் பாதையை"}, {"w": 3, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "இன்னும் பலனளிக்காது"}, {"w": 2, "t": "will avail"}, {"w": 3, "t": "அவனுக்கு"}, {"w": 4, "t": "அவனுடைய செல்வம்"}, {"w": 5, "t": "அவன்விழும்போது"}, {"w": 6, "t": "he falls"}, {"w": 7, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம்மீது"}, {"w": 3, "t": "நேர்வழி காட்டுவதுதான்"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக"}, {"w": 2, "t": "நமக்கே"}, {"w": 3, "t": "மறுமை"}, {"w": 4, "t": "இன்னும் இம்மை"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "ஆகவே, உங்களுக்கு அச்சமூட்டி எச்சரித்தேன்"}, {"w": 2, "t": "நெருப்பை"}, {"w": 3, "t": "கொழுந்துவிட்டெரிகின்றது"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அதில் பற்றி எரிய மாட்டான்"}, {"w": 2, "t": "will burn (in) it"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "பெரும் தீயவன்"}, {"w": 5, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "எவன்"}, {"w": 2, "t": "பொய்ப்பித்தான்"}, {"w": 3, "t": "இன்னும் புறக்கணித்தான்"}, {"w": 4, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இன்னும் அதிலிருந்து தூரமாக்கப்படுவார்"}, {"w": 2, "t": "அல்லாஹ்வை அதிகம் அஞ்சுகிறவர்"}, {"w": 3, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "எவர்/கொடுக்கிறார்"}, {"w": 2, "t": "gives"}, {"w": 3, "t": "தனது செல்வத்தை"}, {"w": 4, "t": "மனத்தூய்மையை நாடியவராக"}, {"w": 5, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் இல்லை/ஒருவரின்"}, {"w": 2, "t": "for anyone"}, {"w": 3, "t": "அவரிடம்"}, {"w": 4, "t": "உபகாரம் ஏதும்"}, {"w": 5, "t": "favor"}, {"w": 6, "t": "கூலிகொடுக்கப்படும்"}, {"w": 7, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "தவிர/தேடுவதை"}, {"w": 2, "t": "seeking"}, {"w": 3, "t": "முகத்தை"}, {"w": 4, "t": "தன் இறைவனின்"}, {"w": 5, "t": "மிக உயர்ந்தவனான"}, {"w": 6, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "திருப்தியடைவார்"}, {"w": 3, "t": "(21)"}]}]}