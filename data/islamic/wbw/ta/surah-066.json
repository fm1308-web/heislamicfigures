{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நபியே!"}, {"w": 2, "t": "Prophet"}, {"w": 3, "t": "நீர் ஏன் விலக்கிக் கொள்கிறீர்"}, {"w": 4, "t": "you prohibit"}, {"w": 5, "t": "ஆகுமாக்கியதை"}, {"w": 6, "t": "has made lawful"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "உமக்கு"}, {"w": 9, "t": "நாடுகிறீர்"}, {"w": 10, "t": "பொருத்தத்தை"}, {"w": 11, "t": "உமது மனைவிகளின்"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "மகா மன்னிப்பாளன்"}, {"w": 14, "t": "மகா கருணையாளன்"}, {"w": 15, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "கடமையாக்கியுள்ளான்"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "உங்களுக்கு"}, {"w": 5, "t": "முறிப்பதை"}, {"w": 6, "t": "உங்கள் சத்தியங்களை"}, {"w": 7, "t": "அல்லாஹ்தான்"}, {"w": 8, "t": "உங்கள் எஜமானன்"}, {"w": 9, "t": "அவன்தான்"}, {"w": 10, "t": "நன்கறிந்தவன்"}, {"w": 11, "t": "மகா ஞானவான்"}, {"w": 12, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இரகசியமாக பேசியபோது/நபி"}, {"w": 2, "t": "confided"}, {"w": 3, "t": "the Prophet"}, {"w": 4, "t": "சிலரிடம்"}, {"w": 5, "t": "one"}, {"w": 6, "t": "தனது மனைவிமார்களில்"}, {"w": 7, "t": "ஒரு பேச்சை"}, {"w": 8, "t": "அவள் அறிவித்து விட்டபோது/அதை"}, {"w": 9, "t": "she informed"}, {"w": 10, "t": "about it"}, {"w": 11, "t": "இன்னும் அதை வெளிப்படுத்தினான்"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "அவருக்கு"}, {"w": 14, "t": "அவர் அறிவித்தார்"}, {"w": 15, "t": "அதில் சிலவற்றை"}, {"w": 16, "t": "இன்னும் புறக்கணித்து விட்டார்"}, {"w": 17, "t": "சிலவற்றை"}, {"w": 18, "t": "a part"}, {"w": 19, "t": "அவர் அவளுக்கு அறிவித்த போது/அதை"}, {"w": 20, "t": "he informed her"}, {"w": 21, "t": "about it"}, {"w": 22, "t": "அவள் கூறினாள்"}, {"w": 23, "t": "யார்"}, {"w": 24, "t": "உமக்கு அறிவித்தார்"}, {"w": 25, "t": "இதை"}, {"w": 26, "t": "அவர் கூறினார்"}, {"w": 27, "t": "எனக்கு அறிவித்தான்"}, {"w": 28, "t": "நன்கறிபவன்"}, {"w": 29, "t": "ஆழ்ந்தறிபவன்"}, {"w": 30, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நீங்கள் இருவரும் திரும்பிவிட்டால்"}, {"w": 2, "t": "you both turn"}, {"w": 3, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "ஏனெனில், திட்டமாக"}, {"w": 6, "t": "சாய்ந்து விட்டன"}, {"w": 7, "t": "உங்கள் இருவரின் உள்ளங்களும்"}, {"w": 8, "t": "நீங்கள் இருவரும் உதவினால்"}, {"w": 9, "t": "you backup each other"}, {"w": 10, "t": "அவருக்கு எதிராக"}, {"w": 11, "t": "ஏனெனில், நிச்சயமாக அல்லாஹ்தான்"}, {"w": 12, "t": "Allah"}, {"w": 13, "t": "He"}, {"w": 14, "t": "அவருக்குப் பாதுகாவலன்"}, {"w": 15, "t": "இன்னும் ஜிப்ரீலும்"}, {"w": 16, "t": "இன்னும் நல்ல முஃமின்களும்"}, {"w": 17, "t": "believers"}, {"w": 18, "t": "வானவர்களும்"}, {"w": 19, "t": "இதற்குப் பின்னர்"}, {"w": 20, "t": "that"}, {"w": 21, "t": "உதவியாளர்கள்"}, {"w": 22, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "கூடும்/அவருடைய இறைவன்"}, {"w": 2, "t": "his Lord"}, {"w": 3, "t": "அவர் உங்களை விவாகரத்து செய்து விட்டால்"}, {"w": 4, "t": "he divorced you"}, {"w": 5, "t": "அவருக்கு பகரமாக வழங்குவான்"}, {"w": 6, "t": "He will substitute for him"}, {"w": 7, "t": "மனைவிகளை"}, {"w": 8, "t": "சிறந்தவர்களான"}, {"w": 9, "t": "உங்களை விட"}, {"w": 10, "t": "முற்றிலும் பணியக்கூடிய"}, {"w": 11, "t": "நம்பிக்கை கொள்ளக்கூடிய"}, {"w": 12, "t": "கீழ்ப்படியக்கூடிய"}, {"w": 13, "t": "வணக்க வழிபாடு செய்யக்கூடிய"}, {"w": 14, "t": "வணக்க வழிபாடு செய்யக்கூடிய"}, {"w": 15, "t": "நோன்பு நோற்கக்கூடிய"}, {"w": 16, "t": "கன்னி கழிந்தவர்களும்"}, {"w": 17, "t": "கன்னிகளும்"}, {"w": 18, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "(you) who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "பாதுகாத்துக் கொள்ளுங்கள்"}, {"w": 5, "t": "உங்களையும்"}, {"w": 6, "t": "உங்கள் குடும்பத்தாரையும்"}, {"w": 7, "t": "நரகத்தைவிட்டு"}, {"w": 8, "t": "அதன் எரிபொருள்"}, {"w": 9, "t": "மக்களும்/கற்களும்"}, {"w": 10, "t": "and stones"}, {"w": 11, "t": "அவற்றின் மீது"}, {"w": 12, "t": "வானவர்கள்"}, {"w": 13, "t": "முரடர்களாக"}, {"w": 14, "t": "கடுமையானவர்களான"}, {"w": 15, "t": "மாறு செய்யமாட்டார்கள்"}, {"w": 16, "t": "they disobey"}, {"w": 17, "t": "அல்லாஹ்விற்கு"}, {"w": 18, "t": "அவன் அவர்களுக்கு ஏவியதில்/இன்னும் செய்வார்கள்"}, {"w": 19, "t": "He Commands them"}, {"w": 20, "t": "but they do"}, {"w": 21, "t": "அவர்கள் எதற்கு ஏவப்பட்டார்களோ"}, {"w": 22, "t": "they are commanded"}, {"w": 23, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிராகரித்தவர்களே!"}, {"w": 2, "t": "(you) who"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "நீங்கள் காரணம் கூறாதீர்கள்"}, {"w": 5, "t": "make excuses"}, {"w": 6, "t": "இன்று"}, {"w": 7, "t": "நீங்கள் கூலி கொடுக்கப்படுவதெல்லாம்"}, {"w": 8, "t": "you will be recompensed"}, {"w": 9, "t": "நீங்கள் செய்து கொண்டிருந்தவற்றுக்குத்தான்"}, {"w": 10, "t": "you used to"}, {"w": 11, "t": "do"}, {"w": 12, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "(you) who believe"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "திரும்புங்கள்"}, {"w": 5, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "பாவமன்னிப்புக் கேட்டு"}, {"w": 8, "t": "உண்மையாக"}, {"w": 9, "t": "கூடும்/உங்கள் இறைவன்"}, {"w": 10, "t": "your Lord"}, {"w": 11, "t": "போக்குவதற்கு"}, {"w": 12, "t": "remove"}, {"w": 13, "t": "உங்களை விட்டும்"}, {"w": 14, "t": "உங்கள் பாவங்களை"}, {"w": 15, "t": "இன்னும் உங்களை பிரவேசிக்க வைப்பான்"}, {"w": 16, "t": "சொர்க்கங்களில்"}, {"w": 17, "t": "ஓடும்"}, {"w": 18, "t": "அவற்றின் கீழ்"}, {"w": 19, "t": "underneath it"}, {"w": 20, "t": "நதிகள்"}, {"w": 21, "t": "அந்நாளில்"}, {"w": 22, "t": "கேவலப்படுத்த மாட்டான்"}, {"w": 23, "t": "will be disgraced"}, {"w": 24, "t": "அல்லாஹ்"}, {"w": 25, "t": "நபியையும்"}, {"w": 26, "t": "நம்பிக்கை கொண்டவர்களையும்/அவருடன்"}, {"w": 27, "t": "believed"}, {"w": 28, "t": "with him"}, {"w": 29, "t": "அவர்களின் ஒளி"}, {"w": 30, "t": "விரைந்து வரும்"}, {"w": 31, "t": "அவர்களுக்கு முன்னும்"}, {"w": 32, "t": "their hands"}, {"w": 33, "t": "அவர்களின் வலப்பக்கங்களிலும்"}, {"w": 34, "t": "கூறுவார்கள்"}, {"w": 35, "t": "எங்கள் இறைவா!"}, {"w": 36, "t": "முழுமையாக்கு!"}, {"w": 37, "t": "எங்களுக்கு"}, {"w": 38, "t": "எங்கள் ஒளியை"}, {"w": 39, "t": "இன்னும் எங்களை மன்னிப்பாயாக!"}, {"w": 40, "t": "to us"}, {"w": 41, "t": "நிச்சயமாக நீ"}, {"w": 42, "t": "எல்லாப் பொருள்கள் மீதும்"}, {"w": 43, "t": "every"}, {"w": 44, "t": "thing"}, {"w": 45, "t": "பேராற்றலுடையவன்"}, {"w": 46, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நபியே!"}, {"w": 2, "t": "Prophet"}, {"w": 3, "t": "ஜிஹாது செய்வீராக"}, {"w": 4, "t": "நிராகரிப்பாளர்களிடமும்"}, {"w": 5, "t": "நயவஞ்சகர்களிடமும்"}, {"w": 6, "t": "இன்னும் கடுமை காட்டுவீராக"}, {"w": 7, "t": "அவர்களிடம்"}, {"w": 8, "t": "அவர்களின் தங்குமிடம்"}, {"w": 9, "t": "நரகம்தான்"}, {"w": 10, "t": "மிகக் கெட்டதாகும்"}, {"w": 11, "t": "மீளுமிடங்களில்"}, {"w": 12, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "விவரிக்கின்றான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "ஓர் உதாரணமாக"}, {"w": 4, "t": "நிராகரித்தவர்களுக்கு"}, {"w": 5, "t": "disbelieved "}, {"w": 6, "t": "மனைவியையும்"}, {"w": 7, "t": "நூஹூடைய"}, {"w": 8, "t": "மனைவியையும்"}, {"w": 9, "t": "லூத்துடைய"}, {"w": 10, "t": "இருவரும் இருந்தனர்"}, {"w": 11, "t": "கீழ்"}, {"w": 12, "t": "இரு அடியார்களுக்கு"}, {"w": 13, "t": "நமது அடியார்களில்"}, {"w": 14, "t": "Our slaves"}, {"w": 15, "t": "நல்ல(வர்கள்)"}, {"w": 16, "t": "அவ்விருவரும் அவ்விருவருக்கும் மோசடி செய்தனர்"}, {"w": 17, "t": "ஆகவே, அவ்விருவரும் தடுக்கவில்லை"}, {"w": 18, "t": "they availed"}, {"w": 19, "t": "அவ்விருவரைவிட்டும்"}, {"w": 20, "t": "அல்லாஹ்விடம்"}, {"w": 21, "t": "Allah"}, {"w": 22, "t": "எதையும்/கூறப்பட்டது"}, {"w": 23, "t": "and it was said"}, {"w": 24, "t": "நீங்கள் இருவரும் நுழையுங்கள்"}, {"w": 25, "t": "நரகத்தில்"}, {"w": 26, "t": "நுழைபவர்களுடன்"}, {"w": 27, "t": "those who enter"}, {"w": 28, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "விவரிக்கின்றான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "உதாரணமாக"}, {"w": 4, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 5, "t": "believed "}, {"w": 6, "t": "மனைவியை"}, {"w": 7, "t": "ஃபிர்அவ்னின்"}, {"w": 8, "t": "அவள் கூறிய சமயத்தை நினைவு கூர்வீராக!"}, {"w": 9, "t": "she said"}, {"w": 10, "t": "என் இறைவா"}, {"w": 11, "t": "அமைத்துத் தா!"}, {"w": 12, "t": "எனக்கு"}, {"w": 13, "t": "உன்னிடம்"}, {"w": 14, "t": "ஓர் இல்லத்தை"}, {"w": 15, "t": "சொர்க்கத்தில்"}, {"w": 16, "t": "Paradise"}, {"w": 17, "t": "இன்னும் என்னை பாதுகாத்துக் கொள்"}, {"w": 18, "t": "ஃபிர்அவ்னை விட்டும்"}, {"w": 19, "t": "Firaun"}, {"w": 20, "t": "இன்னும் அவனது செயல்களை"}, {"w": 21, "t": "இன்னும் என்னை பாதுகாத்துக் கொள்"}, {"w": 22, "t": "மக்களை விட்டும்"}, {"w": 23, "t": "the people"}, {"w": 24, "t": "அநியாயக்கார(ர்கள்)"}, {"w": 25, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் மர்யமை"}, {"w": 2, "t": "மகள்"}, {"w": 3, "t": "இம்ரானின்"}, {"w": 4, "t": "எவள்"}, {"w": 5, "t": "பேணிக்கொண்டாள்"}, {"w": 6, "t": "தனது மறைவிடத்தை"}, {"w": 7, "t": "ஆகவே நாம் ஊதினோம்"}, {"w": 8, "t": "அதில்"}, {"w": 9, "t": "நமது உயிரிலிருந்து"}, {"w": 10, "t": "Our Spirit"}, {"w": 11, "t": "இன்னும் உண்மைப்படுத்தினாள்"}, {"w": 12, "t": "வாக்கியங்களையும்"}, {"w": 13, "t": "தனது இறைவனின்"}, {"w": 14, "t": "அவனது வேதங்களையும்"}, {"w": 15, "t": "இன்னும் இருந்தாள்"}, {"w": 16, "t": "மிகவும் பணிந்தவர்களில்"}, {"w": 17, "t": "the devoutly obedient"}, {"w": 18, "t": "(12)"}]}]}