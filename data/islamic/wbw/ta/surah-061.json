{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "துதிக்கின்றார்கள்"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "வானங்களில் உள்ளவர்களும்"}, {"w": 4, "t": "(is) in"}, {"w": 5, "t": "the heavens"}, {"w": 6, "t": "பூமியில் உள்ளவர்களும்"}, {"w": 7, "t": "(is) in"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "அவன்தான்"}, {"w": 10, "t": "மிகைத்தவன்"}, {"w": 11, "t": "மகா ஞானவான்"}, {"w": 12, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "(you) who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "ஏன் கூறுகிறீர்கள்?"}, {"w": 5, "t": "(do) you say"}, {"w": 6, "t": "நீங்கள் செய்யாதவற்றை"}, {"w": 7, "t": "not"}, {"w": 8, "t": "you do"}, {"w": 9, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "பெரும் கோபத்திற்குரியது"}, {"w": 2, "t": "hatred"}, {"w": 3, "t": "அல்லாஹ்விடம்"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "நீங்கள் கூறுவது"}, {"w": 6, "t": "you say"}, {"w": 7, "t": "நீங்கள் செய்யாதவற்றை"}, {"w": 8, "t": "not"}, {"w": 9, "t": "you do"}, {"w": 10, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 2, "t": "Allah"}, {"w": 3, "t": "விரும்புகின்றான்"}, {"w": 4, "t": "போர் புரிபவர்களை"}, {"w": 5, "t": "fight"}, {"w": 6, "t": "அவனுடைய பாதையில்"}, {"w": 7, "t": "His Way"}, {"w": 8, "t": "வரிசையாக நின்று"}, {"w": 9, "t": "அவர்களோ கட்டிடத்தைப் போல்"}, {"w": 10, "t": "(were) a structure"}, {"w": 11, "t": "உறுதியான(து)"}, {"w": 12, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "கூறிய சமயத்தை நினைவு கூர்வீராக!"}, {"w": 2, "t": "said"}, {"w": 3, "t": "மூஸா"}, {"w": 4, "t": "தனது மக்களுக்கு"}, {"w": 5, "t": "என் மக்களே!"}, {"w": 6, "t": "எனக்கு ஏன் தொந்தரவு தருகிறீர்கள்?"}, {"w": 7, "t": "do you hurt me"}, {"w": 8, "t": "திட்டமாக"}, {"w": 9, "t": "நீங்கள் அறிவீர்கள்"}, {"w": 10, "t": "நிச்சயமாக நான்"}, {"w": 11, "t": "தூதர்"}, {"w": 12, "t": "அல்லாஹ்வின்"}, {"w": 13, "t": "உங்களுக்கு"}, {"w": 14, "t": "அவர்கள் சருகிய போது"}, {"w": 15, "t": "they deviated"}, {"w": 16, "t": "திருப்பிவிட்டான்"}, {"w": 17, "t": "அல்லாஹ்(வும்)"}, {"w": 18, "t": "அவர்களின் உள்ளங்களை"}, {"w": 19, "t": "அல்லாஹ்"}, {"w": 20, "t": "நேர்வழி செலுத்த மாட்டான்"}, {"w": 21, "t": "guide"}, {"w": 22, "t": "மக்களை"}, {"w": 23, "t": "பாவிகளான"}, {"w": 24, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கூறியதை நினைவு கூர்வீராக!"}, {"w": 2, "t": "said"}, {"w": 3, "t": "ஈஸா"}, {"w": 4, "t": "மர்யமுடைய மகன்"}, {"w": 5, "t": "(of) Maryam"}, {"w": 6, "t": "இஸ்ரவேலர்களே!"}, {"w": 7, "t": "(of) Israel"}, {"w": 8, "t": "நிச்சயமாக நான்"}, {"w": 9, "t": "தூதர்"}, {"w": 10, "t": "அல்லாஹ்வின்"}, {"w": 11, "t": "உங்களுக்கு"}, {"w": 12, "t": "நான் உண்மைப்படுத்துகின்றேன்"}, {"w": 13, "t": "எனக்கு முன்னுள்ளதை"}, {"w": 14, "t": "(was) between"}, {"w": 15, "t": "my hands"}, {"w": 16, "t": "தவ்றாத்தை"}, {"w": 17, "t": "the Taurat"}, {"w": 18, "t": "இன்னும் நற்செய்தி கூறுகின்றேன்"}, {"w": 19, "t": "ஒரு தூதரை"}, {"w": 20, "t": "வருகின்றார்"}, {"w": 21, "t": "எனக்குப் பின்"}, {"w": 22, "t": "after me"}, {"w": 23, "t": "அவரது பெயர்"}, {"w": 24, "t": "அஹ்மத்"}, {"w": 25, "t": "அவர் வந்த போது"}, {"w": 26, "t": "அவர்களிடம்"}, {"w": 27, "t": "அத்தாட்சிகளுடன்"}, {"w": 28, "t": "கூறினார்கள்"}, {"w": 29, "t": "இது"}, {"w": 30, "t": "சூனியமாகும்"}, {"w": 31, "t": "தெளிவான"}, {"w": 32, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "யார்?/அநியாயக்காரர்"}, {"w": 2, "t": "(is) more wrong"}, {"w": 3, "t": "இட்டுக் கட்டுபவரை விட"}, {"w": 4, "t": "invents"}, {"w": 5, "t": "அல்லாஹ்வின் மீது"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "பொய்யை"}, {"w": 8, "t": "அவரோ"}, {"w": 9, "t": "அழைக்கப்படுகிறார்"}, {"w": 10, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 11, "t": "Islam"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "நேர்வழி செலுத்த மாட்டான்"}, {"w": 14, "t": "guide"}, {"w": 15, "t": "மக்களை"}, {"w": 16, "t": "அநியாயக்கார(ர்கள்)"}, {"w": 17, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவர்கள் நாடுகின்றனர்"}, {"w": 2, "t": "அவர்கள் அணைத்துவிட"}, {"w": 3, "t": "ஒளியை"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "தங்களது வாய்களினால்"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "முழுமைப்படுத்துவான்"}, {"w": 8, "t": "தனது ஒளியை"}, {"w": 9, "t": "வெறுத்தாலும் சரியே!"}, {"w": 10, "t": "dislike"}, {"w": 11, "t": "நிராகரிப்பாளர்கள்"}, {"w": 12, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "அனுப்பினான்"}, {"w": 4, "t": "தனது தூதரை"}, {"w": 5, "t": "நேர்வழியைக் கொண்டும்"}, {"w": 6, "t": "இன்னும் சத்திய மார்க்கத்தை"}, {"w": 7, "t": "(of) the truth"}, {"w": 8, "t": "அதை மேலோங்க வைப்பதற்காக"}, {"w": 9, "t": "எல்லா மார்க்கங்களை விட"}, {"w": 10, "t": "the religion"}, {"w": 11, "t": "all of them"}, {"w": 12, "t": "வெறுத்தாலும் சரியே!"}, {"w": 13, "t": "dislike (it)"}, {"w": 14, "t": "இணைவைப்பவர்கள்"}, {"w": 15, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "(you) who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "உங்களுக்கு நான் அறிவிக்கட்டுமா?"}, {"w": 5, "t": "I guide you"}, {"w": 6, "t": "ஒரு வியாபாரத்தை"}, {"w": 7, "t": "a transaction"}, {"w": 8, "t": "அது உங்களை பாதுகாக்கும்"}, {"w": 9, "t": "தண்டனையை விட்டும்"}, {"w": 10, "t": "a punishment"}, {"w": 11, "t": "வலி தரக்கூடிய(து)"}, {"w": 12, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நீங்கள் நம்பிக்கை கொள்ள வேண்டும்"}, {"w": 2, "t": "அல்லாஹ்வையும்"}, {"w": 3, "t": "அவனது தூதரையும்"}, {"w": 4, "t": "இன்னும் ஜிஹாது செய்யுங்கள்!"}, {"w": 5, "t": "பாதையில்"}, {"w": 6, "t": "(the) way"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "உங்கள் செல்வங்களாலும்"}, {"w": 9, "t": "உங்கள் உயிர்களாலும்"}, {"w": 10, "t": "அதுதான்"}, {"w": 11, "t": "சிறந்தது"}, {"w": 12, "t": "உங்களுக்கு"}, {"w": 13, "t": "நீங்கள் இருந்தால்"}, {"w": 14, "t": "you"}, {"w": 15, "t": "அறிபவர்களாக"}, {"w": 16, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவன் மன்னிப்பான்"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "உங்கள் பாவங்களை"}, {"w": 4, "t": "இன்னும் உங்களை நுழைப்பான்"}, {"w": 5, "t": "சொர்க்கங்களில்"}, {"w": 6, "t": "ஓடும்"}, {"w": 7, "t": "அவற்றின் கீழ்"}, {"w": 8, "t": "underneath it"}, {"w": 9, "t": "நதிகள்"}, {"w": 10, "t": "இன்னும் தங்குமிடங்களில்"}, {"w": 11, "t": "உயர்ந்த"}, {"w": 12, "t": "சொர்க்கங்களில்"}, {"w": 13, "t": "Gardens"}, {"w": 14, "t": "அத்ன்"}, {"w": 15, "t": "இதுதான்"}, {"w": 16, "t": "மகத்தான வெற்றி"}, {"w": 17, "t": "the great"}, {"w": 18, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "வேறு ஒன்றும்"}, {"w": 2, "t": "அதை நீங்கள் விரும்புவீர்கள்"}, {"w": 3, "t": "உதவியும்"}, {"w": 4, "t": "அல்லாஹ்வின் புறத்தில் இருந்து"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "வெற்றியும்"}, {"w": 7, "t": "வெகு விரைவில்"}, {"w": 8, "t": "இன்னும் நற்செய்தி கூறுவீராக"}, {"w": 9, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 10, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "நீங்கள் ஆகிவிடுங்கள்"}, {"w": 5, "t": "உதவியாளர்களாக"}, {"w": 6, "t": "அல்லாஹ்வின்"}, {"w": 7, "t": "கூறியதைப் போன்று"}, {"w": 8, "t": "said"}, {"w": 9, "t": "ஈஸா"}, {"w": 10, "t": "மர்யமுடைய மகன்"}, {"w": 11, "t": "(of) Maryam"}, {"w": 12, "t": "உற்ற தோழர்களை நோக்கி"}, {"w": 13, "t": "யார்"}, {"w": 14, "t": "எனது உதவியாளர்கள்"}, {"w": 15, "t": "அல்லாஹ்விற்காக"}, {"w": 16, "t": "Allah"}, {"w": 17, "t": "கூறினார்(கள்)"}, {"w": 18, "t": "உற்றதோழர்கள்"}, {"w": 19, "t": "நாங்கள்"}, {"w": 20, "t": "உதவி செய்பவர்கள்"}, {"w": 21, "t": "அல்லாஹ்விற்கு"}, {"w": 22, "t": "ஆகவே நம்பிக்கை கொண்டது"}, {"w": 23, "t": "ஒரு பிரிவு"}, {"w": 24, "t": "இஸ்ரவேலர்களில்"}, {"w": 25, "t": "Children"}, {"w": 26, "t": "(of) Israel"}, {"w": 27, "t": "இன்னும் நிராகரித்தது"}, {"w": 28, "t": "ஒரு பிரிவு"}, {"w": 29, "t": "ஆகவே, நாம் பலப்படுத்தினோம்"}, {"w": 30, "t": "நம்பிக்கை கொண்டவர்களை"}, {"w": 31, "t": "believed"}, {"w": 32, "t": "அவர்களின் பகைவர்களுக்கு எதிராக"}, {"w": 33, "t": "their enemy"}, {"w": 34, "t": "ஆகவே ஆகிவிட்டார்கள்"}, {"w": 35, "t": "வெற்றியாளர்களாக"}, {"w": 36, "t": "(14)"}]}]}