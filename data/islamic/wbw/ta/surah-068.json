{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நூன்/எழுது கோல் மீது(ம்) சத்தியமாக!"}, {"w": 2, "t": "By the pen"}, {"w": 3, "t": "இன்னும் அவர்கள் எழுதுகின்றவற்றின் மீதும்"}, {"w": 4, "t": "they write"}, {"w": 5, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நீர் இல்லை"}, {"w": 2, "t": "you (are)"}, {"w": 3, "t": "அருளால்"}, {"w": 4, "t": "உமது இறைவனின்"}, {"w": 5, "t": "பைத்தியக்காரராக"}, {"w": 6, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உமக்கு"}, {"w": 3, "t": "நற்கூலி உண்டு"}, {"w": 4, "t": "முடிவற்ற"}, {"w": 5, "t": "end"}, {"w": 6, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நிச்சயமாக நீர்"}, {"w": 2, "t": "நற்குணத்தில்"}, {"w": 3, "t": "(of) a moral character"}, {"w": 4, "t": "மகத்தான"}, {"w": 5, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "விரைவில் நீரும் காண்பீர்"}, {"w": 2, "t": "அவர்களும் காண்பார்கள்"}, {"w": 3, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "உங்களில் யார்"}, {"w": 2, "t": "சோதிக்கப்பட்டவர்"}, {"w": 3, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உமது இறைவன்"}, {"w": 3, "t": "அவன்"}, {"w": 4, "t": "மிக அறிந்தவன்"}, {"w": 5, "t": "வழிதவறியவனை"}, {"w": 6, "t": "has strayed"}, {"w": 7, "t": "அவனது பாதையில் இருந்து"}, {"w": 8, "t": "His way"}, {"w": 9, "t": "அவன்தான்"}, {"w": 10, "t": "மிக அறிந்தவன்"}, {"w": 11, "t": "நேர்வழி பெற்றவர்களை(யும்)"}, {"w": 12, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஆகவே, நீர் கீழ்ப்படியாதீர்"}, {"w": 2, "t": "obey"}, {"w": 3, "t": "பொய்ப்பிப்பவர்களுக்கு"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "ஆசைப்படுகின்றனர்"}, {"w": 2, "t": "நீர் அனுசரித்து போகவேண்டும் என்று"}, {"w": 3, "t": "you should compromise"}, {"w": 4, "t": "அப்படியென்றால் அவர்களும் அனுசரிப்பார்கள்"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நீர் கீழ்ப்படியாதீர்!"}, {"w": 2, "t": "obey"}, {"w": 3, "t": "எவருக்கும்"}, {"w": 4, "t": "அதிகம் சத்தியம் செய்கின்றவன்"}, {"w": 5, "t": "அற்பமானவன்"}, {"w": 6, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அதிகம் புறம் பேசுபவன்"}, {"w": 2, "t": "அதிகம் கோள் சொல்பவன்"}, {"w": 3, "t": "with malicious gossip"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அதிகம் தடுப்பவன்"}, {"w": 2, "t": "நன்மையை"}, {"w": 3, "t": "வரம்பு மீறி"}, {"w": 4, "t": "பெரும் பாவி"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அசிங்கமானவன்"}, {"w": 2, "t": "பிறகு"}, {"w": 3, "t": "இதற்கு"}, {"w": 4, "t": "ஈனன்"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இருந்த காரணத்தால்"}, {"w": 2, "t": "(he) is"}, {"w": 3, "t": "செல்வ(மு)ம் உடையவனாக"}, {"w": 4, "t": "(of) wealth"}, {"w": 5, "t": "ஆண் பிள்ளைகளும்"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஓதப்பட்டால்"}, {"w": 2, "t": "are recited"}, {"w": 3, "t": "அவன் மீது"}, {"w": 4, "t": "நமது வசனங்கள்"}, {"w": 5, "t": "கூறுகின்றான்"}, {"w": 6, "t": "கட்டுக் கதைகள்"}, {"w": 7, "t": "முன்னோரின்"}, {"w": 8, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "விரைவில் அவனுக்கு அடையாளமிடுவோம்"}, {"w": 2, "t": "மூக்கின் மீது"}, {"w": 3, "t": "the snout"}, {"w": 4, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அவர்களை சோதித்தோம்"}, {"w": 3, "t": "நாம் சோதித்ததுபோல்"}, {"w": 4, "t": "We tried"}, {"w": 5, "t": "தோட்ட முடையவர்களை"}, {"w": 6, "t": "(of) the garden"}, {"w": 7, "t": "அவர்கள் சத்தியம் செய்த சமயத்தை நினைவு கூருங்கள்!"}, {"w": 8, "t": "they swore"}, {"w": 9, "t": "அதை அவர்கள் நிச்சயமாக அறுவடை செய்ய வேண்டும்"}, {"w": 10, "t": "அவர்கள் அதிகாலையில் இருக்கும் போது"}, {"w": 11, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவர்கள் அல்லாஹ் நாடினால் என்று கூறவில்லை"}, {"w": 2, "t": "making exception"}, {"w": 3, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இரவில் சுற்றியது"}, {"w": 2, "t": "அதன் மீது"}, {"w": 3, "t": "ஒரு கட்டளை"}, {"w": 4, "t": "உமது இறைவனிடமிருந்து"}, {"w": 5, "t": "your Lord"}, {"w": 6, "t": "அவர்கள் தூங்கியவர்களாக இருந்த போது"}, {"w": 7, "t": "were asleep"}, {"w": 8, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "ஆகிவிட்டது"}, {"w": 2, "t": "அது கடுமையான இருள் நிறைந்த இரவைப் போன்று"}, {"w": 3, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "ஒருவரை ஒருவர் அழைத்தனர்"}, {"w": 2, "t": "அவர்கள் அதிகாலையில் ஆனவுடன்"}, {"w": 3, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "காலையில் செல்லுங்கள்"}, {"w": 2, "t": "Go early"}, {"w": 3, "t": "உங்கள் விவசாய நிலத்திற்கு"}, {"w": 4, "t": "your crop"}, {"w": 5, "t": "நீங்கள் இருந்தால்"}, {"w": 6, "t": "you would"}, {"w": 7, "t": "அறுவடை செய்பவர்களாக"}, {"w": 8, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "சென்றனர்"}, {"w": 2, "t": "அவர்கள்/ தங்களுக்குள் தாழ்ந்த குரலில் பேசியவர்களாக"}, {"w": 3, "t": "lowered (their) voices"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அதில் நுழைந்து விடக்கூடாது"}, {"w": 2, "t": "Not"}, {"w": 3, "t": "will enter it"}, {"w": 4, "t": "இன்றைய தினம்"}, {"w": 5, "t": "உங்களிடம்"}, {"w": 6, "t": "ஏழை ஒருவரும்"}, {"w": 7, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இன்னும் காலையில் புறப்பட்டனர்"}, {"w": 2, "t": "ஒரு கெட்ட எண்ணத்துடன்"}, {"w": 3, "t": "determination"}, {"w": 4, "t": "சக்தி உள்ளவர்களாக"}, {"w": 5, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அவர்கள் அதைப் பார்த்த போது"}, {"w": 2, "t": "they saw it"}, {"w": 3, "t": "கூறினார்கள்"}, {"w": 4, "t": "நிச்சயமாக நாங்கள்"}, {"w": 5, "t": "வழிதவறி விட்டோம்"}, {"w": 6, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "இல்லை, மாறாக"}, {"w": 2, "t": "நாங்கள்"}, {"w": 3, "t": "இழப்பிற்குள்ளாகி விட்டோம்"}, {"w": 4, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "அவர்களில் நீதவான்"}, {"w": 3, "t": "நான் உங்களுக்கு கூறவில்லையா?"}, {"w": 4, "t": "I tell"}, {"w": 5, "t": "you"}, {"w": 6, "t": "நீங்கள் இன்ஷா அல்லாஹ் என்று சொல்லி இருக்க வேண்டாமா"}, {"w": 7, "t": "you glorify (Allah)?'"}, {"w": 8, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "மிகப் பரிசுத்தமானவன்"}, {"w": 3, "t": "எங்கள் இறைவன்"}, {"w": 4, "t": "நிச்சயமாக நாங்கள்"}, {"w": 5, "t": "நாங்கள்ஆகிவிட்டோம்"}, {"w": 6, "t": "அநியாயக்காரர்களாக"}, {"w": 7, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "முன்னோக்கினர்"}, {"w": 2, "t": "அவர்களில் சிலர்"}, {"w": 3, "t": "சிலரை"}, {"w": 4, "t": "others"}, {"w": 5, "t": "அவர்களுக்குள் பழித்தவர்களாக"}, {"w": 6, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "எங்களின் நாசமே!"}, {"w": 3, "t": "நிச்சயமாக நாங்கள் இருந்தோம்"}, {"w": 4, "t": "[we] were"}, {"w": 5, "t": "வரம்பு மீறியவர்களாக"}, {"w": 6, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "கூடும்"}, {"w": 2, "t": "எங்கள் இறைவன்"}, {"w": 3, "t": "எங்களுக்கு பகரமாக தர(க்கூடும்)"}, {"w": 4, "t": "will substitute for us"}, {"w": 5, "t": "சிறந்ததை"}, {"w": 6, "t": "அதை விட"}, {"w": 7, "t": "நிச்சயமாக நாங்கள்"}, {"w": 8, "t": "பக்கம்"}, {"w": 9, "t": "எங்கள் இறைவன்"}, {"w": 10, "t": "ஆசை உள்ளவர்கள்"}, {"w": 11, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "தண்டனை"}, {"w": 3, "t": "தண்டனை"}, {"w": 4, "t": "மறுமையின்"}, {"w": 5, "t": "மிகப் பெரியது"}, {"w": 6, "t": "அவர்கள் இருக்க வேண்டுமே!"}, {"w": 7, "t": "they"}, {"w": 8, "t": "அறிந்தவர்களாக"}, {"w": 9, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நிச்சயமாக இறையச்சம் உள்ளவர்களுக்கு"}, {"w": 2, "t": "for the righteous"}, {"w": 3, "t": "தங்கள் இறைவனிடம்"}, {"w": 4, "t": "their Lord"}, {"w": 5, "t": "சொர்க்கங்கள்"}, {"w": 6, "t": "இன்பம் நிறைந்த"}, {"w": 7, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "ஆக்குவோமா?"}, {"w": 2, "t": "முற்றிலும் பணிந்தவர்களை"}, {"w": 3, "t": "குற்றவாளிகளைப் போல்"}, {"w": 4, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "உங்களுக்கு என்ன ஆனது"}, {"w": 2, "t": "(is) for you"}, {"w": 3, "t": "எப்படி"}, {"w": 4, "t": "நீங்கள் தீர்ப்பளிக்கிறீர்கள்"}, {"w": 5, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "?/உங்களுக்கு"}, {"w": 2, "t": "(is) for you"}, {"w": 3, "t": "வேதம்"}, {"w": 4, "t": "அதில்"}, {"w": 5, "t": "படிக்கின்றீர்களா"}, {"w": 6, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உங்களுக்கு/அதில்"}, {"w": 3, "t": "in it"}, {"w": 4, "t": "நீங்கள் விரும்புவதெல்லாம் உண்டா?"}, {"w": 5, "t": "you choose"}, {"w": 6, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "?/உங்களுக்கு"}, {"w": 2, "t": "for you"}, {"w": 3, "t": "ஒப்பந்தங்கள்"}, {"w": 4, "t": "நம்மிடம்"}, {"w": 5, "t": "உறுதியான"}, {"w": 6, "t": "மறுமை நாள் வரை"}, {"w": 7, "t": "(the) Day"}, {"w": 8, "t": "(of) the Resurrection"}, {"w": 9, "t": "நிச்சயமாக உங்களுக்கு"}, {"w": 10, "t": "for you"}, {"w": 11, "t": "நீங்கள் தீர்ப்பளிப்பதெல்லாம்"}, {"w": 12, "t": "you judge"}, {"w": 13, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "அவர்களிடம் கேட்பீராக"}, {"w": 2, "t": "அவர்களில் யார்"}, {"w": 3, "t": "இதற்கு"}, {"w": 4, "t": "பொறுப்பாளர்"}, {"w": 5, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "இவர்களுக்கு உண்டா?"}, {"w": 2, "t": "(are) for them"}, {"w": 3, "t": "கூட்டாளிகள்"}, {"w": 4, "t": "அவர்கள் கொண்டு வரட்டும்"}, {"w": 5, "t": "அவர்களின் அந்த கூட்டாளிகளை"}, {"w": 6, "t": "அவர்கள் இருந்தால்"}, {"w": 7, "t": "they are"}, {"w": 8, "t": "உண்மையாளர்களாக"}, {"w": 9, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "அகற்றப்படுகின்ற"}, {"w": 3, "t": "கெண்டைக்காலை விட்டும்"}, {"w": 4, "t": "the shin"}, {"w": 5, "t": "இன்னும் அவர்கள் அழைக்கப்படுவார்கள்"}, {"w": 6, "t": "சிரம்பணிய"}, {"w": 7, "t": "prostrate"}, {"w": 8, "t": "ஆனால், அவர்கள் சக்தி பெறமாட்டார்கள்"}, {"w": 9, "t": "they will be able"}, {"w": 10, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "தாழ்ந்து இருக்கும்"}, {"w": 2, "t": "அவர்களின் பார்வைகள்"}, {"w": 3, "t": "அவர்களை சூழும்"}, {"w": 4, "t": "இழிவு"}, {"w": 5, "t": "அவர்கள் அழைக்கப்பட்டுக் கொண்டிருந்தார்கள்"}, {"w": 6, "t": "they were"}, {"w": 7, "t": "called"}, {"w": 8, "t": "தொழுகைக்கு/அவர்கள் சுகமானவர்களாக இருந்தபோது"}, {"w": 9, "t": "prostrate"}, {"w": 10, "t": "while they"}, {"w": 11, "t": "(were) sound"}, {"w": 12, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "என்னை(யும்) விட்டு விடுவீராக!"}, {"w": 2, "t": "பொய்ப் பிப்பவர்களையும்"}, {"w": 3, "t": "denies"}, {"w": 4, "t": "இந்த வேதத்தை"}, {"w": 5, "t": "Statement"}, {"w": 6, "t": "அவர்களை கொஞ்சம் கொஞ்சமாகப் பிடிப்போம்"}, {"w": 7, "t": "அவர்கள் அறியாத விதத்தில்"}, {"w": 8, "t": "where"}, {"w": 9, "t": "not"}, {"w": 10, "t": "they know"}, {"w": 11, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நாம் தவணை அளிப்போம்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "எனது சூழ்ச்சி"}, {"w": 5, "t": "மிக பலமானது"}, {"w": 6, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "இவர்களிடம் நீர் கேட்கின்றீரா?"}, {"w": 2, "t": "you ask them"}, {"w": 3, "t": "கூலி ஏதும்"}, {"w": 4, "t": "அவர்கள்"}, {"w": 5, "t": "கடனால்"}, {"w": 6, "t": "(the) debt"}, {"w": 7, "t": "சிரமப்படுகிறார்களா?"}, {"w": 8, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "அவர்களிடம் இருக்கின்றதா?"}, {"w": 2, "t": "(is) with them"}, {"w": 3, "t": "மறைவானவை"}, {"w": 4, "t": "அவர்கள்"}, {"w": 5, "t": "எழுதுகின்றனரா?"}, {"w": 6, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "பொறுமை காப்பீராக!"}, {"w": 2, "t": "தீர்ப்புக்காக"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "நீர் ஆகிவிடாதீர்"}, {"w": 5, "t": "be"}, {"w": 6, "t": "மீனுடையவரைப்போல்"}, {"w": 7, "t": "(of) the fish"}, {"w": 8, "t": "அவர் அழைத்த நேரத்தில்"}, {"w": 9, "t": "he called out"}, {"w": 10, "t": "அவர்"}, {"w": 11, "t": "கடும் கோபமுடையவராக"}, {"w": 12, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அவரை அடைந்திருக்காவிட்டால்/அருள்"}, {"w": 2, "t": "that"}, {"w": 3, "t": "overtook him"}, {"w": 4, "t": "a Favor"}, {"w": 5, "t": "அவருடைய இறைவனிடமிருந்து"}, {"w": 6, "t": "his Lord"}, {"w": 7, "t": "எறியப்பட்டிருப்பார்"}, {"w": 8, "t": "ஒரு பெருவெளியில்"}, {"w": 9, "t": "அவர் இருந்தார்"}, {"w": 10, "t": "பழிப்பிற்குரிய வராகத்தான்"}, {"w": 11, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "பிறகு, அவரை தேர்ந்தெடுத்தான்"}, {"w": 2, "t": "அவரது இறைவன்"}, {"w": 3, "t": "அவரை ஆக்கினான்"}, {"w": 4, "t": "நல்லவர்களில்"}, {"w": 5, "t": "the righteous"}, {"w": 6, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நிச்சயமாக நெருங்கினார்(கள்)"}, {"w": 2, "t": "would almost"}, {"w": 3, "t": "நிராகரித்தவர்கள்"}, {"w": 4, "t": "disbelieve"}, {"w": 5, "t": "உம்மை நீக்கிவிட"}, {"w": 6, "t": "தங்கள் பார்வைகளால்"}, {"w": 7, "t": "அவர்கள் செவியுற்றபோது"}, {"w": 8, "t": "they hear"}, {"w": 9, "t": "அறிவுரையை"}, {"w": 10, "t": "இன்னும் அவர்கள் கூறினார்கள்"}, {"w": 11, "t": "நிச்சயமாக அவர்"}, {"w": 12, "t": "ஒரு பைத்தியக்காரர்தான்"}, {"w": 13, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "அது இல்லை"}, {"w": 2, "t": "it (is)"}, {"w": 3, "t": "ஓர் அறிவுரையே தவிர"}, {"w": 4, "t": "a Reminder"}, {"w": 5, "t": "அகிலத்தார்களுக்கு"}, {"w": 6, "t": "(52)"}]}]}