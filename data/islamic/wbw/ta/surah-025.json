{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "மிக்க அருள் நிறைந்தவன்"}, {"w": 2, "t": "எவன்/இறக்கினான்"}, {"w": 3, "t": "sent down"}, {"w": 4, "t": "பகுத்தறிவிக்கும் வேதத்தை"}, {"w": 5, "t": "தனது அடியார் மீது"}, {"w": 6, "t": "His slave"}, {"w": 7, "t": "அவர் இருப்பதற்காக"}, {"w": 8, "t": "அகிலத்தார்களை"}, {"w": 9, "t": "எச்சரிப்பவராக"}, {"w": 10, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "எவன்/ அவனுக்கே உரியது"}, {"w": 2, "t": "to Him (belongs)"}, {"w": 3, "t": "ஆட்சி"}, {"w": 4, "t": "வானங்கள்"}, {"w": 5, "t": "இன்னும் பூமி"}, {"w": 6, "t": "அவன் எடுத்துக் கொள்ளவில்லை"}, {"w": 7, "t": "He has taken"}, {"w": 8, "t": "குழந்தையை"}, {"w": 9, "t": "இல்லை"}, {"w": 10, "t": "He has"}, {"w": 11, "t": "அவனுக்கு"}, {"w": 12, "t": "இணை"}, {"w": 13, "t": "ஆட்சியில்"}, {"w": 14, "t": "the dominion"}, {"w": 15, "t": "இன்னும் அவன்படைத்தான்"}, {"w": 16, "t": "எல்லாவற்றையும்"}, {"w": 17, "t": "thing"}, {"w": 18, "t": "அவற்றை நிர்ணயித்தான்"}, {"w": 19, "t": "சீராக"}, {"w": 20, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அவர்கள் எடுத்துக் கொண்டனர்"}, {"w": 2, "t": "அவனையன்றி"}, {"w": 3, "t": "besides Him"}, {"w": 4, "t": "கடவுள்களை"}, {"w": 5, "t": "படைக்க மாட்டார்கள்"}, {"w": 6, "t": "they create"}, {"w": 7, "t": "எதையும்"}, {"w": 8, "t": "அவர்கள்"}, {"w": 9, "t": "படைக்கப்படுகிறார்கள்"}, {"w": 10, "t": "இன்னும் உரிமை பெற மாட்டார்கள்"}, {"w": 11, "t": "they possess"}, {"w": 12, "t": "தங்களுக்குத் தாமே"}, {"w": 13, "t": "தீமை செய்வதற்கும்"}, {"w": 14, "t": "நன்மை செய்வதற்கும்"}, {"w": 15, "t": "any benefit"}, {"w": 16, "t": "இன்னும் உரிமை பெற மாட்டார்கள்"}, {"w": 17, "t": "they control"}, {"w": 18, "t": "இறப்பிற்கும்"}, {"w": 19, "t": "வாழ்விற்கும்"}, {"w": 20, "t": "life"}, {"w": 21, "t": "மீண்டும் உயிர்த்தெழ செய்வதற்கும்"}, {"w": 22, "t": "resurrection"}, {"w": 23, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "கூறுகின்றனர்"}, {"w": 2, "t": "நிராகரிப்பாளர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "இது இல்லை"}, {"w": 5, "t": "this"}, {"w": 6, "t": "தவிர"}, {"w": 7, "t": "இட்டுக்கட்டப்பட்டதே"}, {"w": 8, "t": "இதை இட்டுக்கட்டினார்"}, {"w": 9, "t": "இன்னும் உதவினர்/இவருக்கு"}, {"w": 10, "t": "இதற்கு"}, {"w": 11, "t": "மக்கள்"}, {"w": 12, "t": "மற்ற"}, {"w": 13, "t": "ஆகவே, திட்டமாக"}, {"w": 14, "t": "இவர்கள் வந்தனர்"}, {"w": 15, "t": "அநியாயத்திற்கும்"}, {"w": 16, "t": "பொய்யுக்கும்"}, {"w": 17, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இன்னும் கூறினர்"}, {"w": 2, "t": "கதைகள்"}, {"w": 3, "t": "முன்னோரின்"}, {"w": 4, "t": "அவர் எழுதிக் கொண்டார்/இவற்றை"}, {"w": 5, "t": "இவை"}, {"w": 6, "t": "எடுத்தியம்பப் படுகின்றன"}, {"w": 7, "t": "அவர் மீது"}, {"w": 8, "t": "காலையிலும்"}, {"w": 9, "t": "இன்னும் மாலையிலும்"}, {"w": 10, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கூறுவீராக"}, {"w": 2, "t": "இதை இறக்கினான்"}, {"w": 3, "t": "எவன்/அறிகின்றான்"}, {"w": 4, "t": "knows"}, {"w": 5, "t": "இரகசியத்தை"}, {"w": 6, "t": "வானங்களிலும்"}, {"w": 7, "t": "the heavens"}, {"w": 8, "t": "பூமியிலும்"}, {"w": 9, "t": "நிச்சயமாக அவன்"}, {"w": 10, "t": "இருக்கிறான்"}, {"w": 11, "t": "மகாமன்னிப்பாளனாக"}, {"w": 12, "t": "பெரும் கருணையாளனாக"}, {"w": 13, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவர்கள் கூறுகின்றனர்"}, {"w": 2, "t": "என்ன!"}, {"w": 3, "t": "இந்த"}, {"w": 4, "t": "தூதருக்கு"}, {"w": 5, "t": "இவர் சாப்பிடுகிறார்"}, {"w": 6, "t": "உணவு"}, {"w": 7, "t": "இன்னும் நடக்கிறார்"}, {"w": 8, "t": "கடைத் தெருக்களில்"}, {"w": 9, "t": "the markets"}, {"w": 10, "t": "இறக்கப்பட்டு இருக்க வேண்டாமா?"}, {"w": 11, "t": "is sent down"}, {"w": 12, "t": "இவர் மீது"}, {"w": 13, "t": "ஒரு வானவர்"}, {"w": 14, "t": "அவர் இருக்கிறார்"}, {"w": 15, "t": "இவருடன்"}, {"w": 16, "t": "எச்சரிப்பவராக"}, {"w": 17, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "இறக்கப்பட வேண்டாமா!"}, {"w": 3, "t": "இவருக்கு"}, {"w": 4, "t": "ஒரு பொக்கிஷம்"}, {"w": 5, "t": "அல்லது"}, {"w": 6, "t": "இருக்க வேண்டாமா!"}, {"w": 7, "t": "இவருக்கு"}, {"w": 8, "t": "ஒரு தோட்டம்"}, {"w": 9, "t": "இவர் புசிப்பாரே!"}, {"w": 10, "t": "அதிலிருந்து"}, {"w": 11, "t": "இன்னும் கூறுகின்றனர்"}, {"w": 12, "t": "அநியாயக்காரர்கள்"}, {"w": 13, "t": "நீங்கள் பின்பற்றவில்லை"}, {"w": 14, "t": "you follow"}, {"w": 15, "t": "தவிர"}, {"w": 16, "t": "ஒரு மனிதரை"}, {"w": 17, "t": "குடல் உள்ள"}, {"w": 18, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "பார்ப்பீராக!"}, {"w": 2, "t": "எப்படி"}, {"w": 3, "t": "அவர்கள் விவரிக்கின்றனர்"}, {"w": 4, "t": "உமக்கு"}, {"w": 5, "t": "தன்மைகளை"}, {"w": 6, "t": "ஆகவே, அவர்கள் வழிகெட்டனர்"}, {"w": 7, "t": "அவர்கள் சக்தி பெறமாட்டார்கள்"}, {"w": 8, "t": "they are able (to find)"}, {"w": 9, "t": "ஒரு பாதைக்கு"}, {"w": 10, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அருள் நிறைந்தவன்"}, {"w": 2, "t": "எவன்/அவன் நாடினால்"}, {"w": 3, "t": "if"}, {"w": 4, "t": "He willed"}, {"w": 5, "t": "ஏற்படுத்துவான்"}, {"w": 6, "t": "உமக்கு"}, {"w": 7, "t": "சிறந்ததை"}, {"w": 8, "t": "இவற்றை விட"}, {"w": 9, "t": "that "}, {"w": 10, "t": "சொர்க்கங்களை"}, {"w": 11, "t": "ஓடும்"}, {"w": 12, "t": "அவற்றை சுற்றி"}, {"w": 13, "t": "underneath it"}, {"w": 14, "t": "நதிகள்"}, {"w": 15, "t": "இன்னும் ஏற்படுத்துவான்"}, {"w": 16, "t": "உமக்கு"}, {"w": 17, "t": "மாளிகைகளை"}, {"w": 18, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "அவர்கள் பொய்ப்பித்தனர்"}, {"w": 3, "t": "உலக முடிவை"}, {"w": 4, "t": "இன்னும் தயார்படுத்தியுள்ளோம்"}, {"w": 5, "t": "பொய்ப்பிப்பவருக்கு"}, {"w": 6, "t": "deny"}, {"w": 7, "t": "உலக முடிவை"}, {"w": 8, "t": "கொழுந்து விட்டெரியும் நெருப்பை"}, {"w": 9, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "பார்த்தால்/அவர்களை அது"}, {"w": 2, "t": "it sees them"}, {"w": 3, "t": "இடத்திலிருந்து"}, {"w": 4, "t": "a place"}, {"w": 5, "t": "தூரமான"}, {"w": 6, "t": "செவிமடுப்பார்கள்"}, {"w": 7, "t": "அதனுடைய"}, {"w": 8, "t": "சப்தத்தையும்"}, {"w": 9, "t": "இரைச்சலையும்"}, {"w": 10, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அவர்கள் போடப்பட்டால்"}, {"w": 2, "t": "they are thrown"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "இடத்தில்"}, {"w": 5, "t": "நெருக்கமான"}, {"w": 6, "t": "கட்டப்பட்டவர்களாக"}, {"w": 7, "t": "அழைப்பார்கள்"}, {"w": 8, "t": "அங்கு"}, {"w": 9, "t": "கைசேதமே என்று"}, {"w": 10, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அழைக்காதீர்கள்"}, {"w": 2, "t": "call"}, {"w": 3, "t": "இன்று"}, {"w": 4, "t": "கைசேதமே என்று"}, {"w": 5, "t": "ஒரு முறை"}, {"w": 6, "t": "அழையுங்கள்"}, {"w": 7, "t": "கைசேதமே என்று"}, {"w": 8, "t": "பல முறை"}, {"w": 9, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நீர் கேட்பீராக!"}, {"w": 2, "t": "அது?"}, {"w": 3, "t": "சிறந்ததா"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "ஜன்னதுல் குல்து"}, {"w": 6, "t": "(of) Eternity"}, {"w": 7, "t": "எது"}, {"w": 8, "t": "வாக்களிக்கப்பட்டனர்"}, {"w": 9, "t": "இறையச்சமுள்ளவர்கள்"}, {"w": 10, "t": "அது இருக்கும்"}, {"w": 11, "t": "அவர்களுக்கு"}, {"w": 12, "t": "கூலியாகவும்"}, {"w": 13, "t": "மீளுமிடமாகவும்"}, {"w": 14, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவர்களுக்கு"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "அவர்கள் நாடுவார்கள்/எது"}, {"w": 4, "t": "they wish"}, {"w": 5, "t": "நிரந்தரமாக இருப்பார்கள்"}, {"w": 6, "t": "இருக்கிறது"}, {"w": 7, "t": "மீது"}, {"w": 8, "t": "உமது இறைவன்"}, {"w": 9, "t": "வாக்காக"}, {"w": 10, "t": "வேண்டப்பட்ட"}, {"w": 11, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நாளின்போது"}, {"w": 2, "t": "அவன் எழுப்புவான் அவர்களையும்"}, {"w": 3, "t": "அவர்கள் வணங்கியவர்களையும்"}, {"w": 4, "t": "they worship"}, {"w": 5, "t": "அல்லாஹ்வையன்றி"}, {"w": 6, "t": "besides Allah"}, {"w": 7, "t": "besides Allah"}, {"w": 8, "t": "கேட்பான்"}, {"w": 9, "t": "நீங்கள் வழிகெடுத்தீர்களா?"}, {"w": 10, "t": "[you] mislead"}, {"w": 11, "t": "எனது அடியார்களை"}, {"w": 12, "t": "நீங்கள்தான்"}, {"w": 13, "t": "அல்லது"}, {"w": 14, "t": "அவர்கள்"}, {"w": 15, "t": "தாமாகதவறவிட்டனரா"}, {"w": 16, "t": "பாதையை"}, {"w": 17, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவர்கள் கூறுவர்"}, {"w": 2, "t": "நீ மிகப் பரிசுத்தமானவன்"}, {"w": 3, "t": "இல்லை"}, {"w": 4, "t": "it was proper"}, {"w": 5, "t": "தகுதியானதாக"}, {"w": 6, "t": "எங்களுக்கு"}, {"w": 7, "t": "எடுத்துக் கொள்வது"}, {"w": 8, "t": "we take"}, {"w": 9, "t": "உன்னை அன்றி"}, {"w": 10, "t": "besides You"}, {"w": 11, "t": "பாதுகாவலர்களை"}, {"w": 12, "t": "protectors"}, {"w": 13, "t": "எனினும்"}, {"w": 14, "t": "நீ அவர்களுக்கு சுகமளித்தாய்"}, {"w": 15, "t": "மூதாதைகளுக்கும் அவர்களுடைய"}, {"w": 16, "t": "இறுதியாக"}, {"w": 17, "t": "அவர்கள் மறந்தனர்"}, {"w": 18, "t": "அறிவுரையை"}, {"w": 19, "t": "இன்னும் ஆகிவிட்டனர்"}, {"w": 20, "t": "மக்களாக"}, {"w": 21, "t": "அழிந்து போகும்"}, {"w": 22, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "ஆகவே, திட்டமாக"}, {"w": 2, "t": "பொய்ப்பித்துவிட்டனர் உங்களை"}, {"w": 3, "t": "நீங்கள் கூறியதில்"}, {"w": 4, "t": "you say"}, {"w": 5, "t": "ஆகவே, நீங்கள் சக்தி பெறமாட்டீர்கள்"}, {"w": 6, "t": "you are able"}, {"w": 7, "t": "திருப்பி விடுவதற்கோ"}, {"w": 8, "t": "உதவுவதற்கோ"}, {"w": 9, "t": "(to) help"}, {"w": 10, "t": "யார்"}, {"w": 11, "t": "அநீதி இழைத்துக் கொண்டாரோ"}, {"w": 12, "t": "உங்களில்"}, {"w": 13, "t": "அவருக்கு சுவைக்க வைப்போம்"}, {"w": 14, "t": "தண்டனையை"}, {"w": 15, "t": "பெரிய"}, {"w": 16, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நாம் அனுப்பவில்லை"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "உமக்கு முன்னர்"}, {"w": 4, "t": "தூதர்களில் எவரையும்"}, {"w": 5, "t": "Messengers"}, {"w": 6, "t": "தவிர"}, {"w": 7, "t": "நிச்சயமாக அவர்கள்"}, {"w": 8, "t": "உண்பவர்களாக"}, {"w": 9, "t": "உணவு"}, {"w": 10, "t": "இன்னும் நடந்து செல்பவர்களாக"}, {"w": 11, "t": "கடைத் தெருக்களில்"}, {"w": 12, "t": "the markets"}, {"w": 13, "t": "ஆக்கினோம்"}, {"w": 14, "t": "உங்களில் சிலரை"}, {"w": 15, "t": "சிலருக்கு"}, {"w": 16, "t": "சோதனையாக"}, {"w": 17, "t": "நீங்கள் பொறுப்பீர்களா?"}, {"w": 18, "t": "இருக்கிறான்"}, {"w": 19, "t": "உமது இறைவன்"}, {"w": 20, "t": "உற்று நோக்குபவனாக"}, {"w": 21, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "கூறினார்(கள்)"}, {"w": 2, "t": "ஆதரவு வைக்காதவர்கள்"}, {"w": 3, "t": "(do) not"}, {"w": 4, "t": "expect"}, {"w": 5, "t": "நம் சந்திப்பை"}, {"w": 6, "t": "இறக்கப்பட வேண்டாமா?"}, {"w": 7, "t": "are sent down"}, {"w": 8, "t": "எங்கள் மீது"}, {"w": 9, "t": "வானவர்கள்"}, {"w": 10, "t": "அல்லது"}, {"w": 11, "t": "நாங்கள் பார்க்க வேண்டாமா?"}, {"w": 12, "t": "எங்கள் இறைவனை"}, {"w": 13, "t": "திட்டவட்டமாக"}, {"w": 14, "t": "அவர்கள் பெருமை அடித்தனர்"}, {"w": 15, "t": "தங்களுக்குள்"}, {"w": 16, "t": "themselves"}, {"w": 17, "t": "இன்னும் கடுமையாக அழிச்சாட்டியம் செய்தனர்"}, {"w": 18, "t": "(with) insolence"}, {"w": 19, "t": "மிகப்பெரிய அளவில்"}, {"w": 20, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "அவர்கள் பார்ப்பார்கள்"}, {"w": 3, "t": "வானவர்களை"}, {"w": 4, "t": "அறவே இல்லை"}, {"w": 5, "t": "நற்செய்தி"}, {"w": 6, "t": "இந்நாளில்"}, {"w": 7, "t": "குற்றவாளிகளுக்கு"}, {"w": 8, "t": "இன்னும் கூறுவார்கள்"}, {"w": 9, "t": "உங்களுக்கு தடுக்கப்பட்டு விட்டது"}, {"w": 10, "t": "முற்றிலும்"}, {"w": 11, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நாம் நாடுவோம்"}, {"w": 2, "t": "அவர்கள் செய்ததை"}, {"w": 3, "t": "whatever"}, {"w": 4, "t": "they did"}, {"w": 5, "t": "செயல்களில்"}, {"w": 6, "t": "(the) deed(s)"}, {"w": 7, "t": "பிறகு அதை ஆக்கிவிடுவோம்"}, {"w": 8, "t": "புழுதியாக"}, {"w": 9, "t": "பரத்தப்பட்ட"}, {"w": 10, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "சொர்க்கவாசிகள்"}, {"w": 2, "t": "(of) Paradise"}, {"w": 3, "t": "அந்நாளில்"}, {"w": 4, "t": "சிறந்தவர்கள்"}, {"w": 5, "t": "தங்குமிடத்தால்"}, {"w": 6, "t": "இன்னும் மிக சிறப்பானவர்கள்"}, {"w": 7, "t": "ஓய்வெடுக்கும் இடத்தால்"}, {"w": 8, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "பிளந்துவிடும்"}, {"w": 3, "t": "வானம்"}, {"w": 4, "t": "வெள்ளை மேகத்தைக் கொண்டு"}, {"w": 5, "t": "இன்னும் இறக்கப்படும் (நாளில்)"}, {"w": 6, "t": "வானவர்கள்"}, {"w": 7, "t": "இறங்குதல்"}, {"w": 8, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "ஆட்சி"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "உண்மையான"}, {"w": 4, "t": "ரஹ்மானிற்கே"}, {"w": 5, "t": "இருக்கும்"}, {"w": 6, "t": "நாளாக"}, {"w": 7, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 8, "t": "the disbelievers"}, {"w": 9, "t": "மிக சிரமமான"}, {"w": 10, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அந்நாளில்"}, {"w": 2, "t": "கடிப்பான்"}, {"w": 3, "t": "அநியாயக்காரன்"}, {"w": 4, "t": "தனது இரு கரங்களையும்"}, {"w": 5, "t": "his hands"}, {"w": 6, "t": "கூறுவான்"}, {"w": 7, "t": "நான் எடுத்துக் கொண்டிருக்க வேண்டுமே!"}, {"w": 8, "t": "I had taken"}, {"w": 9, "t": "தூதருடன்"}, {"w": 10, "t": "the Messenger"}, {"w": 11, "t": "ஒரு வழியை"}, {"w": 12, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "என் நாசமே!"}, {"w": 2, "t": "நான் எடுத்திருக்கக் கூடாதே!"}, {"w": 3, "t": "not"}, {"w": 4, "t": "I had taken"}, {"w": 5, "t": "இன்னவனை"}, {"w": 6, "t": "நண்பனாக"}, {"w": 7, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "என்னை வழிகெடுத்து விட்டான்"}, {"w": 3, "t": "அறிவுரையிலிருந்து"}, {"w": 4, "t": "the Reminder"}, {"w": 5, "t": "பின்னர்"}, {"w": 6, "t": "அது என்னிடம் வந்த"}, {"w": 7, "t": "it (had) come to me"}, {"w": 8, "t": "இருக்கிறான்"}, {"w": 9, "t": "ஷைத்தான்"}, {"w": 10, "t": "மனிதனை"}, {"w": 11, "t": "கைவிடுபவனாக"}, {"w": 12, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "கூறுவார்"}, {"w": 2, "t": "தூதர்"}, {"w": 3, "t": "என் இறைவா!"}, {"w": 4, "t": "நிச்சயமாக"}, {"w": 5, "t": "எனது மக்கள்"}, {"w": 6, "t": "எடுத்துக் கொண்டனர்"}, {"w": 7, "t": "இந்த குர்ஆனை"}, {"w": 8, "t": "the Quran"}, {"w": 9, "t": "புறக்கணிக்கப் பட்டதாக"}, {"w": 10, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "நாம் ஆக்கினோம்"}, {"w": 3, "t": "ஒவ்வொரு"}, {"w": 4, "t": "நபிக்கும்"}, {"w": 5, "t": "எதிரிகளை"}, {"w": 6, "t": "குற்றவாளிகளில்"}, {"w": 7, "t": "the criminals"}, {"w": 8, "t": "போதுமானவன்"}, {"w": 9, "t": "உமது இறைவன்"}, {"w": 10, "t": "நேர்வழி காட்டுபவனாக"}, {"w": 11, "t": "இன்னும் உதவுபவனாக"}, {"w": 12, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "கூறினர்"}, {"w": 2, "t": "நிராகரிப்பாளர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "இறக்கப்பட வேண்டாமா!"}, {"w": 5, "t": "was revealed"}, {"w": 6, "t": "இவர் மீது"}, {"w": 7, "t": "இந்த குர்ஆன்"}, {"w": 8, "t": "ஒட்டு மொத்தமாக"}, {"w": 9, "t": "ஒரே தடவையில்"}, {"w": 10, "t": "இவ்வாறுதான்"}, {"w": 11, "t": "உறுதிப்படுத்துவதற்காக"}, {"w": 12, "t": "அதன் மூலம்"}, {"w": 13, "t": "உமது உள்ளத்தை"}, {"w": 14, "t": "இன்னும் இதை கற்பித்தோம்."}, {"w": 15, "t": "சிறிது சிறிதாக"}, {"w": 16, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "அவர்கள் உம்மிடம் கூறமாட்டார்கள்"}, {"w": 2, "t": "they come to you"}, {"w": 3, "t": "எந்த ஒரு தன்மையையும்"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "உமக்கு நாம் கூறியே"}, {"w": 6, "t": "சத்தியத்தையும்"}, {"w": 7, "t": "இன்னும் மிக அழகான"}, {"w": 8, "t": "விளக்கத்தை(யும்)"}, {"w": 9, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "எழுப்பப்படுகிறார்களோ"}, {"w": 3, "t": "மீது"}, {"w": 4, "t": "தங்கள் முகங்களின்"}, {"w": 5, "t": "பக்கம்"}, {"w": 6, "t": "நரகத்தின்"}, {"w": 7, "t": "அவர்கள்தான்"}, {"w": 8, "t": "மிக கெட்டவர்கள்"}, {"w": 9, "t": "தங்குமிடத்தால்"}, {"w": 10, "t": "இன்னும் மிக வழிதவறியவர்கள்"}, {"w": 11, "t": "பாதையால்"}, {"w": 12, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "கொடுத்தோம்"}, {"w": 3, "t": "மூஸாவுக்கு/வேதத்தை"}, {"w": 4, "t": "the Scripture"}, {"w": 5, "t": "இன்னும் ஆக்கினோம்"}, {"w": 6, "t": "அவருடன்"}, {"w": 7, "t": "அவரது சகோதரர்"}, {"w": 8, "t": "ஹாரூனை"}, {"w": 9, "t": "உதவியாளராக"}, {"w": 10, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "நாம் கூறினோம்"}, {"w": 2, "t": "நீங்கள் இருவரும் செல்லுங்கள்"}, {"w": 3, "t": "மக்களிடம்"}, {"w": 4, "t": "the people"}, {"w": 5, "t": "பொய்ப்பித்தவர்கள்"}, {"w": 6, "t": "have denied"}, {"w": 7, "t": "நமது அத்தாட்சிகளை"}, {"w": 8, "t": "ஆகவே நாம் அவர்களை அழித்து விட்டோம்"}, {"w": 9, "t": "முற்றிலும் தரை மட்டமாக"}, {"w": 10, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இன்னும் மக்களையும்"}, {"w": 2, "t": "நூஹூடைய"}, {"w": 3, "t": "போது"}, {"w": 4, "t": "அவர்கள் பொய்ப்பித்தனர்"}, {"w": 5, "t": "தூதர்களை"}, {"w": 6, "t": "அவர்களை மூழ்கடித்தோம்"}, {"w": 7, "t": "அவர்களை ஆக்கினோம்"}, {"w": 8, "t": "மக்களுக்கு"}, {"w": 9, "t": "ஓர் அத்தாட்சியாக"}, {"w": 10, "t": "இன்னும் நாம் தயார் படுத்தியுள்ளோம்"}, {"w": 11, "t": "அநியாயக்காரர்களுக்கு"}, {"w": 12, "t": "தண்டனையை"}, {"w": 13, "t": "வலி தரும்"}, {"w": 14, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "ஆது"}, {"w": 2, "t": "ஸமூது"}, {"w": 3, "t": "கிணறு வாசிகள்"}, {"w": 4, "t": "(of) Ar-rass"}, {"w": 5, "t": "இன்னும் பல தலைமுறையினரை"}, {"w": 6, "t": "இவர்களுக்கிடையில்"}, {"w": 7, "t": "that"}, {"w": 8, "t": "பல"}, {"w": 9, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "எல்லோருக்கும்"}, {"w": 2, "t": "நாம் விவரித்தோம்"}, {"w": 3, "t": "அவர்களுக்கு/பல உதாரணங்களை"}, {"w": 4, "t": "the examples"}, {"w": 5, "t": "எல்லோரையும்"}, {"w": 6, "t": "நாம் அழித்துவிட்டோம்"}, {"w": 7, "t": "அடியோடு"}, {"w": 8, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அவர்கள் வந்திருக்கின்றனர்"}, {"w": 3, "t": "அருகில்"}, {"w": 4, "t": "ஊரின்"}, {"w": 5, "t": "பொழியப்பட்டது"}, {"w": 6, "t": "was showered"}, {"w": 7, "t": "மழை"}, {"w": 8, "t": "மிக மோசமான"}, {"w": 9, "t": "அதை அவர்கள் பார்த்திருக்கவில்லையா?"}, {"w": 10, "t": "they [were]"}, {"w": 11, "t": "see it"}, {"w": 12, "t": "மாறாக"}, {"w": 13, "t": "இருந்தனர்"}, {"w": 14, "t": "அவர்கள் ஆதரவு வைக்காதவர்களாக"}, {"w": 15, "t": "expecting"}, {"w": 16, "t": "எழுப்பப்படுவதை"}, {"w": 17, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவர்கள் உம்மைப் பார்த்தால்"}, {"w": 2, "t": "they see you"}, {"w": 3, "t": "உம்மை எடுத்துக் கொள்ளமாட்டார்கள்"}, {"w": 4, "t": "they take you"}, {"w": 5, "t": "தவிர"}, {"w": 6, "t": "கேலியாகவே"}, {"w": 7, "t": "இவரையா?"}, {"w": 8, "t": "எவர்"}, {"w": 9, "t": "அனுப்பினான்"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "தூதராக"}, {"w": 12, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "இவர் நம்மை நிச்சயமாக வழி கெடுத்திருப்பார்"}, {"w": 2, "t": "He would have almost"}, {"w": 3, "t": "[surely] misled us"}, {"w": 4, "t": "நமது தெய்வங்களை விட்டு"}, {"w": 5, "t": "our gods"}, {"w": 6, "t": "நாம் உறுதியாக இருந்திருக்க வில்லையென்றால்"}, {"w": 7, "t": "that"}, {"w": 8, "t": "we had been steadfast"}, {"w": 9, "t": "அவற்றின் மீது"}, {"w": 10, "t": "அவர்கள் அறிந்து கொள்வார்கள்"}, {"w": 11, "t": "will know"}, {"w": 12, "t": "போது"}, {"w": 13, "t": "அவர்கள் பார்க்கும்"}, {"w": 14, "t": "தண்டனையை"}, {"w": 15, "t": "யார்"}, {"w": 16, "t": "மிக வழிகெட்டவர்"}, {"w": 17, "t": "பாதையால்"}, {"w": 18, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "நீர் பார்த்தீரா?"}, {"w": 2, "t": "எடுத்துக் கொண்டவனை"}, {"w": 3, "t": "takes"}, {"w": 4, "t": "தனது கடவுளாக"}, {"w": 5, "t": "தனது மன இச்சையை"}, {"w": 6, "t": "நீர்?"}, {"w": 7, "t": "ஆகுவீரா"}, {"w": 8, "t": "அவனுக்கு"}, {"w": 9, "t": "பொறுப்பாளராக"}, {"w": 10, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "நீர் எண்ணுகிறீரா?"}, {"w": 3, "t": "என்று"}, {"w": 4, "t": "அதிகமானவர்கள் அவர்களில்"}, {"w": 5, "t": "செவிமடுப்பார்கள்"}, {"w": 6, "t": "அல்லது"}, {"w": 7, "t": "சிந்தித்து புரிவார்கள்"}, {"w": 8, "t": "அவர்கள் இல்லை"}, {"w": 9, "t": "they"}, {"w": 10, "t": "தவிர"}, {"w": 11, "t": "கால்நடைகளைப் போன்றே"}, {"w": 12, "t": "மாறாக"}, {"w": 13, "t": "அவர்கள்"}, {"w": 14, "t": "வழிகெட்டவர்கள்"}, {"w": 15, "t": "பாதையால்"}, {"w": 16, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "see"}, {"w": 3, "t": "பக்கம்"}, {"w": 4, "t": "உமது இறைவன்"}, {"w": 5, "t": "எப்படி"}, {"w": 6, "t": "நீட்டுகிறான்"}, {"w": 7, "t": "நிழலை"}, {"w": 8, "t": "அவன் நாடியிருந்தால்"}, {"w": 9, "t": "He willed"}, {"w": 10, "t": "அதை ஆக்கியிருப்பான்"}, {"w": 11, "t": "நிரந்தரமாக"}, {"w": 12, "t": "பிறகு"}, {"w": 13, "t": "நாம் ஆக்கினோம்"}, {"w": 14, "t": "சூரியனை"}, {"w": 15, "t": "அதன் மீது"}, {"w": 16, "t": "ஆதாரமாக"}, {"w": 17, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "அதை கைப்பற்றி விடுகிறோம்"}, {"w": 3, "t": "நம் பக்கம்"}, {"w": 4, "t": "கைப்பற்றுதல்"}, {"w": 5, "t": "மறைவாக"}, {"w": 6, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "ஆக்கினான்"}, {"w": 4, "t": "உங்களுக்கு"}, {"w": 5, "t": "இரவை"}, {"w": 6, "t": "ஓர் ஆடையாகவும்"}, {"w": 7, "t": "இன்னும் தூக்கத்தை"}, {"w": 8, "t": "ஓய்வாகவும்"}, {"w": 9, "t": "இன்னும் ஆக்கினான்"}, {"w": 10, "t": "பகலை"}, {"w": 11, "t": "விழிப்பதற்கும்"}, {"w": 12, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "அனுப்புகிறான்"}, {"w": 4, "t": "காற்றுகளை"}, {"w": 5, "t": "நற்செய்தி கூறக்கூடியதாக"}, {"w": 6, "t": "முன்பாக"}, {"w": 7, "t": "before"}, {"w": 8, "t": "தன் அருளுக்கு"}, {"w": 9, "t": "இன்னும் நாம் இறக்குகிறோம்"}, {"w": 10, "t": "வானத்திலிருந்து"}, {"w": 11, "t": "the sky"}, {"w": 12, "t": "மழை நீரை"}, {"w": 13, "t": "பரிசுத்தமான"}, {"w": 14, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "நாம் உயிர்ப்பிப்பதற்காகவும்"}, {"w": 2, "t": "அதன்மூலம்"}, {"w": 3, "t": "பூமியை"}, {"w": 4, "t": "இறந்த"}, {"w": 5, "t": "இன்னும் நாம் அதை புகட்டுவதற்காகவும்"}, {"w": 6, "t": "நாம் படைத்தவற்றில்"}, {"w": 7, "t": "(to those) We created"}, {"w": 8, "t": "பல கால்நடைகளுக்கும்"}, {"w": 9, "t": "இன்னும் மனிதர்களுக்கும்"}, {"w": 10, "t": "அதிகமான"}, {"w": 11, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "அதை நாம் பிரித்துக் கொடுத்தோம்"}, {"w": 2, "t": "We have distributed it"}, {"w": 3, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 4, "t": "அவர்கள் நல்லறிவு பெறுவதற்காக"}, {"w": 5, "t": "மறுத்து விட்டனர்"}, {"w": 6, "t": "மிகஅதிகமானவர்கள்"}, {"w": 7, "t": "மனிதர்களில்"}, {"w": 8, "t": "தவிர"}, {"w": 9, "t": "நிராகரிப்பதை"}, {"w": 10, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நாம் நாடியிருந்தால்"}, {"w": 2, "t": "We willed"}, {"w": 3, "t": "அனுப்பியிருப்போம்"}, {"w": 4, "t": "ஒவ்வொரு"}, {"w": 5, "t": "every"}, {"w": 6, "t": "ஊரிலும்"}, {"w": 7, "t": "ஓர் எச்சரிப்பாளரை"}, {"w": 8, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "ஆகவே கீழ்ப்படியாதீர்"}, {"w": 2, "t": "obey"}, {"w": 3, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 4, "t": "போர் செய்வீராக! அவர்களிடம்"}, {"w": 5, "t": "இதன்மூலம்"}, {"w": 6, "t": "போர்"}, {"w": 7, "t": "பெரும்"}, {"w": 8, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "இணைத்தான்"}, {"w": 4, "t": "இரு கடல்களை"}, {"w": 5, "t": "இது"}, {"w": 6, "t": "மிக்க மதுரமானது"}, {"w": 7, "t": "இனிப்பு நீராகும்"}, {"w": 8, "t": "இதுவோ"}, {"w": 9, "t": "உப்பு நீராகும்"}, {"w": 10, "t": "மிக்க உவர்ப்பானது"}, {"w": 11, "t": "இன்னும் அவன் ஆக்கினான்"}, {"w": 12, "t": "அவ்விரண்டுக்கும் இடையில்"}, {"w": 13, "t": "ஒரு திரையையும்"}, {"w": 14, "t": "தடுப்பையும்"}, {"w": 15, "t": "முற்றிலும் தடுக்கக்கூடியது"}, {"w": 16, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "படைத்தான்"}, {"w": 4, "t": "நீரிலிருந்து"}, {"w": 5, "t": "the water"}, {"w": 6, "t": "மனிதனை"}, {"w": 7, "t": "இன்னும் அவனை ஆக்கினான்"}, {"w": 8, "t": "இரத்த பந்தமுடையவனாக"}, {"w": 9, "t": "இன்னும் திருமண பந்தமுடையவனாக"}, {"w": 10, "t": "இருக்கிறான்"}, {"w": 11, "t": "உமது இறைவன்"}, {"w": 12, "t": "பேராற்றலுடையவனாக"}, {"w": 13, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "அவர்கள் வணங்குகின்றனர்"}, {"w": 2, "t": "அல்லாஹ்வையன்றி"}, {"w": 3, "t": "besides Allah"}, {"w": 4, "t": "besides Allah"}, {"w": 5, "t": "அவர்களுக்கு நற்பலனளிக்காதவற்றை"}, {"w": 6, "t": "not profits them"}, {"w": 7, "t": "not profits them"}, {"w": 8, "t": "இன்னும் தீங்கிழைக்காதவற்றை"}, {"w": 9, "t": "இன்னும் தீங்கிழைக்காதவற்றை அவர்களுக்கு"}, {"w": 10, "t": "இருக்கிறான்"}, {"w": 11, "t": "நிராகரிப்பாளன்"}, {"w": 12, "t": "எதிராக"}, {"w": 13, "t": "தன் இறைவனுக்கு"}, {"w": 14, "t": "உதவக்கூடியவனாக"}, {"w": 15, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "உம்மை நாம் அனுப்பவில்லை"}, {"w": 2, "t": "We sent you"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "நற்செய்தி கூறுபவராக"}, {"w": 5, "t": "இன்னும் எச்சரிப்பவராகவே"}, {"w": 6, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் உங்களிடம் கேட்கவில்லை"}, {"w": 3, "t": "I ask (of) you"}, {"w": 4, "t": "இதற்காக"}, {"w": 5, "t": "எவ்வித கூலியையும்"}, {"w": 6, "t": "payment"}, {"w": 7, "t": "எனினும்"}, {"w": 8, "t": "யார்"}, {"w": 9, "t": "நாடினானோ"}, {"w": 10, "t": "எடுத்துக்கொள்ள"}, {"w": 11, "t": "take"}, {"w": 12, "t": "தன் இறைவனுடைய"}, {"w": 13, "t": "his Lord"}, {"w": 14, "t": "வழியில்"}, {"w": 15, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "நம்பிக்கை வைப்பீராக"}, {"w": 2, "t": "மீது"}, {"w": 3, "t": "உயிருள்ளவன்"}, {"w": 4, "t": "எவன்"}, {"w": 5, "t": "மரணிக்கமாட்டான்"}, {"w": 6, "t": "does not die"}, {"w": 7, "t": "இன்னும் துதிப்பீராக!"}, {"w": 8, "t": "அவனைப் புகழ்ந்து"}, {"w": 9, "t": "போதுமானவன்"}, {"w": 10, "t": "அவனே"}, {"w": 11, "t": "பாவங்களை"}, {"w": 12, "t": "தன் அடியார்களின்"}, {"w": 13, "t": "ஆழ்ந்தறிபவனாக"}, {"w": 14, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "படைத்தான்"}, {"w": 3, "t": "வானங்களையும்"}, {"w": 4, "t": "பூமியையும்"}, {"w": 5, "t": "அவற்றுக்கு இடையில் உள்ளவற்றையும்"}, {"w": 6, "t": "(is) between them"}, {"w": 7, "t": "ஆறு நாட்களில்"}, {"w": 8, "t": "six"}, {"w": 9, "t": "periods"}, {"w": 10, "t": "பிறகு"}, {"w": 11, "t": "உயர்ந்து விட்டான்"}, {"w": 12, "t": "மீது"}, {"w": 13, "t": "அர்ஷின்"}, {"w": 14, "t": "அவன் பேரருளாளன்"}, {"w": 15, "t": "கேட்பீராக!"}, {"w": 16, "t": "அவனை"}, {"w": 17, "t": "அறிந்தவனிடம்"}, {"w": 18, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "கூறப்பட்டால்"}, {"w": 2, "t": "it is said"}, {"w": 3, "t": "அவர்களுக்கு"}, {"w": 4, "t": "சிரம் பணியுங்கள்"}, {"w": 5, "t": "ரஹ்மானுக்கு"}, {"w": 6, "t": "கூறுகின்றனர்"}, {"w": 7, "t": "யார்?"}, {"w": 8, "t": "பேரருளாளன்"}, {"w": 9, "t": "நாங்கள் சிரம் பணிய வேண்டுமா?"}, {"w": 10, "t": "நீர்ஏவக்கூடியவனுக்கு"}, {"w": 11, "t": "you order us"}, {"w": 12, "t": "அதிகப்படுத்தியது அவர்களுக்கு"}, {"w": 13, "t": "வெறுப்பை"}, {"w": 14, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "மிக்க அருள் நிறைந்தவன்"}, {"w": 2, "t": "எவன்/அமைத்தான்"}, {"w": 3, "t": "has placed"}, {"w": 4, "t": "வானங்களில்"}, {"w": 5, "t": "the skies"}, {"w": 6, "t": "பெரும் கோட்டைகளை"}, {"w": 7, "t": "இன்னும் அமைத்தான்"}, {"w": 8, "t": "அதில்"}, {"w": 9, "t": "சூரியனையும்"}, {"w": 10, "t": "சந்திரனையும்"}, {"w": 11, "t": "ஒளிரும்"}, {"w": 12, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "அமைத்தான்"}, {"w": 4, "t": "இரவையும்"}, {"w": 5, "t": "பகலையும்"}, {"w": 6, "t": "பகரமாக"}, {"w": 7, "t": "நாடுபவருக்கு"}, {"w": 8, "t": "desires"}, {"w": 9, "t": "நல்லறிவு பெற"}, {"w": 10, "t": "remember"}, {"w": 11, "t": "அல்லது"}, {"w": 12, "t": "நாடினார்"}, {"w": 13, "t": "நன்றிசெய்ய"}, {"w": 14, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "அடியார்கள்"}, {"w": 2, "t": "பேரருளாளனுடைய"}, {"w": 3, "t": "எவர்கள்"}, {"w": 4, "t": "நடப்பார்கள்"}, {"w": 5, "t": "பூமியில்"}, {"w": 6, "t": "the earth"}, {"w": 7, "t": "மென்மையாக"}, {"w": 8, "t": "இன்னும் அவர்களிடம் பேசினால்"}, {"w": 9, "t": "address them"}, {"w": 10, "t": "அறிவீனர்கள்"}, {"w": 11, "t": "கூறி விடுவார்கள்"}, {"w": 12, "t": "ஸலாம்"}, {"w": 13, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "இரவு கழிப்பார்கள்"}, {"w": 3, "t": "தங்கள் இறைவனுக்கு"}, {"w": 4, "t": "சிரம் பணிந்தவர்களாக"}, {"w": 5, "t": "நின்றவர்களாக"}, {"w": 6, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "இன்னும் அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "say"}, {"w": 3, "t": "எங்கள் இறைவா!"}, {"w": 4, "t": "திருப்பி விடு"}, {"w": 5, "t": "எங்களை விட்டு"}, {"w": 6, "t": "தண்டனையை"}, {"w": 7, "t": "நரகமுடைய"}, {"w": 8, "t": "நிச்சயமாக"}, {"w": 9, "t": "அதனுடைய தண்டனை"}, {"w": 10, "t": "இருக்கிறது"}, {"w": 11, "t": "நீங்காத ஒன்றாக"}, {"w": 12, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "நிச்சயமாக அது"}, {"w": 2, "t": "மிக கெட்டது"}, {"w": 3, "t": "நிரந்தரமானது"}, {"w": 4, "t": "தற்காலிகமான தங்குமிடத்தாலும்"}, {"w": 5, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "அவர்கள் செலவு செய்தால்"}, {"w": 2, "t": "when"}, {"w": 3, "t": "they spend"}, {"w": 4, "t": "வரம்பு மீறமாட்டார்கள்"}, {"w": 5, "t": "(are) not extravagant"}, {"w": 6, "t": "இன்னும் கருமித்தனமும் காட்ட மாட்டார்கள்"}, {"w": 7, "t": "and are not stingy"}, {"w": 8, "t": "இருக்கும்"}, {"w": 9, "t": "மத்தியில்"}, {"w": 10, "t": "அதற்கு"}, {"w": 11, "t": "நடுநிலையாக"}, {"w": 12, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "அவர்கள் அழைக்க மாட்டார்கள்"}, {"w": 2, "t": "(do) not"}, {"w": 3, "t": "invoke"}, {"w": 4, "t": "அல்லாஹ்வுடன்"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "ஒரு கடவுளை"}, {"w": 7, "t": "வேறு"}, {"w": 8, "t": "இன்னும் கொல்ல மாட்டார்கள்"}, {"w": 9, "t": "[they] kill"}, {"w": 10, "t": "உயிரை"}, {"w": 11, "t": "எது/தடுத்தான்"}, {"w": 12, "t": "Allah has forbidden"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "தவிர"}, {"w": 15, "t": "உரிமையைக் கொண்டே"}, {"w": 16, "t": "இன்னும் விபசாரம் செய்யமாட்டார்கள்"}, {"w": 17, "t": "commit unlawful sexual intercourse"}, {"w": 18, "t": "யார் செய்வாரோ"}, {"w": 19, "t": "does"}, {"w": 20, "t": "இவற்றை"}, {"w": 21, "t": "அவர் சந்திப்பார்"}, {"w": 22, "t": "தண்டனையை"}, {"w": 23, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "பன்மடங்காக ஆக்கப்படும்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "அந்த தண்டனை"}, {"w": 4, "t": "மறுமை நாளில்"}, {"w": 5, "t": "(of) Resurrection"}, {"w": 6, "t": "நிரந்தரமாக தங்கி விடுவார்"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "இழிவுபடுத்தப்பட்டவராக"}, {"w": 9, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "எனினும்,"}, {"w": 2, "t": "யார்"}, {"w": 3, "t": "திருந்தினார்(கள்)"}, {"w": 4, "t": "இன்னும் நம்பிக்கை கொண்டார்(கள்)"}, {"w": 5, "t": "இன்னும் செய்தார்"}, {"w": 6, "t": "செயலை"}, {"w": 7, "t": "நன்மையான"}, {"w": 8, "t": "அவர்கள்"}, {"w": 9, "t": "மாற்றி விடுவான்"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "அவர்களுடைய தீய செயல்களை"}, {"w": 12, "t": "நல்ல செயல்களாக"}, {"w": 13, "t": "இருக்கிறான்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "மகா மன்னிப்பாளனாக"}, {"w": 16, "t": "பெரும் கருணையாளனாக"}, {"w": 17, "t": "(70)"}]}, {"ayah": 71, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "திருந்துவார்"}, {"w": 3, "t": "இன்னும் செய்வார்"}, {"w": 4, "t": "நன்மை"}, {"w": 5, "t": "நிச்சயமாக அவர்"}, {"w": 6, "t": "திரும்பி விடுகிறார்"}, {"w": 7, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 8, "t": "Allah"}, {"w": 9, "t": "திரும்புதல்-முற்றிலும்"}, {"w": 10, "t": "(71)"}]}, {"ayah": 72, "words": [{"w": 1, "t": "இன்னும் அவர்கள் ஆஜராக மாட்டார்கள்"}, {"w": 2, "t": "(do) not"}, {"w": 3, "t": "bear witness"}, {"w": 4, "t": "பொய்யான செயலுக்கு"}, {"w": 5, "t": "இன்னும் இவர்கள் கடந்து சென்றால்"}, {"w": 6, "t": "they pass"}, {"w": 7, "t": "வீணான செயலுக்கு"}, {"w": 8, "t": "கடந்து சென்று விடுவார்கள்"}, {"w": 9, "t": "கண்ணியவான்களாக"}, {"w": 10, "t": "(72)"}]}, {"ayah": 73, "words": [{"w": 1, "t": "இன்னும் எவர்கள்/அவர்கள் அறிவுறுத்தப்பட்டால்"}, {"w": 2, "t": "when"}, {"w": 3, "t": "they are reminded"}, {"w": 4, "t": "வசனங்களைக் கொண்டு"}, {"w": 5, "t": "தங்கள் இறைவனின்"}, {"w": 6, "t": "விழ மாட்டார்கள்"}, {"w": 7, "t": "fall"}, {"w": 8, "t": "அவற்றின் மீது"}, {"w": 9, "t": "செவிடர்களாக"}, {"w": 10, "t": "இன்னும் குருடர்களாக"}, {"w": 11, "t": "(73)"}]}, {"ayah": 74, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "say"}, {"w": 3, "t": "எங்கள் இறைவா!"}, {"w": 4, "t": "தருவாயாக!"}, {"w": 5, "t": "எங்களுக்கு"}, {"w": 6, "t": "எங்கள் மனைவிகள் மூலமும்"}, {"w": 7, "t": "our spouses"}, {"w": 8, "t": "எங்கள் சந்ததிகள் மூலமும்"}, {"w": 9, "t": "குளிர்ச்சியை"}, {"w": 10, "t": "கண்களுக்கு"}, {"w": 11, "t": "எங்களை ஆக்குவாயாக!"}, {"w": 12, "t": "இறையச்சமுள்ளவர்களுக்கு"}, {"w": 13, "t": "இமாம்களாக"}, {"w": 14, "t": "(74)"}]}, {"ayah": 75, "words": [{"w": 1, "t": "இவர்கள்"}, {"w": 2, "t": "கூலியாக கொடுக்கப்படுவார்கள்"}, {"w": 3, "t": "அறையை"}, {"w": 4, "t": "அவர்கள் பொறுமையாக இருந்ததால்"}, {"w": 5, "t": "they were patient"}, {"w": 6, "t": "சந்திக்கப்படுவார்கள்"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "முகமனைக்கொண்டும்"}, {"w": 9, "t": "ஸலாமைக் கொண்டும்"}, {"w": 10, "t": "(75)"}]}, {"ayah": 76, "words": [{"w": 1, "t": "அவர்கள் நிரந்தரமாக தங்கி இருப்பார்கள்"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "அது மிக அழகானது"}, {"w": 4, "t": "நிரந்தரமான தங்குமிடத்தாலும்"}, {"w": 5, "t": "தற்காலிகமான தங்குமிடத்தாலும்"}, {"w": 6, "t": "(76)"}]}, {"ayah": 77, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "ஒரு பொருட்டாகவே கருதமாட்டான்"}, {"w": 3, "t": "will care"}, {"w": 4, "t": "உங்களை"}, {"w": 5, "t": "என் இறைவன்"}, {"w": 6, "t": "இல்லாதிருந்தால்"}, {"w": 7, "t": "பிரார்த்தனை உங்கள்"}, {"w": 8, "t": "திட்டமாக"}, {"w": 9, "t": "நீங்கள் பொய்ப்பித்தீர்கள்"}, {"w": 10, "t": "இது கண்டிப்பாக இருக்கும்"}, {"w": 11, "t": "will be"}, {"w": 12, "t": "உங்களை தொடரக்கூடியதாக"}, {"w": 13, "t": "(77)"}]}]}