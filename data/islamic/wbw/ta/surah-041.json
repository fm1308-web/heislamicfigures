 "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "நாம் இதை ஆக்கி இருந்தால்"}, {"w": 2, "t": "We (had) made it"}, {"w": 3, "t": "குர்ஆனாக"}, {"w": 4, "t": "அரபி அல்லாத மொழி"}, {"w": 5, "t": "கூறியிருப்பார்கள்"}, {"w": 6, "t": "விவரிக்கப்பட்டிருக்க வேண்டாமா?"}, {"w": 7, "t": "are explained in detail"}, {"w": 8, "t": "இதன் வசனங்கள்"}, {"w": 9, "t": "அரபி அல்லாத ஒரு மொழியிலா!"}, {"w": 10, "t": "இன்னும் அரபி ஆயிற்றே !"}, {"w": 11, "t": "கூறுவீராக!/இது"}, {"w": 12, "t": "It (is)"}, {"w": 13, "t": "நம்பிக்கை கொண்டவர்களுக்கு"}, {"w": 14, "t": "believe"}, {"w": 15, "t": "நேர்வழி(யும்)"}, {"w": 16, "t": "நிவாரணமும்"}, {"w": 17, "t": "எவர்கள்/நம்பிக்கை கொள்ளவில்லையோ"}, {"w": 18, "t": "(do) not"}, {"w": 19, "t": "believe"}, {"w": 20, "t": "அவர்களின் காதுகளில்"}, {"w": 21, "t": "their ears"}, {"w": 22, "t": "செவிட்டுத்தனம்"}, {"w": 23, "t": "அது"}, {"w": 24, "t": "அவர்கள் மீது"}, {"w": 25, "t": "மறைந்திருக்கிறது"}, {"w": 26, "t": "அவர்கள்"}, {"w": 27, "t": "அழைக்கப்படுவார்கள்"}, {"w": 28, "t": "இடத்தில் இருந்து"}, {"w": 29, "t": "a place"}, {"w": 30, "t": "மிக தூரமான"}, {"w": 31, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் கொடுத்தோம்"}, {"w": 3, "t": "மூஸாவிற்கு"}, {"w": 4, "t": "வேதத்தை"}, {"w": 5, "t": "ஆனால் முரண்பாடு செய்யப்பட்டது/அதில்"}, {"w": 6, "t": "therein"}, {"w": 7, "t": "ஒரு வாக்கு முந்தியிருக்கவில்லை என்றால்"}, {"w": 8, "t": "(for) a word"}, {"w": 9, "t": "(that) preceded"}, {"w": 10, "t": "உமது இறைவனிடமிருந்து"}, {"w": 11, "t": "your Lord"}, {"w": 12, "t": "தீர்ப்பளிக்கப்பட்டிருக்கும்"}, {"w": 13, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 14, "t": "இன்னும் நிச்சயமாக அவர்கள்"}, {"w": 15, "t": "சந்தேகத்தில்தான்"}, {"w": 16, "t": "doubt"}, {"w": 17, "t": "இதில்"}, {"w": 18, "t": "மிக ஆழமான"}, {"w": 19, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "யார் செய்வாரோ"}, {"w": 2, "t": "does"}, {"w": 3, "t": "நல்லதை"}, {"w": 4, "t": "அது அவருக்குத்தான் நன்மையாகும்"}, {"w": 5, "t": "இன்னும் யார்"}, {"w": 6, "t": "தீயதை செய்வாரோ"}, {"w": 7, "t": "அது அவருக்குத்தான் கேடாகும்"}, {"w": 8, "t": "இல்லை"}, {"w": 9, "t": "உமது இறைவன்"}, {"w": 10, "t": "அநியாயம் செய்பவனாக"}, {"w": 11, "t": "அடியார்களுக்கு"}, {"w": 12, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "அவன் பக்கமே"}, {"w": 2, "t": "திருப்பப்படுகிறது"}, {"w": 3, "t": "அறிவு"}, {"w": 4, "t": "மறுமையைப் பற்றிய"}, {"w": 5, "t": "வெளிவருவதில்லை"}, {"w": 6, "t": "comes out"}, {"w": 7, "t": "பழங்களில் எதுவும்"}, {"w": 8, "t": "fruits"}, {"w": 9, "t": "அவற்றின் பாலைகளில் இருந்து"}, {"w": 10, "t": "their coverings"}, {"w": 11, "t": "கர்ப்பமடைவதுமில்லை"}, {"w": 12, "t": "bears"}, {"w": 13, "t": "பெண்களில் எவரும்"}, {"w": 14, "t": "female"}, {"w": 15, "t": "இன்னும் குழந்தை பெற்றெடுப்பதுமில்லை"}, {"w": 16, "t": "gives birth"}, {"w": 17, "t": "அவனது ஞானமில்லாமல்"}, {"w": 18, "t": "with His knowledge"}, {"w": 19, "t": "நாளில்"}, {"w": 20, "t": "அவர்களை அவன் அழைக்கின்ற"}, {"w": 21, "t": "எங்கே"}, {"w": 22, "t": "எனது இணைகள்"}, {"w": 23, "t": "அவர்கள்கூறுவார்கள்"}, {"w": 24, "t": "நாங்கள் உனக்கு அறிவித்து விட்டோம்"}, {"w": 25, "t": "எங்களில் இல்லை"}, {"w": 26, "t": "among us"}, {"w": 27, "t": "சாட்சி சொல்பவர் யாரும்"}, {"w": 28, "t": "witness"}, {"w": 29, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "இன்னும் மறைந்துவிடும்"}, {"w": 2, "t": "அவர்களை விட்டும்"}, {"w": 3, "t": "அவர்கள் பிரார்த்தித்துக் கொண்டிருந்தவை"}, {"w": 4, "t": "they were"}, {"w": 5, "t": "invoking"}, {"w": 6, "t": "இதற்கு முன்னர்"}, {"w": 7, "t": "before"}, {"w": 8, "t": "இன்னும் அறிந்து கொள்வார்கள்"}, {"w": 9, "t": "தங்களுக்கு இல்லை"}, {"w": 10, "t": "for them"}, {"w": 11, "t": "தப்பிப்பதற்குரிய இடம் எதுவும்"}, {"w": 12, "t": "place of escape"}, {"w": 13, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "சடைவடையமாட்டான்"}, {"w": 2, "t": "get tired"}, {"w": 3, "t": "மனிதன்"}, {"w": 4, "t": "பிரார்த்திப்பதில்"}, {"w": 5, "t": "praying"}, {"w": 6, "t": "நன்மைக்காக"}, {"w": 7, "t": "அவனுக்கு நிகழ்ந்தால்"}, {"w": 8, "t": "touches him"}, {"w": 9, "t": "தீமைகள்"}, {"w": 10, "t": "நிராசை அடைந்தவனாக"}, {"w": 11, "t": "நம்பிக்கை இழந்தவனாக"}, {"w": 12, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "நாம் அவனுக்கு சுவைக்க வைத்தால்"}, {"w": 2, "t": "ஓர் அருளை"}, {"w": 3, "t": "நம் புறத்தில் இருந்து"}, {"w": 4, "t": "பின்னர்"}, {"w": 5, "t": "after"}, {"w": 6, "t": "தீங்குக்கு"}, {"w": 7, "t": "அவனுக்கு நிகந்ததது"}, {"w": 8, "t": "இன்னும் கூறுகிறான்"}, {"w": 9, "t": "இது"}, {"w": 10, "t": "எனக்குரியது"}, {"w": 11, "t": "நான் எண்ணவில்லை"}, {"w": 12, "t": "and not"}, {"w": 13, "t": "மறுமை"}, {"w": 14, "t": "நிகழும்"}, {"w": 15, "t": "நான் திரும்பக் கொண்டு வரப்பட்டாலும்"}, {"w": 16, "t": "and if"}, {"w": 17, "t": "என் இறைவனிடம்"}, {"w": 18, "t": "to"}, {"w": 19, "t": "நிச்சயமாக எனக்கு"}, {"w": 20, "t": "indeed"}, {"w": 21, "t": "அவனிடம்"}, {"w": 22, "t": "சொர்க்கம் உண்டு"}, {"w": 23, "t": "நாம் நிச்சயமாக அறிவிப்போம்"}, {"w": 24, "t": "நிராகரித்தவர்களுக்கு"}, {"w": 25, "t": "those who"}, {"w": 26, "t": "அவர்கள் செய்ததை"}, {"w": 27, "t": "about what"}, {"w": 28, "t": "இன்னும் நிச்சயமாக அவர்களுக்கு சுவைக்க வைப்போம்"}, {"w": 29, "t": "கடுமையான வேதனையை"}, {"w": 30, "t": "of"}, {"w": 31, "t": "a punishment"}, {"w": 32, "t": "severe"}, {"w": 33, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நாம் அருள் புரிந்தால்"}, {"w": 2, "t": "We bestow favor"}, {"w": 3, "t": "மனிதன் மீது"}, {"w": 4, "t": "man"}, {"w": 5, "t": "புறக்கணித்து செல்கிறான்"}, {"w": 6, "t": "தூரமாகி விடுகிறான்"}, {"w": 7, "t": "and distances himself"}, {"w": 8, "t": "இன்னும் அவனுக்குநிகழ்ந்தால்"}, {"w": 9, "t": "touches him"}, {"w": 10, "t": "தீங்கு"}, {"w": 11, "t": "பிரார்த்தனை உடையவனாக"}, {"w": 12, "t": "(of) supplication"}, {"w": 13, "t": "மிக அதிகமான"}, {"w": 14, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நீங்கள் அறிவியுங்கள்"}, {"w": 3, "t": "இருந்தால்"}, {"w": 4, "t": "it is"}, {"w": 5, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 6, "t": "from"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "பிறகு"}, {"w": 9, "t": "நீங்கள் நிராகரித்து விட்டால்"}, {"w": 10, "t": "அதை/யார்?"}, {"w": 11, "t": "who"}, {"w": 12, "t": "மிகப் பெரிய வழிகேடன்"}, {"w": 13, "t": "ஒருவனைவிட"}, {"w": 14, "t": "அவன்"}, {"w": 15, "t": "முரண்பாட்டில்"}, {"w": 16, "t": "opposition"}, {"w": 17, "t": "வெகு தூரமான"}, {"w": 18, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "விரைவில் அவர்களுக்கு நாம் காண்பிப்போம்"}, {"w": 2, "t": "நமது அத்தாட்சிகளை"}, {"w": 3, "t": "பல பகுதிகளிலும்"}, {"w": 4, "t": "the horizons"}, {"w": 5, "t": "அவர்களிலும்"}, {"w": 6, "t": "themselves"}, {"w": 7, "t": "இறுதியாக"}, {"w": 8, "t": "தெளிவாகிவிடும்"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "நிச்சயமாக இதுதான்"}, {"w": 11, "t": "உண்மை"}, {"w": 12, "t": "போதாதா?"}, {"w": 13, "t": "sufficient"}, {"w": 14, "t": "உமது இறைவனுக்கு"}, {"w": 15, "t": "நிச்சயமாக தான்"}, {"w": 16, "t": "எல்லாவற்றையும்"}, {"w": 17, "t": "all"}, {"w": 18, "t": "things"}, {"w": 19, "t": "நன்கு பார்ப்பவனாக"}, {"w": 20, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 2, "t": "நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "சந்தேகத்தில் இருக்கின்றனர்"}, {"w": 4, "t": "doubt"}, {"w": 5, "t": "சந்திப்பதில்"}, {"w": 6, "t": "(the) meeting"}, {"w": 7, "t": "தங்கள் இறைவனை"}, {"w": 8, "t": "அறிந்து கொள்ளுங்கள்!"}, {"w": 9, "t": "நிச்சயமாக அவன்"}, {"w": 10, "t": "எல்லாவற்றையும்"}, {"w": 11, "t": "things"}, {"w": 12, "t": "சூழ்ந்தவன்"}, {"w": 13, "t": "(54)"}]}]}