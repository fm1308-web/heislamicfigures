{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "ஹா மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இறக்கப்பட்ட வேதமாகும்"}, {"w": 2, "t": "பேரன்பாளனிடமிருந்து"}, {"w": 3, "t": "the Most Gracious"}, {"w": 4, "t": "பேரருளாளன்"}, {"w": 5, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "வேதமாகும்"}, {"w": 2, "t": "விவரிக்கப்பட்டன"}, {"w": 3, "t": "இதன் வசனங்கள்"}, {"w": 4, "t": "குர்ஆன்"}, {"w": 5, "t": "அரபி மொழியிலான"}, {"w": 6, "t": "மக்களுக்காக"}, {"w": 7, "t": "அறிகின்றார்கள்"}, {"w": 8, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நற்செய்தி கூறக்கூடியது"}, {"w": 2, "t": "அச்சமூட்டி எச்சரிக்கக் கூடியது"}, {"w": 3, "t": "புறக்கணித்தனர்"}, {"w": 4, "t": "அதிகமானோர் அவர்களில்"}, {"w": 5, "t": "இன்னும் அவர்கள்"}, {"w": 6, "t": "செவியேற்பதில்லை"}, {"w": 7, "t": "hear"}, {"w": 8, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவர்கள் கூறினார்கள்"}, {"w": 2, "t": "எங்கள் உள்ளங்கள்"}, {"w": 3, "t": "திரைகளில்தான்"}, {"w": 4, "t": "coverings"}, {"w": 5, "t": "எதில்/நீர் எங்களை அழைக்கின்றீர்களோ"}, {"w": 6, "t": "you call us"}, {"w": 7, "t": "அதன் பக்கம்"}, {"w": 8, "t": "இன்னும் எங்கள்செவிகளில்"}, {"w": 9, "t": "our ears"}, {"w": 10, "t": "செவிட்டுத்தனம்"}, {"w": 11, "t": "இன்னும் எங்களுக்கு மத்தியிலும்"}, {"w": 12, "t": "and between us"}, {"w": 13, "t": "உமக்கு மத்தியிலும்"}, {"w": 14, "t": "ஒரு திரை"}, {"w": 15, "t": "ஆகவே நீர் செய்வீராக!"}, {"w": 16, "t": "நிச்சயமாக நாங்கள்"}, {"w": 17, "t": "செய்வோம்"}, {"w": 18, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் எல்லாம்"}, {"w": 3, "t": "I am"}, {"w": 4, "t": "ஒரு மனிதர்தான்"}, {"w": 5, "t": "உங்களைப் போன்ற"}, {"w": 6, "t": "வஹீ  அறிவிக்கப்படுகிறது"}, {"w": 7, "t": "எனக்கு"}, {"w": 8, "t": "உங்கள் கடவுள் எல்லாம்"}, {"w": 9, "t": "your god"}, {"w": 10, "t": "ஒரே ஒருகடவுள்தான்"}, {"w": 11, "t": "One"}, {"w": 12, "t": "ஆகவே, நீங்கள் நேர்வழி நடங்கள்!"}, {"w": 13, "t": "அவன் பக்கமே"}, {"w": 14, "t": "இன்னும் அவனிடம் பாவமன்னிப்புக் கேளுங்கள்!"}, {"w": 15, "t": "நாசம்தான்/இணைவைப்பவர்களுக்கு"}, {"w": 16, "t": "to the polytheists"}, {"w": 17, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "எவர்கள்/அவர்கள் கொடுப்பதில்லை"}, {"w": 2, "t": "(do) not"}, {"w": 3, "t": "give"}, {"w": 4, "t": "ஸகாத்தை"}, {"w": 5, "t": "இன்னும் அவர்கள்"}, {"w": 6, "t": "மறுமையை"}, {"w": 7, "t": "அவர்கள்"}, {"w": 8, "t": "நிராகரிக்கின்றனர்"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்/நம்பிக்கை கொண்டனர்"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நன்மைகளை"}, {"w": 6, "t": "அவர்களுக்கு உண்டு"}, {"w": 7, "t": "நற்கூலி"}, {"w": 8, "t": "முடிவற்ற(து)"}, {"w": 9, "t": "never ending"}, {"w": 10, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நீங்கள் நிராகரிக்கின்றீர்களா?"}, {"w": 3, "t": "[surely] disbelieve"}, {"w": 4, "t": "படைத்தவனை"}, {"w": 5, "t": "created"}, {"w": 6, "t": "பூமியை"}, {"w": 7, "t": "இரண்டு நாள்களில்"}, {"w": 8, "t": "two periods"}, {"w": 9, "t": "இன்னும் ஏற்படுத்துகின்றீர்களா?"}, {"w": 10, "t": "அவனுக்கு"}, {"w": 11, "t": "இணைகளை"}, {"w": 12, "t": "அவன்தான்"}, {"w": 13, "t": "இறைவன்"}, {"w": 14, "t": "அகிலங்களின்"}, {"w": 15, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் ஏற்படுத்தினான்"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "மலைகளை"}, {"w": 4, "t": "அதற்கு மேலாக"}, {"w": 5, "t": "above it"}, {"w": 6, "t": "இன்னும் அருள்வளம் புரிந்தான்"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "இன்னும் திட்டமிட்டு நிர்ணயித்தான்"}, {"w": 9, "t": "அதில்"}, {"w": 10, "t": "அதன் உணவுகளை"}, {"w": 11, "t": "நான்கு"}, {"w": 12, "t": "four"}, {"w": 13, "t": "நாள்களில்"}, {"w": 14, "t": "சரியான பதிலாக"}, {"w": 15, "t": "விசாரிப்பவர்களுக்கு"}, {"w": 16, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "அவன் உயர்ந்தான்"}, {"w": 3, "t": "வானத்திற்கு மேல்"}, {"w": 4, "t": "the heaven"}, {"w": 5, "t": "அது (இருந்தது)"}, {"w": 6, "t": "ஓர் ஆவியாக"}, {"w": 7, "t": "அவன் கூறினான்"}, {"w": 8, "t": "அதற்கு(ம்)"}, {"w": 9, "t": "பூமிக்கும்"}, {"w": 10, "t": "நீங்கள் இருவரும் வாருங்கள்"}, {"w": 11, "t": "விருப்பத்துடன்"}, {"w": 12, "t": "அல்லது"}, {"w": 13, "t": "வெறுப்புடன்"}, {"w": 14, "t": "அவை இரண்டும்"}, {"w": 15, "t": "நாங்கள் வந்தோம்/விருப்பமுள்ளவர்களாகவே"}, {"w": 16, "t": "willingly"}, {"w": 17, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "ஆக, முடித்தான்/அவற்றை"}, {"w": 2, "t": "ஏழு/வானங்களாக"}, {"w": 3, "t": "heavens"}, {"w": 4, "t": "இரண்டு நாள்களில்"}, {"w": 5, "t": "two periods"}, {"w": 6, "t": "இன்னும் அறிவித்தான்"}, {"w": 7, "t": "ஒவ்வொரு"}, {"w": 8, "t": "each"}, {"w": 9, "t": "வானத்திலும்"}, {"w": 10, "t": "அதன் காரியத்தை"}, {"w": 11, "t": "இன்னும் அலங்கரித்தோம்"}, {"w": 12, "t": "வானத்தை"}, {"w": 13, "t": "சமீபமான(து)"}, {"w": 14, "t": "நட்சத்திரங்களால்"}, {"w": 15, "t": "இன்னும் பாதுகாப்பதற்காக"}, {"w": 16, "t": "இது/ஏற்பாடாகும்"}, {"w": 17, "t": "(is the) Decree"}, {"w": 18, "t": "மிகைத்தவன்"}, {"w": 19, "t": "நன்கறிந்தவன்"}, {"w": 20, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அவர்கள் புறக்கணித்தால்"}, {"w": 2, "t": "they turn away"}, {"w": 3, "t": "கூறுவீராக!"}, {"w": 4, "t": "உங்களுக்கு எச்சரிக்கிறேன்"}, {"w": 5, "t": "ஒரு பேரழிவை"}, {"w": 6, "t": "போன்ற"}, {"w": 7, "t": "(ஏற்பட்ட) பேரழிவை"}, {"w": 8, "t": "ஆது உடைய"}, {"w": 9, "t": "இன்னும் ஸமூது"}, {"w": 10, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவர்களிடம் வந்தபோது/தூதர்கள்"}, {"w": 2, "t": "came to them"}, {"w": 3, "t": "the Messengers"}, {"w": 4, "t": "அவர்களுக்கு முன்னிருந்து(ம்)"}, {"w": 5, "t": "from before them"}, {"w": 6, "t": "from before them"}, {"w": 7, "t": "இன்னும் அவர்களுக்குப் பின்னிருந்து"}, {"w": 8, "t": "behind them"}, {"w": 9, "t": "வணங்காதீர்கள்"}, {"w": 10, "t": "worship"}, {"w": 11, "t": "தவிர"}, {"w": 12, "t": "அல்லாஹ்வை"}, {"w": 13, "t": "அவர்கள் கூறினார்கள்"}, {"w": 14, "t": "நாடியிருந்தால்"}, {"w": 15, "t": "(had) willed"}, {"w": 16, "t": "எங்கள் இறைவன்"}, {"w": 17, "t": "இறக்கி இருப்பான்"}, {"w": 18, "t": "வானவர்களை"}, {"w": 19, "t": "நிச்சயமாக நாங்கள்"}, {"w": 20, "t": "எதைக் கொடுத்து அனுப்பப்பட்டீர்களோ"}, {"w": 21, "t": "you have been sent"}, {"w": 22, "t": "அதை"}, {"w": 23, "t": "நிராகரிப்பவர்கள்தான்"}, {"w": 24, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஆக, ஆது சமுதாயம்"}, {"w": 2, "t": "Aad"}, {"w": 3, "t": "பெருமை அடித்தனர்"}, {"w": 4, "t": "பூமியில்"}, {"w": 5, "t": "the land"}, {"w": 6, "t": "அநியாயமாக"}, {"w": 7, "t": "[the] right"}, {"w": 8, "t": "இன்னும் கூறினார்கள்"}, {"w": 9, "t": "யார்/மிக பலசாலி(கள்)"}, {"w": 10, "t": "(is) mightier"}, {"w": 11, "t": "எங்களை விட"}, {"w": 12, "t": "வலிமையால்"}, {"w": 13, "t": "இவர்கள் கவனிக்கவில்லையா?"}, {"w": 14, "t": "they see"}, {"w": 15, "t": "நிச்சயமாக"}, {"w": 16, "t": "அல்லாஹ்"}, {"w": 17, "t": "எவன்/படைத்தான்/அவர்களை"}, {"w": 18, "t": "created them"}, {"w": 19, "t": "அவன்"}, {"w": 20, "t": "மிக பலசாலி"}, {"w": 21, "t": "அவர்களை விட"}, {"w": 22, "t": "வலிமையால்"}, {"w": 23, "t": "அவர்கள் இருந்தனர்"}, {"w": 24, "t": "நமது வசனங்களை"}, {"w": 25, "t": "மறுப்பவர்களாக"}, {"w": 26, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "ஆகவே அனுப்பினோம்"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "காற்றை"}, {"w": 4, "t": "கடும் குளிர்(ந்தது)"}, {"w": 5, "t": "நாள்களில்"}, {"w": 6, "t": "(the) days"}, {"w": 7, "t": "துரதிர்ஷ்டமான"}, {"w": 8, "t": "நாம் அவர்களுக்கு சுவைக்க வைப்பதற்காக"}, {"w": 9, "t": "வேதனையை"}, {"w": 10, "t": "கேவலமான"}, {"w": 11, "t": "இவ்வுலகில்"}, {"w": 12, "t": "the life"}, {"w": 13, "t": "(of) the world"}, {"w": 14, "t": "வேதனையோ"}, {"w": 15, "t": "மறுமையின்"}, {"w": 16, "t": "மிக கேவலமானது"}, {"w": 17, "t": "இன்னும் அவர்கள் உதவி செய்யப்படமாட்டார்கள்"}, {"w": 18, "t": "will not be helped"}, {"w": 19, "t": "will not be helped"}, {"w": 20, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "ஆக, ஸமூது சமுதாயம்"}, {"w": 2, "t": "Thamud"}, {"w": 3, "t": "அவர்களுக்கு நேர்வழிகாட்டினோம்"}, {"w": 4, "t": "(ஆனால்) அதிகம் விரும்பினார்கள்"}, {"w": 5, "t": "குருட்டுத் தனத்தைத்தான்"}, {"w": 6, "t": "நேர்வழியை விட"}, {"w": 7, "t": "the guidance"}, {"w": 8, "t": "ஆகவே, அவர்களைப் பிடித்தது"}, {"w": 9, "t": "பேரழிவு"}, {"w": 10, "t": "வேதனையின்"}, {"w": 11, "t": "இழிவான"}, {"w": 12, "t": "அவர்கள் செய்து கொண்டிருந்தவற்றின் காரணமாக"}, {"w": 13, "t": "they used to"}, {"w": 14, "t": "earn"}, {"w": 15, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நாம் பாதுகாத்தோம்"}, {"w": 2, "t": "எவர்கள்/ நம்பிக்கைகொண்டனர்"}, {"w": 3, "t": "believed"}, {"w": 4, "t": "இன்னும் இருந்தார்கள்"}, {"w": 5, "t": "அஞ்சுபவர்களாக"}, {"w": 6, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நாளில்/ஒன்று திரட்டப்படுகின்றார்(கள்)"}, {"w": 2, "t": "will be gathered"}, {"w": 3, "t": "எதிரிகள்"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "நரகத்தின் பக்கம்"}, {"w": 6, "t": "the Fire"}, {"w": 7, "t": "ஆகவே, அவர்கள்"}, {"w": 8, "t": "நிறுத்தி வைக்கப்படுவார்கள்"}, {"w": 9, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இறுதியாக"}, {"w": 2, "t": "அவர்கள் அதனிடம் வரும் போது"}, {"w": 3, "t": "when"}, {"w": 4, "t": "they come to it"}, {"w": 5, "t": "சாட்சி கூறும்"}, {"w": 6, "t": "அவர்களுக்கு எதிராகவே"}, {"w": 7, "t": "அவர்களுடைய செவி(யும்)"}, {"w": 8, "t": "அவர்களுடைய பார்வைகளும்"}, {"w": 9, "t": "அவர்களுடைய தோல்களும்"}, {"w": 10, "t": "அவர்கள் செய்து கொண்டிருந்ததைப் பற்றி"}, {"w": 11, "t": "they used to"}, {"w": 12, "t": "do"}, {"w": 13, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "தங்களுடைய தோல்களிடம்"}, {"w": 3, "t": "ஏன் சாட்சிகூறினீர்கள்"}, {"w": 4, "t": "you testify"}, {"w": 5, "t": "எங்களுக்கு எதிராக"}, {"w": 6, "t": "அவை கூறும்"}, {"w": 7, "t": "எங்களை(யும்) பேச வைத்தான்"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "எவன்/பேசவைத்தான்"}, {"w": 10, "t": "makes speak"}, {"w": 11, "t": "எல்லாவற்றையும்"}, {"w": 12, "t": "thing"}, {"w": 13, "t": "அவன்தான்"}, {"w": 14, "t": "உங்களைப் படைத்தான்"}, {"w": 15, "t": "முதல் முறையாக"}, {"w": 16, "t": "time"}, {"w": 17, "t": "இன்னும் அவன் பக்கம்தான்"}, {"w": 18, "t": "நீங்கள் திரும்பக் கொண்டு வரப்படுவீர்கள்"}, {"w": 19, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நீங்கள் இருக்கவில்லை"}, {"w": 2, "t": "you were"}, {"w": 3, "t": "மறைப்பவர்களாக"}, {"w": 4, "t": "சாட்சி கூறிவிடும் என்பதற்காக"}, {"w": 5, "t": "testify"}, {"w": 6, "t": "உங்களுக்கு எதிராக"}, {"w": 7, "t": "உங்கள் செவியும்"}, {"w": 8, "t": "உங்கள் பார்வைகளும்"}, {"w": 9, "t": "your sight"}, {"w": 10, "t": "உங்கள் தோல்களும்"}, {"w": 11, "t": "your skins"}, {"w": 12, "t": "என்றாலும்"}, {"w": 13, "t": "நீங்கள் எண்ணினீர்கள்"}, {"w": 14, "t": "நிச்சயமாக"}, {"w": 15, "t": "அல்லாஹ்"}, {"w": 16, "t": "அறியமாட்டான்"}, {"w": 17, "t": "know"}, {"w": 18, "t": "அதிகமானதை"}, {"w": 19, "t": "நீங்கள் செய்வதில்"}, {"w": 20, "t": "you do"}, {"w": 21, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அந்த"}, {"w": 2, "t": "உங்கள் எண்ணம்தான்"}, {"w": 3, "t": "எது/எண்ணினீர்கள்"}, {"w": 4, "t": "you assumed"}, {"w": 5, "t": "உங்கள் இறைவனைப் பற்றி"}, {"w": 6, "t": "உங்களை நாசமாக்கியது"}, {"w": 7, "t": "ஆகவே, நீங்கள் ஆகிவிட்டீர்கள்"}, {"w": 8, "t": "நஷ்டவாளிகளில்"}, {"w": 9, "t": "the losers"}, {"w": 10, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவர்கள் பொறுமையாக இருந்தாலும்"}, {"w": 2, "t": "they endure"}, {"w": 3, "t": "நரகம்தான்"}, {"w": 4, "t": "தங்குமிடமாகும்"}, {"w": 5, "t": "அவர்களுக்குரிய"}, {"w": 6, "t": "அவர்கள் தங்களைத் திருப்புமாறு கோரினால்"}, {"w": 7, "t": "they ask for favor"}, {"w": 8, "t": "அப்படி அவர்கள் திருப்பப்பட மாட்டார்கள்"}, {"w": 9, "t": "they"}, {"w": 10, "t": "(will be) of"}, {"w": 11, "t": "those who receive favor"}, {"w": 12, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நாம் இலகுவாக்கி அமைத்துக் கொடுத்தோம்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "சில நண்பர்களை"}, {"w": 4, "t": "அலங்கரித்துக் காட்டினார்கள்/அவர்களுக்கு"}, {"w": 5, "t": "to them"}, {"w": 6, "t": "அவர்களுக்கு முன்னுள்ளதை(யும்)"}, {"w": 7, "t": "(was) before them"}, {"w": 8, "t": "(was) before them"}, {"w": 9, "t": "அவர்களுக்கு பின்னுள்ளதையும்"}, {"w": 10, "t": "(was) behind them"}, {"w": 11, "t": "இன்னும் உறுதியாகிவிட்டது"}, {"w": 12, "t": "இவர்கள் மீதும்"}, {"w": 13, "t": "விதிக்கப்பட்ட அதே விதி"}, {"w": 14, "t": "சமுதாயங்களுக்கு"}, {"w": 15, "t": "nations"}, {"w": 16, "t": "சென்று விட்டனர்"}, {"w": 17, "t": "(that have) passed away"}, {"w": 18, "t": "இவர்களுக்கு முன்னர்"}, {"w": 19, "t": "before them"}, {"w": 20, "t": "ஜின்களில்"}, {"w": 21, "t": "the jinn"}, {"w": 22, "t": "மற்றும் மனிதர்களில்"}, {"w": 23, "t": "நிச்சயமாக இவர்கள்"}, {"w": 24, "t": "இருக்கின்றனர்"}, {"w": 25, "t": "நஷ்டவாளிகளாக"}, {"w": 26, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "நிராகரிப்பாளர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "செவியுறாதீர்கள்"}, {"w": 5, "t": "listen"}, {"w": 6, "t": "இந்த குர்ஆனை"}, {"w": 7, "t": "Quran"}, {"w": 8, "t": "கூச்சல் குழப்பங்களை ஏற்படுத்துங்கள்!"}, {"w": 9, "t": "அதில்"}, {"w": 10, "t": "நீங்கள்வெற்றி பெறுவீர்கள்"}, {"w": 11, "t": "overcome"}, {"w": 12, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "ஆகவே, நிச்சயமாக சுவைக்க வைப்போம்"}, {"w": 2, "t": "நிராகரித்தவர்களுக்கு"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "வேதனையை"}, {"w": 5, "t": "கடுமையான"}, {"w": 6, "t": "இன்னும் அவர்களுக்கு நிச்சயமாக கூலி கொடுப்போம்"}, {"w": 7, "t": "மிகக் கெட்ட செயலுக்கு"}, {"w": 8, "t": "அவர்கள் செய்து கொண்டிருந்தவற்றில்"}, {"w": 9, "t": "they used to"}, {"w": 10, "t": "do"}, {"w": 11, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இதுதான்"}, {"w": 2, "t": "கூலியாகும்"}, {"w": 3, "t": "எதிரிகளுக்குரிய"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "நரகம்தான்"}, {"w": 6, "t": "அவர்களுக்கு/அதில்"}, {"w": 7, "t": "therein"}, {"w": 8, "t": "நிரந்தரமாக தங்கும் இல்லம்"}, {"w": 9, "t": "(of) the eternity"}, {"w": 10, "t": "கூலியாக"}, {"w": 11, "t": "அவர்கள் இருந்ததற்கு"}, {"w": 12, "t": "they used to"}, {"w": 13, "t": "நமது வசனங்களை"}, {"w": 14, "t": "மறுப்பவர்களாக"}, {"w": 15, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "கூறுவார்(கள்)"}, {"w": 2, "t": "நிராகரிப்பவர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "எங்கள் இறைவா"}, {"w": 5, "t": "எங்களுக்குக் காண்பி"}, {"w": 6, "t": "எவர்கள்/வழிகெடுத்தனர்/எங்களை"}, {"w": 7, "t": "misled us"}, {"w": 8, "t": "ஜின் மற்றும் மனிதர்களில்"}, {"w": 9, "t": "the jinn"}, {"w": 10, "t": "and the men"}, {"w": 11, "t": "அ(வ்விரு)வர்களை ஆக்கிக் கொள்கிறோம்"}, {"w": 12, "t": "எங்கள் பாதங்களுக்குக் கீழ்"}, {"w": 13, "t": "our feet"}, {"w": 14, "t": "ஆகிவிடுவதற்காக"}, {"w": 15, "t": "மிகக் கீழ்த்தரமானவர்களில்"}, {"w": 16, "t": "the lowest"}, {"w": 17, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "நிச்சயமாக எவர்கள்"}, {"w": 2, "t": "those who"}, {"w": 3, "t": "கூறினார்கள்"}, {"w": 4, "t": "எங்கள் இறைவன்"}, {"w": 5, "t": "அல்லாஹ்தான்"}, {"w": 6, "t": "பிறகு/உறுதியாக இருந்தார்கள்"}, {"w": 7, "t": "stand firm "}, {"w": 8, "t": "இறங்குவார்கள்"}, {"w": 9, "t": "அவர்கள் மீது"}, {"w": 10, "t": "வானவர்கள்"}, {"w": 11, "t": "நீங்கள் பயப்படாதீர்கள்!"}, {"w": 12, "t": "fear"}, {"w": 13, "t": "இன்னும் கவலைப்படாதீர்கள்!"}, {"w": 14, "t": "grieve"}, {"w": 15, "t": "நற்செய்தி பெறுங்கள்!"}, {"w": 16, "t": "சொர்க்கத்தைக் கொண்டு"}, {"w": 17, "t": "எது/வாக்களிக்கப்பட்டவர்களாக இருந்தீர்கள்"}, {"w": 18, "t": "you were"}, {"w": 19, "t": "promised"}, {"w": 20, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நாங்கள் உங்கள் பொறுப்பாளர்கள்"}, {"w": 2, "t": "(are) your protectors"}, {"w": 3, "t": "வாழ்க்கையிலும்"}, {"w": 4, "t": "the life"}, {"w": 5, "t": "இந்த உலக"}, {"w": 6, "t": "மறுமையிலும்"}, {"w": 7, "t": "the Hereafter"}, {"w": 8, "t": "உங்களுக்கு உண்டு"}, {"w": 9, "t": "அதில்"}, {"w": 10, "t": "எதை/விரும்புகின்றது"}, {"w": 11, "t": "desire"}, {"w": 12, "t": "உங்கள் மனங்கள்"}, {"w": 13, "t": "உங்களுக்கு உண்டு"}, {"w": 14, "t": "அதில்"}, {"w": 15, "t": "எதை/கேட்கின்றீர்கள்"}, {"w": 16, "t": "you ask"}, {"w": 17, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "விருந்தோம்பலாக"}, {"w": 2, "t": "இருந்து"}, {"w": 3, "t": "மகா மன்னிப்பாளன்"}, {"w": 4, "t": "மகா கருணையாளன்"}, {"w": 5, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "யார்?"}, {"w": 2, "t": "மிக அழகானவர்"}, {"w": 3, "t": "பேச்சால்"}, {"w": 4, "t": "ஒருவரைவிட"}, {"w": 5, "t": "அழைத்தார்"}, {"w": 6, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "இன்னும் செய்தார்"}, {"w": 9, "t": "நல்லதை"}, {"w": 10, "t": "இன்னும் கூறுகின்றார்"}, {"w": 11, "t": "நிச்சயமாக நான்"}, {"w": 12, "t": "முஸ்லிம்களில் உள்ளவன்"}, {"w": 13, "t": "those who submit"}, {"w": 14, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "சமமாகாது"}, {"w": 2, "t": "(are) equal"}, {"w": 3, "t": "நன்மையும்"}, {"w": 4, "t": "தீமையும்"}, {"w": 5, "t": "the evil (deed)"}, {"w": 6, "t": "தடுப்பீராக!"}, {"w": 7, "t": "மிக அழகியதைக் கொண்டு"}, {"w": 8, "t": "[it]"}, {"w": 9, "t": "(is) better"}, {"w": 10, "t": "அப்போது"}, {"w": 11, "t": "எவர்/உமக்கு இடையில்"}, {"w": 12, "t": "between you"}, {"w": 13, "t": "ஒருவருக்கும்"}, {"w": 14, "t": "பகைமை"}, {"w": 15, "t": "போல்/அவர்"}, {"w": 16, "t": "ஓர் உறவுக்காரரை"}, {"w": 17, "t": "நெருக்கமான"}, {"w": 18, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இதை கொடுக்கப்பட மாட்டார்கள்"}, {"w": 2, "t": "it is granted"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "பொறுமையாளர்கள்"}, {"w": 5, "t": "(are) patient"}, {"w": 6, "t": "இன்னும் இதை கொடுக்கப்பட மாட்டார்கள்"}, {"w": 7, "t": "it is granted"}, {"w": 8, "t": "பெரும் பாக்கியம் உடையவர்கள் தவிர"}, {"w": 9, "t": "(to the) owner"}, {"w": 10, "t": "(of) fortune"}, {"w": 11, "t": "great"}, {"w": 12, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "நிச்சயமாக உம்மைத் தூண்டினால்"}, {"w": 2, "t": "whisper comes to you"}, {"w": 3, "t": "ஷைத்தானிடமிருந்து"}, {"w": 4, "t": "the Shaitaan"}, {"w": 5, "t": "தீய எண்ணம்"}, {"w": 6, "t": "பாதுகாவல் தேடுவீராக!"}, {"w": 7, "t": "அல்லாஹ்விடம்"}, {"w": 8, "t": "நிச்சயமாக அவன்தான்"}, {"w": 9, "t": "[He]"}, {"w": 10, "t": "நன்கு செவியுறுபவன்"}, {"w": 11, "t": "நன்கறிந்தவன்"}, {"w": 12, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "அவனுடைய அத்தாட்சிகளில் உள்ளவைதான்"}, {"w": 2, "t": "His Signs"}, {"w": 3, "t": "இரவு"}, {"w": 4, "t": "பகல்"}, {"w": 5, "t": "சூரியன்"}, {"w": 6, "t": "சந்திரன்"}, {"w": 7, "t": "சிரம் பணியாதீர்கள்!"}, {"w": 8, "t": "prostrate"}, {"w": 9, "t": "சூரியனுக்கும்"}, {"w": 10, "t": "சந்திரனுக்கும்"}, {"w": 11, "t": "to the moon"}, {"w": 12, "t": "சிரம் பணியுங்கள்"}, {"w": 13, "t": "அல்லாஹ்விற்கு"}, {"w": 14, "t": "இவற்றைப் படைத்தவன்"}, {"w": 15, "t": "created them"}, {"w": 16, "t": "நீங்கள் இருந்தால்"}, {"w": 17, "t": "you"}, {"w": 18, "t": "அவனை"}, {"w": 19, "t": "வணங்குபவர்களாக"}, {"w": 20, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "அவர்கள் பெருமையடித்து விலகினால்"}, {"w": 2, "t": "they are arrogant"}, {"w": 3, "t": "உமது இறைவனிடம் இருக்கின்றவர்கள்"}, {"w": 4, "t": "(are) near"}, {"w": 5, "t": "your Lord"}, {"w": 6, "t": "துதிக்கின்றனர்"}, {"w": 7, "t": "அவனை"}, {"w": 8, "t": "இரவிலும்"}, {"w": 9, "t": "பகலிலும்"}, {"w": 10, "t": "அவர்கள்"}, {"w": 11, "t": "சோர்வடைய மாட்டார்கள்"}, {"w": 12, "t": "tire"}, {"w": 13, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "இன்னும் அவனுடைய அத்தாட்சிகளில் உள்ளதுதான்"}, {"w": 2, "t": "His Signs"}, {"w": 3, "t": "நிச்சயமாக நீர்"}, {"w": 4, "t": "பார்க்கின்றீர்"}, {"w": 5, "t": "பூமியை"}, {"w": 6, "t": "காய்ந்ததாக"}, {"w": 7, "t": "பிறகு, நாம் இறக்கினால்"}, {"w": 8, "t": "We send down"}, {"w": 9, "t": "அதன் மீது"}, {"w": 10, "t": "நீரை"}, {"w": 11, "t": "செழிப்படைகிறது"}, {"w": 12, "t": "இன்னும் அது வளர்கிறது"}, {"w": 13, "t": "நிச்சயமாக"}, {"w": 14, "t": "எவன்/உயிர்ப்பித்தான்/அதை"}, {"w": 15, "t": "gives it life"}, {"w": 16, "t": "உயிர்ப்பிப்பவன்"}, {"w": 17, "t": "மரணித்தவர்களை(யும்)"}, {"w": 18, "t": "நிச்சயமாக அவன்"}, {"w": 19, "t": "எல்லாவற்றின் மீதும்"}, {"w": 20, "t": "every"}, {"w": 21, "t": "thing"}, {"w": 22, "t": "பேராற்றலுடையவன்"}, {"w": 23, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "தடம் புரளுபவர்கள்"}, {"w": 3, "t": "distort"}, {"w": 4, "t": "நமது வசனங்களில்"}, {"w": 5, "t": "Our Verses"}, {"w": 6, "t": "மறைந்துவிட மாட்டார்கள்"}, {"w": 7, "t": "hidden"}, {"w": 8, "t": "நம்மீது"}, 