{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நிகழ்ந்து விட்டால்"}, {"w": 2, "t": "occurs"}, {"w": 3, "t": "நிகழக்கூடிய மறுமை"}, {"w": 4, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "முடியாது"}, {"w": 2, "t": "அது நிகழ்வதை"}, {"w": 3, "t": "பொய்ப்பிக்க"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "தாழ்த்தக்கூடியது"}, {"w": 2, "t": "உயர்த்தக்கூடியது"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "குலுக்கப்பட்டால்"}, {"w": 2, "t": "will be shaken"}, {"w": 3, "t": "பூமி"}, {"w": 4, "t": "பலமாக"}, {"w": 5, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "தூளாக ஆக்கப்பட்டால்"}, {"w": 2, "t": "மலைகள்"}, {"w": 3, "t": "தூள்"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "ஆகிவிடும்"}, {"w": 2, "t": "ஒளிக் கதிர்களைப் போல்"}, {"w": 3, "t": "பரவுகின்ற(து)"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நீங்கள் ஆகிவிடுவீர்கள்"}, {"w": 2, "t": "வகையினராக"}, {"w": 3, "t": "மூன்று"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அருள் மிகுந்த வலப்பக்கம் உடையவர்கள்!"}, {"w": 2, "t": "(of) the right"}, {"w": 3, "t": "யார்? அருள் மிகுந்த வலப்பக்கம் உடையவர்கள்!"}, {"w": 4, "t": "(are the) companions"}, {"w": 5, "t": "(of) the right"}, {"w": 6, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "துர்பாக்கியம் நிறைந்த இடப்பக்கம் உடையவர்கள்!"}, {"w": 2, "t": "(of) the left"}, {"w": 3, "t": "துர்பாக்கியம் நிறைந்த இடப்பக்கம் உடையவர்கள் யார்?"}, {"w": 4, "t": "(are the) companions"}, {"w": 5, "t": "(of) the left"}, {"w": 6, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "முந்தியவர்கள்தான்"}, {"w": 2, "t": "முந்தியவர்கள்"}, {"w": 3, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவர்கள்"}, {"w": 2, "t": "மிக நெருக்கமானவர்கள்"}, {"w": 3, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "சொர்க்கங்களில்"}, {"w": 2, "t": "Gardens"}, {"w": 3, "t": "இன்பங்கள் நிறைந்த"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அதிகமானவர்கள்"}, {"w": 2, "t": "முந்தியவர்களில்"}, {"w": 3, "t": "the former (people)"}, {"w": 4, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் குறைவானவர்கள்"}, {"w": 2, "t": "பின்னோரில்"}, {"w": 3, "t": "the later (people)"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "கட்டில்களின் மீது"}, {"w": 2, "t": "thrones"}, {"w": 3, "t": "ஆபரணங்களால் அலங்கரிக்கப்பட்ட(து)"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "சாய்ந்தவர்களாக"}, {"w": 2, "t": "அவற்றின் மீது"}, {"w": 3, "t": "ஒருவரை ஒருவர் பார்த்தவர்களாக"}, {"w": 4, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "சுற்றி வருவார்கள்"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "சிறுவர்கள்"}, {"w": 4, "t": "நிரந்தரமான(வர்கள்)"}, {"w": 5, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "குவளைகளுடனும்"}, {"w": 2, "t": "கூஜாக்களுடனும்"}, {"w": 3, "t": "கிண்ணங்களுடனும்"}, {"w": 4, "t": "தூய்மையான மது நிறைந்த"}, {"w": 5, "t": "a flowing stream"}, {"w": 6, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவர்கள் தலைவலிக்கும் ஆளாக மாட்டார்கள்/ அதனால்"}, {"w": 2, "t": "they will get headache"}, {"w": 3, "t": "therefrom"}, {"w": 4, "t": "அவர்கள் அறிவு தடுமாறவும் மாட்டார்கள்"}, {"w": 5, "t": "they will get intoxicated"}, {"w": 6, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "பழங்களுடனும்"}, {"w": 2, "t": "அவர்கள் விரும்பி தேர்ந்தெடுக்கின்ற"}, {"w": 3, "t": "they select"}, {"w": 4, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "மாமிசங்களுடனும்"}, {"w": 2, "t": "பறவை"}, {"w": 3, "t": "அவர்கள் மனம் விரும்புகின்றவற்றின்"}, {"w": 4, "t": "they desire"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "வெண்மையான பெண்கள்"}, {"w": 2, "t": "கண்ணழகிகளான"}, {"w": 3, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "போல் உள்ள"}, {"w": 2, "t": "முத்துக்களை"}, {"w": 3, "t": "பாதுகாக்கப்பட்ட(து)"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "கூலியாக/அவர்கள் செய்து கொண்டிருந்தவற்றுக்கு"}, {"w": 2, "t": "for what"}, {"w": 3, "t": "they used (to)"}, {"w": 4, "t": "do"}, {"w": 5, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவர்கள் செவியுற மாட்டார்கள்"}, {"w": 2, "t": "they will hear"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "வீண் பேச்சுகளை(யும்)"}, {"w": 5, "t": "பாவமான பேச்சுகளையும்"}, {"w": 6, "t": "sinful (speech)"}, {"w": 7, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "பேச்சைத் தவிர"}, {"w": 2, "t": "a saying"}, {"w": 3, "t": "ஸலாம் ஸலாம்"}, {"w": 4, "t": "Peace"}, {"w": 5, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "வலது பக்கம் உடையவர்கள்!"}, {"w": 2, "t": "(of) the right"}, {"w": 3, "t": "வலது பக்கம் உடையவர்கள் யார்"}, {"w": 4, "t": "(are the) companions"}, {"w": 5, "t": "(of) the right"}, {"w": 6, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "மரங்களின் அருகிலும்"}, {"w": 2, "t": "lote trees"}, {"w": 3, "t": "முட்கள் நீக்கப்பட்ட இலந்தை"}, {"w": 4, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "வாழை மரங்களுக்கு"}, {"w": 2, "t": "குலைகுலையாய் தொங்குகின்ற"}, {"w": 3, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "நிழல்களிலும்"}, {"w": 2, "t": "நீங்காத"}, {"w": 3, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நீருக்கு அருகிலும்"}, {"w": 2, "t": "ஓடிக்கொண்டே இருக்கின்ற"}, {"w": 3, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "பழங்களுக்கு அருகிலும்"}, {"w": 2, "t": "அதிகமான"}, {"w": 3, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "தீர்ந்துவிடாத"}, {"w": 2, "t": "limited"}, {"w": 3, "t": "தடுக்கப்படாத"}, {"w": 4, "t": "forbidden"}, {"w": 5, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "விரிப்புகளிலும்"}, {"w": 2, "t": "உயர்வான"}, {"w": 3, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அவர்களை உருவாக்குவோம்"}, {"w": 3, "t": "முற்றிலும் புதிதாகவே"}, {"w": 4, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "அவர்களை நாம் ஆக்குவோம்"}, {"w": 2, "t": "கன்னிப் பெண்களாக"}, {"w": 3, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "கணவனை நேசிப்பவர்களாக"}, {"w": 2, "t": "சம வயதுடையவர்களாக"}, {"w": 3, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "வலப் பக்கமுடையவர்களுக்காக"}, {"w": 2, "t": "(of) the right"}, {"w": 3, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "அதிகமானவர்கள்"}, {"w": 2, "t": "முன்னோரிலும்"}, {"w": 3, "t": "the former people"}, {"w": 4, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "அதிகமானவர்கள்"}, {"w": 2, "t": "இன்னும் பின்னோரிலும்"}, {"w": 3, "t": "the later people"}, {"w": 4, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "இடப்பக்கமுடையவர்கள்!"}, {"w": 2, "t": "(of) the left"}, {"w": 3, "t": "இடப்பக்கமுடையவர்கள் யார்?"}, {"w": 4, "t": "(are the) companions"}, {"w": 5, "t": "(of) the left"}, {"w": 6, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "கடுமையான வெப்பக் காற்றிலும்"}, {"w": 2, "t": "scorching fire"}, {"w": 3, "t": "நன்கு கொதிக்கின்ற சுடு நீரிலும்"}, {"w": 4, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "நிழலிலும்"}, {"w": 2, "t": "கரும் புகையின்"}, {"w": 3, "t": "black smoke"}, {"w": 4, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "குளிர்ந்திருக்காது"}, {"w": 2, "t": "cool"}, {"w": 3, "t": "நறுமணம் உடையதாகவும் இருக்காது"}, {"w": 4, "t": "pleasant"}, {"w": 5, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "இருந்தனர்"}, {"w": 3, "t": "இதற்கு முன்னர்"}, {"w": 4, "t": "that"}, {"w": 5, "t": "சுகவாசிகளாக"}, {"w": 6, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "இருந்தனர்/பிடிவாதம் பிடித்தவர்களாக"}, {"w": 2, "t": "persisting"}, {"w": 3, "t": "பாவத்தின் மீது"}, {"w": 4, "t": "the sin"}, {"w": 5, "t": "பெரும்"}, {"w": 6, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "இருந்தனர்"}, {"w": 2, "t": "கூறுபவர்களாக"}, {"w": 3, "t": "நாங்கள் இறந்துவிட்டால்"}, {"w": 4, "t": "we die"}, {"w": 5, "t": "இன்னும் ஆகிவிட்டால்"}, {"w": 6, "t": "மண்ணாக(வும்)"}, {"w": 7, "t": "எலும்புகளாகவும்"}, {"w": 8, "t": "நாங்கள் எழுப்பப்படுவோமா?"}, {"w": 9, "t": "surely be resurrected"}, {"w": 10, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "எங்கள் மூதாதைகளுமா"}, {"w": 2, "t": "முன்னோர்களான"}, {"w": 3, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "நீர் கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "முன்னோரும்"}, {"w": 4, "t": "பின்னோரும்"}, {"w": 5, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "ஒன்று சேர்க்கப்படுவீர்கள்"}, {"w": 2, "t": "ஒரு குறிப்பிட்ட நேரத்தில்"}, {"w": 3, "t": "(the) appointment"}, {"w": 4, "t": "நாளின்/அறியப்பட்ட"}, {"w": 5, "t": "well-known"}, {"w": 6, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நிச்சயமாக நீங்கள்"}, {"w": 3, "t": "வழிகேடர்களே!"}, {"w": 4, "t": "O those astray"}, {"w": 5, "t": "பொய்ப்பிக்கின்ற"}, {"w": 6, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "சாப்பிடுவீர்கள்"}, {"w": 2, "t": "மரத்தில் இருந்துதான்"}, {"w": 3, "t": "(the) tree"}, {"w": 4, "t": "சக்கூம்"}, {"w": 5, "t": "Zaqqum"}, {"w": 6, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "நிரப்புவீர்கள்"}, {"w": 2, "t": "அதில் இருந்து"}, {"w": 3, "t": "வயிறுகளை"}, {"w": 4, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "குடிப்பீர்கள்"}, {"w": 2, "t": "அதற்கு மேலாக"}, {"w": 3, "t": "கடுமையாக கொதிக்கின்ற சுடு நீரை"}, {"w": 4, "t": "the scalding water"}, {"w": 5, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "இன்னும் குடிப்பீர்கள்"}, {"w": 2, "t": "குடிப்பதைப் போல்"}, {"w": 3, "t": "தாகித்த ஒட்டகங்கள்"}, {"w": 4, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "இதுதான்"}, {"w": 2, "t": "அவர்களுக்குரிய விருந்தோம்பலாகும்"}, {"w": 3, "t": "கூலி நாளில்"}, {"w": 4, "t": "(of) Judgment"}, {"w": 5, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "நாம்தான்/உங்களைப் படைத்தோம்"}, {"w": 2, "t": "[We] created you"}, {"w": 3, "t": "உண்மை என நம்பமாட்டீர்களா?"}, {"w": 4, "t": "you admit the truth"}, {"w": 5, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "அறிவியுங்கள்!"}, {"w": 2, "t": "நீங்கள் செலுத்துகின்ற இந்திரியத்தைப் பற்றி"}, {"w": 3, "t": "you emit"}, {"w": 4, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "அதை நீங்கள் படைக்கின்றீர்களா?"}, {"w": 2, "t": "who create it"}, {"w": 3, "t": "அல்லது/நாம்தான்"}, {"w": 4, "t": "(are) We"}, {"w": 5, "t": "படைப்பவர்களா?"}, {"w": 6, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "நாம்தான்"}, {"w": 2, "t": "நிர்ணயித்தோம்"}, {"w": 3, "t": "உங்களுக்கு மத்தியில்"}, {"w": 4, "t": "மரணத்தை"}, {"w": 5, "t": "நாங்கள் இல்லை"}, {"w": 6, "t": "We"}, {"w": 7, "t": "முடியாதவர்கள்"}, {"w": 8, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "நாங்கள் மாற்றுவதற்கு"}, {"w": 2, "t": "that"}, {"w": 3, "t": "We (will) change"}, {"w": 4, "t": "உங்கள் உருவங்களை"}, {"w": 5, "t": "இன்னும் உங்களை உருவாக்கிவிடுவதற்கு"}, {"w": 6, "t": "நீங்கள் அறியாத ஒன்றில்"}, {"w": 7, "t": "what"}, {"w": 8, "t": "not"}, {"w": 9, "t": "you know"}, {"w": 10, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நீங்கள் அறிந்தீர்கள்."}, {"w": 3, "t": "படைத்திருப்பதை"}, {"w": 4, "t": "முதல் முறை"}, {"w": 5, "t": "நீங்கள் நல்லுபதேசம் பெறமாட்டீர்களா?"}, {"w": 6, "t": "you take heed"}, {"w": 7, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "நீங்கள் அறிவியுங்கள்!"}, {"w": 2, "t": "எதை/உழுகின்றீர்கள்"}, {"w": 3, "t": "you sow"}, {"w": 4, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "அதை நீங்கள் முளைக்க வைக்கின்றீர்களா?"}, {"w": 2, "t": "cause it to grow"}, {"w": 3, "t": "அல்லது"}, {"w": 4, "t": "நாம்தான்"}, {"w": 5, "t": "முளைக்க வைக்கின்றோமா?"}, {"w": 6, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "நாம் நாடினால்"}, {"w": 2, "t": "We willed"}, {"w": 3, "t": "அதை ஆக்கிவிடுவோம்"}, {"w": 4, "t": "குப்பையாக"}, {"w": 5, "t": "நீங்கள் ஆகி இருப்பீர்கள்"}, {"w": 6, "t": "நீங்கள் ஆச்சரியப்படுகின்றவர்களாக"}, {"w": 7, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "நிச்சயமாக நாங்கள் நஷ்டவாளிகள்"}, {"w": 2, "t": "surely are laden with debt"}, {"w": 3, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "மாறாக/நாங்கள்"}, {"w": 2, "t": "we"}, {"w": 3, "t": "பெரும் இழப்புக்குள்ளானவர்கள்"}, {"w": 4, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "அறிவியுங்கள்!"}, {"w": 2, "t": "தண்ணீரைப் பற்றி"}, {"w": 3, "t": "எது"}, {"w": 4, "t": "குடிக்கின்றீர்கள்"}, {"w": 5, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "அதை நீங்கள் இறக்கினீர்களா?"}, {"w": 2, "t": "who send it down"}, {"w": 3, "t": "கார்மேகத்தில் இருந்து"}, {"w": 4, "t": "the rain clouds"}, {"w": 5, "t": "அல்லது/நாம்தான்"}, {"w": 6, "t": "We"}, {"w": 7, "t": "இறக்குகின்றவர்களா?"}, {"w": 8, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "நாம் நாடினால்"}, {"w": 2, "t": "We willed"}, {"w": 3, "t": "அதை ஆக்கிவிடுவோம்"}, {"w": 4, "t": "உப்பு நீராக"}, {"w": 5, "t": "நீங்கள் நன்றி செலுத்த வேண்டாமா?"}, {"w": 6, "t": "then why are you not grateful"}, {"w": 7, "t": "(70)"}]}, {"ayah": 71, "words": [{"w": 1, "t": "அறிவியுங்கள்!"}, {"w": 2, "t": "நெருப்பைப் பற்றி"}, {"w": 3, "t": "எது"}, {"w": 4, "t": "தீ மூட்டுகின்றீர்கள்"}, {"w": 5, "t": "(71)"}]}, {"ayah": 72, "words": [{"w": 1, "t": "நீங்கள் உருவாக்கினீர்களா?"}, {"w": 2, "t": "who produced"}, {"w": 3, "t": "அதன் மரத்தை"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "நாம்"}, {"w": 6, "t": "உருவாக்குகின்றோமா?"}, {"w": 7, "t": "(72)"}]}, {"ayah": 73, "words": [{"w": 1, "t": "நாம்"}, {"w": 2, "t": "அதை ஆக்கினோம்"}, {"w": 3, "t": "ஒரு நினைவூட்டலாகவும்"}, {"w": 4, "t": "ஒரு பலனாகவும்"}, {"w": 5, "t": "பயணிகளுக்கு"}, {"w": 6, "t": "(73)"}]}, {"ayah": 74, "words": [{"w": 1, "t": "ஆகவே, துதிப்பீராக!"}, {"w": 2, "t": "பெயரை"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "மகத்தான"}, {"w": 5, "t": "(74)"}]}, {"ayah": 75, "words": [{"w": 1, "t": "நான் சத்தியம் செய்கின்றேன்"}, {"w": 2, "t": "I swear"}, {"w": 3, "t": "விழுகின்ற இடங்கள் மீது"}, {"w": 4, "t": "நட்சத்திரங்கள்"}, {"w": 5, "t": "(75)"}]}, {"ayah": 76, "words": [{"w": 1, "t": "நிச்சயமாக இது"}, {"w": 2, "t": "சத்தியமாகும்"}, {"w": 3, "t": "நீங்கள் அறிந்து கொண்டால்"}, {"w": 4, "t": "you know "}, {"w": 5, "t": "மாபெரும்"}, {"w": 6, "t": "(76)"}]}, {"ayah": 77, "words": [{"w": 1, "t": "நிச்சயமாக இது குர்ஆனாகும்"}, {"w": 2, "t": "(is) surely, a Quran"}, {"w": 3, "t": "கண்ணியமான"}, {"w": 4, "t": "(77)"}]}, {"ayah": 78, "words": [{"w": 1, "t": "பதிவேட்டில் உள்ள"}, {"w": 2, "t": "a Book"}, {"w": 3, "t": "பாதுகாக்கப்பட்ட(து)"}, {"w": 4, "t": "(78)"}]}, {"ayah": 79, "words": [{"w": 1, "t": "இதைத் தொடமாட்டார்கள்"}, {"w": 2, "t": "touch it"}, {"w": 3, "t": "மிகவும் பரிசுத்தமானவர்களைத் தவிர"}, {"w": 4, "t": "the purified"}, {"w": 5, "t": "(79)"}]}, {"ayah": 80, "words": [{"w": 1, "t": "இறக்கப்பட்ட வேதமாகும்"}, {"w": 2, "t": "இறைவனிடமிருந்து"}, {"w": 3, "t": "(the) Lord"}, {"w": 4, "t": "அகிலங்களின்"}, {"w": 5, "t": "(80)"}]}, {"ayah": 81, "words": [{"w": 1, "t": "?/இந்த"}, {"w": 2, "t": "பேச்சை"}, {"w": 3, "t": "நீங்கள்/அலட்சியம் செய்கின்றீர்கள்"}, {"w": 4, "t": "(are) indifferent"}, {"w": 5, "t": "(81)"}]}, {"ayah": 82, "words": [{"w": 1, "t": "ஆக்கிக் கொண்டீர்களா?"}, {"w": 2, "t": "உங்கள் நன்றியாக"}, {"w": 3, "t": "நிச்சயமாக நீங்கள்"}, {"w": 4, "t": "பொய்ப்பிப்பதையே"}, {"w": 5, "t": "(82)"}]}, {"ayah": 83, "words": [{"w": 1, "t": "தடுத்திருக்கவேண்டாமா அது அடைந்தபோது"}, {"w": 2, "t": "when"}, {"w": 3, "t": "it reaches"}, {"w": 4, "t": "தொண்டைக் குழியை"}, {"w": 5, "t": "(83)"}]}, {"ayah": 84, "words": [{"w": 1, "t": "நீங்கள்/அந்நேரத்தில்"}, {"w": 2, "t": "(at) that time"}, {"w": 3, "t": "நீங்கள் பார்க்கின்றீர்கள்"}, {"w": 4, "t": "(84)"}]}, {"ayah": 85, "words": [{"w": 1, "t": "நாம்"}, {"w": 2, "t": "மிக அருகில்"}, {"w": 3, "t": "அவருக்கு"}, {"w": 4, "t": "உங்களை விட"}, {"w": 5, "t": "என்றாலும்"}, {"w": 6, "t": "நீங்கள் பார்க்க முடியாது"}, {"w": 7, "t": "you (do) not see"}, {"w": 8, "t": "(85)"}]}, {"ayah": 86, "words": [{"w": 1, "t": "நீங்கள் இருந்தால்"}, {"w": 2, "t": "if"}, {"w": 3, "t": "you are"}, {"w": 4, "t": "கூலி கொடுக்கப்படாதவர்களாக"}, {"w": 5, "t": "to be recompensed"}, {"w": 6, "t": "(86)"}]}, {"ayah": 87, "words": [{"w": 1, "t": "அதை நீங்கள் திரும்ப கொண்டு வந்திருக்கலாமல்லவா?"}, {"w": 2, "t": "நீங்கள் இருந்தால்"}, {"w": 3, "t": "you are"}, {"w": 4, "t": "உண்மையாளர்களாக"}, {"w": 5, "t": "(87)"}]}, {"ayah": 88, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "இருந்தால்"}, {"w": 3, "t": "he was"}, {"w": 4, "t": "நெருக்கமானவர்களில்"}, {"w": 5, "t": "those brought near"}, {"w": 6, "t": "(88)"}]}, {"ayah": 89, "words": [{"w": 1, "t": "இறையருளும்"}, {"w": 2, "t": "உணவும்"}, {"w": 3, "t": "சொர்க்கமும்"}, {"w": 4, "t": "இன்பம் நிறைந்த"}, {"w": 5, "t": "(89)"}]}, {"ayah": 90, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "இருந்தால்"}, {"w": 3, "t": "he was"}, {"w": 4, "t": "வலப்பக்கம் உடையவர்களில்"}, {"w": 5, "t": "(the) companions"}, {"w": 6, "t": "(of) the right"}, {"w": 7, "t": "(90)"}]}, {"ayah": 91, "words": [{"w": 1, "t": "ஸலாம் உண்டாகட்டும்"}, {"w": 2, "t": "உமக்கு"}, {"w": 3, "t": "வலப்பக்கம் உடையவர்களில்"}, {"w": 4, "t": "(the) companions"}, {"w": 5, "t": "(of) the right"}, {"w": 6, "t": "(91)"}]}, {"ayah": 92, "words": [{"w": 1, "t": "ஆக/இருந்தால்"}, {"w": 2, "t": "if"}, {"w": 3, "t": "he was"}, {"w": 4, "t": "பொய்ப்பித்த(வர்களில்)"}, {"w": 5, "t": "the deniers"}, {"w": 6, "t": "வழிகெட்டவர்கள்"}, {"w": 7, "t": "(92)"}]}, {"ayah": 93, "words": [{"w": 1, "t": "விருந்து(ம்)"}, {"w": 2, "t": "கடுமையாக கொதிக்கின்ற சுடு நீரின்"}, {"w": 3, "t": "(the) scalding water"}, {"w": 4, "t": "(93)"}]}, {"ayah": 94, "words": [{"w": 1, "t": "நெருப்பில் பொசுக்குவதும்தான்"}, {"w": 2, "t": "நரகத்தில்"}, {"w": 3, "t": "(94)"}]}, {"ayah": 95, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இதுதான்"}, {"w": 3, "t": "surely, it"}, {"w": 4, "t": "உண்மையாகும்"}, {"w": 5, "t": "மிக உறுதியான"}, {"w": 6, "t": "(95)"}]}, {"ayah": 96, "words": [{"w": 1, "t": "ஆக, துதிப்பீராக!"}, {"w": 2, "t": "பெயரை"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "மகத்தான(வன்)"}, {"w": 5, "t": "(96)"}]}]}