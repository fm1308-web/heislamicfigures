: 8, "t": "(is) in"}, {"w": 9, "t": "their bellies"}, {"w": 10, "t": "இன்னும் உங்களுக்கு"}, {"w": 11, "t": "அவற்றில்"}, {"w": 12, "t": "பலன்களும்"}, {"w": 13, "t": "அதிகமான"}, {"w": 14, "t": "இன்னும் அவற்றிலிருந்து"}, {"w": 15, "t": "நீங்கள் புசியுங்கள்"}, {"w": 16, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "அவற்றின் மீதும்"}, {"w": 2, "t": "கப்பல்கள் மீதும்"}, {"w": 3, "t": "[the] ships"}, {"w": 4, "t": "நீங்கள் சுமக்கப்படுகிறீர்கள்"}, {"w": 5, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "நூஹை"}, {"w": 4, "t": "அவருடைய மக்களிடம்"}, {"w": 5, "t": "his people"}, {"w": 6, "t": "அவர் கூறினார்"}, {"w": 7, "t": "எனது மக்களே"}, {"w": 8, "t": "வணங்குங்கள்"}, {"w": 9, "t": "அல்லாஹ்வை"}, {"w": 10, "t": "இல்லை"}, {"w": 11, "t": "உங்களுக்கு"}, {"w": 12, "t": "கடவுள் யாரும்"}, {"w": 13, "t": "god"}, {"w": 14, "t": "அவனையன்றி"}, {"w": 15, "t": "நீங்கள் அஞ்ச வேண்டாமா?"}, {"w": 16, "t": "you fear"}, {"w": 17, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "கூறினர்"}, {"w": 2, "t": "தலைவர்கள்"}, {"w": 3, "t": "எவர்கள்"}, {"w": 4, "t": "நிராகரித்தனர்"}, {"w": 5, "t": "அவருடைய மக்களில்"}, {"w": 6, "t": "his people"}, {"w": 7, "t": "இல்லை"}, {"w": 8, "t": "இவர்"}, {"w": 9, "t": "தவிர"}, {"w": 10, "t": "மனிதரே"}, {"w": 11, "t": "உங்களைப் போன்ற"}, {"w": 12, "t": "அவர் நாடுகிறார்"}, {"w": 13, "t": "மேன்மை அடைய"}, {"w": 14, "t": "assert (his) superiority"}, {"w": 15, "t": "உங்கள் மீது"}, {"w": 16, "t": "நாடியிருந்தால்"}, {"w": 17, "t": "Allah had willed"}, {"w": 18, "t": "அல்லாஹ்"}, {"w": 19, "t": "இறக்கி இருப்பான்"}, {"w": 20, "t": "வானவர்களை"}, {"w": 21, "t": "நாங்கள் கேள்விப்பட்டதில்லை"}, {"w": 22, "t": "we heard"}, {"w": 23, "t": "இதை"}, {"w": 24, "t": "எங்கள் மூதாதைகளில்"}, {"w": 25, "t": "our forefathers"}, {"w": 26, "t": "முன்னோர்களான"}, {"w": 27, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவர் இல்லை"}, {"w": 2, "t": "he"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "ஓர் ஆடவரே"}, {"w": 5, "t": "அவருக்கு"}, {"w": 6, "t": "பைத்தியம் (ஏற்பட்டிருக்கிறது)"}, {"w": 7, "t": "எதிர் பார்த்திருங்கள்"}, {"w": 8, "t": "அவருக்கு"}, {"w": 9, "t": "வரை"}, {"w": 10, "t": "ஒரு காலம்"}, {"w": 11, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவா"}, {"w": 3, "t": "எனக்கு நீ உதவுவாயாக"}, {"w": 4, "t": "அவர்கள் என்னை பொய்ப்பித்து விட்டதால்"}, {"w": 5, "t": "they deny me"}, {"w": 6, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நாம் வஹீ  அறிவித்தோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "நீர் செய்வீராக"}, {"w": 4, "t": "construct"}, {"w": 5, "t": "கப்பலை"}, {"w": 6, "t": "நமது கண்களுக்கு முன்னும்"}, {"w": 7, "t": "நமது அறிவிப்பின்படியும்"}, {"w": 8, "t": "வந்துவிட்டால்"}, {"w": 9, "t": "comes"}, {"w": 10, "t": "நம் கட்டளை"}, {"w": 11, "t": "பொங்க ஆரம்பித்து விட்டால்"}, {"w": 12, "t": "அடுப்பு"}, {"w": 13, "t": "அதில்/ஏற்றுவீராக"}, {"w": 14, "t": "into it"}, {"w": 15, "t": "எல்லாவற்றிலிருந்தும்"}, {"w": 16, "t": "every (kind)"}, {"w": 17, "t": "ஜோடிகளையும்"}, {"w": 18, "t": "இரண்டு"}, {"w": 19, "t": "இன்னும் உமது குடும்பத்தினரையும்"}, {"w": 20, "t": "தவிர"}, {"w": 21, "t": "எவன்"}, {"w": 22, "t": "முந்திவிட்டதோ"}, {"w": 23, "t": "அவன் மீது"}, {"w": 24, "t": "வாக்கு"}, {"w": 25, "t": "அவர்களில்"}, {"w": 26, "t": "இன்னும் என்னிடம் நீர் உரையாடாதீர்"}, {"w": 27, "t": "address Me"}, {"w": 28, "t": "அநியாயக்காரர்கள் விஷயத்தில்"}, {"w": 29, "t": "those who"}, {"w": 30, "t": "wronged"}, {"w": 31, "t": "நிச்சயமாக அவர்கள்"}, {"w": 32, "t": "மூழ்கடிக்கப்படுவார்கள்"}, {"w": 33, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நீர் ஏறிவிட்டால்"}, {"w": 2, "t": "you (have) boarded"}, {"w": 3, "t": "நீரும்"}, {"w": 4, "t": "இன்னும் உன்னுடன் இருப்பவரும்"}, {"w": 5, "t": "(is) with you"}, {"w": 6, "t": "கப்பலில்"}, {"w": 7, "t": "the ship"}, {"w": 8, "t": "கூறுவீராக"}, {"w": 9, "t": "எல்லாப் புகழும்"}, {"w": 10, "t": "அல்லாஹ்விற்கே"}, {"w": 11, "t": "எவன்/எங்களை பாதுகாத்தான்"}, {"w": 12, "t": "(has) saved us"}, {"w": 13, "