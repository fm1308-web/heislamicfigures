w": 19, "t": "அவர் சாப்பிடுகிறார்"}, {"w": 20, "t": "நீங்கள் சாப்பிடுவதிலிருந்து"}, {"w": 21, "t": "you eat"}, {"w": 22, "t": "அதில்"}, {"w": 23, "t": "இன்னும் அவர் குடிக்கிறார்"}, {"w": 24, "t": "நீங்கள் குடிப்பதிலிருந்து"}, {"w": 25, "t": "you drink"}, {"w": 26, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நீங்கள் கீழ்ப்படிந்து நடந்தால்"}, {"w": 2, "t": "மனிதருக்கு"}, {"w": 3, "t": "உங்களைப் போன்ற"}, {"w": 4, "t": "நிச்சயமாக நீங்கள்"}, {"w": 5, "t": "அப்போது"}, {"w": 6, "t": "நஷ்டவாளிகள்தான்"}, {"w": 7, "t": "surely (will be) losers"}, {"w": 8, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "அவர் உங்களுக்கு வாக்குறுதி கூறுகிறாரா"}, {"w": 2, "t": "நிச்சயமாக நீங்கள்"}, {"w": 3, "t": "நீங்கள் மரணித்துவிட்டால்"}, {"w": 4, "t": "you are dead"}, {"w": 5, "t": "இன்னும் ஆகிவிட்டால்"}, {"w": 6, "t": "மண்ணாகவும்"}, {"w": 7, "t": "எலும்புகளாகவும்"}, {"w": 8, "t": "நிச்சயமாக நீங்கள்"}, {"w": 9, "t": "வெளியேற்றப்படுவீர்கள்"}, {"w": 10, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "வெகு தூரம்"}, {"w": 2, "t": "வெகு தூரம்"}, {"w": 3, "t": "நீங்கள் வாக்களிக்கப்படுவது"}, {"w": 4, "t": "you are promised"}, {"w": 5, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "it"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "நமது வாழ்க்கை"}, {"w": 5, "t": "உலக"}, {"w": 6, "t": "நாம் இறந்து விடுகிறோம்"}, {"w": 7, "t": "இன்னும் நாம் வாழ்கிறோம்"}, {"w": 8, "t": "இன்னும் அல்லர்"}, {"w": 9, "t": "நாம்"}, {"w": 10, "t": "எழுப்பப்படுபவர்கள்"}, {"w": 11, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "அவர் இல்லை"}, {"w": 2, "t": "(is) he"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "ஒரு மனிதரே"}, {"w": 5, "t": "இட்டுக்கட்டினார்"}, {"w": 6, "t": "மீது"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "பொய்யை"}, {"w": 9, "t": "இல்லை"}, {"w": 10, "t": "நாங்கள்"}, {"w": 11, "t": "அவரை"}, {"w": 12, "t": "நம்பிக்கை கொண்டவர்களாக"}, {"w": 13, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவா"}, {"w": 3, "t": "எனக்கு நீ உதவுவாயாக"}, {"w": 4, "t": "அவர்கள் என்னை பொய்ப்பித்து விட்டதால்"}, {"w": 5, "t": "they deny me"}, {"w": 6, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "விரைவில்"}, {"w": 3, "t": "After a little while"}, {"w": 4, "t": "அவர்கள் ஆகிவிடுவார்கள்"}, {"w": 5, "t": "கைசேதப்பட்டவர்களாக"}, {"w": 6, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவர்களைப் பிடித்துக் கொண்டது"}, {"w": 2, "t": "பெரிய சப்தம்"}, {"w": 3, "t": "உண்மையில்"}, {"w": 4, "t": "அவர்களை மாற்றி விடுவோம்"}, {"w": 5, "t": "நுரைகளாக"}, {"w": 6, "t": "தொலைந்து போகட்டும்"}, {"w": 7, "t": "கூட்டம்"}, {"w": 8, "t": "அநியாயக்கார"}, {"w": 9, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம் உருவாக்கினோம்"}, {"w": 3, "t": "பின்னர்"}, {"w": 4, "t": "பின்னர் அவர்களுக்கு"}, {"w": 5, "t": "தலைமுறைகளை"}, {"w": 6, "t": "வேறு (பல)"}, {"w": 7, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "முந்தவும் மாட்டார்கள்"}, {"w": 2, "t": "can precede"}, {"w": 3, "t": "எந்த ஒரு சமுதாயம்"}, {"w": 4, "t": "nation"}, {"w": 5, "t": "தனது தவணையை"}, {"w": 6, "t": "இன்னும் பிந்தவும் மாட்டார்கள்"}, {"w": 7, "t": "they (can) delay (it)"}, {"w": 8, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "நமது தூதர்களை"}, {"w": 4, "t": "தொடர்ச்சியாக"}, {"w": 5, "t": "வந்தபோதெல்லாம்"}, {"w": 6, "t": "Every time"}, {"w": 7, "t": "came"}, {"w": 8, "t": "ஒரு சமுதாயத்திற்கு"}, {"w": 9, "t": "அதன் தூதர்"}, {"w": 10, "t": "அவர்கள் அவரை பொய்ப்பித்தனர்"}, {"w": 11, "t": "ஆகவே, பின்னர் கொண்டு வந்தோம்"}, {"w": 12, "t": "அவர்களில் சிலரை"}, {"w": 13, "t": "சிலரை"}, {"w": 14, "t": "அவர்களை நாம் ஆக்கிவிட்டோம்"}, {"w": 15, "t": "படிப்பினை நிறைந்த நிகழ்வுகளாக"}, {"w": 16, "t": "தொலைந்து போகட்டும்"}, {"w": 17, "t": "மக்கள்"}, {"w": 18, "t": "நம்பிக்கை கொள்ள மாட்டார்கள்"}, {"w": 19, "t": "they believe"}, {"w": 20, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "மூஸாவையும்"}, {"w": 4, "t": "இன்னும் அவருடையசகோதரர்"}, {"w": 5, "t": "ஹாரூனையும்"}, {"w": 6, "t": "நமது அத்தாட்சிகளைக் கொண்டும்"}, {"w": 7, "t": "இன்னும் ஆதாரத்தைக் கொண்டும்"}, {"w": 8, "t": "தெளிவான"}, {"w": 9, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "ஃபிர்அவ்னிடமும்"}, {"w": 2, "t": "Firaun"}, {"w": 3, "t": "இன்னும் அவனுடைய சமுதாயத் தலைவர்களிடமும்"}, {"w": 4, "t": "அவர்கள் பெருமையடித்தனர்"}, {"w": 5, "t": "அவர்கள் இருந்தனர்"}, {"w": 6, "t": "மக்களாக"}, {"w": 7, "t": "ஆதிக்கம் செலுத்தக்கூடிய"}, {"w": 8, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "கூறினர்"}, {"w": 2, "t": "நாங்கள் நம்பிக்கை கொள்வோமா"}, {"w": 3, "t": "இரு மனிதர்களை"}, {"w": 4, "t": "எங்களைப் போன்ற"}, {"w": 5, "t": "அவ்விருவரின் சமுதாயமோ"}, {"w": 6, "t": "எங்களுக்கு"}, {"w": 7, "t": "பணிந்தவர்களாக இருக்கின்றனர்"}, {"w": 8, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "அவர்கள் பொய்ப்பித்தனர் அவ்விருவரையும்"}, {"w": 2, "t": "ஆகவே, அவர்கள் ஆகிவிட்டனர்"}, {"w": 3, "t": "அழிக்கப்பட்டவர்களில்"}, {"w": 4, "t": "those who were destroyed"}, {"w": 5, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் கொடுத்தோம்"}, {"w": 3, "t": "மூஸாவிற்கு"}, {"w": 4, "t": "வேதத்தை"}, {"w": 5, "t": "அவர்கள் நேர்வழி பெறுவதற்காக"}, {"w": 6, "t": "be guided"}, {"w": 7, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "இன்னும் நாம் ஆக்கினோம்"}, {"w": 2, "t": "மகனையும்"}, {"w": 3, "t": "மர்யமுடைய"}, {"w": 4, "t": "அவருடைய தாயையும்"}, {"w": 5, "t": "ஓர் அத்தாட்சியாக"}, {"w": 6, "t": "இன்னும் அவ்விருவரையும் ஒதுங்க வைத்தோம்"}, {"w": 7, "t": "உயரமானதின் பக்கம்"}, {"w": 8, "t": "a high ground"}, {"w": 9, "t": "உறுதியாக"}, {"w": 10, "t": "சமமான இடத்திற்கும்"}, {"w": 11, "t": "ஓடும் நீரூற்றுக்கும்"}, {"w": 12, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "தூதர்களே"}, {"w": 2, "t": "O Messengers"}, {"w": 3, "t": "சாப்பிடுங்கள்"}, {"w": 4, "t": "நல்லவற்றிலிருந்து"}, {"w": 5, "t": "the good things"}, {"w": 6, "t": "இன்னும் செய்யுங்கள்"}, {"w": 7, "t": "நல்ல செயலை"}, {"w": 8, "t": "நிச்சயமாக நான்"}, {"w": 9, "t": "நீங்கள் செய்வதை"}, {"w": 10, "t": "you do"}, {"w": 11, "t": "நன்கறிந்தவன்"}, {"w": 12, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இதுதான்"}, {"w": 3, "t": "உங்களது மார்க்கம்"}, {"w": 4, "t": "மார்க்கம்/ஒரே ஒரு"}, {"w": 5, "t": "one"}, {"w": 6, "t": "நான்தான்"}, {"w": 7, "t": "உங்கள் இறைவன்"}, {"w": 8, "t": "ஆகவே, என்னை அஞ்சிக் கொள்ளுங்கள்"}, {"w": 9, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "அவர்கள் பிரித்துக் கொண்டனர்"}, {"w": 2, "t": "காரியத்தை தங்களது"}, {"w": 3, "t": "தங்களுக்கு மத்தியில்"}, {"w": 4, "t": "பல வேதங்களாக"}, {"w": 5, "t": "ஒவ்வொரு"}, {"w": 6, "t": "பிரிவும்"}, {"w": 7, "t": "தங்களிடம் உள்ளதைக் கொண்டு"}, {"w": 8, "t": "they have"}, {"w": 9, "t": "பெருமைப்படுகின்றனர்"}, {"w": 10, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "ஆகவே அவர்களை விட்டுவிடுவீராக!"}, {"w": 2, "t": "அவர்களுடைய வழிகேட்டில்"}, {"w": 3, "t": "their confusion"}, {"w": 4, "t": "வரை"}, {"w": 5, "t": "காலம்"}, {"w": 6, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "அவர்கள் எண்ணுகின்றனரா"}, {"w": 2, "t": "நிச்சயமாக எதை நாம் கொடுக்கிறோமோ"}, {"w": 3, "t": "நிச்சயமாக எதை நாம் கொடுக்கிறோமோ அவர்களுக்கு"}, {"w": 4, "t": "அதை"}, {"w": 5, "t": "செல்வத்திலிருந்தும்"}, {"w": 6, "t": "wealth"}, {"w": 7, "t": "ஆண் பிள்ளைகளிலிருந்தும்"}, {"w": 8, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "நாம் விரைகிறோம்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "நன்மைகளில்"}, {"w": 4, "t": "the good"}, {"w": 5, "t": "மாறாக"}, {"w": 6, "t": "அவர்கள் உணர மாட்டார்கள்"}, {"w": 7, "t": "they perceive"}, {"w": 8, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "அவர்கள்"}, {"w": 4, "t": "பயத்தால்"}, {"w": 5, "t": "(the) fear"}, {"w": 6, "t": "தங்கள் இறைவனின்"}, {"w": 7, "t": "அச்சம் கொண்டவர்கள்"}, {"w": 8, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "இன்னும் எவர்கள்/அவர்கள்"}, {"w": 2, "t": "[they]"}, {"w": 3, "t": "வசனங்களை"}, {"w": 4, "t": "தங்கள் இறைவனின்"}, {"w": 5, "t": "நம்பிக்கை கொள்பவர்கள்"}, {"w": 6, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "இன்னும் எவர்கள்"}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "தங்கள் இறைவனுக்கு"}, {"w": 4, "t": "இணைவைக்காதவர்கள்"}, {"w": 5, "t": "associate partners"}, {"w": 6, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "இன்னும் அவர்கள்"}, {"w": 2, "t": "கொடுப்பார்கள்"}, {"w": 3, "t": "எதைக் கொடுத்தார்கள்"}, {"w": 4, "t": "they give"}, {"w": 5, "t": "அவர்களுடைய உள்ளங்களோ"}, {"w": 6, "t": "பயந்தவையாக இருக்கும்"}, {"w": 7, "t": "நிச்சயம் தாங்கள்"}, {"w": 8, "t": "பக்கம்"}, {"w": 9, "t": "தங்கள் இறைவனின்"}, {"w": 10, "t": "திரும்பக்கூடியவர்கள்"}, {"w": 11, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "அவர்கள்தான்"}, {"w": 2, "t": "விரைகின்றார்கள்"}, {"w": 3, "t": "நன்மைகளில்"}, {"w": 4, "t": "the good (deeds)"}, {"w": 5, "t": "இன்னும் அவர்கள்"}, {"w": 6, "t": "அவற்றுக்கு"}, {"w": 7, "t": "முந்தக் கூடியவர்கள்"}, {"w": 8, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "நாம் சிரமம் தருவதில்லை"}, {"w": 2, "t": "We burden"}, {"w": 3, "t": "எந்த ஓர் ஆன்மாவுக்கும்"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "அதன் வசதிக்கு உட்பட்டே"}, {"w": 6, "t": "இன்னும் நம்மிடம் இருக்கின்றது"}, {"w": 7, "t": "ஒரு புத்தகம்"}, {"w": 8, "t": "பேசுகின்றது"}, {"w": 9, "t": "சத்தியத்தைக் கொண்டு"}, {"w": 10, "t": "அவர்கள்"}, {"w": 11, "t": "அநீதி இழைக்கப்பட மாட்டார்கள்"}, {"w": 12, "t": "be wronged"}, {"w": 13, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "அவர்களது உள்ளங்கள்"}, {"w": 3, "t": "அறியாமையில்"}, {"w": 4, "t": "confusion"}, {"w": 5, "t": "இதை விட்டு"}, {"w": 6, "t": "this"}, {"w": 7, "t": "இன்னும் அவர்களுக்கு"}, {"w": 8, "t": "செயல்கள்"}, {"w": 9, "t": "வேறு உள்ளன"}, {"w": 10, "t": "besides"}, {"w": 11, "t": "that"}, {"w": 12, "t": "அவர்கள்"}, {"w": 13, "t": "அதைத்தான்"}, {"w": 14, "t": "செய்பவர்கள்"}, {"w": 15, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "இறுதியாக"}, {"w": 2, "t": "நாம் பிடித்தால்"}, {"w": 3, "t": "We seize"}, {"w": 4, "t": "அவர்களின் சுகவாசிகளை"}, {"w": 5, "t": "வேதனையைக் கொண்டு"}, {"w": 6, "t": "அப்போது அவர்கள்"}, {"w": 7, "t": "They"}, {"w": 8, "t": "கதறுகின்றனர்"}, {"w": 9, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "கதறாதீர்கள்"}, {"w": 2, "t": "cry for help"}, {"w": 3, "t": "இன்றைய தினம்"}, {"w": 4, "t": "நிச்சயமாக நீங்கள்"}, {"w": 5, "t": "நம்மிடமிருந்து"}, {"w": 6, "t": "பாதுகாக்கப்பட மாட்டீர்கள்"}, {"w": 7, "t": "will be helped"}, {"w": 8, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "இருந்தன"}, {"w": 3, "t": "எனது வசனங்கள்"}, {"w": 4, "t": "ஓதப்பட்டும்"}, {"w": 5, "t": "உங்கள் மீது"}, {"w": 6, "t": "நீங்கள் இருந்தீர்கள்"}, {"w": 7, "t": "மீது"}, {"w": 8, "t": "உங்கள் குதிங்கால்கள்"}, {"w": 9, "t": "பின்னோக்கி செல்பவர்களாக"}, {"w": 10, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "பெருமை அடித்தவர்களாக"}, {"w": 2, "t": "அதைக் கொண்டு"}, {"w": 3, "t": "இரவில் நிம்மதியாக இதைப் பேசியவர்களாக"}, {"w": 4, "t": "வீணானதைக் கூறுகின்றனர்"}, {"w": 5, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "இவர்கள் ஆழ்ந்து ஆராய வேண்டாமா"}, {"w": 2, "t": "they ponder"}, {"w": 3, "t": "இந்த பேச்சை"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "வந்ததா இவர்களிடம்"}, {"w": 6, "t": "எது/வரவில்லை"}, {"w": 7, "t": "not"}, {"w": 8, "t": "(had) come"}, {"w": 9, "t": "மூதாதைகளுக்கு இவர்களது"}, {"w": 10, "t": "முன்னோர்களான"}, {"w": 11, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "அறியவில்லையா"}, {"w": 3, "t": "they recognize"}, {"w": 4, "t": "தங்களது தூதரை"}, {"w": 5, "t": "ஆகவே, அவர்கள்"}, {"w": 6, "t": "அவரை"}, {"w": 7, "t": "மறுக்கின்றனரா"}, {"w": 8, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "இவர்கள் கூறுகின்றனரா"}, {"w": 3, "t": "அவருக்கு"}, {"w": 4, "t": "பைத்தியம்"}, {"w": 5, "t": "மாறாக"}, {"w": 6, "t": "வந்துள்ளார் அவர்களிடம்"}, {"w": 7, "t": "உண்மையைக் கொண்டு"}, {"w": 8, "t": "இன்னும் அதிகமானவர்கள் அவர்களில்"}, {"w": 9, "t": "உண்மையை"}, {"w":