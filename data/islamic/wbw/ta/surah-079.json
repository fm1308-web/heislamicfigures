{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "பறிப்பவர்கள் மீது சத்தியமாக"}, {"w": 2, "t": "கடுமையாக"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "கைப்பற்றுவோர் மீது சத்தியமாக"}, {"w": 2, "t": "மென்மையாக"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நீந்துவோர்மீது சத்தியமாக!"}, {"w": 2, "t": "நீந்துதல்"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "முந்துவோர் மீது சத்தியமாக"}, {"w": 2, "t": "முந்துதல்"}, {"w": 3, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நிர்வகிப்போர் மீது சத்தியமாக!"}, {"w": 2, "t": "காரியத்தை"}, {"w": 3, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "அதிர்ச்சியுறுகின்ற"}, {"w": 3, "t": "பூமி"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அதைத் தொடரும்"}, {"w": 2, "t": "பின்தொடரக்கூடியது"}, {"w": 3, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "உள்ளங்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "நடுங்கும்"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவற்றின் பார்வைகள்"}, {"w": 2, "t": "கீழ் நோக்கும்"}, {"w": 3, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "கூறுகிறார்கள்"}, {"w": 2, "t": "?/நிச்சயமாக நாம்"}, {"w": 3, "t": "திருப்பப்படுவோமா?"}, {"w": 4, "t": "முந்தியநிலைமைக்கு"}, {"w": 5, "t": "the former state"}, {"w": 6, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நாம் மாறி இருந்தாலுமா?"}, {"w": 2, "t": "we are"}, {"w": 3, "t": "எலும்புகளாக"}, {"w": 4, "t": "உக்கிப்போன"}, {"w": 5, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "கூறுகிறார்கள்/அது"}, {"w": 2, "t": "This"}, {"w": 3, "t": "அவ்வாறாயின்"}, {"w": 4, "t": "திரும்புதல்"}, {"w": 5, "t": "நஷ்டமான"}, {"w": 6, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அதுவெல்லாம்"}, {"w": 2, "t": "it"}, {"w": 3, "t": "ஓர் அதட்டல்தான்"}, {"w": 4, "t": "ஒரே"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அப்போது அவர்கள்"}, {"w": 2, "t": "They"}, {"w": 3, "t": "பூமியின் மேற்பரப்பில்"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "உமக்கு வந்ததா?"}, {"w": 2, "t": "(there) come to you"}, {"w": 3, "t": "செய்தி"}, {"w": 4, "t": "மூஸாவுடைய"}, {"w": 5, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவரை அழைத்த சமயத்தை"}, {"w": 2, "t": "called him"}, {"w": 3, "t": "அவருடைய இறைவன்"}, {"w": 4, "t": "பள்ளத்தாக்கில்"}, {"w": 5, "t": "பரிசுத்தமான"}, {"w": 6, "t": "துவா"}, {"w": 7, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "செல்வீராக"}, {"w": 2, "t": "ஃபிர்அவ்னிடம்"}, {"w": 3, "t": "Firaun"}, {"w": 4, "t": "நிச்சயமாக அவன்"}, {"w": 5, "t": "வரம்பு மீறினான்"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இன்னும் கூறுவீராக"}, {"w": 2, "t": "உனக்கு விருப்பமா?"}, {"w": 3, "t": "[for] you"}, {"w": 4, "t": "நீ பரிசுத்தமடைவதற்கு"}, {"w": 5, "t": "[that]"}, {"w": 6, "t": "purify yourself"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் உனக்கு நான் நேர்வழி காட்டுவதற்கு"}, {"w": 2, "t": "பக்கம்"}, {"w": 3, "t": "உன் இறைவன்"}, {"w": 4, "t": "ஆகவே நீ பயந்து கொள்வாய்"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "ஆகவே அவனுக்குக் காண்பித்தார்"}, {"w": 2, "t": "அத்தாட்சியை"}, {"w": 3, "t": "மிகப்பெரிய"}, {"w": 4, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "ஆனால், அவன் பொய்ப்பித்தான்"}, {"w": 2, "t": "இன்னும் மாறுசெய்தான்"}, {"w": 3, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "விலகினான்"}, {"w": 3, "t": "முயன்றவனாக"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "இன்னும் ஒன்று சேர்த்தான்"}, {"w": 2, "t": "இன்னும் கூவி அழைத்தான்"}, {"w": 3, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "இன்னும் கூறினான்"}, {"w": 2, "t": "நான்தான்"}, {"w": 3, "t": "உங்கள் இறைவன்"}, {"w": 4, "t": "மிக உயர்வான"}, {"w": 5, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "ஆகவே அவனைப் பிடித்தான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "தண்டனையைக் கொண்டு"}, {"w": 4, "t": "மறுமையின்"}, {"w": 5, "t": "இன்னும் இம்மை"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இதில் இருக்கிறது"}, {"w": 3, "t": "that"}, {"w": 4, "t": "ஒரு படிப்பினை"}, {"w": 5, "t": "பயப்படுகிறவருக்கு"}, {"w": 6, "t": "fears"}, {"w": 7, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நீங்களா?"}, {"w": 2, "t": "மிகக் கடினமானவர்கள்"}, {"w": 3, "t": "படைப்பால்"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "வானமா?"}, {"w": 6, "t": "அதை அமைத்தான்"}, {"w": 7, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "உயர்த்தினான்"}, {"w": 2, "t": "அதன் முகட்டை"}, {"w": 3, "t": "இன்னும் அதை ஒழுங்குபடுத்தினான்"}, {"w": 4, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "இன்னும் இருளாக்கினான்"}, {"w": 2, "t": "அதன் இரவை"}, {"w": 3, "t": "இன்னும் வெளியாக்கினான்"}, {"w": 4, "t": "அதன் பகலை"}, {"w": 5, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "இன்னும் பூமியை"}, {"w": 2, "t": "அதன் பின்னர்"}, {"w": 3, "t": "that"}, {"w": 4, "t": "அதை விரித்தான்"}, {"w": 5, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "வெளியாக்கினான்"}, {"w": 2, "t": "அதிலிருந்து"}, {"w": 3, "t": "அதன் நீரை"}, {"w": 4, "t": "இன்னும் அதன் மேய்ச்சலை"}, {"w": 5, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "இன்னும் மலைகளை"}, {"w": 2, "t": "அவற்றை நிறுவினான்"}, {"w": 3, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "பலன் தருவதற்காக"}, {"w": 2, "t": "உங்களுக்கும்"}, {"w": 3, "t": "இன்னும் உங்கள் கால்நடைகளுக்கும்"}, {"w": 4, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "ஆகவே, வந்தால்"}, {"w": 2, "t": "comes"}, {"w": 3, "t": "பயங்கரமானஅழிவு"}, {"w": 4, "t": "மிகப்பெரிய"}, {"w": 5, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "(அந்)நாளில் நினைத்துப் பார்ப்பான்"}, {"w": 2, "t": "will remember"}, {"w": 3, "t": "மனிதன்"}, {"w": 4, "t": "தான் செய்ததை"}, {"w": 5, "t": "he strove (for)"}, {"w": 6, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "இன்னும் வெளியாக்கப்படும்"}, {"w": 2, "t": "நரகம்"}, {"w": 3, "t": "காண்பவருக்கு"}, {"w": 4, "t": "sees"}, {"w": 5, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "ஆகவே, யார்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "வரம்பு மீறினானோ"}, {"w": 4, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "இன்னும் தேர்ந்தெடுத்தானோ"}, {"w": 2, "t": "உலக வாழ்க்கை"}, {"w": 3, "t": "(of) the world"}, {"w": 4, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நரகம்தான்"}, {"w": 3, "t": "it"}, {"w": 4, "t": "தங்குமிடம்"}, {"w": 5, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "ஆகவே யார்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "பயந்தான்"}, {"w": 4, "t": "(தான்) நிற்கின்ற நாளை"}, {"w": 5, "t": "தன் இறைவனுக்கு முன்"}, {"w": 6, "t": "இன்னும் தடுத்தானோ"}, {"w": 7, "t": "ஆன்மாவை"}, {"w": 8, "t": "இச்சையை விட்டு"}, {"w": 9, "t": "the vain desires"}, {"w": 10, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "சொர்க்கம்தான்"}, {"w": 3, "t": "it (is)"}, {"w": 4, "t": "தங்குமிடம்"}, {"w": 5, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "உம்மிடம் கேட்கிறார்கள்"}, {"w": 2, "t": "மறுமையைப் பற்றி"}, {"w": 3, "t": "the Hour"}, {"w": 4, "t": "எப்போது"}, {"w": 5, "t": "அது நிகழும்"}, {"w": 6, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "எதில் இருக்கிறீர்?"}, {"w": 2, "t": "நீர்"}, {"w": 3, "t": "அதைக் கூறுவதற்கு"}, {"w": 4, "t": "(to) mention it"}, {"w": 5, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "உம் இறைவன் பக்கம் தான்"}, {"w": 2, "t": "your Lord"}, {"w": 3, "t": "அதன் முடிவு (இருக்கிறது)"}, {"w": 4, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நீரெல்லாம்"}, {"w": 2, "t": "you"}, {"w": 3, "t": "எச்சரிப்பவரே"}, {"w": 4, "t": "அதைப் பயப்படுகிறவரை"}, {"w": 5, "t": "fears it"}, {"w": 6, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "போன்றே/நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "நாளில்"}, {"w": 3, "t": "அவர்கள் அதைக் காணுகின்ற"}, {"w": 4, "t": "தங்கவில்லை"}, {"w": 5, "t": "they had remained"}, {"w": 6, "t": "தவிர"}, {"w": 7, "t": "ஒரு மாலை"}, {"w": 8, "t": "அல்லது"}, {"w": 9, "t": "அதன் முற்பகல்"}, {"w": 10, "t": "(46)"}]}]}