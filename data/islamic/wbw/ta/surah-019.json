{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "காஃப் ஹா யா ஐன் ஸாத்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நினைவு கூர்வது"}, {"w": 2, "t": "அருள் செய்ததை"}, {"w": 3, "t": "உமது இறைவன்"}, {"w": 4, "t": "தன் அடியார்"}, {"w": 5, "t": "ஸகரிய்யாவுக்கு"}, {"w": 6, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அவர் அழைத்தபோது"}, {"w": 2, "t": "he called"}, {"w": 3, "t": "தன் இறைவனை"}, {"w": 4, "t": "அழைத்தல்"}, {"w": 5, "t": "மறைவாக"}, {"w": 6, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவா!"}, {"w": 3, "t": "நிச்சயமாக நான்"}, {"w": 4, "t": "பலவீனமடைந்து விட்டது"}, {"w": 5, "t": "எலும்பு"}, {"w": 6, "t": "என்னில்"}, {"w": 7, "t": "வெளுத்து விட்டது"}, {"w": 8, "t": "தலை"}, {"w": 9, "t": "நரையால்"}, {"w": 10, "t": "நான் ஆகமாட்டேன்"}, {"w": 11, "t": "I have been"}, {"w": 12, "t": "உன்னிடம் (நான்) பிரார்த்தித்ததில்"}, {"w": 13, "t": "என் இறைவா"}, {"w": 14, "t": "துர்பாக்கியவனாக"}, {"w": 15, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "பயப்படுகிறேன்"}, {"w": 3, "t": "உறவினர்களை"}, {"w": 4, "t": "எனக்குப் பின்னால்"}, {"w": 5, "t": "after me"}, {"w": 6, "t": "இன்னும் இருக்கிறாள்"}, {"w": 7, "t": "என் மனைவி"}, {"w": 8, "t": "மலடியாக"}, {"w": 9, "t": "ஆகவே, தா!"}, {"w": 10, "t": "எனக்கு"}, {"w": 11, "t": "உன் புறத்திலிருந்து"}, {"w": 12, "t": "Yourself"}, {"w": 13, "t": "ஒரு வாரிசை"}, {"w": 14, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "அவர் எனக்கும் வாரிசாக ஆகுவார்"}, {"w": 2, "t": "இன்னும் வாரிசாக ஆகுவார்"}, {"w": 3, "t": "கிளையினருக்கு"}, {"w": 4, "t": "(the) family"}, {"w": 5, "t": "யஃகூபுடைய"}, {"w": 6, "t": "இன்னும் அவரை ஆக்கு"}, {"w": 7, "t": "என் இறைவா!"}, {"w": 8, "t": "பொருந்திக் கொள்ளப்பட்டவராக"}, {"w": 9, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "ஸகரிய்யாவே!"}, {"w": 2, "t": "நிச்சயமாக நாம்"}, {"w": 3, "t": "உமக்கு நற்செய்தி தருகிறோம்"}, {"w": 4, "t": "ஒரு ஆண் குழந்தையைக் கொண்டு"}, {"w": 5, "t": "அதன் பெயர்"}, {"w": 6, "t": "யஹ்யா"}, {"w": 7, "t": "நாம் படைக்கவில்லை"}, {"w": 8, "t": "We (have) assigned"}, {"w": 9, "t": "அதற்கு"}, {"w": 10, "t": "இதற்கு முன்"}, {"w": 11, "t": "before"}, {"w": 12, "t": "ஒப்பானவரை"}, {"w": 13, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவா"}, {"w": 3, "t": "எப்படி?"}, {"w": 4, "t": "கிடைக்கும்"}, {"w": 5, "t": "எனக்கு"}, {"w": 6, "t": "குழந்தை"}, {"w": 7, "t": "இருக்கிறாள்"}, {"w": 8, "t": "என் மனைவி"}, {"w": 9, "t": "மலடியாக"}, {"w": 10, "t": "நானோ அடைந்து விட்டேன்"}, {"w": 11, "t": "I have reached"}, {"w": 12, "t": "முதுமையின்"}, {"w": 13, "t": "the old age"}, {"w": 14, "t": "எல்லையை"}, {"w": 15, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "அப்படித்தான்"}, {"w": 3, "t": "கூறினான்"}, {"w": 4, "t": "உம் இறைவன்"}, {"w": 5, "t": "அது"}, {"w": 6, "t": "எனக்கு"}, {"w": 7, "t": "மிக எளிது"}, {"w": 8, "t": "திட்டமாக"}, {"w": 9, "t": "நான் உன்னைப் படைத்திருக்கிறேன்"}, {"w": 10, "t": "இதற்கு முன்னர்"}, {"w": 11, "t": "before"}, {"w": 12, "t": "நீர் இருக்காதபோது"}, {"w": 13, "t": "you were"}, {"w": 14, "t": "ஒரு பொருளாக"}, {"w": 15, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவா"}, {"w": 3, "t": "எனக்கு ஏற்படுத்து"}, {"w": 4, "t": "for me"}, {"w": 5, "t": "ஓர் அத்தாட்சியை"}, {"w": 6, "t": "அவன் கூறினான்"}, {"w": 7, "t": "உமக்கு அத்தாட்சியாகும்"}, {"w": 8, "t": "பேசாமல் இருப்பது தான்"}, {"w": 9, "t": "you will speak"}, {"w": 10, "t": "மக்களிடம்"}, {"w": 11, "t": "மூன்று"}, {"w": 12, "t": "இரவுகள்"}, {"w": 13, "t": "நீர் சுகமாக இருக்க"}, {"w": 14, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவர் வெளியேறி வந்தார்"}, {"w": 2, "t": "தனது மக்களுக்கு முன்"}, {"w": 3, "t": "his people"}, {"w": 4, "t": "இருந்து"}, {"w": 5, "t": "தொழுமிடம்"}, {"w": 6, "t": "ஜாடை காண்பித்தார்"}, {"w": 7, "t": "அவர்களை நோக்கி"}, {"w": 8, "t": "துதியுங்கள் என்று"}, {"w": 9, "t": "glorify (Allah)"}, {"w": 10, "t": "காலையிலும்"}, {"w": 11, "t": "மாலையிலும்"}, {"w": 12, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "யஹ்யாவே"}, {"w": 2, "t": "பற்றிப் பிடிப்பீராக"}, {"w": 3, "t": "வேதத்தை"}, {"w": 4, "t": "பலமாக"}, {"w": 5, "t": "இன்னும் அவருக்குக் கொடுத்தோம்"}, {"w": 6, "t": "ஞானத்தை"}, {"w": 7, "t": "சிறு குழந்தை"}, {"w": 8, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இரக்கத்தையும்"}, {"w": 2, "t": "நம்மிடமிருந்து"}, {"w": 3, "t": "Us"}, {"w": 4, "t": "தூய்மையையும்"}, {"w": 5, "t": "இன்னும் அவர் இருந்தார்"}, {"w": 6, "t": "இறையச்சமுடையவராக"}, {"w": 7, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் நன்மை புரிபவராக"}, {"w": 2, "t": "தன் பெற்றோருக்கு"}, {"w": 3, "t": "அவர் இருக்கவில்லை"}, {"w": 4, "t": "he was"}, {"w": 5, "t": "முரடராக"}, {"w": 6, "t": "மாறுசெய்பவராக"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "இன்னும் ஈடேற்றம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "நாளிலும்"}, {"w": 4, "t": "பிறந்த/நாளிலும்"}, {"w": 5, "t": "and (the) day"}, {"w": 6, "t": "அவர் மரணிக்கின்ற"}, {"w": 7, "t": "அவர் எழுப்பப்படுகின்ற நாளிலும்"}, {"w": 8, "t": "he will be raised"}, {"w": 9, "t": "உயிர் பெற்றவராக"}, {"w": 10, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இன்னும் நினைவு கூறுவீராக"}, {"w": 2, "t": "இவ்வேதத்தில்"}, {"w": 3, "t": "the Book"}, {"w": 4, "t": "மர்யமை"}, {"w": 5, "t": "ஒதுங்கியபோது"}, {"w": 6, "t": "she withdrew"}, {"w": 7, "t": "தன் குடும்பத்தினரை விட்டு"}, {"w": 8, "t": "her family"}, {"w": 9, "t": "இடத்திற்கு"}, {"w": 10, "t": "கிழக்கில்"}, {"w": 11, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அவர் ஏற்படுத்திக் கொண்டார்"}, {"w": 2, "t": "அவர்களுக்கு முன்னாலிருந்து"}, {"w": 3, "t": "from them"}, {"w": 4, "t": "ஒரு திரையை"}, {"w": 5, "t": "நாம் அனுப்பினோம்"}, {"w": 6, "t": "அவரிடம்"}, {"w": 7, "t": "நமது தூதரை"}, {"w": 8, "t": "அவர் தோன்றினார்"}, {"w": 9, "t": "அவளுக்கு"}, {"w": 10, "t": "ஒரு மனிதராக"}, {"w": 11, "t": "முழுமையான"}, {"w": 12, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "பாதுகாவல் தேடுகிறேன்"}, {"w": 4, "t": "ரஹ்மானிடம்"}, {"w": 5, "t": "உம்மிடமிருந்து"}, {"w": 6, "t": "நீர் இருந்தால்"}, {"w": 7, "t": "you are"}, {"w": 8, "t": "இறையச்சமுடையவராக"}, {"w": 9, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "நானெல்லாம்"}, {"w": 3, "t": "I am"}, {"w": 4, "t": "தூதர்தான்"}, {"w": 5, "t": "உமது இறைவனின்"}, {"w": 6, "t": "நான்வழங்குவதற்காக"}, {"w": 7, "t": "உமக்கு"}, {"w": 8, "t": "ஒரு குழந்தையை"}, {"w": 9, "t": "பரிசுத்தமான"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "எப்படி?"}, {"w": 3, "t": "எனக்கு ஏற்படும்"}, {"w": 4, "t": "for me"}, {"w": 5, "t": "குழந்தை"}, {"w": 6, "t": "இன்னும் என்னை தொடவில்லை"}, {"w": 7, "t": "has touched me"}, {"w": 8, "t": "ஓர் ஆடவர்"}, {"w": 9, "t": "இன்னும் நான் இல்லையே"}, {"w": 10, "t": "I am"}, {"w": 11, "t": "விபச்சாரியாக"}, {"w": 12, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "அப்படித்தான் நடக்கும்"}, {"w": 3, "t": "கூறுகிறான்"}, {"w": 4, "t": "உமது இறைவன்"}, {"w": 5, "t": "அது"}, {"w": 6, "t": "தனக்கு"}, {"w": 7, "t": "எளிதாகும்"}, {"w": 8, "t": "அவரை நாம் ஆக்குவதற்காகவும்"}, {"w": 9, "t": "ஓர் அத்தாட்சியாக"}, {"w": 10, "t": "மனிதர்களுக்கு"}, {"w": 11, "t": "ஓர் அருளாக"}, {"w": 12, "t": "நம்புறத்திலிருந்து"}, {"w": 13, "t": "இது இருக்கிறது"}, {"w": 14, "t": "ஒரு காரியமாக"}, {"w": 15, "t": "முடிவுசெய்யப்பட்ட"}, {"w": 16, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "பின்னர், அவர் அவரை கர்ப்பத்தில் சுமந்தாள்"}, {"w": 2, "t": "அதனுடன் விலகிச் சென்றார்"}, {"w": 3, "t": "with him"}, {"w": 4, "t": "இடத்திற்கு"}, {"w": 5, "t": "தூரமான"}, {"w": 6, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "கொண்டு சென்றது அவரை"}, {"w": 2, "t": "பிரசவ வேதனை"}, {"w": 3, "t": "மரத்தடிக்கு"}, {"w": 4, "t": "(the) trunk"}, {"w": 5, "t": "பேரிச்சமரம்"}, {"w": 6, "t": "அவர் கூறினார்"}, {"w": 7, "t": "நான் மரணிக்க வேண்டுமே"}, {"w": 8, "t": "I (had) died"}, {"w": 9, "t": "முன்னரே"}, {"w": 10, "t": "இதற்கு"}, {"w": 11, "t": "இன்னும் நான் இருக்க வேண்டுமே"}, {"w": 12, "t": "முற்றிலும் மறக்கப்பட்டவளாக"}, {"w": 13, "t": "forgotten"}, {"w": 14, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவரை அவர் கூவி அழைத்தார்"}, {"w": 2, "t": "அதனுடைய அடிப்புறத்திலிருந்து"}, {"w": 3, "t": "beneath her"}, {"w": 4, "t": "கவலைப்படாதீர்"}, {"w": 5, "t": "grieve"}, {"w": 6, "t": "ஏற்படுத்தி இருக்கின்றான்"}, {"w": 7, "t": "(has) placed"}, {"w": 8, "t": "உமது இறைவன்"}, {"w": 9, "t": "உமக்குக் கீழ்"}, {"w": 10, "t": "ஓர் ஊற்றை"}, {"w": 11, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இன்னும் அசைப்பீராக"}, {"w": 2, "t": "உம் பக்கம்"}, {"w": 3, "t": "நடுத்தண்டை"}, {"w": 4, "t": "பேரிச்ச மரத்தின்"}, {"w": 5, "t": "கொட்டும்"}, {"w": 6, "t": "உம்மீது"}, {"w": 7, "t": "பழங்களை"}, {"w": 8, "t": "பழுத்த"}, {"w": 9, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "இன்னும் நீர் புசிப்பீராக"}, {"w": 2, "t": "பருகுவீராக"}, {"w": 3, "t": "குளிர்வீராக"}, {"w": 4, "t": "கண்"}, {"w": 5, "t": "ஆகவே நீர் பார்த்தால்"}, {"w": 6, "t": "you see"}, {"w": 7, "t": "மனிதரில்"}, {"w": 8, "t": "human being"}, {"w": 9, "t": "யாரையும்"}, {"w": 10, "t": "கூறுவீராக"}, {"w": 11, "t": "நிச்சயமாக நான்/நேர்ச்சை செய்துள்ளேன்"}, {"w": 12, "t": "[I] have vowed"}, {"w": 13, "t": "ரஹ்மானுக்கு"}, {"w": 14, "t": "நோன்பை"}, {"w": 15, "t": "ஆகவே நான் அறவே பேசமாட்டேன்"}, {"w": 16, "t": "I will speak"}, {"w": 17, "t": "இன்று"}, {"w": 18, "t": "எந்த மனிதனிடமும்"}, {"w": 19, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அவர் வந்தார்"}, {"w": 2, "t": "அதைக் கொண்டு"}, {"w": 3, "t": "தனது மக்களிடம்"}, {"w": 4, "t": "அதைச் சுமந்தவராக"}, {"w": 5, "t": "அவர்கள் கூறினார்கள்"}, {"w": 6, "t": "மர்யமே!"}, {"w": 7, "t": "நீ செய்து விட்டாய்"}, {"w": 8, "t": "you (have) brought"}, {"w": 9, "t": "ஒரு காரியத்தை"}, {"w": 10, "t": "பெரிய"}, {"w": 11, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "சகோதரியே"}, {"w": 2, "t": "ஹாரூனுடைய"}, {"w": 3, "t": "இருக்கவில்லை"}, {"w": 4, "t": "was"}, {"w": 5, "t": "உமது தந்தை"}, {"w": 6, "t": "கெட்டவராக"}, {"w": 7, "t": "an evil man"}, {"w": 8, "t": "இருக்கவில்லை"}, {"w": 9, "t": "was"}, {"w": 10, "t": "உமது தாயும்"}, {"w": 11, "t": "நடத்தைகெட்டவளாக"}, {"w": 12, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "ஜாடை காண்பித்தார்"}, {"w": 2, "t": "அதன் பக்கம்"}, {"w": 3, "t": "அவர்கள் கூறினார்கள்"}, {"w": 4, "t": "எப்படி"}, {"w": 5, "t": "நாங்கள் பேசுவோம்"}, {"w": 6, "t": "இருக்கின்றவரிடம்"}, {"w": 7, "t": "is"}, {"w": 8, "t": "மடியில்"}, {"w": 9, "t": "the cradle"}, {"w": 10, "t": "குழந்தையாக"}, {"w": 11, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "அடிமை"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "எனக்குக்கொடுப்பான்"}, {"w": 6, "t": "வேதத்தை"}, {"w": 7, "t": "என்னை ஆக்குவான்"}, {"w": 8, "t": "நபியாக"}, {"w": 9, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "இன்னும் அவன் என்னை ஆக்குவான்"}, {"w": 2, "t": "அருள்மிக்கவனாக"}, {"w": 3, "t": "நான் எங்கிருந்தாலும்"}, {"w": 4, "t": "wherever"}, {"w": 5, "t": "I am"}, {"w": 6, "t": "எனக்கு கட்டளையிட்டுள்ளான்"}, {"w": 7, "t": "தொழுகையைக் கொண்டும்"}, {"w": 8, "t": "ஸகாத்தைக் கொண்டும்"}, {"w": 9, "t": "நான்இருக்கின்றவரை"}, {"w": 10, "t": "as long as I am"}, {"w": 11, "t": "உயிருள்ளவனாக"}, {"w": 12, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "நன்மைசெய்பவனாக"}, {"w": 2, "t": "என் தாய்க்கு"}, {"w": 3, "t": "இன்னும் அவன் என்னை ஆக்கவில்லை"}, {"w": 4, "t": "He (has) made me"}, {"w": 5, "t": "பெருமையுடையவனாக"}, {"w": 6, "t": "தீயவனாக"}, {"w": 7, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "ஈடேற்றம் உண்டாகுக"}, {"w": 2, "t": "எனக்கு"}, {"w": 3, "t": "நாளிலும்"}, {"w": 4, "t": "நான் பிறந்த"}, {"w": 5, "t": "நான் மரணிக்கின்றநாளிலும்"}, {"w": 6, "t": "I will die"}, {"w": 7, "t": "நான் எழுப்பப்படுகின்ற நாளிலும்"}, {"w": 8, "t": "I will be raised"}, {"w": 9, "t": "உயிருள்ளவனாக"}, {"w": 10, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இவர்தான்"}, {"w": 2, "t": "ஈஸா"}, {"w": 3, "t": "மகன்"}, {"w": 4, "t": "மர்யமுடைய"}, {"w": 5, "t": "கூறுங்கள்"}, {"w": 6, "t": "உண்மையானகூற்றை"}, {"w": 7, "t": "எது/இதில்தான்"}, {"w": 8, "t": "about it"}, {"w": 9, "t": "அவர்கள் தர்க்கிக்கின்றனர்"}, {"w": 10, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "தகுந்ததல்ல"}, {"w": 2, "t": "(it) is"}, {"w": 3, "t": "அல்லாஹ்விற்கு"}, {"w": 4, "t": "அவன் எடுத்துக் கொள்வது"}, {"w": 5, "t": "He should take"}, {"w": 6, "t": "குழந்தையை"}, {"w": 7, "t": "any son"}, {"w": 8, "t": "அவன் மகா பரிசுத்தமானவன்"}, {"w": 9, "t": "அவன் முடிவு செய்தால்"}, {"w": 10, "t": "He decrees"}, {"w": 11, "t": "ஒரு காரியத்தை"}, {"w": 12, "t": "அவன் கூறுவதெல்லாம்"}, {"w": 13, "t": "He says"}, {"w": 14, "t": "அதற்கு"}, {"w": 15, "t": "ஆகு"}, {"w": 16, "t": "அது ஆகிவிடும்"}, {"w": 17, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "அல்லாஹ்தான்"}, {"w": 3, "t": "என் இறைவனும்"}, {"w": 4, "t": "உங்கள் இறைவனும்"}, {"w": 5, "t": "ஆகவே, அவனையே வணங்குங்கள்!"}, {"w": 6, "t": "இதுதான்"}, {"w": 7, "t": "நேரான பாதை"}, {"w": 8, "t": "straight"}, {"w": 9, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "ஆனால் தர்க்கித்தனர்"}, {"w": 2, "t": "பல பிரிவினர்"}, {"w": 3, "t": "தங்களுக்கு மத்தியில்"}, {"w": 4, "t": "from among them"}, {"w": 5, "t": "ஆகவே கேடுதான்"}, {"w": 6, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 7, "t": "disbelieve"}, {"w": 8, "t": "அவர் காணும்போது"}, {"w": 9, "t": "(the) witnessing"}, {"w": 10, "t": "நாளை"}, {"w": 11, "t": "மகத்தான"}, {"w": 12, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "நன்றாக செவிசாய்ப்பார்கள்"}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "நன்றாக பார்ப்பார்கள்"}, {"w": 4, "t": "நாளில்"}, {"w": 5, "t": "நம்மிடம் அவர்கள் வருகின்ற"}, {"w": 6, "t": "எனினும்"}, {"w": 7, "t": "அநியாயக்காரர்கள்"}, {"w": 8, "t": "இன்றைய தினம்"}, {"w": 9, "t": "வழிகேட்டில்தான்"}, {"w": 10, "t": "error"}, {"w": 11, "t": "தெளிவான"}, {"w": 12, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "அவர்களை எச்சரிப்பீராக"}, {"w": 2, "t": "நாளை(ப் பற்றி)"}, {"w": 3, "t": "துயரமான"}, {"w": 4, "t": "தீர்ப்பு முடிவு செய்யப்படும்போது"}, {"w": 5, "t": "has been decided"}, {"w": 6, "t": "the matter"}, {"w": 7, "t": "அவர்கள் இருக்கின்றனர்"}, {"w": 8, "t": "அறியாமையில்"}, {"w": 9, "t": "heedlessness"}, {"w": 10, "t": "அவர்கள்"}, {"w": 11, "t": "நம்பிக்கை கொள்ள மாட்டார்கள்"}, {"w": 12, "t": "believe"}, {"w": 13, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நிச்சயமாக நாம்தான்"}, {"w": 2, "t": "[We]"}, {"w": 3, "t": "வாரிசாகுவோம்"}, {"w": 4, "t": "பூமி/இன்னும் அதில் இருப்பவர்களுக்கு"}, {"w": 5, "t": "and whoever"}, {"w": 6, "t": "(is) on it"}, {"w": 7, "t": "இன்னும் நம்மிடமே"}, {"w": 8, "t": "அவர்கள் திரும்பக் கொண்டு வரப்படுவார்கள்"}, {"w": 9, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "நினைவு கூர்வீராக"}, {"w": 2, "t": "இவ்வேதத்தில்"}, {"w": 3, "t": "the Book"}, {"w": 4, "t": "இப்றாஹீமை"}, {"w": 5, "t": "நிச்சயமாக அவர்"}, {"w": 6, "t": "இருக்கிறார்"}, {"w": 7, "t": "உண்மையாளராக"}, {"w": 8, "t": "நபியாக"}, {"w": 9, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "(அந்த) சமயத்தை கூறினார்"}, {"w": 2, "t": "he said"}, {"w": 3, "t": "தனது தந்தைக்கு"}, {"w": 4, "t": "என் தந்தையே"}, {"w": 5, "t": "ஏன் வணங்குகிறீர்?"}, {"w": 6, "t": "(do) you worship"}, {"w": 7, "t": "கேட்காதவற்றை"}, {"w": 8, "t": "not"}, {"w": 9, "t": "hears"}, {"w": 10, "t": "இன்னும் பார்க்காதவற்றை"}, {"w": 11, "t": "sees"}, {"w": 12, "t": "இன்னும் தடுக்காதவற்றை"}, {"w": 13, "t": "benefits"}, {"w": 14, "t": "உம்மை விட்டு"}, {"w": 15, "t": "எதையும்"}, {"w": 16, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "என் தந்தையே"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "எனக்கு வந்திருக்கிறது"}, {"w": 4, "t": "(has) come to me"}, {"w": 5, "t": "கல்வியில்"}, {"w": 6, "t": "the knowledge"}, {"w": 7, "t": "உமக்கு வரவில்லை"}, {"w": 8, "t": "not"}, {"w": 9, "t": "came to you"}, {"w": 10, "t": "ஆகவே, என்னைப் பின்பற்றுவீராக"}, {"w": 11, "t": "நான் உமக்கு வழிகாட்டுவேன்"}, {"w": 12, "t": "பாதையை"}, {"w": 13, "t": "நேரான"}, {"w": 14, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "என் தந்தையே"}, {"w": 2, "t": "வணங்காதீர்"}, {"w": 3, "t": "worship"}, {"w": 4, "t": "ஷைத்தானை"}, {"w": 5, "t": "நிச்சயமாக"}, {"w": 6, "t": "ஷைத்தான்"}, {"w": 7, "t": "இருக்கிறான்"}, {"w": 8, "t": "ரஹ்மானுக்கு"}, {"w": 9, "t": "மாறுசெய்பவனாக"}, {"w": 10, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "என் தந்தையே"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "நான் பயப்படுகிறேன்"}, {"w": 4, "t": "உம்மைவந்தடைந்தால்"}, {"w": 5, "t": "will touch you"}, {"w": 6, "t": "ஒரு வேதனை"}, {"w": 7, "t": "இருந்து"}, {"w": 8, "t": "பேரருளாளன்"}, {"w": 9, "t": "நீர் ஆகிவிடுவீர்"}, {"w": 10, "t": "ஷைத்தானுக்கு"}, {"w": 11, "t": "நண்பராக"}, {"w": 12, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "நீ வெறுக்கிறாயா?"}, {"w": 3, "t": "நீ"}, {"w": 4, "t": "என் தெய்வங்களை"}, {"w": 5, "t": "my gods"}, {"w": 6, "t": "இப்றாஹீமே"}, {"w": 7, "t": "நீர் விலகவில்லை என்றால்"}, {"w": 8, "t": "not"}, {"w": 9, "t": "you desist"}, {"w": 10, "t": "நிச்சயமாக நான் உன்னை கடுமையாக ஏசுவேன்"}, {"w": 11, "t": "இன்னும் என்னை விட்டு விலகிவிடு"}, {"w": 12, "t": "பாதுகாப்புப் பெற்றவராக"}, {"w": 13, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "பாதுகாப்பு உண்டாகுக"}, {"w": 3, "t": "உமக்கு"}, {"w": 4, "t": "பாவமன்னிப்புக் கோருவேன்"}, {"w": 5, "t": "உமக்காக"}, {"w": 6, "t": "என் இறைவனிடம்"}, {"w": 7, "t": "நிச்சயமாக அவன்"}, {"w": 8, "t": "இருக்கின்றான்"}, {"w": 9, "t": "என் மீது"}, {"w": 10, "t": "அருளுடையவனாக"}, {"w": 11, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "இன்னும் உங்களை விட்டு விலகி விடுகின்றேன்"}, {"w": 2, "t": "இன்னும் நீங்கள் வணங்குகின்றவற்றை"}, {"w": 3, "t": "you invoke"}, {"w": 4, "t": "அல்லாஹ்வையன்றி"}, {"w": 5, "t": "besides"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "நான் பிரார்த்திப்பேன்"}, {"w": 8, "t": "என் இறைவனிடம்"}, {"w": 9, "t": "ஆகாமல் இருப்பேன்"}, {"w": 10, "t": "that not"}, {"w": 11, "t": "I will be"}, {"w": 12, "t": "பிரார்த்திப்பதில்"}, {"w": 13, "t": "என் இறைவனிடம்"}, {"w": 14, "t": "நம்பிக்கை அற்றவனாக"}, {"w": 15, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அவர் அவர்களை விட்டு விலகியபோது"}, {"w": 2, "t": "he left them"}, {"w": 3, "t": "இன்னும் அவர்கள் வணங்கியதை"}, {"w": 4, "t": "they worshipped"}, {"w": 5, "t": "அன்றி"}, {"w": 6, "t": "besides Allah"}, {"w": 7, "t": "அல்லாஹ்வை"}, {"w": 8, "t": "வழங்கினோம்"}, {"w": 9, "t": "அவருக்கு"}, {"w": 10, "t": "இஸ்ஹாக்கை"}, {"w": 11, "t": "இன்னும் யஃகூபை"}, {"w": 12, "t": "இன்னும் ஒவ்வொருவரையும்"}, {"w": 13, "t": "ஆக்கினோம்"}, {"w": 14, "t": "நபியாக"}, {"w": 15, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "வழங்கினோம்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "நமது அருளிலிருந்து"}, {"w": 4, "t": "Our Mercy"}, {"w": 5, "t": "இன்னும் ஏற்படுத்தினோம்"}, {"w": 6, "t": "அவர்களுக்கு"}, {"w": 7, "t": "புகழை"}, {"w": 8, "t": "உண்மையான"}, {"w": 9, "t": "உயர்வான"}, {"w": 10, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நினைவு கூர்வீராக"}, {"w": 2, "t": "இவ்வேதத்தில்"}, {"w": 3, "t": "the Book"}, {"w": 4, "t": "மூஸாவை"}, {"w": 5, "t": "நிச்சயமாக அவர்"}, {"w": 6, "t": "இருக்கிறார்/தேர்ந்தெடுக்கப்பட்டவராக"}, {"w": 7, "t": "chosen"}, {"w": 8, "t": "இன்னும் இருக்கிறார்"}, {"w": 9, "t": "தூதராக/நபியாக"}, {"w": 10, "t": "a Prophet"}, {"w": 11, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "இன்னும் அவரை அழைத்தோம்"}, {"w": 2, "t": "பக்கத்தில்"}, {"w": 3, "t": "(the) side"}, {"w": 4, "t": "மலை/வலது"}, {"w": 5, "t": "the right"}, {"w": 6, "t": "அவரை நாம் நெருக்கமாக்கினோம்"}, {"w": 7, "t": "அவரை இரகசியம் பேசுகிறவராக"}, {"w": 8, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "இன்னும் வழங்கினோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "நமது அருளால்"}, {"w": 4, "t": "Our Mercy"}, {"w": 5, "t": "அவருடைய சகோதரர்"}, {"w": 6, "t": "ஹாரூனை"}, {"w": 7, "t": "நபியாக"}, {"w": 8, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "நினைவு கூர்வீராக"}, {"w": 2, "t": "இவ்வேதத்தில்"}, {"w": 3, "t": "the Book"}, {"w": 4, "t": "இஸ்மாயீலை"}, {"w": 5, "t": "நிச்சயமாக அவர்"}, {"w": 6, "t": "இருக்கிறார்"}, {"w": 7, "t": "உண்மையாளராக"}, {"w": 8, "t": "வாக்கில்"}, {"w": 9, "t": "இன்னும் இருக்கிறார்"}, {"w": 10, "t": "தூதராக"}, {"w": 11, "t": "நபியாக"}, {"w": 12, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "இருந்தார்"}, {"w": 2, "t": "ஏவுகின்றவராக"}, {"w": 3, "t": "தனது குடும்பத்தினரை"}, {"w": 4, "t": "தொழுகையைக் கொண்டு"}, {"w": 5, "t": "ஸகாத்தைக் கொண்டு"}, {"w": 6, "t": "இருந்தார்"}, {"w": 7, "t": "தன் இறைவனிடம்"}, {"w": 8, "t": "his Lord"}, {"w": 9, "t": "திருப்திக்குரியவராக"}, {"w": 10, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "நினைவு கூர்வீராக"}, {"w": 2, "t": "இவ்வேதத்தில்"}, {"w": 3, "t": "the Book"}, {"w": 4, "t": "இத்ரீஸை"}, {"w": 5, "t": "நிச்சயமாக அவர்"}, {"w": 6, "t": "இருக்கிறார்"}, {"w": 7, "t": "உண்மையாளராக"}, {"w": 8, "t": "நபியாக"}, {"w": 9, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "இன்னும் அவரை உயர்த்தினோம்"}, {"w": 2, "t": "இடத்திற்கு"}, {"w": 3, "t": "உயர்ந்த"}, {"w": 4, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "இவர்கள்தான்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "அருள் புரிந்திருக்கின்றான்"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "இவர்கள் மீது"}, {"w": 6, "t": "நபிமார்களில்"}, {"w": 7, "t": "the Prophets"}, {"w": 8, "t": "சந்ததிகளில்"}, {"w": 9, "t": "(the) offspring"}, {"w": 10, "t": "ஆதமுடைய"}, {"w": 11, "t": "இன்னும் நாம் ஏற்றியவர்களிலும்"}, {"w": 12, "t": "We carried"}, {"w": 13, "t": "நூஹூடன்"}, {"w": 14, "t": "Nuh"}, {"w": 15, "t": "சந்ததிகளிலும்"}, {"w": 16, "t": "(the) offspring"}, {"w": 17, "t": "இப்றாஹீம்"}, {"w": 18, "t": "இன்னும் இஸ்ராயீல்"}, {"w": 19, "t": "நாம் நேர்வழிகாட்டி"}, {"w": 20, "t": "We guided"}, {"w": 21, "t": "தேர்ந்தெடுத்தவர்கள்"}, {"w": 22, "t": "ஓதப்பட்டால்"}, {"w": 23, "t": "were recited"}, {"w": 24, "t": "அவர்கள் மீது"}, {"w": 25, "t": "வசனங்கள்"}, {"w": 26, "t": "பேரருளாளனுடைய"}, {"w": 27, "t": "விழுந்து விடுவார்கள்"}, {"w": 28, "t": "சிரம்பணிந்தவர்களாக"}, {"w": 29, "t": "அழுதவர்களாக"}, {"w": 30, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "தோன்றினார்கள்"}, {"w": 2, "t": "பின்"}, {"w": 3, "t": "பின் அவர்களுக்கு"}, {"w": 4, "t": "ஒரு கூட்டம்"}, {"w": 5, "t": "பாழாக்கினர்"}, {"w": 6, "t": "தொழுகையை"}, {"w": 7, "t": "இன்னும் பின்பற்றினர்"}, {"w": 8, "t": "மன இச்சைகளை"}, {"w": 9, "t": "அவர்கள் சந்திப்பார்கள்"}, {"w": 10, "t": "they will meet"}, {"w": 11, "t": "கய்யை"}, {"w": 12, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "திருந்தியவர்கள்"}, {"w": 3, "t": "repented"}, {"w": 4, "t": "நம்பிக்கை கொண்டு"}, {"w": 5, "t": "இன்னும் செய்தவரை"}, {"w": 6, "t": "நல்லது"}, {"w": 7, "t": "அவர்கள்"}, {"w": 8, "t": "நுழைவார்கள்"}, {"w": 9, "t": "சொர்க்கத்தில்"}, {"w": 10, "t": "அறவே அநீதி செய்யப்பட மாட்டார்கள்"}, {"w": 11, "t": "they will be wronged"}, {"w": 12, "t": "(in) anything"}, {"w": 13, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "சொர்க்கங்களில்"}, {"w": 2, "t": "அத்ன்"}, {"w": 3, "t": "எது/வாக்களித்துள்ளான்"}, {"w": 4, "t": "promised"}, {"w": 5, "t": "பேரருளாளன்"}, {"w": 6, "t": "தன் அடியார்களுக்கு"}, {"w": 7, "t": "மறைவில்"}, {"w": 8, "t": "நிச்சயமாக அவன்"}, {"w": 9, "t": "இருக்கிறது"}, {"w": 10, "t": "அவனுடைய வாக்கு"}, {"w": 11, "t": "நிகழக்கூடியதாக"}, {"w": 12, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "செவிமடுக்க மாட்டார்கள்"}, {"w": 2, "t": "they will hear"}, {"w": 3, "t": "அவற்றில்"}, {"w": 4, "t": "வீணானவற்றை"}, {"w": 5, "t": "எனினும்"}, {"w": 6, "t": "ஸலாமை"}, {"w": 7, "t": "இன்னும் அவர்களுக்கு"}, {"w": 8, "t": "அவர்களுடைய உணவு"}, {"w": 9, "t": "அவற்றில்"}, {"w": 10, "t": "காலையிலும்"}, {"w": 11, "t": "மாலையிலும்"}, {"w": 12, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "இந்த"}, {"w": 2, "t": "சொர்க்கம்"}, {"w": 3, "t": "வாரிசாக ஆக்குவோம்"}, {"w": 4, "t": "We give (as) inheritance"}, {"w": 5, "t": "நமது அடியார்களில்"}, {"w": 6, "t": "Our slaves"}, {"w": 7, "t": "எவர்/இருக்கின்றார்"}, {"w": 8, "t": "is"}, {"w": 9, "t": "இறையச்சமுடையவராக"}, {"w": 10, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "இறங்க மாட்டோம்"}, {"w": 2, "t": "we descend"}, {"w": 3, "t": "உத்தரவைக் கொண்டே தவிர"}, {"w": 4, "t": "by (the) Command"}, {"w": 5, "t": "உமது இறைவனின்"}, {"w": 6, "t": "அவனுக்கே சொந்தம்"}, {"w": 7, "t": "எங்களுக்கு முன் இருப்பவையும்"}, {"w": 8, "t": "(is) before us"}, {"w": 9, "t": "(is) before us"}, {"w": 10, "t": "எங்களுக்கு பின் இருப்பவையும்"}, {"w": 11, "t": "(is) behind us"}, {"w": 12, "t": "அவற்றுக்கு மத்தியில் இருப்பவையும்"}, {"w": 13, "t": "(is) between"}, {"w": 14, "t": "that"}, {"w": 15, "t": "இருக்கவில்லை"}, {"w": 16, "t": "is"}, {"w": 17, "t": "உமது இறைவன்"}, {"w": 18, "t": "மறதியாளனாக"}, {"w": 19, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "இறைவன்"}, {"w": 2, "t": "வானங்கள்/இன்னும் பூமி"}, {"w": 3, "t": "and the earth"}, {"w": 4, "t": "இன்னும் அவை இரண்டிற்கும் இடையில் உள்ளவை"}, {"w": 5, "t": "(is) between both of them"}, {"w": 6, "t": "ஆகவே, அவனை வணங்குவீராக"}, {"w": 7, "t": "இன்னும் பொறுமையாக இருப்பீராக"}, {"w": 8, "t": "அவனை வணங்குவதில்"}, {"w": 9, "t": "நீர் அறிவீரா"}, {"w": 10, "t": "you know"}, {"w": 11, "t": "அவனுக்கு"}, {"w": 12, "t": "ஒப்பானவரை"}, {"w": 13, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "கூறுகிறான்"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "நான் மரணித்து விட்டால்"}, {"w": 4, "t": "What! When"}, {"w": 5, "t": "I am dead"}, {"w": 6, "t": "கண்டிப்பாக எழுப்பப்படுவேனா"}, {"w": 7, "t": "I be brought forth"}, {"w": 8, "t": "உயிருள்ளவனாக"}, {"w": 9, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "சிந்திக்க வேண்டாமா!"}, {"w": 2, "t": "remember"}, {"w": 3, "t": "மனிதன்"}, {"w": 4, "t": "நிச்சயமாக நாம்"}, {"w": 5, "t": "அவனைப் படைத்ததை"}, {"w": 6, "t": "முன்னர்"}, {"w": 7, "t": "before"}, {"w": 8, "t": "அவன் இருக்கவில்லை"}, {"w": 9, "t": "he was"}, {"w": 10, "t": "எந்த ஒரு பொருளாகவும்"}, {"w": 11, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "உம் இறைவன் மீது சத்தியமாக"}, {"w": 2, "t": "நிச்சயமாக நாம் அவர்களை எழுப்புவோம்"}, {"w": 3, "t": "இன்னும் ஷைத்தான்களை"}, {"w": 4, "t": "பிறகு"}, {"w": 5, "t": "அவர்களைக் கொண்டு வருவோம்"}, {"w": 6, "t": "சுற்றி"}, {"w": 7, "t": "நரகத்தை"}, {"w": 8, "t": "முழந்தாளிட்டவர்களாக"}, {"w": 9, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "கழட்டி எடுப்போம்"}, {"w": 3, "t": "ஒவ்வொரு"}, {"w": 4, "t": "every"}, {"w": 5, "t": "கூட்டத்திலும்"}, {"w": 6, "t": "அவர்களில்"}, {"w": 7, "t": "கடுமையானவரை"}, {"w": 8, "t": "ரஹ்மானுக்கு"}, {"w": 9, "t": "the Most Gracious"}, {"w": 10, "t": "பாவம் செய்வதில்"}, {"w": 11, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம்"}, {"w": 3, "t": "மிக அறிந்தவர்கள்"}, {"w": 4, "t": "எவர்கள்/அவர்கள்"}, {"w": 5, "t": "[they]"}, {"w": 6, "t": "மிகவும் தகுதியானவர்கள்"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "கடுமையாக வேதனை அனுபவிப்பதற்கு"}, {"w": 9, "t": "(70)"}]}, {"ayah": 71, "words": [{"w": 1, "t": "உங்களில் (ஒவ்வொருவரும்) இல்லை"}, {"w": 2, "t": "(any) of you"}, {"w": 3, "t": "தவிர/அதில் நுழையக்கூடியவராக"}, {"w": 4, "t": "(will be) passing over it"}, {"w": 5, "t": "இருக்கிறது"}, {"w": 6, "t": "உமது இறைவன் மீது"}, {"w": 7, "t": "your Lord"}, {"w": 8, "t": "தீர்ப்பாக"}, {"w": 9, "t": "முடிவு செய்யப்பட்ட"}, {"w": 10, "t": "(71)"}]}, {"ayah": 72, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "பாதுகாப்போம்"}, {"w": 3, "t": "இறையச்சமுடையவர்களை"}, {"w": 4, "t": "feared (Allah)"}, {"w": 5, "t": "இன்னும் விட்டுவிடுவோம்"}, {"w": 6, "t": "அநியாயக்காரர்களை"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "முழந்தாளிட்ட வர்களாக"}, {"w": 9, "t": "(72)"}]}, {"ayah": 73, "words": [{"w": 1, "t": "ஓதப்பட்டால்"}, {"w": 2, "t": "are recited"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "நமது வசனங்கள்"}, {"w": 5, "t": "தெளிவான"}, {"w": 6, "t": "கூறுகின்றனர்"}, {"w": 7, "t": "நிராகரித்தவர்கள்"}, {"w": 8, "t": "disbelieved"}, {"w": 9, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 10, "t": "believed"}, {"w": 11, "t": "யார்?"}, {"w": 12, "t": "இரு பிரிவினரில்"}, {"w": 13, "t": "சிறந்தவர்"}, {"w": 14, "t": "தங்குமிடத்தால்"}, {"w": 15, "t": "மிக அழகானவர்"}, {"w": 16, "t": "சபையால்"}, {"w": 17, "t": "(73)"}]}, {"ayah": 74, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "நாம் அழித்தோம்"}, {"w": 3, "t": "அவர்களுக்கு முன்"}, {"w": 4, "t": "தலைமுறையினரை"}, {"w": 5, "t": "a generation "}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "மிக அழகானவர்கள்"}, {"w": 8, "t": "பொருட்களாலும்"}, {"w": 9, "t": "தோற்றத்தாலும்"}, {"w": 10, "t": "(74)"}]}, {"ayah": 75, "words": [{"w": 1, "t": "கூறுவீராக"}, {"w": 2, "t": "யார்"}, {"w": 3, "t": "இருக்கின்றாரோ"}, {"w": 4, "t": "வழிகேட்டில்"}, {"w": 5, "t": "[the] error"}, {"w": 6, "t": "நீட்டிவிடட்டும்"}, {"w": 7, "t": "அவருக்கு"}, {"w": 8, "t": "பேரருளாளன்"}, {"w": 9, "t": "நீட்டிவிடுதல்"}, {"w": 10, "t": "இறுதியாக"}, {"w": 11, "t": "அவர்கள் பார்த்தால்"}, {"w": 12, "t": "they see"}, {"w": 13, "t": "அவர்கள் வாக்களிக்கப்பட்டதை"}, {"w": 14, "t": "they were promised"}, {"w": 15, "t": "ஒன்று"}, {"w": 16, "t": "வேதனையை"}, {"w": 17, "t": "அல்லது"}, {"w": 18, "t": "மறுமையை"}, {"w": 19, "t": "அறிவார்கள்"}, {"w": 20, "t": "யார்"}, {"w": 21, "t": "என்பதை"}, {"w": 22, "t": "மிகக் கெட்டவர்"}, {"w": 23, "t": "தங்குமிடத்தால்"}, {"w": 24, "t": "மிகப் பலவீனமானவர்"}, {"w": 25, "t": "படையால்"}, {"w": 26, "t": "(75)"}]}, {"ayah": 76, "words": [{"w": 1, "t": "அதிகப்படுத்துவான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "நேர்வழி நடப்போருக்கு"}, {"w": 4, "t": "accept guidance"}, {"w": 5, "t": "நேர்வழியை"}, {"w": 6, "t": "நிரந்தரமான"}, {"w": 7, "t": "நன்மைகள்தான்"}, {"w": 8, "t": "மிகச் சிறந்தது"}, {"w": 9, "t": "உங்கள் இறைவனிடம்"}, {"w": 10, "t": "your Lord"}, {"w": 11, "t": "நற்கூலியால்"}, {"w": 12, "t": "இன்னும் மிகச் சிறந்தது"}, {"w": 13, "t": "முடிவால்"}, {"w": 14, "t": "(76)"}]}, {"ayah": 77, "words": [{"w": 1, "t": "நீர் பார்த்தீரா?"}, {"w": 2, "t": "நிராகரித்தவனை"}, {"w": 3, "t": "disbelieved"}, {"w": 4, "t": "நமது வசனங்களை"}, {"w": 5, "t": "கூறுகின்றான்"}, {"w": 6, "t": "நிச்சயமாக நான் கொடுக்கப்படுவேன்"}, {"w": 7, "t": "செல்வமும்"}, {"w": 8, "t": "சந்ததியும்"}, {"w": 9, "t": "(77)"}]}, {"ayah": 78, "words": [{"w": 1, "t": "அறிந்துகொண்டானா"}, {"w": 2, "t": "மறைவானதை"}, {"w": 3, "t": "அல்லது"}, {"w": 4, "t": "ஏற்படுத்திக் கொண்டானா"}, {"w": 5, "t": "ரஹ்மானிடம்"}, {"w": 6, "t": "the Most Gracious"}, {"w": 7, "t": "ஓர் ஒப்பந்தத்தை"}, {"w": 8, "t": "(78)"}]}, {"ayah": 79, "words": [{"w": 1, "t": "ஒருக்காலும் அவ்வாறல்ல"}, {"w": 2, "t": "பதிவு செய்கிறோம்"}, {"w": 3, "t": "அவன் கூறுவதை"}, {"w": 4, "t": "he says"}, {"w": 5, "t": "இன்னும் அதிகப்படுத்துவோம்"}, {"w": 6, "t": "அவனுக்கு"}, {"w": 7, "t": "வேதனையில்"}, {"w": 8, "t": "the punishment"}, {"w": 9, "t": "அதிகப்படுத்துதல்"}, {"w": 10, "t": "(79)"}]}, {"ayah": 80, "words": [{"w": 1, "t": "இன்னும் வாரிசாகி விடுவோம்"}, {"w": 2, "t": "அவன் கூறியவற்றுக்கு"}, {"w": 3, "t": "he says"}, {"w": 4, "t": "இன்னும் நம்மிடம் வருவான்"}, {"w": 5, "t": "தனியாக"}, {"w": 6, "t": "(80)"}]}, {"ayah": 81, "words": [{"w": 1, "t": "இன்னும் ஏற்படுத்திக் கொண்டனர்"}, {"w": 2, "t": "அல்லாஹ்வையன்றி"}, {"w": 3, "t": "besides Allah"}, {"w": 4, "t": "besides Allah"}, {"w": 5, "t": "பல தெய்வங்களை"}, {"w": 6, "t": "அவை இருக்கும் என்பதற்காக"}, {"w": 7, "t": "தங்களுக்கு"}, {"w": 8, "t": "பாதுகாப்பாக"}, {"w": 9, "t": "(81)"}]}, {"ayah": 82, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "அவை நிராகரித்து விடும்"}, {"w": 3, "t": "அவர்களின் வழிபாட்டை"}, {"w": 4, "t": "இன்னும் அவை மாறிவிடும்"}, {"w": 5, "t": "அவர்களுக்கு"}, {"w": 6, "t": "எதிரானவையாக"}, {"w": 7, "t": "(82)"}]}, {"ayah": 83, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "நிச்சயமாக நாம்"}, {"w": 4, "t": "ஏவி விட்டுள்ளோம்"}, {"w": 5, "t": "ஷைத்தான்களை"}, {"w": 6, "t": "நிராகரிப்பவர்கள் மீது"}, {"w": 7, "t": "the disbelievers"}, {"w": 8, "t": "பிடித்துஅசைக்கின்றன அவர்களை"}, {"w": 9, "t": "பிடித்து அசைத்தல்"}, {"w": 10, "t": "(83)"}]}, {"ayah": 84, "words": [{"w": 1, "t": "ஆகவே அவசரப்படாதீர்"}, {"w": 2, "t": "make haste"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "நிச்சயமாக நாம்"}, {"w": 5, "t": "எண்ணுகிறோம்"}, {"w": 6, "t": "அவர்களுக்காக"}, {"w": 7, "t": "எண்ணுதல்"}, {"w": 8, "t": "(84)"}]}, {"ayah": 85, "words": [{"w": 1, "t": "நாளில்..."}, {"w": 2, "t": "நாம் ஒன்று திரட்டுகின்(«)ற(£ம்)"}, {"w": 3, "t": "இறையச்சமுள்ளவர்களை"}, {"w": 4, "t": "ரஹ்மானின் பக்கம்"}, {"w": 5, "t": "the Most Gracious"}, {"w": 6, "t": "குழுவாக"}, {"w": 7, "t": "(85)"}]}, {"ayah": 86, "words": [{"w": 1, "t": "இன்னும் நாம் ஓட்டிக் கொண்டு வருகின்(«)ற(£ம்)"}, {"w": 2, "t": "பாவிகளை, குற்றவாளிகளை"}, {"w": 3, "t": "நரகத்தின் பக்கம்"}, {"w": 4, "t": "Hell"}, {"w": 5, "t": "தாகித்தவர்களாக"}, {"w": 6, "t": "(86)"}]}, {"ayah": 87, "words": [{"w": 1, "t": "அவர்கள் உரிமை பெறமாட்டார்கள்"}, {"w": 2, "t": "they will have the power"}, {"w": 3, "t": "சிபாரிசுக்கு"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "ஏற்படுத்தியவரை"}, {"w": 6, "t": "has taken"}, {"w": 7, "t": "ரஹ்மானிடம்"}, {"w": 8, "t": "the Most Gracious"}, {"w": 9, "t": "ஓர் ஒப்பந்தத்தை"}, {"w": 10, "t": "(87)"}]}, {"ayah": 88, "words": [{"w": 1, "t": "இன்னும் கூறுகிறார்கள்"}, {"w": 2, "t": "எடுத்துக் கொண்டான்"}, {"w": 3, "t": "பேரருளாளன்"}, {"w": 4, "t": "குழந்தையை"}, {"w": 5, "t": "(88)"}]}, {"ayah": 89, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "சொல்லி விட்டீர்கள்"}, {"w": 3, "t": "ஒரு காரியத்தை"}, {"w": 4, "t": "பெரிய"}, {"w": 5, "t": "(89)"}]}, {"ayah": 90, "words": [{"w": 1, "t": "நெருங்கி விட்டன"}, {"w": 2, "t": "வானங்கள்"}, {"w": 3, "t": "துண்டு துண்டாகி விடுவதற்கு"}, {"w": 4, "t": "therefrom"}, {"w": 5, "t": "இன்னும் பிளந்து விடுவதற்கு"}, {"w": 6, "t": "பூமி"}, {"w": 7, "t": "இன்னும் விழுந்து விடுவதற்கு"}, {"w": 8, "t": "மலைகள்"}, {"w": 9, "t": "விழுவது"}, {"w": 10, "t": "(90)"}]}, {"ayah": 91, "words": [{"w": 1, "t": "அவர்கள் ஏற்படுத்தியதால்"}, {"w": 2, "t": "they invoke"}, {"w": 3, "t": "ரஹ்மானுக்கு"}, {"w": 4, "t": "குழந்தையை"}, {"w": 5, "t": "(91)"}]}, {"ayah": 92, "words": [{"w": 1, "t": "தகுந்ததல்ல"}, {"w": 2, "t": "is appropriate"}, {"w": 3, "t": "ரஹ்மானுக்கு"}, {"w": 4, "t": "ஏற்படுத்திக்கொள்வது"}, {"w": 5, "t": "He should take"}, {"w": 6, "t": "குழந்தையை"}, {"w": 7, "t": "(92)"}]}, {"ayah": 93, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "ஒவ்வொருவரும்"}, {"w": 3, "t": "வானங்களில் உள்ள"}, {"w": 4, "t": "(are) in"}, {"w": 5, "t": "the heavens"}, {"w": 6, "t": "இன்னும் பூமியில்"}, {"w": 7, "t": "தவிர"}, {"w": 8, "t": "வருவாரே"}, {"w": 9, "t": "பேரருளாளனிடம்"}, {"w": 10, "t": "அடிமையாக"}, {"w": 11, "t": "(93)"}]}, {"ayah": 94, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "அவர்களை கணக்கிட்டு வைத்திருக்கிறான்"}, {"w": 3, "t": "இன்னும் அவர்களை எண்ணி வைத்திருக்கிறான்"}, {"w": 4, "t": "எண்ணுதல்"}, {"w": 5, "t": "(94)"}]}, {"ayah": 95, "words": [{"w": 1, "t": "அவர்கள் ஒவ்வொருவரும்"}, {"w": 2, "t": "அவனிடம் வருவார்"}, {"w": 3, "t": "மறுமை நாளில்"}, {"w": 4, "t": "(of) the Resurrection"}, {"w": 5, "t": "தனியாக"}, {"w": 6, "t": "(95)"}]}, {"ayah": 96, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 3, "t": "believed"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நன்மைகளை"}, {"w": 6, "t": "ஏற்படுத்துவான்"}, {"w": 7, "t": "அவர்களுக்கு"}, {"w": 8, "t": "பேரருளாளன்"}, {"w": 9, "t": "அன்பை"}, {"w": 10, "t": "(96)"}]}, {"ayah": 97, "words": [{"w": 1, "t": "இதை நாம் இலகுவாக்கியதெல்லாம்"}, {"w": 2, "t": "We (have) made it easy"}, {"w": 3, "t": "உமது நாவில்"}, {"w": 4, "t": "நீர் நற்செய்தி கூறுவதற்காகவும்"}, {"w": 5, "t": "இதன் மூலம்"}, {"w": 6, "t": "இறையச்சமுள்ளவர்களுக்கு"}, {"w": 7, "t": "நீர் எச்சரிப்பதற்காகவும்"}, {"w": 8, "t": "இதன் மூலம்"}, {"w": 9, "t": "மக்களை"}, {"w": 10, "t": "தர்க்கிக்கின்ற(வர்கள்)"}, {"w": 11, "t": "(97)"}]}, {"ayah": 98, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "நாம் அழித்தோம்"}, {"w": 3, "t": "இவர்களுக்கு முன்"}, {"w": 4, "t": "தலைமுறையினரை"}, {"w": 5, "t": "a generation"}, {"w": 6, "t": "நீர் பார்க்கிறீரா?"}, {"w": 7, "t": "you perceive"}, {"w": 8, "t": "அவர்களில்"}, {"w": 9, "t": "யாரையும்"}, {"w": 10, "t": "one"}, {"w": 11, "t": "அல்லது"}, {"w": 12, "t": "நீர் கேட்கிறீரா"}, {"w": 13, "t": "அவர்களுடைய"}, {"w": 14, "t": "சப்தத்தை"}, {"w": 15, "t": "(98)"}]}]}