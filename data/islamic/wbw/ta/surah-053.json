{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நட்சத்திரத்தின் மீது சத்தியமாக"}, {"w": 2, "t": "அது விழும்போது"}, {"w": 3, "t": "it goes down"}, {"w": 4, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "வழி தவறவுமில்லை"}, {"w": 2, "t": "has strayed"}, {"w": 3, "t": "உங்கள் தோழர்"}, {"w": 4, "t": "வழி கெடவுமில்லை"}, {"w": 5, "t": "has he erred"}, {"w": 6, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அவர் பேச மாட்டார்"}, {"w": 2, "t": "he speaks"}, {"w": 3, "t": "மன இச்சையால்"}, {"w": 4, "t": "the desire"}, {"w": 5, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இது வேறு இல்லை"}, {"w": 2, "t": "it"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "வஹ்யே"}, {"w": 5, "t": "அறிவிக்கப்படுகின்ற(து)"}, {"w": 6, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இவருக்கு இதை கற்பித்தார்"}, {"w": 2, "t": "வலிமைமிக்கவர்"}, {"w": 3, "t": "ஆற்றலால்"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "அழகிய தோற்றமுடையவர்"}, {"w": 2, "t": "Possessor of soundness"}, {"w": 3, "t": "நேர் சமமானார்(கள்)"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவரும்"}, {"w": 2, "t": "வான உச்சியில்"}, {"w": 3, "t": "மிக உயர்ந்த"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "பிறகு/நெருக்கமானார்"}, {"w": 2, "t": "he approached"}, {"w": 3, "t": "இன்னும் மிக அதிகமாக நெருங்கினார்"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "ஆகிவிட்டார்"}, {"w": 2, "t": "மிக நெருக்கமாக"}, {"w": 3, "t": "இரண்டு வில்லின் அளவுக்கு"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "அதைவிட"}, {"w": 6, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "வஹீ  அறிவித்தார்"}, {"w": 2, "t": "அவனுடைய அடிமைக்கு"}, {"w": 3, "t": "His slave"}, {"w": 4, "t": "எதை வஹீ  அறிவித்தானோ"}, {"w": 5, "t": "he revealed"}, {"w": 6, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "பொய்ப்பிக்கவில்லை"}, {"w": 2, "t": "lied"}, {"w": 3, "t": "உள்ளம்"}, {"w": 4, "t": "எதை பார்த்தாரோ"}, {"w": 5, "t": "it saw"}, {"w": 6, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவரிடம் நீங்கள் தர்க்கம் செய்கின்றீர்களா?"}, {"w": 2, "t": "அவர் பார்த்ததில்"}, {"w": 3, "t": "what"}, {"w": 4, "t": "he saw"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அவர் அவரைப் பார்த்தார்"}, {"w": 3, "t": "மற்றொரு முறை"}, {"w": 4, "t": "another"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "சித்ரத்துல் முன்தஹா என்ற இடத்தில்"}, {"w": 2, "t": "(the) Lote Tree"}, {"w": 3, "t": "(of) the utmost boundary"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அங்குதான் இருக்கின்றது"}, {"w": 2, "t": "சொர்க்கம்/அல்மஃவா"}, {"w": 3, "t": "(of) Abode"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "சூழ்ந்து கொள்ளும்போது"}, {"w": 2, "t": "covered"}, {"w": 3, "t": "அந்த சித்ராவை"}, {"w": 4, "t": "எது சூழ்ந்து கொள்ளுமோ அது"}, {"w": 5, "t": "covers"}, {"w": 6, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "சாயவில்லை"}, {"w": 2, "t": "swerved"}, {"w": 3, "t": "பார்வை"}, {"w": 4, "t": "மீறவுமில்லை"}, {"w": 5, "t": "it transgressed"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "திட்டவட்டமாக பார்த்தார்"}, {"w": 2, "t": "he saw"}, {"w": 3, "t": "அத்தாட்சிகளில்"}, {"w": 4, "t": "(the) Signs"}, {"w": 5, "t": "தனது இறைவனின்"}, {"w": 6, "t": "பெரிய"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நீங்கள் அறிவியுங்கள்!"}, {"w": 2, "t": "லாத்"}, {"w": 3, "t": "இன்னும் உஸ்ஸா"}, {"w": 4, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இன்னும் மனாத்தைப் பற்றி"}, {"w": 2, "t": "மூன்றாவது"}, {"w": 3, "t": "மற்றொரு"}, {"w": 4, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "உங்களுக்கு?"}, {"w": 2, "t": "ஆண் பிள்ளையும்"}, {"w": 3, "t": "அவனுக்கு"}, {"w": 4, "t": "பெண் பிள்ளையுமா?"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "அப்படியென்றால்/ஒரு பங்கீடாகும்"}, {"w": 3, "t": "(is) a division"}, {"w": 4, "t": "அநியாயமான"}, {"w": 5, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "இவை வேறில்லை"}, {"w": 2, "t": "they"}, {"w": 3, "t": "பெயர்களே தவிர"}, {"w": 4, "t": "names"}, {"w": 5, "t": "இவற்றுக்கு பெயர் வைத்தீர்கள்"}, {"w": 6, "t": "நீங்களும்"}, {"w": 7, "t": "உங்கள் மூதாதைகளும்"}, {"w": 8, "t": "இறக்கவில்லை"}, {"w": 9, "t": "has Allah sent down"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "இவற்றுக்கு"}, {"w": 12, "t": "எவ்வித ஆதாரத்தையும்"}, {"w": 13, "t": "authority"}, {"w": 14, "t": "நீங்கள் பின்பற்றுவதில்லை"}, {"w": 15, "t": "they follow"}, {"w": 16, "t": "தவிர"}, {"w": 17, "t": "வீண்எண்ணத்தையும்"}, {"w": 18, "t": "விரும்புகின்றதையும்"}, {"w": 19, "t": "desire"}, {"w": 20, "t": "மனங்கள்"}, {"w": 21, "t": "திட்டவட்டமாக"}, {"w": 22, "t": "வந்துள்ளது"}, {"w": 23, "t": "அவர்களின் இறைவனிடமிருந்து"}, {"w": 24, "t": "their Lord"}, {"w": 25, "t": "நேர்வழி"}, {"w": 26, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "மனிதனுக்கு கிடைத்துவிடுமா?"}, {"w": 2, "t": "(is) for man"}, {"w": 3, "t": "அவன் விரும்பியது"}, {"w": 4, "t": "he wishes"}, {"w": 5, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அல்லாஹ்விற்கே உரியது"}, {"w": 2, "t": "மறுமையும்"}, {"w": 3, "t": "இந்த உலகமும்"}, {"w": 4, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "வானவர்கள்"}, {"w": 3, "t": "(the) Angels"}, {"w": 4, "t": "வானங்களில் உள்ள"}, {"w": 5, "t": "the heavens"}, {"w": 6, "t": "தடுக்காது"}, {"w": 7, "t": "will avail"}, {"w": 8, "t": "அவர்களின் சிபாரிசு"}, {"w": 9, "t": "எதையும்"}, {"w": 10, "t": "தவிர/பின்னரே"}, {"w": 11, "t": "after"}, {"w": 12, "t": "after"}, {"w": 13, "t": "அனுமதிக்கு"}, {"w": 14, "t": "Allah has given permission"}, {"w": 15, "t": "அல்லாஹ்வின்"}, {"w": 16, "t": "அவன் நாடுகின்றவருக்கு"}, {"w": 17, "t": "He wills"}, {"w": 18, "t": "இன்னும் அவன் விரும்புகின்ற(வருக்கு)"}, {"w": 19, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம்பிக்கை கொள்ளாதவர்கள்"}, {"w": 3, "t": "(do) not"}, {"w": 4, "t": "believe"}, {"w": 5, "t": "மறுமையை"}, {"w": 6, "t": "பெயர் சூட்டுகின்றார்கள்"}, {"w": 7, "t": "வானவர்களுக்கு"}, {"w": 8, "t": "பெயர்களை"}, {"w": 9, "t": "பெண்களின்"}, {"w": 10, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "அவர்களுக்கு இல்லை"}, {"w": 2, "t": "for them"}, {"w": 3, "t": "அதைப் பற்றி"}, {"w": 4, "t": "எவ்வித கல்வி அறிவும்"}, {"w": 5, "t": "knowledge"}, {"w": 6, "t": "அவர்கள் பின்பற்றுவதில்லை"}, {"w": 7, "t": "they follow"}, {"w": 8, "t": "தவிர"}, {"w": 9, "t": "வீண் எண்ணத்தை"}, {"w": 10, "t": "நிச்சயமாக"}, {"w": 11, "t": "வீண் எண்ணம்"}, {"w": 12, "t": "பலன் தராது"}, {"w": 13, "t": "avail"}, {"w": 14, "t": "உண்மைக்கு பதிலாக"}, {"w": 15, "t": "the truth"}, {"w": 16, "t": "அறவே"}, {"w": 17, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "ஆகவே, நீர் புறக்கணிப்பீராக!"}, {"w": 2, "t": "விலகியவர்களை"}, {"w": 3, "t": "(him) who"}, {"w": 4, "t": "turns away"}, {"w": 5, "t": "நம் நினைவை விட்டு"}, {"w": 6, "t": "Our Reminder"}, {"w": 7, "t": "அவர்கள் நாடவில்லை"}, {"w": 8, "t": "he desires"}, {"w": 9, "t": "தவிர"}, {"w": 10, "t": "உலக வாழ்க்கையை"}, {"w": 11, "t": "(of) the world"}, {"w": 12, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "அதுதான்"}, {"w": 2, "t": "அவர்களது முதிர்ச்சியாகும்"}, {"w": 3, "t": "கல்வியின்"}, {"w": 4, "t": "knowledge"}, {"w": 5, "t": "நிச்சயமாக"}, {"w": 6, "t": "உமது இறைவன்தான்"}, {"w": 7, "t": "(is) He (Who)"}, {"w": 8, "t": "மிக அறிந்தவன்"}, {"w": 9, "t": "வழிதவறியவர்களை"}, {"w": 10, "t": "strays"}, {"w": 11, "t": "தனது பாதையை விட்டு"}, {"w": 12, "t": "His Path"}, {"w": 13, "t": "இன்னும் அவன்"}, {"w": 14, "t": "மிக அறிந்தவன்"}, {"w": 15, "t": "நேர்வழி பெற்றவர்களையும்"}, {"w": 16, "t": "is guided"}, {"w": 17, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "அல்லாஹ்விற்கே உரியன"}, {"w": 2, "t": "வானங்களில் உள்ளவை(யும்)"}, {"w": 3, "t": "(is) in"}, {"w": 4, "t": "the heavens"}, {"w": 5, "t": "பூமியில்உள்ளவையும்"}, {"w": 6, "t": "(is) in"}, {"w": 7, "t": "the earth"}, {"w": 8, "t": "இறுதியில் அவன் கூலி கொடுப்பான்"}, {"w": 9, "t": "தீமை செய்தவர்களுக்கு"}, {"w": 10, "t": "do evil"}, {"w": 11, "t": "அவர்கள் செய்தவற்றுக்கு"}, {"w": 12, "t": "they have done"}, {"w": 13, "t": "கூலி கொடுப்பான்"}, {"w": 14, "t": "நன்மை செய்தவர்களுக்கு"}, {"w": 15, "t": "do good"}, {"w": 16, "t": "சொர்க்கத்தை"}, {"w": 17, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அவர்கள்"}, {"w": 2, "t": "விலகி இருப்பார்கள்"}, {"w": 3, "t": "பெரும் பாவங்களை விட்டும்"}, {"w": 4, "t": "sins"}, {"w": 5, "t": "இன்னும் மானக்கேடான செயல்களை விட்டும்"}, {"w": 6, "t": "தவிர/சிறு தவறுகளை"}, {"w": 7, "t": "the small faults"}, {"w": 8, "t": "நிச்சயமாக"}, {"w": 9, "t": "உமது இறைவன்"}, {"w": 10, "t": "விசாலமான மன்னிப்புடையவன்"}, {"w": 11, "t": "(in) forgiveness"}, {"w": 12, "t": "அவன்"}, {"w": 13, "t": "மிக அறிந்தவனாக"}, {"w": 14, "t": "உங்களை"}, {"w": 15, "t": "உங்களை உருவாக்கிய போதும்"}, {"w": 16, "t": "He produced you"}, {"w": 17, "t": "பூமியில் இருந்து"}, {"w": 18, "t": "the earth"}, {"w": 19, "t": "நீங்கள் இருந்த போதும்"}, {"w": 20, "t": "you (were)"}, {"w": 21, "t": "சிசுக்களாக"}, {"w": 22, "t": "வயிறுகளில்"}, {"w": 23, "t": "(the) wombs"}, {"w": 24, "t": "உங்கள் தாய்மார்களின்"}, {"w": 25, "t": "ஆகவே, பீத்திக் கொள்ளாதீர்கள்"}, {"w": 26, "t": "ascribe purity"}, {"w": 27, "t": "உங்களை நீங்களே"}, {"w": 28, "t": "அவன்"}, {"w": 29, "t": "மிக அறிந்தவன்"}, {"w": 30, "t": "அல்லாஹ்வை அஞ்சியவர்களை"}, {"w": 31, "t": "fears"}, {"w": 32, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "நீர் அறிவிப்பீராக!"}, {"w": 2, "t": "ஒருவன்"}, {"w": 3, "t": "புறக்கணித்தான்"}, {"w": 4, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இன்னும் கொடுத்தான்"}, {"w": 2, "t": "கொஞ்சம்"}, {"w": 3, "t": "பிறகு நிறுத்திக் கொண்டான்"}, {"w": 4, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "அவனிடம் இருக்கிறதா?"}, {"w": 2, "t": "அறிவு"}, {"w": 3, "t": "மறைவானவற்றின்"}, {"w": 4, "t": "அவன்"}, {"w": 5, "t": "பார்க்கின்றானா?"}, {"w": 6, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "அவனுக்கு செய்தி அறிவிக்கப்படவில்லையா?"}, {"w": 2, "t": "not"}, {"w": 3, "t": "he was informed"}, {"w": 4, "t": "ஏடுகளில் உள்ளவற்றைப் பற்றி"}, {"w": 5, "t": "(was) in"}, {"w": 6, "t": "(the) Scriptures"}, {"w": 7, "t": "மூஸாவின்"}, {"w": 8, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இன்னும் இப்ராஹீமுடைய"}, {"w": 2, "t": "எவர்/முழுமையாக நிறைவேற்றினார்"}, {"w": 3, "t": "fulfilled"}, {"w": 4, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "சுமக்காது"}, {"w": 2, "t": "will bear"}, {"w": 3, "t": "பாவம்செய்த ஆன்மா"}, {"w": 4, "t": "பாவத்தை"}, {"w": 5, "t": "இன்னொரு பாவியான ஆன்மாவின்"}, {"w": 6, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "இன்னும் வேறு ஏதுமில்லை"}, {"w": 2, "t": "is not"}, {"w": 3, "t": "மனிதனுக்கு/தவிர"}, {"w": 4, "t": "except"}, {"w": 5, "t": "அவன் எதை அடைய முயற்சித்தானோ"}, {"w": 6, "t": "he strives (for)"}, {"w": 7, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "இன்னும் , நிச்சயமாக"}, {"w": 2, "t": "தனது முயற்சியை"}, {"w": 3, "t": "விரைவில் காண்பான்"}, {"w": 4, "t": "be seen"}, {"w": 5, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "பிறகு/அதற்கு அவன் கூலி கொடுக்கப்படுவான்"}, {"w": 2, "t": "he will be recompensed for it"}, {"w": 3, "t": "கூலியை"}, {"w": 4, "t": "மிக பூரணமான"}, {"w": 5, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "இன்னும் , நிச்சயமாக"}, {"w": 2, "t": "உமது இறைவன் பக்கம்தான்"}, {"w": 3, "t": "your Lord"}, {"w": 4, "t": "இறுதி ஒதுங்குமிடம் இருக்கிறது"}, {"w": 5, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "இன்னும் , நிச்சயமாக அவன்தான்"}, {"w": 2, "t": "[He]"}, {"w": 3, "t": "சிரிக்க வைக்கின்றான்"}, {"w": 4, "t": "இன்னும் அழ வைக்கின்றான்"}, {"w": 5, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக அவன்தான்"}, {"w": 2, "t": "[He]"}, {"w": 3, "t": "மரணிக்க வைக்கின்றான்"}, {"w": 4, "t": "இன்னும் உயிர் கொடுக்கின்றான்"}, {"w": 5, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக அவன்தான்"}, {"w": 2, "t": "படைத்தான்"}, {"w": 3, "t": "இரு ஜோடிகளை"}, {"w": 4, "t": "ஆணை(யும்)"}, {"w": 5, "t": "பெண்ணையும்"}, {"w": 6, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "இந்திரியத்தில் இருந்து"}, {"w": 2, "t": "a semen-drop"}, {"w": 3, "t": "செலுத்தப்படுகின்ற"}, {"w": 4, "t": "it is emitted"}, {"w": 5, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக"}, {"w": 2, "t": "அவன்மீதே கடமையாகஇருக்கிறது"}, {"w": 3, "t": "உருவாக்குவதும்"}, {"w": 4, "t": "மற்றொரு முறை"}, {"w": 5, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக அவன்தான்"}, {"w": 2, "t": "[He]"}, {"w": 3, "t": "செல்வந்தராக ஆக்கினான்"}, {"w": 4, "t": "இன்னும் சேமிப்பைக் கொடுத்தான்"}, {"w": 5, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக அவன்தான்"}, {"w": 2, "t": "[He]"}, {"w": 3, "t": "இறைவன்"}, {"w": 4, "t": "ஷிஃரா நட்சத்திரத்தின்"}, {"w": 5, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாகஅவன்"}, {"w": 2, "t": "அழித்தான்"}, {"w": 3, "t": "ஆது சமுதாயத்தை"}, {"w": 4, "t": "முந்திய"}, {"w": 5, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "இன்னும் ஸமூது சமுதாயத்தை"}, {"w": 2, "t": "ஆக, அவன் விட்டு வைக்கவில்லை"}, {"w": 3, "t": "He spared"}, {"w": 4, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "இன்னும் மக்களையும்"}, {"w": 2, "t": "நூஹூடைய"}, {"w": 3, "t": "இதற்கு முன்னர்"}, {"w": 4, "t": "before"}, {"w": 5, "t": "நிச்சயமாக இவர்கள்"}, {"w": 6, "t": "இவர்கள் இருந்தனர்"}, {"w": 7, "t": "they were"}, {"w": 8, "t": "மிகப் பெரிய அநியாயக்காரர்களாக"}, {"w": 9, "t": "இன்னும் மிகப் பெரிய வரம்பு மீறிகளாக"}, {"w": 10, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "இன்னும் தலைகீழாக புரட்டப்பட்ட சமுதாயத்தை"}, {"w": 2, "t": "அவன்தான் கவிழ்த்தான்"}, {"w": 3, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "அதனால் அவன் அவர்களை மூடினான்"}, {"w": 2, "t": "எதைக் கொண்டு மூடவேண்டுமோ"}, {"w": 3, "t": "covered"}, {"w": 4, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "அத்தாட்சிகளில் எதில்"}, {"w": 2, "t": "the Favors"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "தர்க்கம்செய்கின்றாய்?"}, {"w": 5, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "இவர்"}, {"w": 2, "t": "ஓர்எச்சரிப்பாளர்தான்"}, {"w": 3, "t": "எச்சரிப்பாளர்களில் இருந்து"}, {"w": 4, "t": "the warners"}, {"w": 5, "t": "முந்தியவர்கள்"}, {"w": 6, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "நெருங்கிவிட்டது"}, {"w": 2, "t": "நெருங்கக்கூடியது"}, {"w": 3, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "(யாரும்) அதற்கு இல்லை"}, {"w": 2, "t": "for it"}, {"w": 3, "t": "அன்றி"}, {"w": 4, "t": "besides"}, {"w": 5, "t": "அல்லாஹ்வை"}, {"w": 6, "t": "வெளிப்படுத்துபவர்"}, {"w": 7, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "?/இந்த குர்ஆனினால்"}, {"w": 2, "t": "this"}, {"w": 3, "t": "statement"}, {"w": 4, "t": "நீங்கள் ஆச்சரியப்படுகின்றீர்களா"}, {"w": 5, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "இன்னும் சிரிக்கின்றீர்களா?"}, {"w": 2, "t": "நீங்கள் அழாமல்"}, {"w": 3, "t": "weep"}, {"w": 4, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "நீங்களோ இருக்கின்றீர்கள்"}, {"w": 2, "t": "அலட்சியக்காரர்களாக"}, {"w": 3, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "சிரம் பணியுங்கள்!"}, {"w": 2, "t": "அல்லாஹ்விற்கே"}, {"w": 3, "t": "இன்னும் வணங்குங்கள்!"}, {"w": 4, "t": "(62)"}]}]}