{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "போர்வை போர்த்தியவரே!"}, {"w": 2, "t": "who wraps himself"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இரவில் எழுவீராக!"}, {"w": 2, "t": "(in) the night"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "குறைந்த நேரத்தை"}, {"w": 5, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அதன் பாதியில்"}, {"w": 2, "t": "அல்லது குறைப்பீராக!"}, {"w": 3, "t": "lessen"}, {"w": 4, "t": "அதில்"}, {"w": 5, "t": "கொஞ்சம்"}, {"w": 6, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "அதிகப்படுத்துவீராக!"}, {"w": 3, "t": "அதற்கு மேல்"}, {"w": 4, "t": "இன்னும் நிறுத்தி நிதானமாக ஓதுவீராக!/குர்ஆனை"}, {"w": 5, "t": "the Quran"}, {"w": 6, "t": "நிறுத்தி நிதானமாக ஓதுதல்"}, {"w": 7, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இறக்குவோம்"}, {"w": 3, "t": "உம்மீது"}, {"w": 4, "t": "வேதத்தை"}, {"w": 5, "t": "மிக கனமான"}, {"w": 6, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "வணக்கம்"}, {"w": 3, "t": "இரவு"}, {"w": 4, "t": "அதுதான்"}, {"w": 5, "t": "மிகவும் வலுவான"}, {"w": 6, "t": "தாக்கமுடையது(ம்)"}, {"w": 7, "t": "மிகத் தெளிவானதும்"}, {"w": 8, "t": "அறிவுரையால்"}, {"w": 9, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உமக்கு"}, {"w": 3, "t": "பகலில்"}, {"w": 4, "t": "the day"}, {"w": 5, "t": "நீண்ட ஓய்வு"}, {"w": 6, "t": "prolonged"}, {"w": 7, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் நினைவு கூறுவீராக"}, {"w": 2, "t": "பெயரை"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "இன்னும் ஒதுங்கிவிடுவீராக!"}, {"w": 5, "t": "அவன் பக்கம்"}, {"w": 6, "t": "முற்றிலும் ஒதுங்குதல்"}, {"w": 7, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இறைவன்/கிழக்கு"}, {"w": 2, "t": "(of) the east"}, {"w": 3, "t": "இன்னும் மேற்கின்"}, {"w": 4, "t": "அறவே இல்லை"}, {"w": 5, "t": "வணக்கத்திற்குரியவன்"}, {"w": 6, "t": "அவனைத் தவிர"}, {"w": 7, "t": "Him"}, {"w": 8, "t": "ஆகவே அவனையே ஆக்கிக் கொள்வீராக!"}, {"w": 9, "t": "பொறுப்பாளனாக"}, {"w": 10, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் சகிப்பீராக!"}, {"w": 2, "t": "அவர்கள் பேசுவதை"}, {"w": 3, "t": "what"}, {"w": 4, "t": "they say"}, {"w": 5, "t": "இன்னும் விட்டு விடுவீராக! அவர்களை"}, {"w": 6, "t": "விட்டு விடுதல்"}, {"w": 7, "t": "அழகிய விதத்தில்"}, {"w": 8, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "என்னையும் விட்டு விடுவீராக!"}, {"w": 2, "t": "பொய்ப்பித்தவர்களையும்"}, {"w": 3, "t": "சுகவாசிகளான"}, {"w": 4, "t": "(of) the ease"}, {"w": 5, "t": "இன்னும் அவர்களுக்கு அவகாசம் தருவீராக !"}, {"w": 6, "t": "கொஞ்சம்"}, {"w": 7, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம்மிடம்"}, {"w": 3, "t": "கை, கால் விலங்குகளும்"}, {"w": 4, "t": "சுட்டெரிக்கும்நரகமும்"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "உணவும்/தொண்டையில் சிக்கிக் கொள்ளும்"}, {"w": 2, "t": "that"}, {"w": 3, "t": "chokes"}, {"w": 4, "t": "வேதனையும்"}, {"w": 5, "t": "வலி தரக்கூடிய"}, {"w": 6, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "குலுங்குகின்ற"}, {"w": 3, "t": "பூமி(யும்)"}, {"w": 4, "t": "மலைகளும்"}, {"w": 5, "t": "ஆகிவிடும்"}, {"w": 6, "t": "மலைகள்"}, {"w": 7, "t": "மணலாக"}, {"w": 8, "t": "தூவப்படுகின்ற"}, {"w": 9, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அனுப்பினோம்"}, {"w": 3, "t": "உங்களிடம்"}, {"w": 4, "t": "ஒரு தூதரை"}, {"w": 5, "t": "சாட்சி கூறுகின்ற"}, {"w": 6, "t": "உங்களைப் பற்றி"}, {"w": 7, "t": "நாம் அனுப்பியது போன்று"}, {"w": 8, "t": "We sent"}, {"w": 9, "t": "ஃபிர்அவ்னுக்கு"}, {"w": 10, "t": "Firaun"}, {"w": 11, "t": "ஒரு தூதரை"}, {"w": 12, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "மாறுசெய்தான்"}, {"w": 2, "t": "ஃபிர்அவ்ன்"}, {"w": 3, "t": "அந்த தூதருக்கு"}, {"w": 4, "t": "ஆகவே, நாம் அவனை பிடித்தோம்"}, {"w": 5, "t": "பிடியால்"}, {"w": 6, "t": "தாங்கிக் கொள்ள முடியாத"}, {"w": 7, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "எப்படி?"}, {"w": 2, "t": "பயப்படுவீர்கள்"}, {"w": 3, "t": "நீங்கள் நிராகரித்தால்"}, {"w": 4, "t": "you disbelieve"}, {"w": 5, "t": "ஒரு நாளை"}, {"w": 6, "t": "ஆக்கிவிடுகின்ற"}, {"w": 7, "t": "பிள்ளைகளை"}, {"w": 8, "t": "வயோதிகர்களாக"}, {"w": 9, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "வானம்"}, {"w": 2, "t": "வெடித்து பிளந்து விடும்"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "ஆகும்"}, {"w": 5, "t": "அவனுடைய வாக்கு"}, {"w": 6, "t": "நிறைவேறியே"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இது"}, {"w": 3, "t": "ஓர் அறிவுரையாகும்"}, {"w": 4, "t": "ஆகவே, யார்"}, {"w": 5, "t": "நாடுகின்றாரோ"}, {"w": 6, "t": "ஏற்படுத்திக் கொள்ளட்டும்"}, {"w": 7, "t": "தன் இறைவன் பக்கம்"}, {"w": 8, "t": "his Lord"}, {"w": 9, "t": "ஒரு பாதையை"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உமது இறைவன்"}, {"w": 3, "t": "அறிவான்"}, {"w": 4, "t": "நிச்சயமாக நீர்"}, {"w": 5, "t": "நின்று வணங்குகிறீர்"}, {"w": 6, "t": "குறைவாக"}, {"w": 7, "t": "மூன்றில் இரண்டு பகுதிகளைவிட"}, {"w": 8, "t": "two-thirds"}, {"w": 9, "t": "இரவின்"}, {"w": 10, "t": "இன்னும் அதன் பாதி"}, {"w": 11, "t": "இன்னும் அதன் மூன்றில் ஒரு பகுதி"}, {"w": 12, "t": "ஒரு கூட்டமும்"}, {"w": 13, "t": "உம்முடன் இருப்பவர்களில்"}, {"w": 14, "t": "those who"}, {"w": 15, "t": "(are) with you"}, {"w": 16, "t": "அல்லாஹ்தான்"}, {"w": 17, "t": "நிர்ணயிக்கின்றான்"}, {"w": 18, "t": "இரவை(யும்)"}, {"w": 19, "t": "பகலையும்"}, {"w": 20, "t": "நன்கறிவான்"}, {"w": 21, "t": "அதற்கு சக்திபெறவே மாட்டீர்கள்"}, {"w": 22, "t": "not"}, {"w": 23, "t": "you count it"}, {"w": 24, "t": "ஆகவே மன்னித்தான்"}, {"w": 25, "t": "உங்களை"}, {"w": 26, "t": "ஓதுங்கள்!"}, {"w": 27, "t": "இலகுவானதை"}, {"w": 28, "t": "is easy"}, {"w": 29, "t": "குர்ஆனில்"}, {"w": 30, "t": "the Quran"}, {"w": 31, "t": "அறிவான்"}, {"w": 32, "t": "இருப்பார்(கள்)"}, {"w": 33, "t": "there will be"}, {"w": 34, "t": "உங்களில்"}, {"w": 35, "t": "நோயாளிகள்"}, {"w": 36, "t": "இன்னும் மற்றும் சிலர்"}, {"w": 37, "t": "பயணம் செய்வார்கள்"}, {"w": 38, "t": "பூமியில்"}, {"w": 39, "t": "the land"}, {"w": 40, "t": "தேடியவர்களாக"}, {"w": 41, "t": "அருளை"}, {"w": 42, "t": "(the) Bounty"}, {"w": 43, "t": "அல்லாஹ்வின்"}, {"w": 44, "t": "இன்னும் மற்றும் சிலர்"}, {"w": 45, "t": "போரிடுவார்கள்"}, {"w": 46, "t": "பாதையில்"}, {"w": 47, "t": "(the) way"}, {"w": 48, "t": "அல்லாஹ்வின்"}, {"w": 49, "t": "ஆகவே, ஓதுங்கள்!"}, {"w": 50, "t": "இலகுவானதை"}, {"w": 51, "t": "is easy"}, {"w": 52, "t": "அதிலிருந்து"}, {"w": 53, "t": "இன்னும் நிலை நிறுத்துங்கள்!"}, {"w": 54, "t": "தொழுகையை"}, {"w": 55, "t": "இன்னும் கொடுங்கள்"}, {"w": 56, "t": "ஸகாத்தை"}, {"w": 57, "t": "இன்னும் கடன் கொடுங்கள்!"}, {"w": 58, "t": "அல்லாஹ்விற்கு"}, {"w": 59, "t": "கடனாக"}, {"w": 60, "t": "அழகிய"}, {"w": 61, "t": "நீங்கள் எதை முற்படுத்துகிறீர்களோ"}, {"w": 62, "t": "you send forth"}, {"w": 63, "t": "உங்களுக்காக"}, {"w": 64, "t": "நன்மையில்"}, {"w": 65, "t": "good"}, {"w": 66, "t": "அதை பெறுவீர்கள்"}, {"w": 67, "t": "அல்லாஹ்விடம்"}, {"w": 68, "t": "Allah"}, {"w": 69, "t": "அது"}, {"w": 70, "t": "மிகச் சிறப்பாகவும்"}, {"w": 71, "t": "மிகப் பெரியதாகவும்"}, {"w": 72, "t": "கூலியால்"}, {"w": 73, "t": "இன்னும் பாவமன்னிப்புத் தேடுங்கள்"}, {"w": 74, "t": "அல்லாஹ்விடம்"}, {"w": 75, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 76, "t": "Allah"}, {"w": 77, "t": "மகா மன்னிப்பாளன்"}, {"w": 78, "t": "மகா கருணையாளன்"}, {"w": 79, "t": "(20)"}]}]}