{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "சூரியனின் மீது சத்தியமாக"}, {"w": 2, "t": "அதன் பகலின் மீது சத்தியமாக"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "சந்திரன் மீது சத்தியமாக"}, {"w": 2, "t": "அதைத் தொடரும்போது"}, {"w": 3, "t": "it follows it"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "பகலின் மீது சத்தியமாக"}, {"w": 2, "t": "அதை வெளிப்படுத்தும்போது"}, {"w": 3, "t": "it displays it"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இரவின் மீது சத்தியமாக"}, {"w": 2, "t": "அது அதை மூடும்போது"}, {"w": 3, "t": "it covers it"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "வானத்தின் மீது சத்தியமாக"}, {"w": 2, "t": "அதை அமைத்தவன் மீது சத்தியமாக"}, {"w": 3, "t": "constructed it"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "பூமியின் மீது சத்தியமாக"}, {"w": 2, "t": "அதை விரித்தவன் மீது சத்தியமாக"}, {"w": 3, "t": "spread it"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "ஆன்மாவின் மீது சத்தியமாக"}, {"w": 2, "t": "அதை சீர்படுத்தியவன் மீது சத்தியமாக"}, {"w": 3, "t": "proportioned it"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அதற்கு அறிவித்தவன்"}, {"w": 2, "t": "அதன் தீமையை"}, {"w": 3, "t": "இன்னும் அதன் நன்மையை"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "வெற்றி பெற்றார்"}, {"w": 3, "t": "எவர்/அதைப் பரிசுத்தமாக்கினார்"}, {"w": 4, "t": "purifies it"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "நஷ்டமடைந்தான்"}, {"w": 3, "t": "எவன்"}, {"w": 4, "t": "அதை மறைத்தான்"}, {"w": 5, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "பொய்பித்தது"}, {"w": 2, "t": "ஸமூது சமுதாயம்"}, {"w": 3, "t": "தன் அழிச்சாட்டியத்தால்"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "புறப்பட்டபோது"}, {"w": 2, "t": "(was) sent forth"}, {"w": 3, "t": "அதன் தீயவன்"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "தூதர்"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "பெண் ஒட்டகத்தை"}, {"w": 6, "t": "அல்லாஹ்வுடைய"}, {"w": 7, "t": "இன்னும் அது நீர் பருகுவதை"}, {"w": 8, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவரைப் பொய்ப்பித்தார்கள்"}, {"w": 2, "t": "அதைக் கொன்றார்கள்"}, {"w": 3, "t": "ஆகவே, கடுமையான வேதனையை இறக்கினான்"}, {"w": 4, "t": "அவர்களின் மீது"}, {"w": 5, "t": "அவர்களுடைய இறைவன்"}, {"w": 6, "t": "அவர்களின் பாவத்தினால்"}, {"w": 7, "t": "அதை சமமாக்கினான்"}, {"w": 8, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "இன்னும் பயப்பட மாட்டான்"}, {"w": 2, "t": "He fears"}, {"w": 3, "t": "அதன் முடிவை"}, {"w": 4, "t": "(15)"}]}]}