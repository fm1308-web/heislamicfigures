{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நெருங்கிவிட்டது"}, {"w": 2, "t": "மறுமை"}, {"w": 3, "t": "இன்னும் பிளந்து விட்டது"}, {"w": 4, "t": "சந்திரன்"}, {"w": 5, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவர்கள் பார்த்தால்"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "ஓர் அத்தாட்சியை"}, {"w": 4, "t": "புறக்கணிக்கின்றனர்"}, {"w": 5, "t": "இன்னும் கூறுகின்றனர்"}, {"w": 6, "t": "சூனியமாகும்"}, {"w": 7, "t": "தொடர்ச்சியான(து)"}, {"w": 8, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் அவர்கள் பொய்ப்பித்தனர்"}, {"w": 2, "t": "இன்னும் பின்பற்றினார்கள்"}, {"w": 3, "t": "தங்கள் மன இச்சைகளை"}, {"w": 4, "t": "எல்லா"}, {"w": 5, "t": "காரியங்களும்"}, {"w": 6, "t": "நிலையாகத் தங்கக் கூடியதுதான்"}, {"w": 7, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "வந்துவிட்டது அவர்களிடம்"}, {"w": 3, "t": "செய்திகளில்"}, {"w": 4, "t": "the information"}, {"w": 5, "t": "எதில் இருக்குமோ"}, {"w": 6, "t": "wherein"}, {"w": 7, "t": "எச்சரிக்கை"}, {"w": 8, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "ஞானம்"}, {"w": 2, "t": "மிக ஆழமான(து)"}, {"w": 3, "t": "ஆனால், பலனளிக்க முடியவில்லை"}, {"w": 4, "t": "will avail"}, {"w": 5, "t": "எச்சரிப்பாளர்கள்"}, {"w": 6, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "ஆகவே, நீர் விலகி விடுவீராக!"}, {"w": 2, "t": "அவர்களை விட்டு"}, {"w": 3, "t": "நாளில்"}, {"w": 4, "t": "அழைக்கின்ற"}, {"w": 5, "t": "அழைப்பாளர்"}, {"w": 6, "t": "ஒன்றை நோக்கி"}, {"w": 7, "t": "a thing"}, {"w": 8, "t": "மிக கடினமான(து)"}, {"w": 9, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இழிவடைந்தநிலையில்"}, {"w": 2, "t": "அவர்களது பார்வைகள்"}, {"w": 3, "t": "அவர்கள் வெளியேறுவார்கள்"}, {"w": 4, "t": "புதைக்குழிகளைவிட்டு"}, {"w": 5, "t": "the graves"}, {"w": 6, "t": "அவர்கள் வெட்டுக் கிளிகளைப் போல"}, {"w": 7, "t": "locusts"}, {"w": 8, "t": "பரவி வரக்கூடிய(து)"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "பணிவுடன் பயத்துடன் விரைந்தவர்களாக வருவார்கள்"}, {"w": 2, "t": "அழைப்பாளரை நோக்கி"}, {"w": 3, "t": "the caller"}, {"w": 4, "t": "கூறுவார்கள்"}, {"w": 5, "t": "நிராகரிப்பாளர்கள்"}, {"w": 6, "t": "இது/ஒரு நாள்"}, {"w": 7, "t": "(is) a Day"}, {"w": 8, "t": "சிரமமான"}, {"w": 9, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "பொய்ப்பித்தனர்"}, {"w": 2, "t": "இவர்களுக்கு முன்னர்"}, {"w": 3, "t": "மக்கள்"}, {"w": 4, "t": "நூஹூடைய"}, {"w": 5, "t": "ஆக, அவர்கள் பொய்ப்பித்தனர்"}, {"w": 6, "t": "நமது அடியாரை"}, {"w": 7, "t": "இன்னும் கூறினர்"}, {"w": 8, "t": "ஒரு பைத்தியக்காரர்"}, {"w": 9, "t": "இன்னும் அவர் எச்சரிக்கப்பட்டார்"}, {"w": 10, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "ஆகவே, அவர் பிரார்த்தித்தார்"}, {"w": 2, "t": "தனது இறைவனிடம்"}, {"w": 3, "t": "நிச்சயமாக நான்"}, {"w": 4, "t": "தோற்கடிக்கப்பட்டேன்"}, {"w": 5, "t": "ஆகவே, நீ பழி தீர்ப்பாயாக!"}, {"w": 6, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஆகவே, நாம் திறந்து விட்டோம்"}, {"w": 2, "t": "வாசல்களை"}, {"w": 3, "t": "மேகத்தின்"}, {"w": 4, "t": "மழையைக் கொண்டு"}, {"w": 5, "t": "அடை"}, {"w": 6, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் பீறிட்டு ஓடச்செய்தோம்"}, {"w": 2, "t": "பூமியை"}, {"w": 3, "t": "ஊற்றுக் கண்களால்"}, {"w": 4, "t": "சந்தித்தன"}, {"w": 5, "t": "தண்ணீர்"}, {"w": 6, "t": "ஒரு காரியத்தின் மீது"}, {"w": 7, "t": "a matter"}, {"w": 8, "t": "திட்டமாகநிர்ணயிக்கப்பட்டது"}, {"w": 9, "t": "predestined"}, {"w": 10, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அவரை பயணிக்க வைத்தோம்"}, {"w": 2, "t": "மீது/உடைய (கப்பல்)"}, {"w": 3, "t": "(ark) made of planks"}, {"w": 4, "t": "பலகைகள்"}, {"w": 5, "t": "இன்னும் ஆணிகள்"}, {"w": 6, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அது செல்கிறது"}, {"w": 2, "t": "நமது கண்களுக்கு முன்பாக"}, {"w": 3, "t": "கூலி கொடுப்பதற்காக"}, {"w": 4, "t": "நிராகரிக்கப்பட்டுக் கொண்டிருந்தவருக்கு"}, {"w": 5, "t": "was"}, {"w": 6, "t": "denied"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அதை விட்டுவைத்தோம்"}, {"w": 3, "t": "ஓர் அத்தாட்சியாக"}, {"w": 4, "t": "நல்லறிவு பெறுபவர் யாரும் இருக்கின்றாரா?"}, {"w": 5, "t": "any"}, {"w": 6, "t": "who will receive admonition"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "எப்படி?"}, {"w": 2, "t": "இருந்தன"}, {"w": 3, "t": "எனது வேதனையும்"}, {"w": 4, "t": "எனது எச்சரிக்கையும்"}, {"w": 5, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் எளிதாக்கினோம்"}, {"w": 3, "t": "இந்த குர்ஆனை"}, {"w": 4, "t": "நல்லறிவு பெறுவதற்காக"}, {"w": 5, "t": "நல்லறிவு பெறுபவர் யாரும் இருக்கின்றாரா?"}, {"w": 6, "t": "any"}, {"w": 7, "t": "who will receive admonition"}, {"w": 8, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "பொய்ப்பித்தது"}, {"w": 2, "t": "ஆது சமுதாயம்"}, {"w": 3, "t": "எப்படி?"}, {"w": 4, "t": "இருந்தன"}, {"w": 5, "t": "எனது வேதனை(யும்)"}, {"w": 6, "t": "எனது எச்சரிக்கையும்"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "காற்றை"}, {"w": 5, "t": "குளிர்ந்த சூறாவளி"}, {"w": 6, "t": "நாளில்"}, {"w": 7, "t": "a day"}, {"w": 8, "t": "ஒரு தீமையுடைய"}, {"w": 9, "t": "நிலையான"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அது கழட்டி எரிந்தது"}, {"w": 2, "t": "மக்களை"}, {"w": 3, "t": "போல்/அவர்கள் ஆகிவிட்டார்கள்"}, {"w": 4, "t": "பின் பகுதிகளை"}, {"w": 5, "t": "பேரீட்ச மரத்தின்"}, {"w": 6, "t": "வேரோடு சாய்ந்த"}, {"w": 7, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "எப்படி?"}, {"w": 2, "t": "இருந்தன"}, {"w": 3, "t": "எனது வேதனை(யும்)"}, {"w": 4, "t": "எனது எச்சரிக்கையும்"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் எளிதாக்கினோம்"}, {"w": 3, "t": "இந்த குர்ஆனை"}, {"w": 4, "t": "நல்லறிவு பெறுவதற்காக"}, {"w": 5, "t": "நல்லறிவு பெறுபவர் யாரும் இருக்கின்றாரா?"}, {"w": 6, "t": "any"}, {"w": 7, "t": "who will receive admonition"}, {"w": 8, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "பொய்ப்பித்தனர்"}, {"w": 2, "t": "ஸமூது சமுதாயம்"}, {"w": 3, "t": "எச்சரிக்கையை"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "கூறினர்"}, {"w": 2, "t": "ஒரு மனிதரையா"}, {"w": 3, "t": "எங்களில் இருந்து"}, {"w": 4, "t": "ஒருவராக"}, {"w": 5, "t": "நாங்கள் அவரைப் பின்பற்றுவோம்!"}, {"w": 6, "t": "நிச்சயமாக நாங்கள்"}, {"w": 7, "t": "அப்படி என்றால்"}, {"w": 8, "t": "வழிகேட்டிலும் ஆகிவிடுவோம்"}, {"w": 9, "t": "error"}, {"w": 10, "t": "சிரமத்திலும்"}, {"w": 11, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "இறக்கப்பட்டதா?"}, {"w": 2, "t": "இறைவேதம்"}, {"w": 3, "t": "அவருக்கு மட்டும்"}, {"w": 4, "t": "எங்களுக்கு மத்தியில்"}, {"w": 5, "t": "among us"}, {"w": 6, "t": "இல்லை"}, {"w": 7, "t": "அவர்"}, {"w": 8, "t": "பெரும் பொய்யர்"}, {"w": 9, "t": "பெருமையுடைய(வர்)"}, {"w": 10, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "விரைவில் அறிவார்கள்"}, {"w": 2, "t": "நாளை"}, {"w": 3, "t": "பெரும் பொய்யர் யார்"}, {"w": 4, "t": "(is) the liar"}, {"w": 5, "t": "பெருமையுடைய(வர்)"}, {"w": 6, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அனுப்புவோம்"}, {"w": 3, "t": "பெண் ஒட்டகத்தை"}, {"w": 4, "t": "சோதனையாக"}, {"w": 5, "t": "அவர்களுக்கு"}, {"w": 6, "t": "அவர்களிடம் நீர் எதிர்பார்த்திருப்பீராக!"}, {"w": 7, "t": "இன்னும் பொறுமை காப்பீராக!"}, {"w": 8, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "அவர்களுக்கு அறிவிப்பீராக"}, {"w": 2, "t": "நிச்சயமாக தண்ணீர்"}, {"w": 3, "t": "the water"}, {"w": 4, "t": "பங்காகும்"}, {"w": 5, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 6, "t": "எல்லா நேரங்களிலும் தண்ணீர் குடிக்கப்படுகின்ற"}, {"w": 7, "t": "drink"}, {"w": 8, "t": "ஆஜராக வேண்டும்"}, {"w": 9, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அவர்கள் அழைத்தனர்"}, {"w": 2, "t": "தங்கள் தோழரை"}, {"w": 3, "t": "அவன் பிடித்தான்"}, {"w": 4, "t": "இன்னும் அறுத்தான்"}, {"w": 5, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "எப்படி?"}, {"w": 2, "t": "இருந்தன"}, {"w": 3, "t": "எனது வேதனையும்"}, {"w": 4, "t": "எனது எச்சரிக்கையும்"}, {"w": 5, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அனுப்பினோம்"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "ஒரு சப்தத்தை"}, {"w": 5, "t": "ஒரே"}, {"w": 6, "t": "அவர்கள் ஆகிவிட்டனர்"}, {"w": 7, "t": "தீணிகளைப் போல்"}, {"w": 8, "t": "தொழுவத்தின்"}, {"w": 9, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் எளிதாக்கினோம்"}, {"w": 3, "t": "இந்த குர்ஆனை"}, {"w": 4, "t": "நல்லறிவு பெறுவதற்காக"}, {"w": 5, "t": "நல்லறிவு பெறுபவர் யாரும் இருக்கின்றாரா?"}, {"w": 6, "t": "any"}, {"w": 7, "t": "who will receive admonition"}, {"w": 8, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "பொய்ப்பித்தனர்"}, {"w": 2, "t": "மக்களும்"}, {"w": 3, "t": "லூத்துடைய"}, {"w": 4, "t": "எச்சரிக்கையை"}, {"w": 5, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "கல் மழையை"}, {"w": 5, "t": "லூத்துடைய குடும்பத்தார்களைத் தவிர"}, {"w": 6, "t": "(the) family"}, {"w": 7, "t": "(of) Lut"}, {"w": 8, "t": "அவர்களைப் பாதுகாத்தோம்"}, {"w": 9, "t": "அதிகாலையில்"}, {"w": 10, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "அருட்கொடையாக"}, {"w": 2, "t": "நம்மிடமிருந்து"}, {"w": 3, "t": "Us"}, {"w": 4, "t": "இவ்வாறுதான்"}, {"w": 5, "t": "நாம் கூலி கொடுப்போம்"}, {"w": 6, "t": "நன்றி செலுத்துபவர்களுக்கு"}, {"w": 7, "t": "(is) grateful"}, {"w": 8, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அவர் அவர்களுக்கு எச்சரித்தார்"}, {"w": 3, "t": "நமது தண்டனையை"}, {"w": 4, "t": "அவர்கள் சந்தேகித்தனர்"}, {"w": 5, "t": "எச்சரிக்கையை"}, {"w": 6, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "திட்டவட்டமாக அவரிடம் அடம்பிடித்தனர்"}, {"w": 2, "t": "they demanded from him"}, {"w": 3, "t": "அவரது விருந்தினர்களை வேண்டி"}, {"w": 4, "t": "his guests"}, {"w": 5, "t": "சமமாக்கி விட்டோம்"}, {"w": 6, "t": "அவர்களின் கண்களை"}, {"w": 7, "t": "ஆகவே சுவையுங்கள்"}, {"w": 8, "t": "என் தண்டனையையும்"}, {"w": 9, "t": "என் எச்சரிக்கையையும்"}, {"w": 10, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "திட்டமாக காலையில் அவர்களை வந்தடைந்தது"}, {"w": 2, "t": "seized them in the morning"}, {"w": 3, "t": "அதிகாலை சூரியன் விடிவதற்கு முன்"}, {"w": 4, "t": "வேதனை"}, {"w": 5, "t": "நிலைத்திருக்கக்கூடிய"}, {"w": 6, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "ஆகவே சுவையுங்கள்"}, {"w": 2, "t": "என் வேதனையையும்"}, {"w": 3, "t": "என் எச்சரிக்கையையும்"}, {"w": 4, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் எளிதாக்கினோம்"}, {"w": 3, "t": "இந்த குர்ஆனை"}, {"w": 4, "t": "நல்லறிவு பெறுவதற்காக"}, {"w": 5, "t": "நல்லறிவு பெறுபவர் யாரும் இருக்கின்றாரா?"}, {"w": 6, "t": "any"}, {"w": 7, "t": "who will receive admonition"}, {"w": 8, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "திட்டவட்டமாக/வந்தன"}, {"w": 2, "t": "came"}, {"w": 3, "t": "ஃபிர்அவ்னை பின்பற்றியவர்களுக்கு"}, {"w": 4, "t": "(of) Firaun"}, {"w": 5, "t": "எச்சரிக்கை"}, {"w": 6, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "அவர்கள் பொய்ப்பித்தனர்"}, {"w": 2, "t": "நமது அத்தாட்சிகளை"}, {"w": 3, "t": "எல்லாம்/ஆகவே அவர்களை தண்டித்தோம்"}, {"w": 4, "t": "so We seized them"}, {"w": 5, "t": "தண்டனையால்"}, {"w": 6, "t": "மிக்க மிகைத்தவன்"}, {"w": 7, "t": "மகா வல்லமை உடையவனின்"}, {"w": 8, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "உங்களுடைய நிராகரிப்பாளர்கள் சிறந்தவர்களா?"}, {"w": 2, "t": "better"}, {"w": 3, "t": "அவர்களை விட"}, {"w": 4, "t": "those"}, {"w": 5, "t": "அவர்கள் உங்களுக்கு இருக்கிறதா?"}, {"w": 6, "t": "for you"}, {"w": 7, "t": "விடுதலை பத்திரம்"}, {"w": 8, "t": "வேதங்களில்"}, {"w": 9, "t": "the Scriptures"}, {"w": 10, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "அல்லது கூறுகிறார்களா?"}, {"w": 2, "t": "(do) they say"}, {"w": 3, "t": "நாங்கள் ஆவோம்"}, {"w": 4, "t": "கூட்டம்"}, {"w": 5, "t": "பழிதீர்த்துக் கொள்கின்ற"}, {"w": 6, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "விரைவில் தோற்கடிக் கப்படுவார்கள்"}, {"w": 2, "t": "இந்த கூட்டங்கள்"}, {"w": 3, "t": "இன்னும் காட்டுவார்கள்"}, {"w": 4, "t": "புறமுதுகு"}, {"w": 5, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "மறுமைதான்"}, {"w": 3, "t": "வாக்களிக்கப்பட்ட நேரமாகும் இவர்களின்"}, {"w": 4, "t": "மறுமை"}, {"w": 5, "t": "மிக பயங்கரமானதும்"}, {"w": 6, "t": "மிக கசப்பானதாகும்"}, {"w": 7, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "குற்றவாளிகள்"}, {"w": 3, "t": "வழிகேட்டிலும்"}, {"w": 4, "t": "an error"}, {"w": 5, "t": "மிகப் பெரிய சிரமத்திலும்"}, {"w": 6, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "இழுக்கப்படுவார்கள்"}, {"w": 3, "t": "நரகத்தில்"}, {"w": 4, "t": "the Fire"}, {"w": 5, "t": "அவர்களின் முகங்கள் மீது"}, {"w": 6, "t": "their faces"}, {"w": 7, "t": "சுவையுங்கள்!"}, {"w": 8, "t": "கடுமையை"}, {"w": 9, "t": "சகர் நரகத்தின்"}, {"w": 10, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "எல்லாவற்றையும்"}, {"w": 3, "t": "thing"}, {"w": 4, "t": "அவற்றைப் படைத்தோம்"}, {"w": 5, "t": "ஓர் அளவில்"}, {"w": 6, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "நமது கட்டளை இல்லை"}, {"w": 2, "t": "(is) Our Command"}, {"w": 3, "t": "ஒன்றைத் தவிர"}, {"w": 4, "t": "one"}, {"w": 5, "t": "சிமிட்டுவதைப் போல்"}, {"w": 6, "t": "கண்"}, {"w": 7, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் அழித்தோம்"}, {"w": 3, "t": "உங்கள் சக கொள்கையுடையவர்களை"}, {"w": 4, "t": "நல்லுபதேசம் பெறுபவர் யாரும் உண்டா?"}, {"w": 5, "t": "any"}, {"w": 6, "t": "who will receive admonition"}, {"w": 7, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "எல்லா விஷயங்கள்"}, {"w": 2, "t": "thing"}, {"w": 3, "t": "செய்தனர்/அவற்றை"}, {"w": 4, "t": "ஏடுகளில் உள்ளன"}, {"w": 5, "t": "the written records"}, {"w": 6, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "எல்லா"}, {"w": 2, "t": "சிறியவையும்"}, {"w": 3, "t": "பெரியவையும்"}, {"w": 4, "t": "எழுதப்பட்டு உள்ளது"}, {"w": 5, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இறையச்சமுடையவர்கள்"}, {"w": 3, "t": "சொர்க்கங்களில்"}, {"w": 4, "t": "gardens"}, {"w": 5, "t": "இன்னும் நதிகளில்"}, {"w": 6, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "சபையில்"}, {"w": 2, "t": "a seat"}, {"w": 3, "t": "உண்மையான பேச்சுகளுடைய"}, {"w": 4, "t": "பேரரசனுக்கு அருகில்"}, {"w": 5, "t": "a King"}, {"w": 6, "t": "மகா வல்லமையுடையவன்"}, {"w": 7, "t": "(55)"}]}]}