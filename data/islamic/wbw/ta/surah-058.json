{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "செவியுற்றான்"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "பேச்சை"}, {"w": 5, "t": "உம்மிடம் விவாதிக்கின்றவளின்"}, {"w": 6, "t": "disputes with you"}, {"w": 7, "t": "தனது கணவரின் விஷயத்தில்"}, {"w": 8, "t": "her husband"}, {"w": 9, "t": "முறையிடுகிறாள்"}, {"w": 10, "t": "அல்லாஹ்விடம்"}, {"w": 11, "t": "Allah"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "செவியுறுகின்றான்"}, {"w": 14, "t": "உரையாடலை உங்கள் இருவரின்"}, {"w": 15, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 16, "t": "Allah"}, {"w": 17, "t": "நன்கு செவியுறுபவன்"}, {"w": 18, "t": "உற்று நோக்குபவன்"}, {"w": 19, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "எவர்கள்/ளிஹார் செய்கின்றார்களோ"}, {"w": 2, "t": "pronounce zihar"}, {"w": 3, "t": "உங்களில்"}, {"w": 4, "t": "தங்கள் பெண்கள் இடம்"}, {"w": 5, "t": "(to) their wives"}, {"w": 6, "t": "அவர்கள் ஆகமுடியாது"}, {"w": 7, "t": "they"}, {"w": 8, "t": "அவர்களின் தாய்மார்களாக"}, {"w": 9, "t": "அவர்களின் தாய்மார்கள் இல்லை"}, {"w": 10, "t": "(are) their mothers"}, {"w": 11, "t": "தவிர/எவர்கள்"}, {"w": 12, "t": "those who"}, {"w": 13, "t": "அவர்களை பெற்றெடுத்தார்கள்"}, {"w": 14, "t": "நிச்சயமாக அவர்கள்"}, {"w": 15, "t": "கூறுகின்றனர்"}, {"w": 16, "t": "மிகத் தீயதை"}, {"w": 17, "t": "பேச்சில்"}, {"w": 18, "t": "[the] word"}, {"w": 19, "t": "இன்னும் பொய்யானதை"}, {"w": 20, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 21, "t": "Allah"}, {"w": 22, "t": "மிகவும் பிழை பொறுப்பவன்"}, {"w": 23, "t": "மகா மன்னிப்பாளன்"}, {"w": 24, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "ளிஹார்செய்கிறார்கள்"}, {"w": 3, "t": "தங்கள் பெண்களிடம்"}, {"w": 4, "t": "(to) their wives"}, {"w": 5, "t": "பிறகு"}, {"w": 6, "t": "மீளுகின்றார்களோ"}, {"w": 7, "t": "தாங்கள் கூறியதற்கு"}, {"w": 8, "t": "they said"}, {"w": 9, "t": "உரிமையிடவேண்டும்"}, {"w": 10, "t": "ஓர் அடிமையை"}, {"w": 11, "t": "முன்னர்"}, {"w": 12, "t": "before"}, {"w": 13, "t": "அவர்கள் இருவரும் இணைவதற்கு"}, {"w": 14, "t": "they touch each other"}, {"w": 15, "t": "இதுதான்"}, {"w": 16, "t": "உபதேசிக் கப்படுகிறீர்கள்"}, {"w": 17, "t": "இதற்கு/அல்லாஹ்"}, {"w": 18, "t": "And Allah"}, {"w": 19, "t": "நீங்கள் செய்பவற்றை"}, {"w": 20, "t": "you do"}, {"w": 21, "t": "ஆழ்ந்தறிபவன்"}, {"w": 22, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "எவர்"}, {"w": 2, "t": "வசதி பெறவில்லையோ"}, {"w": 3, "t": "find"}, {"w": 4, "t": "நோன்பிருக்க வேண்டும்"}, {"w": 5, "t": "இரண்டு மாதங்கள்"}, {"w": 6, "t": "தொடர்ந்து"}, {"w": 7, "t": "முன்னர்"}, {"w": 8, "t": "before"}, {"w": 9, "t": "இருவரும் இணைவதற்கு"}, {"w": 10, "t": "they both touch each other"}, {"w": 11, "t": "எவர்"}, {"w": 12, "t": "சக்தி பெறவில்லையோ"}, {"w": 13, "t": "is able"}, {"w": 14, "t": "உணவளிக்கட்டும்"}, {"w": 15, "t": "அறுபது"}, {"w": 16, "t": "ஏழைகளுக்கு"}, {"w": 17, "t": "இது"}, {"w": 18, "t": "ஏனெனில்/நம்பிக்கை கொள்கின்றீர்கள்"}, {"w": 19, "t": "அல்லாஹ்வையும்"}, {"w": 20, "t": "அவனது தூதரையும்"}, {"w": 21, "t": "இவை"}, {"w": 22, "t": "சட்டங்களாகும்"}, {"w": 23, "t": "அல்லாஹ்வின்"}, {"w": 24, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 25, "t": "தண்டனை"}, {"w": 26, "t": "வலி தரக்கூடிய(து)"}, {"w": 27, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "முரண்படுகிறார்கள்"}, {"w": 4, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 5, "t": "அவனது தூதருக்கும்"}, {"w": 6, "t": "இழிவு படுத்தப்படுவார்கள்"}, {"w": 7, "t": "போன்று"}, {"w": 8, "t": "இழிவுபடுத்தப்பட்டது"}, {"w": 9, "t": "இவர்களுக்கு முன்னுள்ளவர்கள்"}, {"w": 10, "t": "before them"}, {"w": 11, "t": "before them"}, {"w": 12, "t": "திட்டமாக"}, {"w": 13, "t": "நாம் இறக்கினோம்"}, {"w": 14, "t": "அத்தாட்சிகளை"}, {"w": 15, "t": "தெளிவான(வை)"}, {"w": 16, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 17, "t": "இழிவுதரும்தண்டனை"}, {"w": 18, "t": "humiliating"}, {"w": 19, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "எழுப்புவான்/ அவர்களை"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "அனைவரையும்"}, {"w": 5, "t": "அவர்களுக்கு அறிவிப்பான்"}, {"w": 6, "t": "அவர்கள் செய்தவற்றை"}, {"w": 7, "t": "they did"}, {"w": 8, "t": "அவற்றை கணக்கிட்டு வைத்துள்ளான்/அல்லாஹ்"}, {"w": 9, "t": "Allah has recorded it"}, {"w": 10, "t": "அவற்றை மறந்துவிட்டார்கள்"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "எல்லாவற்றையும்"}, {"w": 13, "t": "all"}, {"w": 14, "t": "things"}, {"w": 15, "t": "கண்காணிப்பவன்"}, {"w": 16, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "நன்கறிவான்"}, {"w": 6, "t": "வானங்களில் உள்ளவற்றை(யும்)"}, {"w": 7, "t": "(is) in"}, {"w": 8, "t": "the heavens"}, {"w": 9, "t": "பூமியில் உள்ளவற்றையும்"}, {"w": 10, "t": "(is) in"}, {"w": 11, "t": "the earth"}, {"w": 12, "t": "இருக்காது"}, {"w": 13, "t": "there is"}, {"w": 14, "t": "உரையாடல்"}, {"w": 15, "t": "secret counsel"}, {"w": 16, "t": "மூன்று நபர்களின்"}, {"w": 17, "t": "தவிர/அவன்"}, {"w": 18, "t": "He (is)"}, {"w": 19, "t": "அவர்களில் நான்காமவனாக"}, {"w": 20, "t": "இருக்காது/ஐந்து நபர்களின்"}, {"w": 21, "t": "five"}, {"w": 22, "t": "தவிர/அவன்"}, {"w": 23, "t": "He (is)"}, {"w": 24, "t": "அவர்களில் ஆறாவதாக"}, {"w": 25, "t": "இன்னும் இருக்காது/குறைவாக"}, {"w": 26, "t": "less"}, {"w": 27, "t": "அதை விட"}, {"w": 28, "t": "that"}, {"w": 29, "t": "இன்னும் அதிகமாக இருக்காது"}, {"w": 30, "t": "more"}, {"w": 31, "t": "தவிர/அவன்"}, {"w": 32, "t": "He"}, {"w": 33, "t": "அவர்களுடன்"}, {"w": 34, "t": "அவர்கள் எங்கிருந்தாலும் சரியே"}, {"w": 35, "t": "wherever"}, {"w": 36, "t": "they are"}, {"w": 37, "t": "பிறகு"}, {"w": 38, "t": "அவர்களுக்கு அறிவிப்பான்"}, {"w": 39, "t": "அவர்கள் செய்தவற்றை"}, {"w": 40, "t": "they did"}, {"w": 41, "t": "மறுமை நாளில்"}, {"w": 42, "t": "(of) the Resurrection"}, {"w": 43, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 44, "t": "Allah"}, {"w": 45, "t": "எல்லாவற்றையும்"}, {"w": 46, "t": "thing"}, {"w": 47, "t": "நன்கறிந்தவன்"}, {"w": 48, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "தடுக்கப்பட்டவர்களை"}, {"w": 4, "t": "those who"}, {"w": 5, "t": "were forbidden"}, {"w": 6, "t": "கூடிப் பேசுவதை விட்டும்"}, {"w": 7, "t": "secret counsels"}, {"w": 8, "t": "பிறகு"}, {"w": 9, "t": "திரும்புகிறார்கள்"}, {"w": 10, "t": "எதிலிருந்து தடுக்கப்பட்டார்களோ"}, {"w": 11, "t": "they were forbidden"}, {"w": 12, "t": "அதிலிருந்து"}, {"w": 13, "t": "கூடிப் பேசுகிறார்கள்"}, {"w": 14, "t": "பாவத்தையும்"}, {"w": 15, "t": "வரம்புமீறுவதையும்"}, {"w": 16, "t": "மாறுசெய்வதையும்"}, {"w": 17, "t": "தூதருக்கு/அவர்கள் உம்மிடம் வந்தால்"}, {"w": 18, "t": "And when"}, {"w": 19, "t": "they come to you"}, {"w": 20, "t": "உமக்கு முகமன் கூறுகிறார்கள்"}, {"w": 21, "t": "உமக்கு எதை முகமன் கூறவில்லையோ"}, {"w": 22, "t": "not"}, {"w": 23, "t": "greets you"}, {"w": 24, "t": "அதை"}, {"w": 25, "t": "அல்லாஹ்"}, {"w": 26, "t": "கூறுகிறார்கள்"}, {"w": 27, "t": "தங்கள் மனதிற்குள்"}, {"w": 28, "t": "themselves"}, {"w": 29, "t": "நம்மை வேதனை செய்யாமல் இருக்க வேண்டுமே"}, {"w": 30, "t": "Allah punish us"}, {"w": 31, "t": "அல்லாஹ்/நாம் சொல்வதைக் கொண்டு"}, {"w": 32, "t": "for what"}, {"w": 33, "t": "we say"}, {"w": 34, "t": "அவர்களுக்கு போதும்"}, {"w": 35, "t": "நரகமே"}, {"w": 36, "t": "அதில் அவர்கள் எரிந்து பொசுங்குவார்கள்"}, {"w": 37, "t": "அது மீளுமிடங்களில் மிகக் கெட்டதாகும்"}, {"w": 38, "t": "the destination"}, {"w": 39, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "நீங்கள் கூடிப்பேசினால்"}, {"w": 5, "t": "you hold secret counsel"}, {"w": 6, "t": "கூடிப்பேசாதீர்கள்"}, {"w": 7, "t": "hold secret counsel"}, {"w": 8, "t": "பாவமானதையும்"}, {"w": 9, "t": "வரம்புமீறும் காரியத்தையும்"}, {"w": 10, "t": "மாறுசெய்வதையும்"}, {"w": 11, "t": "தூதருக்கு"}, {"w": 12, "t": "கூடிப்பேசுங்கள்!"}, {"w": 13, "t": "நன்மையான விஷயத்தையும்"}, {"w": 14, "t": "இறையச்சம் மிகுந்த விஷயத்தையும்"}, {"w": 15, "t": "அஞ்சிக் கொள்ளுங்கள்!"}, {"w": 16, "t": "அல்லாஹ்வை"}, {"w": 17, "t": "எவன்/அவனிடம்தான்"}, {"w": 18, "t": "to Him"}, {"w": 19, "t": "நீங்கள் ஒன்று திரட்டப்படுவீர்கள்"}, {"w": 20, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "கூடிப்பேசுவது"}, {"w": 2, "t": "the secret counsels"}, {"w": 3, "t": "ஷைத்தான் புறத்திலிருந்து தூண்டப்படுகிறது"}, {"w": 4, "t": "the Shaitaan"}, {"w": 5, "t": "கவலைப்படுத்து வதற்காக"}, {"w": 6, "t": "நம்பிக்கை கொண்டவர்களை"}, {"w": 7, "t": "believe"}, {"w": 8, "t": "அது இல்லை"}, {"w": 9, "t": "அவர்களுக்கு தீங்கு செய்வதாக"}, {"w": 10, "t": "அறவே"}, {"w": 11, "t": "அனுமதி இல்லாமல்"}, {"w": 12, "t": "by Allah's permission"}, {"w": 13, "t": "அல்லாஹ்வின்"}, {"w": 14, "t": "அல்லாஹ்வின் மீதே"}, {"w": 15, "t": "Allah"}, {"w": 16, "t": "நம்பிக்கை வைக்கட்டும்"}, {"w": 17, "t": "நம்பிக்கையாளர்கள்"}, {"w": 18, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "கூறப்பட்டால்"}, {"w": 5, "t": "it is said"}, {"w": 6, "t": "உங்களுக்கு"}, {"w": 7, "t": "இடம் கொடுங்கள்"}, {"w": 8, "t": "சபைகளில்"}, {"w": 9, "t": "the assemblies"}, {"w": 10, "t": "இடம் கொடுங்கள்!"}, {"w": 11, "t": "விசாலப்படுத்துவான்"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "உங்களுக்கு"}, {"w": 14, "t": "கூறப்பட்டால்"}, {"w": 15, "t": "it is said"}, {"w": 16, "t": "நீங்கள் புறப்படுங்கள்"}, {"w": 17, "t": "நீங்கள் புறப்படுங்கள்"}, {"w": 18, "t": "உயர்த்துவான்"}, {"w": 19, "t": "அல்லாஹ்"}, {"w": 20, "t": "நம்பிக்கை கொண்டவர்களை"}, {"w": 21, "t": "believe"}, {"w": 22, "t": "உங்களில்"}, {"w": 23, "t": "இன்னும் கொடுக்கப்பட்டவர்களை"}, {"w": 24, "t": "were given"}, {"w": 25, "t": "கல்வி"}, {"w": 26, "t": "பல அந்தஸ்துகள்"}, {"w": 27, "t": "அல்லாஹ்"}, {"w": 28, "t": "நீங்கள் செய்பவற்றை"}, {"w": 29, "t": "you do"}, {"w": 30, "t": "ஆழ்ந்தறிபவன்"}, {"w": 31, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "நீங்கள் கூடிப்பேசினால்"}, {"w": 5, "t": "you privately consult"}, {"w": 6, "t": "தூதரிடம்"}, {"w": 7, "t": "முற்படுத்துங்கள்"}, {"w": 8, "t": "நீங்கள் கூடிப்பேசுவதற்கு முன்னர்"}, {"w": 9, "t": "before"}, {"w": 10, "t": "your private consultation"}, {"w": 11, "t": "தர்மத்தை"}, {"w": 12, "t": "அது"}, {"w": 13, "t": "உங்களுக்கு மிகச் சிறந்தது(ம்)"}, {"w": 14, "t": "for you"}, {"w": 15, "t": "மிக பரிசுத்தமானதும்"}, {"w": 16, "t": "நீங்கள் வசதி பெறவில்லை என்றால்"}, {"w": 17, "t": "not"}, {"w": 18, "t": "you find"}, {"w": 19, "t": "நிச்சயமாக"}, {"w": 20, "t": "அல்லாஹ்"}, {"w": 21, "t": "மகா மன்னிப்பாளன்"}, {"w": 22, "t": "மகா கருணையாளன்"}, {"w": 23, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நீங்கள் பயப்படுகிறீர்களா?"}, {"w": 2, "t": "நீங்கள் முற்படுத்துவதற்கு"}, {"w": 3, "t": "offer"}, {"w": 4, "t": "முன்னர்"}, {"w": 5, "t": "before"}, {"w": 6, "t": "உங்கள் உரையாடலுக்கு"}, {"w": 7, "t": "தர்மங்களை"}, {"w": 8, "t": "நீங்கள் அப்படி செய்யவில்லை என்றால்"}, {"w": 9, "t": "you do not"}, {"w": 10, "t": "you do not"}, {"w": 11, "t": "மன்னித்துவிட்டதால்"}, {"w": 12, "t": "அல்லாஹ்வும்"}, {"w": 13, "t": "உங்களை"}, {"w": 14, "t": "நிலை நிறுத்துங்கள்"}, {"w": 15, "t": "தொழுகையை"}, {"w": 16, "t": "இன்னும் கொடுங்கள்!"}, {"w": 17, "t": "ஸகாத்தை"}, {"w": 18, "t": "இன்னும் கீழ்ப்படியுங்கள்!"}, {"w": 19, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 20, "t": "அவனது தூதருக்கும்"}, {"w": 21, "t": "அல்லாஹ்"}, {"w": 22, "t": "ஆழ்ந்தறிபவன்"}, {"w": 23, "t": "நீங்கள் செய்பவற்றை"}, {"w": 24, "t": "you do"}, {"w": 25, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "நண்பர்களாக எடுத்துக் கொண்டவர்களை"}, {"w": 4, "t": "those who"}, {"w": 5, "t": "take as allies"}, {"w": 6, "t": "மக்களை/ கோபப்பட்டானோ"}, {"w": 7, "t": "wrath"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "அவர்கள் மீது"}, {"w": 10, "t": "அவர்கள் உங்களை சேர்ந்தவர்கள் இல்லை"}, {"w": 11, "t": "They (are) not"}, {"w": 12, "t": "of you"}, {"w": 13, "t": "அவர்களை சேர்ந்தவர்களும் இல்லை"}, {"w": 14, "t": "of them"}, {"w": 15, "t": "இன்னும் சத்தியம் செய்கின்றனர்"}, {"w": 16, "t": "பொய்யான விஷயத்தின் மீது"}, {"w": 17, "t": "the lie"}, {"w": 18, "t": "அவர்கள் அறிந்து கொண்டே"}, {"w": 19, "t": "know"}, {"w": 20, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஏற்படுத்தி இருக்கின்றான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "அவர்களுக்கு"}, {"w": 4, "t": "வேதனையை"}, {"w": 5, "t": "கடுமையான(து)"}, {"w": 6, "t": "நிச்சயமாக அவர்கள்"}, {"w": 7, "t": "மிகக் கெட்டவையாகும்"}, {"w": 8, "t": "அவர்கள் செய்துகொண்டிருந்தவை"}, {"w": 9, "t": "they used to"}, {"w": 10, "t": "do"}, {"w": 11, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "எடுத்துக் கொண்டனர்"}, {"w": 2, "t": "தங்கள் சத்தியங்களை"}, {"w": 3, "t": "ஒரு கேடயமாக"}, {"w": 4, "t": "தடுக்கின்றனர்"}, {"w": 5, "t": "மார்க்கத்தை விட்டும்"}, {"w": 6, "t": "(the) way of Allah"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "ஆகவே, அவர்களுக்கு உண்டு"}, {"w": 9, "t": "தண்டனை"}, {"w": 10, "t": "இழிவுதரக்கூடிய(து)"}, {"w": 11, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அறவே தடுக்க மாட்டார்கள்"}, {"w": 2, "t": "will avail"}, {"w": 3, "t": "அவர்களை விட்டும்"}, {"w": 4, "t": "அவர்களின் செல்வங்களோ"}, {"w": 5, "t": "அவர்களின் பிள்ளைகளோ"}, {"w": 6, "t": "their children"}, {"w": 7, "t": "அல்லாஹ்விடம்"}, {"w": 8, "t": "Allah"}, {"w": 9, "t": "எதையும்"}, {"w": 10, "t": "அவர்கள்"}, {"w": 11, "t": "நரகவாசிகள்"}, {"w": 12, "t": "(of) the Fire"}, {"w": 13, "t": "அவர்கள்/அதில்"}, {"w": 14, "t": "in it"}, {"w": 15, "t": "நிரந்தரமாக"}, {"w": 16, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "எழுப்புவான்/ அவர்களை"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "அனைவரையும்"}, {"w": 5, "t": "அவர்கள் சத்தியம் செய்வார்கள்"}, {"w": 6, "t": "அவனுக்கு முன்/போன்று"}, {"w": 7, "t": "as"}, {"w": 8, "t": "அவர்கள் சத்தியம் செய்வது"}, {"w": 9, "t": "உங்களுக்கு முன்"}, {"w": 10, "t": "அவர்கள் எண்ணுவார்கள்"}, {"w": 11, "t": "நிச்சயமாக தாங்கள்"}, {"w": 12, "t": "ஒரு செயலின் மீது"}, {"w": 13, "t": "something"}, {"w": 14, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 15, "t": "நிச்சயமாக அவர்கள்தான்"}, {"w": 16, "t": "[they]"}, {"w": 17, "t": "பொய்யர்கள்"}, {"w": 18, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "ஆதிக்கம் செலுத்துகின்றான்"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "ஷைத்தான்"}, {"w": 4, "t": "அவர்களுக்கு மறக்கவைத்து விட்டான்"}, {"w": 5, "t": "நினைவை"}, {"w": 6, "t": "அல்லாஹ்வின்"}, {"w": 7, "t": "அவர்கள்தான்"}, {"w": 8, "t": "கட்சியினர்"}, {"w": 9, "t": "ஷைத்தானின்"}, {"w": 10, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 11, "t": "நிச்சயமாக கட்சியினர்தான்"}, {"w": 12, "t": "(the) party"}, {"w": 13, "t": "ஷைத்தானின்"}, {"w": 14, "t": "அவர்கள்தான்"}, {"w": 15, "t": "நஷ்டவாளிகள்"}, {"w": 16, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "முரண்படுகிறார்கள்"}, {"w": 4, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 5, "t": "அவனது தூதருக்கும்"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "மிக இழிவானவர்களில்"}, {"w": 8, "t": "the most humiliated"}, {"w": 9, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "விதித்துவிட்டான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "நிச்சயமாக வெல்வோம்"}, {"w": 4, "t": "நானும்"}, {"w": 5, "t": "எனது தூதரும்தான்"}, {"w": 6, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "மிக வலிமை உள்ளவன்"}, {"w": 9, "t": "மிகைத்தவன்"}, {"w": 10, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நீர் காணமாட்டீர்"}, {"w": 2, "t": "You will not find"}, {"w": 3, "t": "மக்களை"}, {"w": 4, "t": "நம்பிக்கை கொள்கின்றனர்"}, {"w": 5, "t": "அல்லாஹ்வையும்"}, {"w": 6, "t": "மறுமை நாளையும்"}, {"w": 7, "t": "the Last"}, {"w": 8, "t": "நேசிப்பவர்களாக"}, {"w": 9, "t": "எவரை"}, {"w": 10, "t": "முரண்படுகின்றார்"}, {"w": 11, "t": "அல்லாஹ்விற்கும்"}, {"w": 12, "t": "அவனது தூதருக்கும்"}, {"w": 13, "t": "அவர்கள் இருந்தாலும் சரியே!"}, {"w": 14, "t": "they were"}, {"w": 15, "t": "தங்கள் தந்தைகளாக"}, {"w": 16, "t": "அல்லது"}, {"w": 17, "t": "தங்கள் பிள்ளைகளாக"}, {"w": 18, "t": "அல்லது"}, {"w": 19, "t": "தங்கள் சகோதரர்களாக"}, {"w": 20, "t": "அல்லது"}, {"w": 21, "t": "தங்கள் குடும்பத்தினராக"}, {"w": 22, "t": "அவர்கள்"}, {"w": 23, "t": "உறுதிபடுத்திவிட்டான்"}, {"w": 24, "t": "அவர்களின் உள்ளங்களில்"}, {"w": 25, "t": "their hearts"}, {"w": 26, "t": "ஈமானை"}, {"w": 27, "t": "இன்னும் பலப்படுத்தினான்/அவர்களை"}, {"w": 28, "t": "உதவியைக் கொண்டு"}, {"w": 29, "t": "தன் புறத்தில் இருந்து"}, {"w": 30, "t": "இன்னும் அவர்களை நுழைப்பான்"}, {"w": 31, "t": "சொர்க்கங்களில்"}, {"w": 32, "t": "ஓடும்"}, {"w": 33, "t": "அவற்றின் கீழ்"}, {"w": 34, "t": "underneath it"}, {"w": 35, "t": "நதிகள்"}, {"w": 36, "t": "நிரந்தரமாக தங்குவார்கள்"}, {"w": 37, "t": "அவற்றில்"}, {"w": 38, "t": "பொருந்திக்கொள்வான்"}, {"w": 39, "t": "அல்லாஹ்"}, {"w": 40, "t": "அவர்களை"}, {"w": 41, "t": "இன்னும் பொருந்திக் கொள்வார்கள்/அவனை"}, {"w": 42, "t": "with Him"}, {"w": 43, "t": "அவர்கள்தான்"}, {"w": 44, "t": "கட்சியினர்"}, {"w": 45, "t": "அல்லாஹ்வின்"}, {"w": 46, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 47, "t": "நிச்சயமாக"}, {"w": 48, "t": "கட்சியினர்தான்"}, {"w": 49, "t": "அல்லாஹ்வின்"}, {"w": 50, "t": "அவர்கள்"}, {"w": 51, "t": "வெற்றியாளர்கள்"}, {"w": 52, "t": "(22)"}]}]}