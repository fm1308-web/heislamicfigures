{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அலிஃப், லாம், மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "தோற்கடிக்கப்பட்டனர்"}, {"w": 2, "t": "ரோமர்கள்"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "கீழ்ப் பகுதியில்"}, {"w": 2, "t": "(the) nearest"}, {"w": 3, "t": "பூமியின்"}, {"w": 4, "t": "இன்னும் அவர்கள்"}, {"w": 5, "t": "பின்னர்"}, {"w": 6, "t": "after"}, {"w": 7, "t": "அவர்கள் தோற்கடிக்கப்பட்டதன்"}, {"w": 8, "t": "அவர்கள் தோற்கடிப்பார்கள்"}, {"w": 9, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "சில ஆண்டுகளில்"}, {"w": 2, "t": "a few"}, {"w": 3, "t": "years"}, {"w": 4, "t": "அல்லாஹ்விற்கே உரியது"}, {"w": 5, "t": "அதிகாரம்"}, {"w": 6, "t": "முன்னரும்"}, {"w": 7, "t": "before"}, {"w": 8, "t": "பின்னரும்"}, {"w": 9, "t": "and after"}, {"w": 10, "t": "அந்நாளில்"}, {"w": 11, "t": "மகிழ்ச்சியடைவார்கள்"}, {"w": 12, "t": "நம்பிக்கையாளர்கள்"}, {"w": 13, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "உதவியால்"}, {"w": 2, "t": "அல்லாஹ்வின்"}, {"w": 3, "t": "அவன் உதவுகின்றான்"}, {"w": 4, "t": "தான் நாடியவர்களுக்கு"}, {"w": 5, "t": "He wills"}, {"w": 6, "t": "அவன்தான்"}, {"w": 7, "t": "மிகைத்தவன்"}, {"w": 8, "t": "பெரும் கருணையாளன்"}, {"w": 9, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "வாக்களிக்கின்றான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "மாற்ற மாட்டான்"}, {"w": 4, "t": "fail"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "தனது வாக்கை"}, {"w": 7, "t": "என்றாலும்"}, {"w": 8, "t": "மக்களில் அதிகமானவர்கள்"}, {"w": 9, "t": "[the] people"}, {"w": 10, "t": "அறியமாட்டார்கள்"}, {"w": 11, "t": "know"}, {"w": 12, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவர்கள் அறிவார்கள்"}, {"w": 2, "t": "வெளிரங்கத்தை(த்தான்)"}, {"w": 3, "t": "வாழ்க்கையின்"}, {"w": 4, "t": "the life"}, {"w": 5, "t": "இவ்வுலக"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "மறுமையைப் பற்றி"}, {"w": 8, "t": "the Hereafter"}, {"w": 9, "t": "தான்"}, {"w": 10, "t": "கவனமற்றவர்கள்"}, {"w": 11, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவர்க