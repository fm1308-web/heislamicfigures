{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "நீங்கள் முந்தாதீர்கள்"}, {"w": 5, "t": "put (yourselves) forward "}, {"w": 6, "t": "முன்பாக"}, {"w": 7, "t": "before Allah"}, {"w": 8, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 9, "t": "அவனது தூதருக்கும்"}, {"w": 10, "t": "அஞ்சிக் கொள்ளுங்கள்!"}, {"w": 11, "t": "அல்லாஹ்வை"}, {"w": 12, "t": "நிச்சயமாக"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "நன்கு செவியுறுபவன்"}, {"w": 15, "t": "நன்கறிந்தவன்"}, {"w": 16, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "உயர்த்தாதீர்கள்!"}, {"w": 5, "t": "raise"}, {"w": 6, "t": "உங்கள் சப்தங்களை"}, {"w": 7, "t": "மேல்"}, {"w": 8, "t": "சப்தத்திற்கு"}, {"w": 9, "t": "நபியின்"}, {"w": 10, "t": "இன்னும் உரக்கப் பேசாதீர்கள்!"}, {"w": 11, "t": "be loud"}, {"w": 12, "t": "அவருக்கு முன்"}, {"w": 13, "t": "பேசுவதில்"}, {"w": 14, "t": "உரக்கப் பேசுவதைப் போல்"}, {"w": 15, "t": "உங்களில் சிலர்"}, {"w": 16, "t": "சிலருக்கு முன்"}, {"w": 17, "t": "பாழாகிவிடாமல் இருப்பதற்காக"}, {"w": 18, "t": "become worthless"}, {"w": 19, "t": "உங்கள் அமல்கள்"}, {"w": 20, "t": "நீங்கள் உணராமல் இருக்கின்ற நிலையில்"}, {"w": 21, "t": "(do) not"}, {"w": 22, "t": "perceive"}, {"w": 23, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "தாழ்த்திக் கொள்பவர்கள்"}, {"w": 3, "t": "lower"}, {"w": 4, "t": "தங்கள் சப்தங்களை"}, {"w": 5, "t": "அருகில்"}, {"w": 6, "t": "தூதருக்கு"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "அவர்களைத்தான்"}, {"w": 9, "t": "(are) the ones"}, {"w": 10, "t": "சோதித்து தேர்வு செய்துள்ளான்"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "அவர்களுடைய உள்ளங்களை"}, {"w": 13, "t": "இறையச்சத்திற்காக"}, {"w": 14, "t": "அவர்களுக்கு உண்டு"}, {"w": 15, "t": "மன்னிப்பு(ம்)"}, {"w": 16, "t": "மகத்தான கூலியும்"}, {"w": 17, "t": "great"}, {"w": 18, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உம்மை சப்தமிட்டு அழைப்பவர்கள்"}, {"w": 3, "t": "call you"}, {"w": 4, "t": "பின்னால் இருந்து"}, {"w": 5, "t": "behind"}, {"w": 6, "t": "அறைகளுக்கு"}, {"w": 7, "t": "அவர்களில் அதிகமானவர்கள்"}, {"w": 8, "t": "அறியமாட்டார்கள்"}, {"w": 9, "t": "understand"}, {"w": 10, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவர்கள் பொறுமையாக இருந்திருந்தால்"}, {"w": 2, "t": "they"}, {"w": 3, "t": "had been patient"}, {"w": 4, "t": "வரை/நீர் வெளியேறி வருகின்ற"}, {"w": 5, "t": "you came out"}, {"w": 6, "t": "அவர்களிடம்"}, {"w": 7, "t": "அது இருந்திருக்கும்"}, {"w": 8, "t": "நன்றாக"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "மகா மன்னிப்பாளன்"}, {"w": 12, "t": "மகா கருணையாளன்"}, {"w": 13, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "உங்களிடம் வந்தால்"}, {"w": 5, "t": "comes to you"}, {"w": 6, "t": "பாவியான ஒருவர்"}, {"w": 7, "t": "ஒரு செய்தியைக் கொண்டு"}, {"w": 8, "t": "நன்கு தெளிவு பெறுங்கள்!"}, {"w": 9, "t": "நீங்கள்சேதமேற்படுத்தி விடாமல் இருப்பதற்காக"}, {"w": 10, "t": "you harm"}, {"w": 11, "t": "ஒரு கூட்டத்திற்கு"}, {"w": 12, "t": "அறியாமல்"}, {"w": 13, "t": "ஆகிவிடுவீர்கள்"}, {"w": 14, "t": "நீங்கள் செய்ததற்காக"}, {"w": 15, "t": "what"}, {"w": 16, "t": "you have done"}, {"w": 17, "t": "வருந்தியவர்களாக"}, {"w": 18, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "உங்களுக்கு மத்தியில்"}, {"w": 4, "t": "அல்லாஹ்வின் தூதர்"}, {"w": 5, "t": "(is the) Messenger of Allah"}, {"w": 6, "t": "அவர் உங்களுக்கு கட்டுப்பட்டு நடந்தால்"}, {"w": 7, "t": "he were to obey you"}, {"w": 8, "t": "அதிகமானவற்றில்"}, {"w": 9, "t": "much"}, {"w": 10, "t": "காரியங்களில்"}, {"w": 11, "t": "the matter"}, {"w": 12, "t": "நீங்கள் சிரமப்பட்டுவிடுவீர்கள்"}, {"w": 13, "t": "என்றாலும்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "விருப்பமாக்கினான்"}, {"w": 16, "t": "உங்களுக்கு ஈமானை"}, {"w": 17, "t": "the Faith"}, {"w": 18, "t": "இன்னும் அதை அலங்கரித்தான்"}, {"w": 19, "t": "உங்கள் உள்ளங்களில்"}, {"w": 20, "t": "your hearts"}, {"w": 21, "t": "இன்னும் வெறுப்பாக்கினான்"}, {"w": 22, "t": "உங்களிடம்"}, {"w": 23, "t": "இறை நிராகரிப்பை(யும்)"}, {"w": 24, "t": "பாவத்தையும்"}, {"w": 25, "t": "மாறுசெய்வதையும்"}, {"w": 26, "t": "இத்தகையவர்கள்தான்"}, {"w": 27, "t": "(are) they "}, {"w": 28, "t": "சத்தியவழி நடப்பவர்கள்"}, {"w": 29, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அருளாக(வும்)"}, {"w": 2, "t": "அல்லாஹ்வின் புறத்தில் இருந்து"}, {"w": 3, "t": "from Allah"}, {"w": 4, "t": "கிருபையாகவும்"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "நன்கறிந்தவன்"}, {"w": 7, "t": "மகா ஞானவான்"}, {"w": 8, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இரு பிரிவினர்"}, {"w": 2, "t": "two parties"}, {"w": 3, "t": "நம்பிக்கையாளர்களில்"}, {"w": 4, "t": "the believers"}, {"w": 5, "t": "தங்களுக்குள் சண்டையிட்டால்"}, {"w": 6, "t": "சமாதானம் செய்யுங்கள்!"}, {"w": 7, "t": "அவ்விருவருக்கும் மத்தியில்"}, {"w": 8, "t": "எல்லை மீறினால்"}, {"w": 9, "t": "oppresses"}, {"w": 10, "t": "அவ்விருவரில் ஒரு பிரிவினர்"}, {"w": 11, "t": "மற்றொரு பிரிவினர்மீது"}, {"w": 12, "t": "the other"}, {"w": 13, "t": "சண்டை செய்யுங்கள்"}, {"w": 14, "t": "எல்லை மீறுகின்றவர்களிடம்"}, {"w": 15, "t": "oppresses"}, {"w": 16, "t": "அவர்கள் திரும்புகின்றவரை"}, {"w": 17, "t": "it returns"}, {"w": 18, "t": "கட்டளையின் பக்கம்"}, {"w": 19, "t": "(the) command"}, {"w": 20, "t": "அல்லாஹ்வின்"}, {"w": 21, "t": "அவர்கள் திரும்பிவிட்டால்"}, {"w": 22, "t": "it returns"}, {"w": 23, "t": "சமாதானம் செய்யுங்கள்!"}, {"w": 24, "t": "அவ்விருவருக்கும் மத்தியில்"}, {"w": 25, "t": "நீதமாக"}, {"w": 26, "t": "இன்னும் நேர்மையாக இருங்கள்"}, {"w": 27, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 28, "t": "Allah"}, {"w": 29, "t": "நேசிக்கின்றான்"}, {"w": 30, "t": "நேர்மையாளர்களை"}, {"w": 31, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நம்பிக்கையாளர்கள் எல்லாம்"}, {"w": 2, "t": "the believers"}, {"w": 3, "t": "சகோதரர்கள் ஆவர்"}, {"w": 4, "t": "ஆகவே சமாதானம் செய்யுங்கள்!"}, {"w": 5, "t": "மத்தியில்"}, {"w": 6, "t": "உங்கள் இரு சகோதரர்களுக்கு"}, {"w": 7, "t": "அஞ்சுங்கள்"}, {"w": 8, "t": "அல்லாஹ்வை"}, {"w": 9, "t": "நீங்கள் கருணை காட்டப்படுவீர்கள்"}, {"w": 10, "t": "receive mercy"}, {"w": 11, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "பரிகாசம் செய்ய வேண்டாம்"}, {"w": 5, "t": "ridicule"}, {"w": 6, "t": "ஒரு கூட்டம்"}, {"w": 7, "t": "இன்னொரு கூட்டத்தை"}, {"w": 8, "t": "(another) people"}, {"w": 9, "t": "அவர்கள் இருக்கலாம்"}, {"w": 10, "t": "that"}, {"w": 11, "t": "they may be"}, {"w": 12, "t": "சிறந்தவர்களாக"}, {"w": 13, "t": "இவர்களை விட"}, {"w": 14, "t": "பெண்களும் பரிகாசம் செய்ய வேண்டாம்"}, {"w": 15, "t": "women"}, {"w": 16, "t": "பெண்களை"}, {"w": 17, "t": "(other) women"}, {"w": 18, "t": "அவர்கள் இருக்கலாம்"}, {"w": 19, "t": "that"}, {"w": 20, "t": "they may be"}, {"w": 21, "t": "சிறந்தவர்களாக"}, {"w": 22, "t": "இவர்களை விட"}, {"w": 23, "t": "இன்னும் குத்திப் பேச வேண்டாம்"}, {"w": 24, "t": "insult"}, {"w": 25, "t": "உங்களை"}, {"w": 26, "t": "பட்டப் பெயர் சூட்டாதீர்கள்"}, {"w": 27, "t": "call each other"}, {"w": 28, "t": "தீய பட்டப் பெயர்களைக் கொண்டு"}, {"w": 29, "t": "பெயர்களில் மிக கெட்டது"}, {"w": 30, "t": "the name"}, {"w": 31, "t": "பாவிகள்"}, {"w": 32, "t": "பின்னர்"}, {"w": 33, "t": "நம்பிக்கை கொண்டதன்"}, {"w": 34, "t": "யார் திருந்தி திரும்பவில்லையோ"}, {"w": 35, "t": "(does) not"}, {"w": 36, "t": "repent"}, {"w": 37, "t": "அவர்கள்தான்"}, {"w": 38, "t": "they"}, {"w": 39, "t": "அநியாயக்காரர்கள்"}, {"w": 40, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "O you who believe"}, {"w": 3, "t": "O you who believe"}, {"w": 4, "t": "தவிர்த்துவிடுங்கள்!"}, {"w": 5, "t": "அதிகமானவற்றை"}, {"w": 6, "t": "எண்ணங்களில்"}, {"w": 7, "t": "the assumption"}, {"w": 8, "t": "நிச்சயமாக சில"}, {"w": 9, "t": "some"}, {"w": 10, "t": "எண்ணங்களில்"}, {"w": 11, "t": "பாவமாகும்"}, {"w": 12, "t": "ஆராயாதீர்கள்!"}, {"w": 13, "t": "spy"}, {"w": 14, "t": "புறம் பேசவேண்டாம்"}, {"w": 15, "t": "backbite"}, {"w": 16, "t": "உங்களில் சிலர்"}, {"w": 17, "t": "சிலரைப் பற்றி"}, {"w": 18, "t": "விரும்புவாரா?"}, {"w": 19, "t": "உங்களில் ஒருவர்"}, {"w": 20, "t": "சாப்பிட"}, {"w": 21, "t": "eat"}, {"w": 22, "t": "மாமிசத்தை"}, {"w": 23, "t": "தன் சகோதரனின்"}, {"w": 24, "t": "இறந்த நிலையில்"}, {"w": 25, "t": "அதை நீங்கள் வெறுப்பீர்களே!"}, {"w": 26, "t": "அஞ்சிக்கொள்ளுங்கள்!"}, {"w": 27, "t": "அல்லாஹ்வை"}, {"w": 28, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 29, "t": "Allah"}, {"w": 30, "t": "தவ்பாவை அங்கீகரிப்பவன்"}, {"w": 31, "t": "மகா கருணையாளன்"}, {"w": 32, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "மக்களே!"}, {"w": 2, "t": "O mankind"}, {"w": 3, "t": "நிச்சயமாக நாம்"}, {"w": 4, "t": "உங்களைப் படைத்தோம்"}, {"w": 5, "t": "ஓர் ஆணிலிருந்து"}, {"w": 6, "t": "a male"}, {"w": 7, "t": "இன்னும் ஒரு பெண்"}, {"w": 8, "t": "இன்னும் உங்களை நாம் ஆக்கினோம்"}, {"w": 9, "t": "பல நாட்டவர்களாக(வும்)"}, {"w": 10, "t": "பல குலத்தவர்களாகவும்"}, {"w": 11, "t": "நீங்கள் ஒருவர் ஒருவரை அறிவதற்காக"}, {"w": 12, "t": "நிச்சயமாக"}, {"w": 13, "t": "உங்களில் மிக கண்ணியமானவர்"}, {"w": 14, "t": "அல்லாஹ்விடம்"}, {"w": 15, "t": "Allah"}, {"w": 16, "t": "உங்களில் அதிகம் இறையச்சமுடையவர்தான்"}, {"w": 17, "t": "நிச்சயமாக"}, {"w": 18, "t": "அல்லாஹ்"}, {"w": 19, "t": "நன்கறிந்தவன்"}, {"w": 20, "t": "ஆழ்ந்தறிபவன்"}, {"w": 21, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "கூறுகின்றனர்"}, {"w": 2, "t": "கிராமத்து அரபிகள்"}, {"w": 3, "t": "நாங்கள் ஈமான் கொண்டோம்"}, {"w": 4, "t": "நீர் கூறுவீராக!"}, {"w": 5, "t": "நீங்கள் ஈமான் கொள்ளவில்லை"}, {"w": 6, "t": "you believe"}, {"w": 7, "t": "என்றாலும்"}, {"w": 8, "t": "கூறுங்கள்!"}, {"w": 9, "t": "நாங்கள் முஸ்லிம்களாக ஆகி இருக்கின்றோம்"}, {"w": 10, "t": "நுழையவில்லை"}, {"w": 11, "t": "entered"}, {"w": 12, "t": "ஈமான்"}, {"w": 13, "t": "உங்கள் உள்ளங்களில்"}, {"w": 14, "t": "your hearts"},