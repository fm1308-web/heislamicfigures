{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "வரவில்லையா"}, {"w": 2, "t": "(there) come"}, {"w": 3, "t": "மனிதனுக்கு"}, {"w": 4, "t": "man"}, {"w": 5, "t": "ஒரு நேரம்"}, {"w": 6, "t": "காலத்தில் இருந்து"}, {"w": 7, "t": "time"}, {"w": 8, "t": "அவன் இருக்கவில்லை"}, {"w": 9, "t": "he was"}, {"w": 10, "t": "ஒரு பொருளாக"}, {"w": 11, "t": "நினைவு கூறப்படுகின்ற"}, {"w": 12, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "படைத்தோம்"}, {"w": 3, "t": "மனிதனை"}, {"w": 4, "t": "விந்துத் துளியிலிருந்து"}, {"w": 5, "t": "a semen-drop"}, {"w": 6, "t": "கலக்கப்பட்ட"}, {"w": 7, "t": "அவனை நாம் சோதிக்கின்றோம்"}, {"w": 8, "t": "ஆகவே, அவனை ஆக்கினோம்"}, {"w": 9, "t": "செவியுறுபவனாக"}, {"w": 10, "t": "பார்ப்பவனாக"}, {"w": 11, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அவனுக்கு வழிகாட்டினோம்"}, {"w": 3, "t": "பாதையை"}, {"w": 4, "t": "ஒன்று"}, {"w": 5, "t": "நன்றி உள்ளவனாக"}, {"w": 6, "t": "அவர்கள் நன்றி கெட்டவனாக"}, {"w": 7, "t": "(he) be ungrateful"}, {"w": 8, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "தயார் செய்துள்ளோம்"}, {"w": 3, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 4, "t": "சங்கிலிகளை(யும்)"}, {"w": 5, "t": "விலங்குகளையும்"}, {"w": 6, "t": "கொழுந்துவிட்டெரியும் நெருப்பையும்"}, {"w": 7, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நல்லவர்கள்"}, {"w": 3, "t": "பருகுவார்கள்"}, {"w": 4, "t": "ஒரு மது குவளையிலிருந்து"}, {"w": 5, "t": "a cup"}, {"w": 6, "t": "இருக்கும்"}, {"w": 7, "t": "அதன் கலப்பு"}, {"w": 8, "t": "காஃபூர் நறுமணத்தால்"}, {"w": 9, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "ஓர் ஊற்றாகும்"}, {"w": 2, "t": "அருந்துவார்கள்"}, {"w": 3, "t": "அதில் இருந்து"}, {"w": 4, "t": "அடியார்கள்"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "அதை அவர்கள் ஓட வைப்பார்கள்"}, {"w": 7, "t": "ஓட வைத்தல்"}, {"w": 8, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிறைவேற்றுவார்கள்"}, {"w": 2, "t": "நேர்ச்சையை"}, {"w": 3, "t": "இன்னும் பயப்படுவார்கள்"}, {"w": 4, "t": "ஒரு நாளை"}, {"w": 5, "t": "இருக்கும்"}, {"w": 6, "t": "அதன் தீமை"}, {"w": 7, "t": "சூழ்ந்ததாக, பரவியதாக, கடுமையானதாக"}, {"w": 8, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் உணவளிப்பார்கள்"}, {"w": 2, "t": "உணவை"}, {"w": 3, "t": "அதன் பிரியம் இருப்பதுடன்"}, {"w": 4, "t": "love (for) it"}, {"w": 5, "t": "ஏழைகளுக்கும்"}, {"w": 6, "t": "அனாதைகளுக்கும்"}, {"w": 7, "t": "கைதிகளுக்கும்"}, {"w": 8, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நாங்கள் உங்களுக்கு உணவளிப்பதெல்லாம்"}, {"w": 2, "t": "we feed you"}, {"w": 3, "t": "முகத்திற்காகத்தான்"}, {"w": 4, "t": "அல்லாஹ்வின்"}, {"w": 5, "t": "நாங்கள் நாடவில்லை"}, {"w": 6, "t": "we desire"}, {"w": 7, "t": "உங்களிடம்"}, {"w": 8, "t": "கூலியையும்"}, {"w": 9, "t": "நன்றியையும்"}, {"w": 10, "t": "thanks"}, {"w": 11, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "பயப்படுகின்றோம்"}, {"w": 3, "t": "எங்கள் இறைவனிடம்"}, {"w": 4, "t": "our Lord"}, {"w": 5, "t": "ஒரு நாளை"}, {"w": 6, "t": "கடுகடுக்கின்ற"}, {"w": 7, "t": "சுருங்கிவிடுகின்ற"}, {"w": 8, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஆகவே அவர்களை பாதுகாப்பான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "தீமையில் இருந்து"}, {"w": 4, "t": "அந்நாளின்/இன்னும் அவர்களுக்கு கொடுப்பான்"}, {"w": 5, "t": "Day"}, {"w": 6, "t": "and will cause them to meet"}, {"w": 7, "t": "முக செழிப்பையும்"}, {"w": 8, "t": "மன மகிழ்ச்சியையும்"}, {"w": 9, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் அவன் அவர்களுக்கு கூலியாகக் கொடுப்பான்"}, {"w": 2, "t": "அவர்கள் பொறுமையாக இருந்ததால்"}, {"w": 3, "t": "they were patient"}, {"w": 4, "t": "சொர்க்கத்தையும்"}, {"w": 5, "t": "பட்டையும்"}, {"w": 6, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "சாய்ந்தவர்களாக"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "கட்டில்களில்"}, {"w": 4, "t": "couches"}, {"w": 5, "t": "காண மாட்டார்கள்"}, {"w": 6, "t": "they will see"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "சூரியனையோ"}, {"w": 9, "t": "குளிரையோ"}, {"w": 10, "t": "freezing cold"}, {"w": 11, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அருகில் இருக்கும்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "அதன் நிழல்கள்"}, {"w": 4, "t": "மிக தாழ்வாக ஆக்கப்பட்டிருக்கும்"}, {"w": 5, "t": "அவற்றின் கனிகள்"}, {"w": 6, "t": "மிக தாழ்வாக"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவர்கள் முன் சுற்றி வரப்படும்"}, {"w": 2, "t": "among them"}, {"w": 3, "t": "பாத்திரங்கள்"}, {"w": 4, "t": "வெள்ளியினால்"}, {"w": 5, "t": "silver"}, {"w": 6, "t": "கெண்டிகள்"}, {"w": 7, "t": "இருக்கின்ற"}, {"w": 8, "t": "கண்ணாடிகளாக"}, {"w": 9, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "கண்ணாடிகளாகும்"}, {"w": 2, "t": "வெள்ளிகலந்த"}, {"w": 3, "t": "silver"}, {"w": 4, "t": "அவற்றை நிர்ணயிப்பார்கள்"}, {"w": 5, "t": "துல்லியமாக"}, {"w": 6, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இன்னும் அவர்களுக்கு புகட்டப்படும்"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "மதுக் குவளையில்"}, {"w": 4, "t": "இருக்கும்"}, {"w": 5, "t": "அதன் கலவை"}, {"w": 6, "t": "இஞ்சியாக"}, {"w": 7, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "ஓர் ஊற்றாகும்"}, {"w": 2, "t": "அதில் உள்ள"}, {"w": 3, "t": "பெயர் கூறப்படும்"}, {"w": 4, "t": "சல்சபீல்"}, {"w": 5, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் சுற்றி வருவார்(கள்)"}, {"w": 2, "t": "அவர்களை"}, {"w": 3, "t": "சிறுவர்கள்"}, {"w": 4, "t": "நிரந்தரமானவர்கள்"}, {"w": 5, "t": "நீர் அவர்களைப் பார்த்தால்"}, {"w": 6, "t": "you see them"}, {"w": 7, "t": "அவர்களை எண்ணுவீர்"}, {"w": 8, "t": "முத்துக்களாக"}, {"w": 9, "t": "பரப்பி வைக்கப்பட்ட"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நீர் பார்த்தாலும்"}, {"w": 2, "t": "you look"}, {"w": 3, "t": "எந்த இடத்தை"}, {"w": 4, "t": "நீர் பார்ப்பீர்"}, {"w": 5, "t": "பேரின்பத்தை(யும்)"}, {"w": 6, "t": "ஆட்சியையும்"}, {"w": 7, "t": "பெரிய"}, {"w": 8, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அவர்களுக்கு மேல்"}, {"w": 2, "t": "ஆடைகளும்"}, {"w": 3, "t": "மென்மையான பட்டும்"}, {"w": 4, "t": "பச்சை நிற"}, {"w": 5, "t": "இன்னும் தடிப்பான பட்டு"}, {"w": 6, "t": "இன்னும் அலங்கரிக்கப் படுவார்கள்"}, {"w": 7, "t": "காப்புகளால்"}, {"w": 8, "t": "வெள்ளியினால்"}, {"w": 9, "t": "silver"}, {"w": 10, "t": "புகட்டுவான்/ அவர்களுக்கு"}, {"w": 11, "t": "அவர்களின் இறைவன்"}, {"w": 12, "t": "பானத்தை"}, {"w": 13, "t": "மிகத் தூய்மையான"}, {"w": 14, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இவை"}, {"w": 3, "t": "இருக்கும்"}, {"w": 4, "t": "உங்களுக்கு"}, {"w": 5, "t": "கூலியாக"}, {"w": 6, "t": "இன்னும் இருக்கும்"}, {"w": 7, "t": "உங்கள் உழைப்புகள்"}, {"w": 8, "t": "நன்றிஅறியப்பட்டதாக"}, {"w": 9, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நாம்தான்"}, {"w": 3, "t": "இறக்கினோம்"}, {"w": 4, "t": "உம்மீது"}, {"w": 5, "t": "இந்த குர்ஆனை"}, {"w": 6, "t": "கொஞ்சம் கொஞ்சமாக இறக்குதல்"}, {"w": 7, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "நீர் சகித்திருப்பீராக!"}, {"w": 2, "t": "தீர்ப்புக்காக"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "நீர் கீழ்ப்படியாதீர்!"}, {"w": 5, "t": "obey"}, {"w": 6, "t": "அவர்களில்"}, {"w": 7, "t": "பாவிக்கும்"}, {"w": 8, "t": "அல்லது"}, {"w": 9, "t": "நிராகரிப்பாளருக்கும்"}, {"w": 10, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நினைவு கூர்வீராக"}, {"w": 2, "t": "பெயரை/ உமது இறைவனின்"}, {"w": 3, "t": "(of) your Lord"}, {"w": 4, "t": "காலையிலும்"}, {"w": 5, "t": "மாலையிலும்"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "இரவில்"}, {"w": 2, "t": "the night"}, {"w": 3, "t": "சிரம் பணிந்து தொழுவீராக!"}, {"w": 4, "t": "அவனுக்காக"}, {"w": 5, "t": "இன்னும் அவனை தொழுது வணங்குவீராக!"}, {"w": 6, "t": "இரவில்"}, {"w": 7, "t": "நீண்ட நேரம்"}, {"w": 8, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நிச்சயமாக/இவர்கள்"}, {"w": 2, "t": "these"}, {"w": 3, "t": "நேசிக்கின்றனர்"}, {"w": 4, "t": "உலக வாழ்க்கையை"}, {"w": 5, "t": "இன்னும் விட்டுவிடுகின்றனர்"}, {"w": 6, "t": "அவர்களுக்கு முன்னர்"}, {"w": 7, "t": "ஒரு நாளை"}, {"w": 8, "t": "மிக கனமான"}, {"w": 9, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நாம்தான்"}, {"w": 2, "t": "அவர்களை படைத்தோம்"}, {"w": 3, "t": "இன்னும் உறுதிப்படுத்தினோம்"}, {"w": 4, "t": "அவர்களின் படைப்பை"}, {"w": 5, "t": "நாம் நாடினால்"}, {"w": 6, "t": "We will"}, {"w": 7, "t": "பதிலாக கொண்டுவருவோம்"}, {"w": 8, "t": "அவர்கள் போன்றவர்களை"}, {"w": 9, "t": "பதிலாக"}, {"w": 10, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இது"}, {"w": 3, "t": "ஓர் அறிவுரையாகும்"}, {"w": 4, "t": "யார் நாடுகிறாரோ"}, {"w": 5, "t": "wills"}, {"w": 6, "t": "அவன் ஏற்படுத்திக் கொள்ளட்டும்"}, {"w": 7, "t": "தன் இறைவனின் பக்கம்"}, {"w": 8, "t": "his Lord"}, {"w": 9, "t": "ஒரு பாதையை"}, {"w": 10, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "நீங்கள் நாடமுடியாது"}, {"w": 2, "t": "you will"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "நாடினால்"}, {"w": 5, "t": "wills"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 8, "t": "Allah"}, {"w": 9, "t": "இருக்கின்றான்"}, {"w": 10, "t": "நன்கறிந்தவனாக"}, {"w": 11, "t": "மகா ஞானவானாக"}, {"w": 12, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நுழைக்கின்றான்"}, {"w": 2, "t": "அவன் நாடுகின்றவர்களை"}, {"w": 3, "t": "He wills"}, {"w": 4, "t": "தனது அருளில்"}, {"w": 5, "t": "His mercy"}, {"w": 6, "t": "அநியாயக்காரர்கள்"}, {"w": 7, "t": "தயார்செய்து வைத்துள்ளான்"}, {"w": 8, "t": "அவர்களுக்காக"}, {"w": 9, "t": "தண்டனையை"}, {"w": 10, "t": "வலி தரக்கூடிய"}, {"w": 11, "t": "(31)"}]}]}