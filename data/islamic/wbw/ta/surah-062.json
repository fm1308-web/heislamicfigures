{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "துதிக்கின்றன"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "வானங்களில் உள்ளவர்களும்"}, {"w": 4, "t": "(is) in"}, {"w": 5, "t": "the heavens"}, {"w": 6, "t": "பூமியில் உள்ளவர்களும்"}, {"w": 7, "t": "(is) in"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "பேரரசனாகிய"}, {"w": 10, "t": "பரிசுத்தவனாகிய"}, {"w": 11, "t": "மிகைத்தவனாகிய"}, {"w": 12, "t": "மகா ஞானவானாகிய"}, {"w": 13, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "அனுப்பினான்"}, {"w": 4, "t": "எழுதப் படிக்கக் கற்காத மக்களில்"}, {"w": 5, "t": "the unlettered"}, {"w": 6, "t": "ஒரு தூதரை"}, {"w": 7, "t": "அவர்களில் இருந்தே"}, {"w": 8, "t": "அவர் ஓதுகிறார்"}, {"w": 9, "t": "அவர்களுக்கு முன்"}, {"w": 10, "t": "அவனது வசனங்களை"}, {"w": 11, "t": "இன்னும் அவர்களை பரிசுத்தப்படுத்துகிறார்"}, {"w": 12, "t": "அவர்களுக்கு கற்பிக்கிறார்"}, {"w": 13, "t": "வேதத்தை(யும்)"}, {"w": 14, "t": "ஞானத்தையும்"}, {"w": 15, "t": "நிச்சயமாக அவர்கள் இருந்தனர்"}, {"w": 16, "t": "they were"}, {"w": 17, "t": "இதற்கு முன்னர்"}, {"w": 18, "t": "before"}, {"w": 19, "t": "தெளிவான வழிகேட்டில்தான்"}, {"w": 20, "t": "an error"}, {"w": 21, "t": "clear"}, {"w": 22, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் வேறு மக்களுக்காக/அவர்களில்"}, {"w": 2, "t": "among them"}, {"w": 3, "t": "அவர்கள் வந்து சேரவில்லை"}, {"w": 4, "t": "joined"}, {"w": 5, "t": "இவர்களுடன்"}, {"w": 6, "t": "அவன்தான்"}, {"w": 7, "t": "மிகைத்தவன்"}, {"w": 8, "t": "மகா ஞானவான்"}, {"w": 9, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "சிறப்பாகும்"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "அதை கொடுக்கின்றான்"}, {"w": 5, "t": "தான் நாடுகின்றவர்களுக்கு/அல்லாஹ்"}, {"w": 6, "t": "He wills"}, {"w": 7, "t": "And Allah"}, {"w": 8, "t": "சிறப்புடையவன்"}, {"w": 9, "t": "(of) Bounty"}, {"w": 10, "t": "மகத்தான"}, {"w": 11, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "உதாரணம்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "பணிக்கப்பட்டார்கள்"}, {"w": 4, "t": "தவ்றாத்தின் படி"}, {"w": 5, "t": "பிறகு/அதன்படி அவர்கள் அமல் செய்யவில்லை"}, {"w": 6, "t": "not"}, {"w": 7, "t": "they bore it"}, {"w": 8, "t": "உதாரணத்தைப் போல்"}, {"w": 9, "t": "கழுதையின்"}, {"w": 10, "t": "சுமக்கிறது"}, {"w": 11, "t": "பல நூல்களை"}, {"w": 12, "t": "மிகக் கெட்டது"}, {"w": 13, "t": "உதாரணம்"}, {"w": 14, "t": "மக்களின்"}, {"w": 15, "t": "பொய்ப்பித்தவர்கள்"}, {"w": 16, "t": "deny"}, {"w": 17, "t": "வசனங்களை"}, {"w": 18, "t": "அல்லாஹ்வின்"}, {"w": 19, "t": "அல்லாஹ் நேர்வழி செலுத்த மாட்டான்"}, {"w": 20, "t": "(does) not"}, {"w": 21, "t": "guide"}, {"w": 22, "t": "அநியாயக்கார மக்களை"}, {"w": 23, "t": "the wrongdoers"}, {"w": 24, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "யூதர்களே!"}, {"w": 3, "t": "you (who)"}, {"w": 4, "t": "(are) Jews"}, {"w": 5, "t": "நீங்கள் பிதற்றினால்"}, {"w": 6, "t": "you claim"}, {"w": 7, "t": "நிச்சயமாக நீங்கள்தான்"}, {"w": 8, "t": "நண்பர்கள்"}, {"w": 9, "t": "அல்லாஹ்வின்"}, {"w": 10, "t": "மற்ற மக்கள் அல்ல"}, {"w": 11, "t": "excluding"}, {"w": 12, "t": "the people"}, {"w": 13, "t": "ஆசைப்படுங்கள்!"}, {"w": 14, "t": "மரணத்தை"}, {"w": 15, "t": "நீங்கள் உண்மையாளர்களாக இருந்தால்"}, {"w": 16, "t": "you are"}, {"w": 17, "t": "truthful"}, {"w": 18, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அதை அவர்கள் ஆசைப்பட மாட்டார்கள்"}, {"w": 2, "t": "they will wish for it"}, {"w": 3, "t": "ஒரு போதும்/முற்படுத்தியவற்றின் காரணமாக"}, {"w": 4, "t": "for what"}, {"w": 5, "t": "(have) sent forth"}, {"w": 6, "t": "அவர்களின் கரங்கள்"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "நன்கறிந்தவன்"}, {"w": 9, "t": "அநியாயக்காரர்களை"}, {"w": 10, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக மரணம்"}, {"w": 3, "t": "the death"}, {"w": 4, "t": "எது/விரண்டு ஓடுகின்றீர்கள்"}, {"w": 5, "t": "you flee"}, {"w": 6, "t": "அதை விட்டு/நிச்சயமாகஅது"}, {"w": 7, "t": "then surely it"}, {"w": 8, "t": "உங்களை சந்திக்கும்"}, {"w": 9, "t": "பிறகு/நீங்கள் திரும்பக் கொண்டு வரப்படுவீர்கள்"}, {"w": 10, "t": "you will be sent back"}, {"w": 11, "t": "அறிந்தவன் பக்கம்"}, {"w": 12, "t": "(the) All-Knower"}, {"w": 13, "t": "மறைவானவற்றையும்"}, {"w": 14, "t": "வெளிப்படையானவற்றையும்"}, {"w": 15, "t": "அவன் உங்களுக்கு அறிவிப்பான்"}, {"w": 16, "t": "நீங்கள் செய்துகொண்டிருந்தவற்றை"}, {"w": 17, "t": "you used to"}, {"w": 18, "t": "do"}, {"w": 19, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "(you) who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "அழைக்கப்பட்டால்"}, {"w": 5, "t": "(the) call is made"}, {"w": 6, "t": "தொழுகைக்காக"}, {"w": 7, "t": "ஜுமுஆ தினத்தன்று"}, {"w": 8, "t": "(the) day"}, {"w": 9, "t": "(of) Friday"}, {"w": 10, "t": "நீங்கள் விரையுங்கள்!"}, {"w": 11, "t": "நினைவின் பக்கம்"}, {"w": 12, "t": "(the) remembrance"}, {"w": 13, "t": "அல்லாஹ்வின்"}, {"w": 14, "t": "இன்னும் விட்டு விடுங்கள்!"}, {"w": 15, "t": "வியாபாரத்தை"}, {"w": 16, "t": "அதுதான்"}, {"w": 17, "t": "மிகச் சிறந்ததாகும்"}, {"w": 18, "t": "உங்களுக்கு"}, {"w": 19, "t": "நீங்கள் இருந்தால்"}, {"w": 20, "t": "you"}, {"w": 21, "t": "அறிகின்றவர்களாக"}, {"w": 22, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "முடிந்துவிட்டால்"}, {"w": 2, "t": "is concluded"}, {"w": 3, "t": "தொழுகை"}, {"w": 4, "t": "பரவிச் செல்லுங்கள்"}, {"w": 5, "t": "பூமியில்"}, {"w": 6, "t": "the land"}, {"w": 7, "t": "இன்னும் தேடுங்கள்"}, {"w": 8, "t": "அருளை"}, {"w": 9, "t": "(the) Bounty"}, {"w": 10, "t": "அல்லாஹ்வின்"}, {"w": 11, "t": "இன்னும் நீங்கள் நினைவு கூருங்கள்!"}, {"w": 12, "t": "அல்லாஹ்வை"}, {"w": 13, "t": "அதிகம்"}, {"w": 14, "t": "நீங்கள் வெற்றி அடைவீர்கள்"}, {"w": 15, "t": "succeed"}, {"w": 16, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவர்கள் பார்த்தால்"}, {"w": 2, "t": "they saw"}, {"w": 3, "t": "ஒரு வர்த்தகத்தையோ"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "ஒரு வேடிக்கையையோ"}, {"w": 6, "t": "அவர்கள் பிரிந்து சென்று விடுவார்கள்"}, {"w": 7, "t": "அதன் பக்கம்"}, {"w": 8, "t": "இன்னும் உம்மை விட்டு விடுவார்கள்"}, {"w": 9, "t": "நின்றவராக"}, {"w": 10, "t": "கூறுவீராக!"}, {"w": 11, "t": "அல்லாஹ்விடம் உள்ளதுதான்"}, {"w": 12, "t": "(is) with"}, {"w": 13, "t": "Allah"}, {"w": 14, "t": "மிகச் சிறந்ததாகும்"}, {"w": 15, "t": "வேடிக்கையை விடவும்"}, {"w": 16, "t": "the sport"}, {"w": 17, "t": "வர்த்தகத்தை விடவும்"}, {"w": 18, "t": "(any) transaction"}, {"w": 19, "t": "அல்லாஹ்தான்"}, {"w": 20, "t": "மிகச் சிறந்தவன்"}, {"w": 21, "t": "உணவளிப்பவர்களில்"}, {"w": 22, "t": "(11)"}]}]}