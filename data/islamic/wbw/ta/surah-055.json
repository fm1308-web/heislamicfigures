{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "விசாலமான கருணையாளன்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவன் கற்பித்தான்"}, {"w": 2, "t": "குர்ஆனை"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "படைத்தான்"}, {"w": 2, "t": "மனிதனை"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவனுக்குகற்பித்தான்"}, {"w": 2, "t": "தெளிவான விளக்கங்களை"}, {"w": 3, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "சூரியனும்"}, {"w": 2, "t": "சந்திரனும்"}, {"w": 3, "t": "ஒரு கணக்கில் ஓடுகின்றன"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "செடிகொடிகளும்"}, {"w": 2, "t": "மரங்களும்"}, {"w": 3, "t": "சிரம் பணிகின்றன"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "வானத்தை"}, {"w": 2, "t": "அதை உயர்த்தினான்"}, {"w": 3, "t": "இன்னும் அமைத்தான்"}, {"w": 4, "t": "தராசை"}, {"w": 5, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நீங்கள் எல்லை மீறாதீர்கள்"}, {"w": 2, "t": "you may transgress"}, {"w": 3, "t": "தராசில்"}, {"w": 4, "t": "the balance"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நிறுத்துங்கள்!"}, {"w": 2, "t": "நிறுவையை"}, {"w": 3, "t": "நீதமாக"}, {"w": 4, "t": "நஷ்டப்படுத்தாதீர்கள்"}, {"w": 5, "t": "make deficient"}, {"w": 6, "t": "தராசில்"}, {"w": 7, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "பூமி"}, {"w": 2, "t": "அதை அமைத்தான்"}, {"w": 3, "t": "படைப்பினங்களுக்காக"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அதில் இருக்கின்றன"}, {"w": 2, "t": "பழங்களும்"}, {"w": 3, "t": "பேரீச்ச மரங்களும்"}, {"w": 4, "t": "குலைகளுடைய"}, {"w": 5, "t": "sheaths"}, {"w": 6, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "தானியங்களும்"}, {"w": 2, "t": "வைக்கோல் உடைய"}, {"w": 3, "t": "husk"}, {"w": 4, "t": "உணவுகளும்"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "படைத்தான்/மனிதனை"}, {"w": 2, "t": "the man"}, {"w": 3, "t": "சுடாத காய்ந்த களிமண்ணிலிருந்து"}, {"w": 4, "t": "clay"}, {"w": 5, "t": "சுட்ட களிமண்ணைப் போல்"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "இன்னும் படைத்தான்"}, {"w": 2, "t": "ஜின்களை"}, {"w": 3, "t": "நடு ஜுவாலையில் இருந்து"}, {"w": 4, "t": "a smokeless flame"}, {"w": 5, "t": "நெருப்பின்"}, {"w": 6, "t": "fire"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இறைவன்/இரு கிழக்கு திசைகளின்"}, {"w": 2, "t": "(of) the two Easts"}, {"w": 3, "t": "இன்னும் இறைவன்"}, {"w": 4, "t": "இரு மேற்கு திசைகளின்"}, {"w": 5, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவன் விட்டுவிட்டான்"}, {"w": 2, "t": "இரு கடல்களும்"}, {"w": 3, "t": "சந்திப்பதற்கு"}, {"w": 4, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அவ்விரண்டுக்கும் இடையில்"}, {"w": 2, "t": "தடை இருக்கிறது"}, {"w": 3, "t": "அவை இரண்டும் எல்லையைக் கடக்காது"}, {"w": 4, "t": "they transgress"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "உற்பத்தியாகின்றன"}, {"w": 2, "t": "அவை இரண்டிலிருந்தும்"}, {"w": 3, "t": "முத்தும்"}, {"w": 4, "t": "பவளமும்"}, {"w": 5, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவனுக்கே உரியன"}, {"w": 2, "t": "கப்பல்கள்"}, {"w": 3, "t": "விரிக்கப்பட்ட/கடலில்"}, {"w": 4, "t": "in"}, {"w": 5, "t": "the sea"}, {"w": 6, "t": "மலைகளைப் போல்"}, {"w": 7, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "எல்லோரும்"}, {"w": 2, "t": "எவர்கள்/அதன்மீது"}, {"w": 3, "t": "(is) on it"}, {"w": 4, "t": "அழிபவர்கள்தான்"}, {"w": 5, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நிலையாக நீடித்து இருக்கும்"}, {"w": 2, "t": "முகம்தான்"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "கண்ணியத்திற்கு(ம்) உரியவனான"}, {"w": 5, "t": "(of) Majesty"}, {"w": 6, "t": "பெரும் கம்பீரத்திற்கும்"}, {"w": 7, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அவனிடமே யாசிக்கின்றன"}, {"w": 2, "t": "வானங்களில் உள்ளவர்கள்"}, {"w": 3, "t": "(is) in"}, {"w": 4, "t": "the heavens"}, {"w": 5, "t": "இன்னும் பூமியில்"}, {"w": 6, "t": "ஒவ்வொரு நாளும்"}, {"w": 7, "t": "day"}, {"w": 8, "t": "அவன்இருக்கின்றான்"}, {"w": 9, "t": "ஒரு காரியத்தில்"}, {"w": 10, "t": "a matter"}, {"w": 11, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நாம் ஒதுங்குவோம்"}, {"w": 2, "t": "உங்களுக்காக"}, {"w": 3, "t": "மனித, ஜின் வர்க்கத்தினரே"}, {"w": 4, "t": "two classes"}, {"w": 5, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அருட்கொடைகளில் எதை"}, {"w": 2, "t": "(of the) favors"}, {"w": 3, "t": "உங்கள் இறைவனின்"}, {"w": 4, "t": "பொய்ப்பிக்கின்றீர்கள்"}, {"w": 5, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "சமூகத்த