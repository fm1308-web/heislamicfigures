{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "உமக்கு வந்ததா?"}, {"w": 2, "t": "(there) come to you"}, {"w": 3, "t": "செய்தி"}, {"w": 4, "t": "சூழக்கூடியதின்"}, {"w": 5, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "முகங்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "இழிவடையும்"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அனுபவிக்கும்"}, {"w": 2, "t": "களைப்படையும்"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "பற்றி எரியும்"}, {"w": 2, "t": "நெருப்பில்"}, {"w": 3, "t": "கடுமையாக எரியக்கூடிய"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "புகட்டப்படும்"}, {"w": 2, "t": "இருந்து"}, {"w": 3, "t": "ஊற்று"}, {"w": 4, "t": "கொதிக்கக்கூடிய"}, {"w": 5, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "உணவு/தவிர"}, {"w": 4, "t": "except"}, {"w": 5, "t": "விஷச் செடியிலிருந்து"}, {"w": 6, "t": "a bitter thorny plant"}, {"w": 7, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "கொழுக்க வைக்காது"}, {"w": 2, "t": "it nourishes"}, {"w": 3, "t": "இன்னும் போக்காது"}, {"w": 4, "t": "it avails"}, {"w": 5, "t": "பசியை"}, {"w": 6, "t": "hunger"}, {"w": 7, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "முகங்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "இன்புற்றிருக்கும்"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "தன் செயலுக்காக"}, {"w": 2, "t": "திருப்தியடைந்திருக்கும்"}, {"w": 3, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "சொர்க்கத்தில்"}, {"w": 2, "t": "a garden"}, {"w": 3, "t": "உயர்வான"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "செவியுறாது"}, {"w": 2, "t": "they will hear"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "வீண் பேச்சை"}, {"w": 5, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அதில் இருக்கும்"}, {"w": 2, "t": "ஊற்று"}, {"w": 3, "t": "ஓடக்கூடிய"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அதில் இருக்கும்"}, {"w": 2, "t": "கட்டில்கள்"}, {"w": 3, "t": "உயர்வான"}, {"w": 4, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் குவளைகள்"}, {"w": 2, "t": "(நிரப்பி) வைக்கப்பட்ட"}, {"w": 3, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "இன்னும் தலையணைகள்"}, {"w": 2, "t": "வரிசையாக வைக்கப்பட்ட"}, {"w": 3, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இன்னும் உயர்ரக விரிப்புகள்"}, {"w": 2, "t": "விரிக்கப்பட்ட"}, {"w": 3, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "பார்க்கமாட்டார்களா?"}, {"w": 2, "t": "they look"}, {"w": 3, "t": "பக்கம்"}, {"w": 4, "t": "ஒட்டகத்தின்"}, {"w": 5, "t": "எவ்வாறு"}, {"w": 6, "t": "அது படைக்கப்பட்டுள்ளது"}, {"w": 7, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இன்னும் பக்கம்"}, {"w": 2, "t": "வானத்தின்"}, {"w": 3, "t": "எவ்வாறு"}, {"w": 4, "t": "அது உயர்த்தப்பட்டுள்ளது"}, {"w": 5, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் பக்கம்"}, {"w": 2, "t": "மலைகளின்"}, {"w": 3, "t": "எவ்வாறு"}, {"w": 4, "t": "அது நிறுவப்பட்டுள்ளது"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இன்னும் பக்கம்"}, {"w": 2, "t": "பூமியின்"}, {"w": 3, "t": "எவ்வாறு"}, {"w": 4, "t": "அது விரிக்கப்பட்டுள்ளது"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "ஆகவே, அறிவுரை கூறுவீராக"}, {"w": 2, "t": "நீரெல்லாம்"}, {"w": 3, "t": "you"}, {"w": 4, "t": "அறிவுரை கூறுபவர்தான்"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நீர் இல்லை"}, {"w": 2, "t": "அவர்களை"}, {"w": 3, "t": "நிர்ப்பந்திப்பவராக"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "எனினும்"}, {"w": 2, "t": "யார்"}, {"w": 3, "t": "விலகினாரோ"}, {"w": 4, "t": "இன்னும் நிராகரித்தாரோ"}, {"w": 5, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவரை வேதனைசெய்வான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "வேதனையால்"}, {"w": 4, "t": "மிகப்பெரும்"}, {"w": 5, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம் பக்கம்தான்"}, {"w": 3, "t": "அவர்களின் திரும்புதல்"}, {"w": 4, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நிச்சயமாக நம்மீதே"}, {"w": 3, "t": "upon Us"}, {"w": 4, "t": "அவர்களை விசாரிப்பது"}, {"w": 5, "t": "(26)"}]}]}