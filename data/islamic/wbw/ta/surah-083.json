{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "கேடுதான்"}, {"w": 2, "t": "மோசடிக்காரர்களுக்கு"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "அவர்கள் அளந்து வாங்கும் போது"}, {"w": 3, "t": "they take a measure"}, {"w": 4, "t": "மக்களிடம்"}, {"w": 5, "t": "the people"}, {"w": 6, "t": "நிறைவாக வாங்குகின்றனர்"}, {"w": 7, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் அவர்கள் அவர்களுக்காக அளந்து கொடுக்கும் போது"}, {"w": 2, "t": "they give by measure (to) them"}, {"w": 3, "t": "அல்லது"}, {"w": 4, "t": "அவர்களுக்காக நிறுத்து கொடுக்கும் போது"}, {"w": 5, "t": "குறைத்துக் கொடுக்கிறார்கள்"}, {"w": 6, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நம்பவில்லையா?"}, {"w": 2, "t": "think"}, {"w": 3, "t": "அவர்கள்"}, {"w": 4, "t": "நிச்சயமாக தாங்கள்"}, {"w": 5, "t": "எழுப்பப்படுவோம்"}, {"w": 6, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "ஒரு நாளில்"}, {"w": 2, "t": "மகத்தான"}, {"w": 3, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "அந்நாளில்"}, {"w": 2, "t": "நிற்பார்கள்"}, {"w": 3, "t": "மக்கள்"}, {"w": 4, "t": "இறைவனுக்கு முன்"}, {"w": 5, "t": "அகிலத்தார்களின்"}, {"w": 6, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "நிச்சயமாக பதிவேடு"}, {"w": 3, "t": "(the) record"}, {"w": 4, "t": "தீயவர்களின்"}, {"w": 5, "t": "சிஜ்ஜீனில்தான் இருக்கும்"}, {"w": 6, "t": "Sijjin"}, {"w": 7, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் எது"}, {"w": 2, "t": "உமக்கு அறிவித்தது"}, {"w": 3, "t": "என்ன(வென்று)"}, {"w": 4, "t": "சிஜ்ஜீன்"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "ஒரு பதிவேடு"}, {"w": 2, "t": "எழுதப்பட்ட"}, {"w": 3, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "கேடுதான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பிப்பவர்களுக்கு"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "பொய்ப்பிக்கின்றனர்"}, {"w": 3, "t": "கூலி நாளை"}, {"w": 4, "t": "(of) the Judgment"}, {"w": 5, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் பொய்ப்பிக்க மாட்டார்"}, {"w": 2, "t": "can deny"}, {"w": 3, "t": "அதை"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "எல்லோரையும்"}, {"w": 6, "t": "வரம்பு மீறுகிறவன்"}, {"w": 7, "t": "பெரும் பாவி"}, {"w": 8, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "ஓதப்பட்டால்"}, {"w": 2, "t": "are recited"}, {"w": 3, "t": "அவன் மீது"}, {"w": 4, "t": "நம் வசனங்கள்"}, {"w": 5, "t": "கூறுகிறான்"}, {"w": 6, "t": "கட்டுக் கதைகள்"}, {"w": 7, "t": "முன்னோரின்"}, {"w": 8, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "மாறாக"}, {"w": 3, "t": "மூடின"}, {"w": 4, "t": "மீது"}, {"w": 5, "t": "அவர்களின் உள்ளங்கள்"}, {"w": 6, "t": "எது/இருந்தார்கள்"}, {"w": 7, "t": "they used to"}, {"w": 8, "t": "செய்கிறார்கள்"}, {"w": 9, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "அவர்களுடைய இறைவனை விட்டு"}, {"w": 4, "t": "their Lord"}, {"w": 5, "t": "அந்நாளில்"}, {"w": 6, "t": "தடுக்கப்பட்டவர்கள்தான்"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "எரியக் கூடியவர்கள்தான்"}, {"w": 4, "t": "ஜஹீம் என்ற நரகத்தில்"}, {"w": 5, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "கூறப்படும்"}, {"w": 3, "t": "இதுதான்"}, {"w": 4, "t": "எது"}, {"w": 5, "t": "இருந்தீர்கள்"}, {"w": 6, "t": "அதை"}, {"w": 7, "t": "நீங்கள் பொய்ப்பித்தீர்கள்"}, {"w": 8, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "நிச்சயமாக பதிவேடு"}, {"w": 3, "t": "(the) record"}, {"w": 4, "t": "நல்லோரின்"}, {"w": 5, "t": "இல்லிய்யூனில்தான்"}, {"w": 6, "t": "Illiyin"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "எது"}, {"w": 2, "t": "உமக்கு அறிவித்தது"}, {"w": 3, "t": "என்ன(வென்று)"}, {"w": 4, "t": "இல்லிய்யூன்"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "ஒரு பதிவேடு"}, {"w": 2, "t": "எழுதப்பட்ட"}, {"w": 3, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அதைக் கண்காணிக்கிறார்கள்"}, {"w": 2, "t": "நெருக்கமானவர்கள்"}, {"w": 3, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நல்லோர்"}, {"w": 3, "t": "நயீம் என்ற சொர்க்கத்தில்"}, {"w": 4, "t": "bliss"}, {"w": 5, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "மீது"}, {"w": 2, "t": "கட்டில்கள்"}, {"w": 3, "t": "பார்ப்பார்கள்"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அறிவீர்"}, {"w": 2, "t": "அவர்களின் முகங்களில்"}, {"w": 3, "t": "their faces"}, {"w": 4, "t": "செழிப்பை"}, {"w": 5, "t": "இன்பத்தின்"}, {"w": 6, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "புகட்டப்படுவார்கள்"}, {"w": 2, "t": "மதுவிலிருந்து"}, {"w": 3, "t": "a pure wine"}, {"w": 4, "t": "முத்திரையிடப்பட்ட"}, {"w": 5, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அதன் முத்திரை"}, {"w": 2, "t": "கஸ்தூரி"}, {"w": 3, "t": "இன்னும் அதில்"}, {"w": 4, "t": "that"}, {"w": 5, "t": "ஆகவே ஆசை வைக்கவும்"}, {"w": 6, "t": "ஆசை வைப்போர்"}, {"w": 7, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "இன்னும் அதன் கலவை"}, {"w": 2, "t": "இருந்து"}, {"w": 3, "t": "தஸ்னீம்"}, {"w": 4, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "ஒரு நீரூற்று"}, {"w": 2, "t": "அதில்பருகுவார்கள்"}, {"w": 3, "t": "from it"}, {"w": 4, "t": "நெருக்கமாக்கப்பட்டவர்கள்"}, {"w": 5, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "குற்றம் புரிந்தவர்கள்"}, {"w": 3, "t": "committed crimes"}, {"w": 4, "t": "இருந்தார்கள்"}, {"w": 5, "t": "நம்பிக்கையாளர்களைப் பார்த்து"}, {"w": 6, "t": "those who"}, {"w": 7, "t": "believed"}, {"w": 8, "t": "சிரிப்பவர்களாக"}, {"w": 9, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "இன்னும் அவர்கள் கடந்து செல்லும் போது"}, {"w": 2, "t": "they passed"}, {"w": 3, "t": "அவர்களை/கண் ஜாடை காட்டுகிறார்கள்"}, {"w": 4, "t": "they winked at one another"}, {"w": 5, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "இன்னும் அவர்கள் திரும்பும் போது"}, {"w": 2, "t": "they returned"}, {"w": 3, "t": "தங்கள் குடும்பத்தாரிடம்"}, {"w": 4, "t": "their people"}, {"w": 5, "t": "திரும்புகிறார்கள்"}, {"w": 6, "t": "மகிழ்ச்சியாளர்களாக"}, {"w": 7, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "இன்னும் அவர்கள் அவர்களைப் பார்க்கும் போது"}, {"w": 2, "t": "they saw them"}, {"w": 3, "t": "கூறுகிறார்கள்"}, {"w": 4, "t": "நிச்சயமாக"}, {"w": 5, "t": "இவர்கள்"}, {"w": 6, "t": "வழிதவறியவர்கள்தான்"}, {"w": 7, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "இன்னும் இவர்கள் அனுப்பப்படவில்லையே"}, {"w": 2, "t": "they had been sent"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "கண்காணிப் பவர்களாக"}, {"w": 5, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "ஆகவே, இன்று"}, {"w": 2, "t": "நம்பிக்கையாளர்கள்"}, {"w": 3, "t": "believed "}, {"w": 4, "t": "நிராகரிப்பாளர்களைப் பார்த்து"}, {"w": 5, "t": "the disbelievers"}, {"w": 6, "t": "சிரிப்பார்கள்"}, {"w": 7, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "மீது"}, {"w": 2, "t": "கட்டில்கள்"}, {"w": 3, "t": "பார்ப்பார்கள்"}, {"w": 4, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "கூலி கொடுக்கப்பட்டார்களா?"}, {"w": 2, "t": "been rewarded"}, {"w": 3, "t": "நிராகரிப்பாளர்கள்"}, {"w": 4, "t": "எது"}, {"w": 5, "t": "இருந்தார்கள்"}, {"w": 6, "t": "செய்கிறார்கள்"}, {"w": 7, "t": "(36)"}]}]}