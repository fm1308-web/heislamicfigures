{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "தொடர்ச்சியாக வீசுகின்ற காற்றுகள் மீது சத்தியமாக!"}, {"w": 2, "t": "one after another"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அதிவேகமாக வீசுகின்ற புயல்காற்றுகள் மீது சத்தியமாக!"}, {"w": 2, "t": "violently"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "பரப்புகின்ற காற்றுகள் மீது சத்தியமாக!"}, {"w": 2, "t": "far and wide"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "தெளிவாக பிரித்துவிடக்கூடியவற்றின் மீது சத்தியமாக!"}, {"w": 2, "t": "(by the) Criterion"}, {"w": 3, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இறக்குகின்றவர்கள் மீது சத்தியமாக!"}, {"w": 2, "t": "(the) Reminder"}, {"w": 3, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "ஒரு காரணமாக"}, {"w": 2, "t": "அல்லது"}, {"w": 3, "t": "எச்சரிக்கையாக இருப்பதற்காக!"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிச்சயமாக நீங்கள் எச்சரிக்கப்படுவது"}, {"w": 2, "t": "you are promised"}, {"w": 3, "t": "நிகழ்ந்தே தீரும்"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நட்சத்திரங்கள் ஒளி மங்கிவிடும்போது"}, {"w": 2, "t": "the stars"}, {"w": 3, "t": "are obliterated"}, {"w": 4, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "வானம் பிளக்கப்படும் போது"}, {"w": 2, "t": "the heaven"}, {"w": 3, "t": "is cleft asunder"}, {"w": 4, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "மலைகள் சுக்கு நூறாக பொசுக்கப்படும்போது"}, {"w": 2, "t": "the mountains"}, {"w": 3, "t": "are blown away"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "தூதர்கள் ஒன்று சேர்க்கப்படும்போது"}, {"w": 2, "t": "the Messengers"}, {"w": 3, "t": "are gathered to their appointed time"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "எந்த நாளுக்காக?"}, {"w": 2, "t": "Day"}, {"w": 3, "t": "அவர்கள் தாமதிக்கப்பட்டு இருக்கிறார்கள்"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "தீர்ப்பு நாளுக்காக"}, {"w": 2, "t": "(of) Judgment"}, {"w": 3, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "உமக்குத் தெரியுமா?"}, {"w": 2, "t": "will make you know"}, {"w": 3, "t": "தீர்ப்பு நாள் என்னவென்று"}, {"w": 4, "t": "(is the) Day"}, {"w": 5, "t": "(of) the Judgment"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "நாம் அழிக்கவில்லையா?"}, {"w": 2, "t": "We destroy"}, {"w": 3, "t": "முன்னோர்களை"}, {"w": 4, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "பிறகு/அவர்களுக்கு பின்தொடர வைத்தோம்"}, {"w": 2, "t": "We follow them up"}, {"w": 3, "t": "பின்னோர்களை"}, {"w": 4, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "நாம் செய்வோம்"}, {"w": 3, "t": "குற்றவாளிகளுக்கு"}, {"w": 4, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நாசம்தான்!/அந்நாளில்"}, {"w": 2, "t": "that Day"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நாம் உங்களை படைக்கவில்லையா?"}, {"w": 2, "t": "We create you"}, {"w": 3, "t": "ஒரு நீரிலிருந்து"}, {"w": 4, "t": "a water"}, {"w": 5, "t": "பலவீனமான"}, {"w": 6, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அதை வைத்தோம்"}, {"w": 2, "t": "ஓர் இடத்தில்"}, {"w": 3, "t": "an abode"}, {"w": 4, "t": "உறுதியான"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "ஒரு தவணை வரை"}, {"w": 2, "t": "a period"}, {"w": 3, "t": "குறிப்பிட்ட"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நாம் திட்டமிட்டோம்"}, {"w": 2, "t": "நாமே சிறந்த திட்டமிடுபவர்கள்"}, {"w": 3, "t": "(are We to) measure"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நாம் ஆக்கவில்லையா?"}, {"w": 2, "t": "We made"}, {"w": 3, "t": "பூமியை"}, {"w": 4, "t": "ஒன்று சேர்க்கக்கூடியதாக"}, {"w": 5, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "உயிருள்ளவர்களையும்"}, {"w": 2, "t": "இறந்தவர்களையும்"}, {"w": 3, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நாம் ஆக்கினோம்"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "மலைகளை"}, {"w": 4, "t": "மிக பிரமாண்டமான"}, {"w": 5, "t": "இன்னும் உங்களுக்கு புகட்டினோம்"}, {"w": 6, "t": "நீரை"}, {"w": 7, "t": "மதுரமான"}, {"w": 8, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "செல்லுங்கள்"}, {"w": 2, "t": "எதன் பக்கம்"}, {"w": 3, "t": "what"}, {"w": 4, "t": "இருந்தீர்களோ"}, {"w": 5, "t": "அதை"}, {"w": 6, "t": "பொய்ப்பிப்பவர்களாக"}, {"w": 7, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "செல்லுங்கள்"}, {"w": 2, "t": "புகையின் பக்கம்"}, {"w": 3, "t": "a shadow"}, {"w": 4, "t": "உடைய/ மூன்று"}, {"w": 5, "t": "three"}, {"w": 6, "t": "கிளைகளை"}, {"w": 7, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நிழல்தரக் கூடியது அல்ல"}, {"w": 2, "t": "cool shade"}, {"w": 3, "t": "அது தடுக்காது"}, {"w": 4, "t": "availing"}, {"w": 5, "t": "ஜுவாலையை"}, {"w": 6, "t": "the flame"}, {"w": 7, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "நிச்சயமாக அது"}, {"w": 2, "t": "எறியும்"}, {"w": 3, "t": "நெருப்பு கங்குகளை"}, {"w": 4, "t": "மாளிகையைப் போல் உள்ள"}, {"w": 5, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "போல்/அவையோ"}, {"w": 2, "t": "ஒட்டகைகளை"}, {"w": 3, "t": "கரு மஞ்சள் நிற"}, {"w": 4, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "நாளாகும்"}, {"w": 3, "t": "அவர்கள் பேசாத"}, {"w": 4, "t": "they will speak"}, {"w": 5, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "அனுமதி தரப்படாது"}, {"w": 2, "t": "will it be permitted"}, {"w": 3, "t": "அவர்களுக்கு"}, {"w": 4, "t": "அவர்கள் காரணம் கூறுவதற்கு"}, {"w": 5, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "இது/நாளாகும்"}, {"w": 2, "t": "(is the) Day"}, {"w": 3, "t": "தீர்ப்பு"}, {"w": 4, "t": "உங்களை(யும்) ஒன்று சேர்த்துள்ளோம்"}, {"w": 5, "t": "முன்னோரையும்"}, {"w": 6, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "இருந்தால்"}, {"w": 2, "t": "is"}, {"w": 3, "t": "உங்களிடம்"}, {"w": 4, "t": "ஒரு சூழ்ச்சி"}, {"w": 5, "t": "எனக்கு சூழ்ச்சி செய்யுங்கள்"}, {"w": 6, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இறையச்சமுடையவர்கள்"}, {"w": 3, "t": "நிழல்களிலும்"}, {"w": 4, "t": "shades"}, {"w": 5, "t": "ஊற்றுகளிலும்"}, {"w": 6, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "பழங்களிலும்"}, {"w": 2, "t": "அவர்கள் விரும்புகின்ற"}, {"w": 3, "t": "they desire"}, {"w": 4, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "உண்ணுங்கள்"}, {"w": 2, "t": "இன்னும் பருகுங்கள்"}, {"w": 3, "t": "இன்பமாக"}, {"w": 4, "t": "for what"}, {"w": 5, "t": "நீங்கள் செய்துகொண்டிருந்தவற்றுக்கு பகரமாக"}, {"w": 6, "t": "do"}, {"w": 7, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இவ்வாறுதான்"}, {"w": 3, "t": "கூலி கொடுப்போம்"}, {"w": 4, "t": "நல்லறம் புரிபவர்களுக்கு"}, {"w": 5, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "உண்ணுங்கள்"}, {"w": 2, "t": "இன்புறுங்கள்"}, {"w": 3, "t": "கொஞ்ச காலம்"}, {"w": 4, "t": "நிச்சயமாக நீங்கள்"}, {"w": 5, "t": "குற்றவாளிகள்"}, {"w": 6, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "நாசம்தான்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "சொல்லப்பட்டால்"}, {"w": 2, "t": "it is said"}, {"w": 3, "t": "அவர்களுக்கு"}, {"w": 4, "t": "தொழுங்கள்"}, {"w": 5, "t": "தொழ மாட்டார்கள்"}, {"w": 6, "t": "they bow"}, {"w": 7, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "எந்த குர்ஆனை"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "பொய்ப்பித்தவர்களுக்கு"}, {"w": 4, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "எந்த குர்ஆனை"}, {"w": 2, "t": "statement"}, {"w": 3, "t": "இதற்குப் பின்னர்"}, {"w": 4, "t": "இவர்கள் நம்பிக்கை கொள்வார்கள்"}, {"w": 5, "t": "(50)"}]}]}