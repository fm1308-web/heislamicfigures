{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "துதிக்கின்றன"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "வானங்களில் உள்ளவை(யும்)"}, {"w": 4, "t": "(is) in"}, {"w": 5, "t": "the heavens"}, {"w": 6, "t": "பூமியில் உள்ளவையும்"}, {"w": 7, "t": "(is) in"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "அவன்தான்"}, {"w": 10, "t": "மிகைத்தவன்"}, {"w": 11, "t": "மகா ஞானவான்"}, {"w": 12, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "எவன்"}, {"w": 3, "t": "வெளியாக்கினான்"}, {"w": 4, "t": "நிராகரித்தவர்களை"}, {"w": 5, "t": "disbelieved"}, {"w": 6, "t": "வேதக்காரர்களில்"}, {"w": 7, "t": "(the) People"}, {"w": 8, "t": "(of) the Scripture"}, {"w": 9, "t": "அவர்களின் இல்லங்களில் இருந்து"}, {"w": 10, "t": "their homes"}, {"w": 11, "t": "முதல் முறை"}, {"w": 12, "t": "ஒன்று சேர்ப்பதற்காக"}, {"w": 13, "t": "நீங்கள் எண்ணவில்லை"}, {"w": 14, "t": "you think"}, {"w": 15, "t": "வெளியேறுவார்கள்"}, {"w": 16, "t": "they would leave"}, {"w": 17, "t": "அவர்கள் எண்ணினார்கள்"}, {"w": 18, "t": "நிச்சயமாக அவர்கள்"}, {"w": 19, "t": "தங்களை பாதுகாக்கும்"}, {"w": 20, "t": "தங்களது கோட்டைகள்"}, {"w": 21, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 22, "t": "Allah"}, {"w": 23, "t": "அவர்களிடம் வந்தான்"}, {"w": 24, "t": "அல்லாஹ்"}, {"w": 25, "t": "அவர்கள் கணித்துப் பார்க்காத விதத்தில்"}, {"w": 26, "t": "where"}, {"w": 27, "t": "not"}, {"w": 28, "t": "they expected"}, {"w": 29, "t": "இன்னும் போட்டான்"}, {"w": 30, "t": "அவர்களின் உள்ளங்களில்"}, {"w": 31, "t": "their hearts"}, {"w": 32, "t": "திகிலை"}, {"w": 33, "t": "நாசப்படுத்தினர்"}, {"w": 34, "t": "தங்கள் வீடுகளை"}, {"w": 35, "t": "தங்கள் கரங்களினாலும்"}, {"w": 36, "t": "கரங்களினாலும்"}, {"w": 37, "t": "முஃமின்களின்"}, {"w": 38, "t": "ஆகவே படிப்பினை பெறுங்கள்!"}, {"w": 39, "t": "அகப்பார்வை உடையவர்களே!"}, {"w": 40, "t": "(with) insight"}, {"w": 41, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "விதித்து இருக்கவில்லை என்றால்"}, {"w": 2, "t": "[that]"}, {"w": 3, "t": "(had) decreed"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "அவர்கள் மீது"}, {"w": 6, "t": "வெளியேறுவதை"}, {"w": 7, "t": "அவன் கண்டிப்பாக அவர்களை வேதனை செய்து இருப்பான்"}, {"w": 8, "t": "இவ்வுலகிலேயே"}, {"w": 9, "t": "the world"}, {"w": 10, "t": "இன்னும் அவர்களுக்கு"}, {"w": 11, "t": "மறுமையில்"}, {"w": 12, "t": "the Hereafter"}, {"w": 13, "t": "வேதனை உண்டு"}, {"w": 14, "t": "நரக(ம்)"}, {"w": 15, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அதற்கு காரணம் நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "(is) because [they]"}, {"w": 3, "t": "மாறுசெய்தார்கள்"}, {"w": 4, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 5, "t": "அவனது தூதருக்கும்"}, {"w": 6, "t": "யார்"}, {"w": 7, "t": "மாறுசெய்வாரோ"}, {"w": 8, "t": "அல்லாஹ்விற்கு"}, {"w": 9, "t": "நிச்சயமாக"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "கடுமையானவன்"}, {"w": 12, "t": "தண்டிப்பதில்"}, {"w": 13, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நீங்கள் வெட்டினாலும்"}, {"w": 2, "t": "you cut down"}, {"w": 3, "t": "பேரித்த மரங்களை"}, {"w": 4, "t": "(the) palm-trees"}, {"w": 5, "t": "அவர்கள்/அவற்றை நீங்கள் விட்டாலும்"}, {"w": 6, "t": "you left them"}, {"w": 7, "t": "நிற்பவையாக"}, {"w": 8, "t": "அவற்றின் வேர்களில்"}, {"w": 9, "t": "their roots"}, {"w": 10, "t": "உத்தரவின்படிதான்"}, {"w": 11, "t": "அல்லாஹ்வின்"}, {"w": 12, "t": "இன்னும் இழிவுபடுத்துவதற்காக"}, {"w": 13, "t": "பாவிகளை"}, {"w": 14, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "எதை உரிமையாக்கிக் கொடுத்தானோ"}, {"w": 2, "t": "(was) restored"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "தனது தூதருக்கு"}, {"w": 5, "t": "His Messenger"}, {"w": 6, "t": "அவர்களிடமிருந்து"}, {"w": 7, "t": "நீங்கள் ஓட்டவில்லை"}, {"w": 8, "t": "you made expedition"}, {"w": 9, "t": "அவற்றை அடைவதற்காக"}, {"w": 10, "t": "குதிரைகளையோ"}, {"w": 11, "t": "horses"}, {"w": 12, "t": "ஒட்டகங்களையோ"}, {"w": 13, "t": "camels"}, {"w": 14, "t": "என்றாலும்"}, {"w": 15, "t": "அல்லாஹ்"}, {"w": 16, "t": "சாட்டுகின்றான்"}, {"w": 17, "t": "தனது தூதர்களை"}, {"w": 18, "t": "தான் நாடுகின்றவர்கள் மீது"}, {"w": 19, "t": "whom"}, {"w": 20, "t": "He wills"}, {"w": 21, "t": "அல்லாஹ்"}, {"w": 22, "t": "எல்லாவற்றின் மீதும்"}, {"w": 23, "t": "every"}, {"w": 24, "t": "thing"}, {"w": 25, "t": "பேராற்றலுடையவன்"}, {"w": 26, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "சண்டையின்றி எதை உரிமையாக்கிக் கொடுத்தானோ"}, {"w": 2, "t": "(was) restored"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "தனது தூதருக்கு"}, {"w": 5, "t": "His Messenger"}, {"w": 6, "t": "ஊர்களில் உள்ளவர்களிடமிருந்து"}, {"w": 7, "t": "(the) people"}, {"w": 8, "t": "(of) the towns"}, {"w": 9, "t": "(அது) அல்லாஹ்விற்கும்"}, {"w": 10, "t": "தூதருக்கும்"}, {"w": 11, "t": "உறவினர்களுக்கும்"}, {"w": 12, "t": "(of) the kindred"}, {"w": 13, "t": "அனாதைகளுக்கும்"}, {"w": 14, "t": "ஏழைகளுக்கும்"}, {"w": 15, "t": "வழிப் போக்கர்களுக்கும்"}, {"w": 16, "t": "the wayfarer"}, {"w": 17, "t": "ஆகாமல் இருப்பதற்காகும்"}, {"w": 18, "t": "not"}, {"w": 19, "t": "it becomes"}, {"w": 20, "t": "சுற்றக்கூடிய பொருளாக"}, {"w": 21, "t": "மத்தியில்"}, {"w": 22, "t": "செல்வந்தர்களுக்கு"}, {"w": 23, "t": "உங்களில் உள்ள"}, {"w": 24, "t": "எதை உங்களுக்குக் கொடுத்தாரோ"}, {"w": 25, "t": "gives you"}, {"w": 26, "t": "தூதர்"}, {"w": 27, "t": "அதைப் பற்றிப் பிடியுங்கள்"}, {"w": 28, "t": "எதை உங்களுக்குத் தடுத்தாரோ"}, {"w": 29, "t": "he forbids you"}, {"w": 30, "t": "அதை விட்டு"}, {"w": 31, "t": "விலகிவிடுங்கள்"}, {"w": 32, "t": "இன்னும் பயந்து கொள்ளுங்கள்"}, {"w": 33, "t": "அல்லாஹ்வை"}, {"w": 34, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 35, "t": "Allah"}, {"w": 36, "t": "கடுமையானவன்"}, {"w": 37, "t": "தண்டிப்பதில்"}, {"w": 38, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஏழைகளுக்கு"}, {"w": 2, "t": "முஹாஜிர்கள்"}, {"w": 3, "t": "எவர்கள்/வெளியேற்றப்பட்டார்கள்"}, {"w": 4, "t": "were expelled"}, {"w": 5, "t": "தங்கள் இல்லங்களை விட்டும்"}, {"w": 6, "t": "their homes"}, {"w": 7, "t": "தங்கள் செல்வங்களை விட்டும்"}, {"w": 8, "t": "தேடுகிறார்கள்"}, {"w": 9, "t": "சிறப்பை(யும்)"}, {"w": 10, "t": "அல்லாஹ்வின்"}, {"w": 11, "t": "Allah"}, {"w": 12, "t": "பொருத்தத்தையும்"}, {"w": 13, "t": "உதவுகிறார்கள்"}, {"w": 14, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 15, "t": "அவனது தூதருக்கும்"}, {"w": 16, "t": "அவர்கள்தான்"}, {"w": 17, "t": "they"}, {"w": 18, "t": "உண்மையாளர்கள்"}, {"w": 19, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அமைத்துக் கொண்டவர்கள்"}, {"w": 2, "t": "settled"}, {"w": 3, "t": "வீடுகளை"}, {"w": 4, "t": "ஈமானையும்"}, {"w": 5, "t": "அவர்களுக்கு முன்னதாக"}, {"w": 6, "t": "before them"}, {"w": 7, "t": "நேசிக்கின்றார்கள்"}, {"w": 8, "t": "ஹிஜ்ரா செய்து வந்தவர்களை"}, {"w": 9, "t": "emigrated"}, {"w": 10, "t": "தங்களிடம்"}, {"w": 11, "t": "இன்னும் அவர்கள் காணமாட்டார்கள்"}, {"w": 12, "t": "they find"}, {"w": 13, "t": "தங்கள் நெஞ்சங்களில்"}, {"w": 14, "t": "their breasts"}, {"w": 15, "t": "எந்தத் தேவையையும்"}, {"w": 16, "t": "தங்களுக்கு கொடுக்கப்பட்டவற்றில்"}, {"w": 17, "t": "they were given"}, {"w": 18, "t": "தேர்ந்தெடுப்பார்கள்"}, {"w": 19, "t": "தங்களை விட"}, {"w": 20, "t": "themselves"}, {"w": 21, "t": "இருந்தாலும்"}, {"w": 22, "t": "was"}, {"w": 23, "t": "தங்களுக்கு"}, {"w": 24, "t": "கடுமையான தேவை"}, {"w": 25, "t": "யார்"}, {"w": 26, "t": "பாதுகாக்கப்படுவாரோ"}, {"w": 27, "t": "கருமித்தனத்தை விட்டும்"}, {"w": 28, "t": "தனது உள்ளத்தின்"}, {"w": 29, "t": "அவர்கள்தான்"}, {"w": 30, "t": "[they]"}, {"w": 31, "t": "வெற்றியாளர்கள்"}, {"w": 32, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "வந்தார்கள்"}, {"w": 3, "t": "இவர்களுக்கு பின்னர்"}, {"w": 4, "t": "after them"}, {"w": 5, "t": "கூறுவார்கள்"}, {"w": 6, "t": "எங்கள் இறைவா"}, {"w": 7, "t": "எங்களை(யும்) மன்னிப்பாயாக"}, {"w": 8, "t": "us"}, {"w": 9, "t": "எங்கள் சகோதரர்களையும்"}, {"w": 10, "t": "எவர்கள்"}, {"w": 11, "t": "எங்களை முந்தினார்கள்"}, {"w": 12, "t": "ஈமானில்"}, {"w": 13, "t": "ஆக்கிவிடாதே"}, {"w": 14, "t": "put"}, {"w": 15, "t": "எங்கள் உள்ளங்களில்"}, {"w": 16, "t": "our hearts"}, {"w": 17, "t": "குரோதத்தை"}, {"w": 18, "t": "நம்பிக்கை கொண்டவர்கள் மீது"}, {"w": 19, "t": "believed"}, {"w": 20, "t": "எங்கள் இறைவா"}, {"w": 21, "t": "நிச்சயமாக நீதான்"}, {"w": 22, "t": "மகா இரக்கமுள்ளவன்"}, {"w": 23, "t": "மகா கருணையாளன்"}, {"w": 24, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "நயவஞ்சகர்களை"}, {"w": 4, "t": "those who"}, {"w": 5, "t": "(were) hypocrites"}, {"w": 6, "t": "கூறுகின்றனர்"}, {"w": 7, "t": "தங்கள் சகோதரர்களுக்கு"}, {"w": 8, "t": "எவர்கள்"}, {"w": 9, "t": "நிராகரித்தனர்"}, {"w": 10, "t": "வேதக்காரர்களில்"}, {"w": 11, "t": "the People"}, {"w": 12, "t": "(of) the Scripture"}, {"w": 13, "t": "நீங்கள் வெளியேற்றப்பட்டால்"}, {"w": 14, "t": "you are expelled"}, {"w": 15, "t": "நிச்சயமாக நாங்களும் வெளியேறுவோம்"}, {"w": 16, "t": "உங்களுடன்"}, {"w": 17, "t": "நாங்கள் கட்டுப்பட மாட்டோம்"}, {"w": 18, "t": "we will obey"}, {"w": 19, "t": "உங்கள் விஷயத்தில்"}, {"w": 20, "t": "யாருக்கும்/எப்போதும்"}, {"w": 21, "t": "ever"}, {"w": 22, "t": "நீங்கள் போர் செய்யப்பட்டால்"}, {"w": 23, "t": "you are fought"}, {"w": 24, "t": "நிச்சயமாக நாங்கள் உங்களுக்கு உதவுவோம்"}, {"w": 25, "t": "அல்லாஹ்"}, {"w": 26, "t": "சாட்சி சொல்கிறான்"}, {"w": 27, "t": "நிச்சயமாக இவர்கள்"}, {"w": 28, "t": "பொய்யர்கள்தான்"}, {"w": 29, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவர்கள் வெளியேற்றப்பட்டால்"}, {"w": 2, "t": "இவர்கள் வெளியேற மாட்டார்கள்"}, {"w": 3, "t": "not"}, {"w": 4, "t": "அவர்களுடன்"}, {"w": 5, "t": "அவர்கள் போர் செய்யப்பட்டால்"}, {"w": 6, "t": "and if"}, {"w": 7, "t": "இவர்கள் அவர்களுக்கு உதவ மாட்டார்கள்"}, {"w": 8, "t": "not"}, {"w": 9, "t": "இவர்கள் அவர்களுக்கு உதவினாலும்"}, {"w": 10, "t": "And if"}, {"w": 11, "t": "இவர்களும் கண்டிப்பாக புறமுதுகுதான் காட்டுவார்கள்"}, {"w": 12, "t": "certainly they will turn"}, {"w": 13, "t": "பிறகு/இவர்கள் உதவி செய்யப்பட மாட்டார்கள்"}, {"w": 14, "t": "then"}, {"w": 15, "t": "not"}, {"w": 16, "t": "they will be helped"}, {"w": 17, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நீங்கள்"}, {"w": 2, "t": "கடுமையான பயதிற்குரியவர்கள்"}, {"w": 3, "t": "(in) fear"}, {"w": 4, "t": "அவர்களின் நெஞ்சங்களில்"}, {"w": 5, "t": "their breasts"}, {"w": 6, "t": "அல்லாஹ்வை விட"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "அதற்கு காரணம் நிச்சயமாக அவர்கள்"}, {"w": 9, "t": "(is) because they"}, {"w": 10, "t": "மக்கள்"}, {"w": 11, "t": "புரிய மாட்டார்கள்"}, {"w": 12, "t": "understand"}, {"w": 13, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "உங்களிடம் போர் புரிய மாட்டார்கள்"}, {"w": 2, "t": "will they fight you"}, {"w": 3, "t": "எல்லோரும் சேர்ந்து"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "பாதுகாப்பான ஊர்களில்"}, {"w": 6, "t": "towns"}, {"w": 7, "t": "fortified"}, {"w": 8, "t": "அல்லது"}, {"w": 9, "t": "பின்னால்"}, {"w": 10, "t": "behind"}, {"w": 11, "t": "சுவர்களுக்கு"}, {"w": 12, "t": "அவர்களின் பகைமை"}, {"w": 13, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 14, "t": "கடுமையாக"}, {"w": 15, "t": "நீர் அவர்களை எண்ணுகின்றீர்"}, {"w": 16, "t": "ஒன்றுசேர்ந்தவர்களாக"}, {"w": 17, "t": "அவர்களின் உள்ளங்களோ"}, {"w": 18, "t": "பலதரப்பட்டதாக"}, {"w": 19, "t": "அதற்கு காரணம் நிச்சயமாக அவர்கள்"}, {"w": 20, "t": "(is) because they"}, {"w": 21, "t": "மக்கள்/ நிச்சயமாக அவர்கள் சிந்தித்துப் புரியமாட்டார்கள்"}, {"w": 22, "t": "not"}, {"w": 23, "t": "they reason"}, {"w": 24, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "உதாரணத்தைப் போன்றுதான்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "இவர்களுக்கு முன்னர்"}, {"w": 4, "t": "before them"}, {"w": 5, "t": "சற்று"}, {"w": 6, "t": "அனுபவித்தார்களே"}, {"w": 7, "t": "கெடுதியை"}, {"w": 8, "t": "தங்கள் காரியத்தின்"}, {"w": 9, "t": "இன்னும் இவர்களுக்கு உண்டு"}, {"w": 10, "t": "தண்டனை"}, {"w": 11, "t": "வலி தரக்கூடியது"}, {"w": 12, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "உதாரணத்தைப் போன்றுதான்"}, {"w": 2, "t": "அந்த ஷைத்தானின்"}, {"w": 3, "t": "அவன் கூறியபோது"}, {"w": 4, "t": "he says"}, {"w": 5, "t": "மனிதனுக்கு"}, {"w": 6, "t": "நீ நிராகரித்து விடு"}, {"w": 7, "t": "அந்த மனிதன் நிராகரித்துவிடவே"}, {"w": 8, "t": "he disbelieves"}, {"w": 9, "t": "கூறிவிடுகிறான்"}, {"w": 10, "t": "நிச்சயமாக நான்"}, {"w": 11, "t": "நீங்கியவன்"}, {"w": 12, "t": "உன்னை விட்டு"}, {"w": 13, "t": "நிச்சயமாக நான்"}, {"w": 14, "t": "பயப்படுகிறேன்"}, {"w": 15, "t": "அல்லாஹ்வை"}, {"w": 16, "t": "இறைவனாகிய"}, {"w": 17, "t": "அகிலங்களின்"}, {"w": 18, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "ஆகிவிடும்"}, {"w": 2, "t": "அவ்விருவரின் முடிவு"}, {"w": 3, "t": "அவ்விருவரும்"}, {"w": 4, "t": "நரகத்தில்"}, {"w": 5, "t": "the Fire"}, {"w": 6, "t": "நிரந்தரமாக தங்குவார்கள்"}, {"w": 7, "t": "அதில்/இதுதான்"}, {"w": 8, "t": "And that"}, {"w": 9, "t": "கூலியாகும்"}, {"w": 10, "t": "அநியாயக்காரர்களின்"}, {"w": 11, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "you (who)"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "அஞ்சிக்கொள்ளுங்கள்"}, {"w": 5, "t": "அல்லாஹ்வை"}, {"w": 6, "t": "பார்த்துக் கொள்ளட்டும்"}, {"w": 7, "t": "ஓர் ஆன்மா/எதை அது முற்படுத்தி இருக்கிறது"}, {"w": 8, "t": "what"}, {"w": 9, "t": "it has sent forth"}, {"w": 10, "t": "மறுமைக்காக"}, {"w": 11, "t": "அஞ்சிக் கொள்ளுங்கள்!"}, {"w": 12, "t": "அல்லாஹ்வை"}, {"w": 13, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 14, "t": "Allah"}, {"w": 15, "t": "ஆழ்ந்தறிபவன்"}, {"w": 16, "t": "நீங்கள் செய்பவற்றை"}, {"w": 17, "t": "you do"}, {"w": 18, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "ஆகிவிடாதீர்கள்"}, {"w": 2, "t": "be"}, {"w": 3, "t": "மறந்தவர்களைப் போல்"}, {"w": 4, "t": "forgot"}, {"w": 5, "t": "அல்லாஹ்வை"}, {"w": 6, "t": "அவன் அவர்களுக்கு மறக்கச் செய்து விட்டான்/அவர்களையே"}, {"w": 7, "t": "themselves"}, {"w": 8, "t": "அவர்கள்தான்"}, {"w": 9, "t": "[they]"}, {"w": 10, "t": "பாவிகள்"}, {"w": 11, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "சமமாக மாட்டார்கள்"}, {"w": 2, "t": "equal"}, {"w": 3, "t": "நரகவாசிகளும்"}, {"w": 4, "t": "(of) the Fire"}, {"w": 5, "t": "சொர்க்க வாசிகளும்"}, {"w": 6, "t": "(of) Paradise"}, {"w": 7, "t": "சொர்க்கவாசிகள்தான்"}, {"w": 8, "t": "(of) Paradise"}, {"w": 9, "t": "they"}, {"w": 10, "t": "வெற்றியாளர்கள்"}, {"w": 11, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "நாம் இறக்கி இருந்தால்"}, {"w": 2, "t": "We (had) sent down"}, {"w": 3, "t": "இந்த குர்ஆனை"}, {"w": 4, "t": "Quran"}, {"w": 5, "t": "ஒரு மலையின் மீது"}, {"w": 6, "t": "a mountain"}, {"w": 7, "t": "நீர் அதைக் கண்டிருப்பீர்"}, {"w": 8, "t": "முற்றிலும் பணிந்ததாக(வும்)"}, {"w": 9, "t": "பிளந்து விடக்கூடியதாக(வும்)"}, {"w": 10, "t": "அச்சத்தால்"}, {"w": 11, "t": "(the) fear"}, {"w": 12, "t": "அல்லாஹ்வின்"}, {"w": 13, "t": "இந்த உதாரணங்கள்"}, {"w": 14, "t": "examples"}, {"w": 15, "t": "இவற்றை விவரிக்கின்றோம்"}, {"w": 16, "t": "மக்களுக்கு"}, {"w": 17, "t": "அவர்கள் சிந்திப்பதற்காக"}, {"w": 18, "t": "give thought"}, {"w": 19, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "எவன்"}, {"w": 4, "t": "அறவே இல்லை"}, {"w": 5, "t": "கடவுள்"}, {"w": 6, "t": "அவனைத் தவிர"}, {"w": 7, "t": "He"}, {"w": 8, "t": "நன்கறிந்தவன்"}, {"w": 9, "t": "மறைவானவற்றை(யும்)"}, {"w": 10, "t": "வெளிப்படையானவற்றையும்/அவன்தான்"}, {"w": 11, "t": "He"}, {"w": 12, "t": "பேரருளாளன்"}, {"w": 13, "t": "பேரன்பாளன்"}, {"w": 14, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அவன்தான்/அல்லாஹ்"}, {"w": 2, "t": "(is) Allah"}, {"w": 3, "t": "எவன்/ அறவே இல்லை"}, {"w": 4, "t": "(there is) no"}, {"w": 5, "t": "கடவுள்"}, {"w": 6, "t": "அவனைத் தவிர"}, {"w": 7, "t": "He"}, {"w": 8, "t": "அரசன்"}, {"w": 9, "t": "மகா தூயவன்"}, {"w": 10, "t": "ஈடேற்றம் அளிப்பவன்"}, {"w": 11, "t": "அபயமளிப்பவன்"}, {"w": 12, "t": "பாதுகாப்பவன்"}, {"w": 13, "t": "மிகைத்தவன்"}, {"w": 14, "t": "அடக்கி ஆள்பவன்"}, {"w": 15, "t": "பெருமைக்குரியவன்"}, {"w": 16, "t": "மகா பரிசுத்தமானவன்"}, {"w": 17, "t": "அல்லாஹ்"}, {"w": 18, "t": "அவர்கள் இணைவைப்பவற்றை விட்டும்"}, {"w": 19, "t": "they associate (with Him)"}, {"w": 20, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "படைப்பவன்"}, {"w": 4, "t": "உருவாக்குபவன்"}, {"w": 5, "t": "உருவம்அமைப்பவன்"}, {"w": 6, "t": "அவனுக்கே உரியன"}, {"w": 7, "t": "பெயர்கள்"}, {"w": 8, "t": "மிக அழகிய"}, {"w": 9, "t": "துதிக்கின்றன"}, {"w": 10, "t": "அவனையே"}, {"w": 11, "t": "வானங்களில் உள்ளவை"}, {"w": 12, "