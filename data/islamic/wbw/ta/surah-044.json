{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "ஹா மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இந்த வேதத்தின் மீது சத்தியமாக!"}, {"w": 2, "t": "தெளிவான(து)"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இதை இறக்கினோம்"}, {"w": 3, "t": "ஓர் இரவில்"}, {"w": 4, "t": "a Night"}, {"w": 5, "t": "அருள்நிறைந்த(து)"}, {"w": 6, "t": "நிச்சயமாக நாம்"}, {"w": 7, "t": "இருந்தோம்"}, {"w": 8, "t": "அச்சமூட்டி எச்சரிப்பவர்களாக"}, {"w": 9, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இதில்தான்"}, {"w": 2, "t": "முடிவு செய்யப்படுகின்றன"}, {"w": 3, "t": "எல்லாக்காரியங்களும்"}, {"w": 4, "t": "affair"}, {"w": 5, "t": "ஞானமிக்க(து)"}, {"w": 6, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "கட்டளையின்படி"}, {"w": 2, "t": "நம்மிடமிருந்து"}, {"w": 3, "t": "Us"}, {"w": 4, "t": "நிச்சயமாக நாம்"}, {"w": 5, "t": "இருந்தோம்"}, {"w": 6, "t": "தூதராக அனுப்பக்கூடியவர்களாகவே"}, {"w": 7, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "ஓர் அருளாக"}, {"w": 2, "t": "உமது இறைவனிடமிருந்து"}, {"w": 3, "t": "your Lord"}, {"w": 4, "t": "நிச்சயமாக"}, {"w": 5, "t": "அவன்தான்"}, {"w": 6, "t": "நன்கு செவியுறுபவன்"}, {"w": 7, "t": "நன்கறிந்தவன்"}, {"w": 8, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இறைவனாவான்"}, {"w": 2, "t": "வானங்கள்/இன்னும் பூமி"}, {"w": 3, "t": "and the earth"}, {"w": 4, "t": "இன்னும் அவை இரண்டிற்கு மத்தியில் உள்ளவற்றின்"}, {"w": 5, "t": "(is) between both of them"}, {"w": 6, "t": "நீங்கள் உறுதி கொள்பவர்களாக இருந்தால்"}, {"w": 7, "t": "you are"}, {"w": 8, "t": "certain"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அறவே இல்லை"}, {"w": 2, "t": "வணக்கத்திற்குரியவன்"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "அவனை"}, {"w": 5, "t": "உயிர்ப்பிக்கின்றான்"}, {"w": 6, "t": "இன்னும் மரணிக்க வைக்கிறான்"}, {"w": 7, "t": "உங்கள் இறைவனும்"}, {"w": 8, "t": "இறைவனும்"}, {"w": 9, "t": "உங்கள் மூதாதைகளின்"}, {"w": 10, "t": "முன்னோர்களான"}, {"w": 11, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "சந்தேகத்தில்"}, {"w": 4, "t": "doubt "}, {"w": 5, "t": "விளையாடுகின்றனர்"}, {"w": 6, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "ஆகவே, எதிர்ப்பார்ப்பீராக!"}, {"w": 2, "t": "நாளை"}, {"w": 3, "t": "வருகின்ற(து)"}, {"w": 4, "t": "வானம்"}, {"w": 5, "t": "புகையைக் கொண்டு"}, {"w": 6, "t": "தெளிவான(து)"}, {"w": 7, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அது சூழ்ந்துகொள்ளும்"}, {"w": 2, "t": "மக்களை"}, {"w": 3, "t": "இது"}, {"w": 4, "t": "வேதனையாகும்"}, {"w": 5, "t": "வலி தரக்கூடிய(து)"}, {"w": 6, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "எங்கள் இறைவா!"}, {"w": 2, "t": "அகற்றி விடுவாயாக"}, {"w": 3, "t": "எங்களை விட்டு"}, {"w": 4, "t": "வேதனையை"}, {"w": 5, "t": "நிச்சயமாக நாங்கள்"}, {"w": 6, "t": "நம்பிக்கையாளர்கள்"}, {"w": 7, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "எப்படி?"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "நல்லறிவு பெறுவது"}, {"w": 4, "t": "திட்டமாக"}, {"w": 5, "t": "வந்தார் அவர்களிடம்"}, {"w": 6, "t": "ஒரு தூதர்"}, {"w": 7, "t": "தெளிவான(வர்)"}, {"w": 8, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "அவர்கள் விலகிவிட்டனர்"}, {"w": 3, "t": "அவரை விட்டு"}, {"w": 4, "t": "இன்னும் , கூறினர்"}, {"w": 5, "t": "கற்பிக்கப்பட்டவர்"}, {"w": 6, "t": "பைத்தியக்காரர்"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "நீக்குவோம்"}, {"w": 3, "t": "இந்த வேதனையை"}, {"w": 4, "t": "கொஞ்சம்"}, {"w": 5, "t": "நிச்சயமாக நீங்கள்"}, {"w": 6, "t": "திரும்புவீர்கள்"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "தாக்குவோம்"}, {"w": 3, "t": "தாக்குதல்"}, {"w": 4, "t": "பெரிய"}, {"w": 5, "t": "நிச்சயமாக நாம்"}, {"w": 6, "t": "பழிவாங்குவோம்"}, {"w": 7, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "சோதித்தோம்"}, {"w": 3, "t": "இவர்களுக்கு முன்னர்"}, {"w": 4, "t": "மக்களை"}, {"w": 5, "t": "ஃபிர்அவ்னுடைய"}, {"w": 6, "t": "அவர்களிடம் வந்தார்"}, {"w": 7, "t": "ஒரு தூதர்"}, {"w": 8, "t": "கண்ணியமான(வர்)"}, {"w": 9, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "ஒப்படைத்துவிடுங்கள்!"}, {"w": 2, "t": "Deliver"}, {"w": 3, "t": "என்னிடம்"}, {"w": 4, "t": "அல்லாஹ்வின் அடியார்களை"}, {"w": 5, "t": "(of) Allah"}, {"w": 6, "t": "நிச்சயமாக நான்"}, {"w": 7, "t": "உங்களுக்கு"}, {"w": 8, "t": "தூதர்"}, {"w": 9, "t": "நம்பிக்கைக்குரிய(வர்)"}, {"w": 10, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அழிச்சாட்டியம் செய்யாதீர்கள்"}, {"w": 2, "t": "(do) not"}, {"w": 3, "t": "exalt yourselves"}, {"w": 4, "t": "அல்லாஹ்விற்கு முன்"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "நிச்சயமாக நான்"}, {"w": 7, "t": "உங்களிடம் வருவேன்"}, {"w": 8, "t": "ஆதாரத்தைக் கொண்டு"}, {"w": 9, "t": "தெளிவான(து)"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "பாதுகாவல் தேடினேன்"}, {"w": 3, "t": "எனது இறைவனிடம்"}, {"w": 4, "t": "இன்னும் உங்கள் இறைவனிடம்"}, {"w": 5, "t": "நீங்கள் என்னை கொல்வதில் இருந்து"}, {"w": 6, "t": "you stone me"}, {"w": 7, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "நீங்கள் என்னை நம்பிக்கை கொள்ளவில்லை என்றால்"}, {"w": 2, "t": "not"}, {"w": 3, "t": "you believe"}, {"w": 4, "t": "me"}, {"w": 5, "t": "என்னை விட்டு விலகிவிடுங்கள்"}, {"w": 6, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "அவர் அழைத்தார்"}, {"w": 2, "t": "தனது இறைவனை"}, {"w": 3, "t": "நிச்சயமாக/இவர்கள்"}, {"w": 4, "t": "these"}, {"w": 5, "t": "மக்கள்"}, {"w": 6, "t": "குற்றம் செய்கின்றவர்கள்"}, {"w": 7, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நீங்கள் அழைத்துச் செல்லுங்கள்"}, {"w": 2, "t": "என் அடியார்களை"}, {"w": 3, "t": "இரவில்"}, {"w": 4, "t": "நிச்சயமாக நீங்கள்"}, {"w": 5, "t": "பின்தொடரப்படுவீர்கள்"}, {"w": 6, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "விட்டுவிடுங்கள்!"}, {"w": 2, "t": "கடலை"}, {"w": 3, "t": "அமைதியாக"}, {"w": 4, "t": "நிச்சயமாக அவர்கள்"}, {"w": 5, "t": "ராணுவம்"}, {"w": 6, "t": "மூழ்கடிக்கப்படுகின்ற"}, {"w": 7, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "விட்டுச் சென்றார்கள்"}, {"w": 3, "t": "தோட்டங்களையும்"}, {"w": 4, "t": "gardens"}, {"w": 5, "t": "ஊற்றுகளையும்"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "விவசாய நிலங்களையும்"}, {"w": 2, "t": "இடங்களையும்"}, {"w": 3, "t": "கண்ணியமான"}, {"w": 4, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "வசதிகளையும்"}, {"w": 2, "t": "இருந்த(னர்)"}, {"w": 3, "t": "அவற்றில்"}, {"w": 4, "t": "இன்புற்றவர்களாக"}, {"w": 5, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இப்படித்தான்"}, {"w": 2, "t": "இவற்றை சொந்தமாக்கினோம்"}, {"w": 3, "t": "மக்களுக்கு/வேறு"}, {"w": 4, "t": "another"}, {"w": 5, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அழவில்லை"}, {"w": 2, "t": "wept"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "வானமும்"}, {"w": 5, "t": "பூமியும்"}, {"w": 6, "t": "அவர்கள் இருக்கவில்லை"}, {"w": 7, "t": "they were"}, {"w": 8, "t": "தவணைத் தரப்படுபவர்களாக(வும்)"}, {"w": 9, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் காப்பாற்றினோம்"}, {"w": 3, "t": "இஸ்ரவேலர்களை"}, {"w": 4, "t": "(the) Children of Israel"}, {"w": 5, "t": "வேதனையிலிருந்து"}, {"w": 6, "t": "the punishment"}, {"w": 7, "t": "இழிவுபடுத்தும்"}, {"w": 8, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "ஃபிர்அவ்னிடமிருந்து"}, {"w": 2, "t": "Firaun"}, {"w": 3, "t": "நிச்சயமாக அவன்"}, {"w": 4, "t": "இருந்தான்"}, {"w": 5, "t": "அழிச்சாட்டியம் செய்பவனாக(வும்)"}, {"w": 6, "t": "வரம்புமீறிகளில்"}, {"w": 7, "t": "the transgressors"}, {"w": 8, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "திட்டவட்டமாக அவர்களை நாம் தேர்ந்தெடுத்தோம்"}, {"w": 2, "t": "We chose them"}, {"w": 3, "t": "அறிந்தே"}, {"w": 4, "t": "knowledge"}, {"w": 5, "t": "அகிலத்தாரை விட"}, {"w": 6, "t": "the worlds"}, {"w": 7, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "அவர்களுக்கு நாம் கொடுத்தோம்"}, {"w": 2, "t": "அத்தாட்சிகளில்"}, {"w": 3, "t": "the Signs"}, {"w": 4, "t": "எது/அதில்/சோதனை"}, {"w": 5, "t": "in it"}, {"w": 6, "t": "(was) a trial"}, {"w": 7, "t": "தெளிவான(து)"}, {"w": 8, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இவர்கள்"}, {"w": 3, "t": "கூறுகின்றனர்"}, {"w": 4, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இது இல்லை"}, {"w": 2, "t": "it"}, {"w": 3, "t": "நமது மரணமே தவிர"}, {"w": 4, "t": "our death"}, {"w": 5, "t": "முதல்"}, {"w": 6, "t": "இன்னும் நாங்கள் இல்லை"}, {"w": 7, "t": "we"}, {"w": 8, "t": "எழுப்பப்படுபவர்களாக"}, {"w": 9, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "எங்கள் மூதாதைகளைக் கொண்டு வாருங்கள்!"}, {"w": 2, "t": "our forefathers"}, {"w": 3, "t": "நீங்கள் இருந்தால்"}, {"w": 4, "t": "you are"}, {"w": 5, "t": "உண்மையாளர்களாக"}, {"w": 6, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இவர்கள் சிறந்தவர்களா"}, {"w": 2, "t": "better"}, {"w": 3, "t": "மக்களா?"}, {"w": 4, "t": "(the) people"}, {"w": 5, "t": "துப்பஃ உடைய"}, {"w": 6, "t": "இன்னும் இவர்களுக்கு முன்னுள்ளவர்களா?"}, {"w": 7, "t": "before them"}, {"w": 8, "t": "before them"}, {"w": 9, "t": "அவர்களை நாம் அழித்துவிட்டோம்"}, {"w": 10, "t": "நிச்சயமாக அவர்கள்"}, {"w": 11, "t": "இருந்தனர்"}, {"w": 12, "t": "குற்றவாளிகளாக"}, {"w": 13, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "நாம் படைக்கவில்லை"}, {"w": 2, "t": "We created"}, {"w": 3, "t": "வானங்களையும்"}, {"w": 4, "t": "பூமியையும்"}, {"w": 5, "t": "அவை இரண்டுக்கும் இடையில் உள்ளவற்றையும்"}, {"w": 6, "t": "(is) between them"}, {"w": 7, "t": "விளையாட்டாக"}, {"w": 8, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "அவ்விரண்டையும் நாம் படைக்கவில்லை"}, {"w": 2, "t": "We created both of them"}, {"w": 3, "t": "உண்மையான காரணத்திற்கே தவிர"}, {"w": 4, "t": "in [the] truth"}, {"w": 5, "t": "என்றாலும்"}, {"w": 6, "t": "அதிகமானவர்கள் அவர்களில்"}, {"w": 7, "t": "அறியமாட்டார்கள்"}, {"w": 8, "t": "know"}, {"w": 9, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நிச்சயமாக தீர்ப்பு நாள்"}, {"w": 2, "t": "(the) Day of Judgment"}, {"w": 3, "t": "(the) Day of Judgment"}, {"w": 4, "t": "இவர்கள் அனைவரின் நேரம் குறிக்கப்பட்ட நாளாகும்"}, {"w": 5, "t": "all"}, {"w": 6, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அந்நாளில்"}, {"w": 2, "t": "தடுக்க மாட்டான்"}, {"w": 3, "t": "will avail"}, {"w": 4, "t": "நண்பன்"}, {"w": 5, "t": "நண்பனை விட்டு"}, {"w": 6, "t": "a relation"}, {"w": 7, "t": "எதையும்"}, {"w": 8, "t": "இன்னும் அவர்கள் உதவி செய்யப்பட மாட்டார்கள்"}, {"w": 9, "t": "they"}, {"w": 10, "t": "will be helped"}, {"w": 11, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "எவர்கள் (மீது)/கருணை புரிந்தான்"}, {"w": 3, "t": "Allah has mercy"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "நிச்சயமாக அவன்தான்"}, {"w": 6, "t": "[He]"}, {"w": 7, "t": "மிகைத்தவன்"}, {"w": 8, "t": "மகா கருணையாளன்"}, {"w": 9, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "நிச்சயமாக மரம்"}, {"w": 2, "t": "(the) tree"}, {"w": 3, "t": "ஸக்கூம்"}, {"w": 4, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "உணவாகும்"}, {"w": 2, "t": "பாவிகளின்"}, {"w": 3, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "உருக்கப்பட்ட செம்பைப் போல் இருக்கும்"}, {"w": 2, "t": "அது கொதிக்கும்"}, {"w": 3, "t": "வயிறுகளில்"}, {"w": 4, "t": "the bellies"}, {"w": 5, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "கொதிப்பதைப் போல்"}, {"w": 2, "t": "கொதிக்கின்ற தண்ணீர்"}, {"w": 3, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "அவனைப் பிடியுங்கள்!"}, {"w": 2, "t": "அவனை இழுத்து வாருங்கள்!"}, {"w": 3, "t": "நடுவில்"}, {"w": 4, "t": "(the) midst"}, {"w": 5, "t": "நரகத்தின்"}, {"w": 6, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "ஊற்றுங்கள்"}, {"w": 3, "t": "மேல்"}, {"w": 4, "t": "அவனது தலைக்கு"}, {"w": 5, "t": "வேதனையை"}, {"w": 6, "t": "(the) punishment"}, {"w": 7, "t": "கொதிக்கின்ற நீரின்"}, {"w": 8, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "நீ சுவை!"}, {"w": 2, "t": "நிச்சயமாக நீதான்"}, {"w": 3, "t": "[you] (were)"}, {"w": 4, "t": "கண்ணியமானவன்"}, {"w": 5, "t": "மதிப்பிற்குரியவன்"}, {"w": 6, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "நிச்சயமாக இதுதான்"}, {"w": 2, "t": "this"}, {"w": 3, "t": "எது/இருந்தீர்கள்/அதை"}, {"w": 4, "t": "you used to"}, {"w": 5, "t": "[about it]"}, {"w": 6, "t": "சந்தேகிப்பவர்களாக"}, {"w": 7, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இறையச்சமுள்ளவர்கள்"}, {"w": 3, "t": "இடத்தில்"}, {"w": 4, "t": "a place"}, {"w": 5, "t": "பாதுகாப்பான"}, {"w": 6, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "சொர்க்கங்களில்"}, {"w": 2, "t": "gardens"}, {"w": 3, "t": "இன்னும் ஊற்றுகளில் இருப்பார்கள்"}, {"w": 4, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "அணிவார்கள்"}, {"w": 2, "t": "மென்மையான பட்டு"}, {"w": 3, "t": "fine silk"}, {"w": 4, "t": "இன்னும் தடிப்பமான பட்டு ஆடைகளை"}, {"w": 5, "t": "ஒருவரை ஒருவர் பார்த்தவர்களாக"}, {"w": 6, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "இன்னும் அவர்களுக்கு நாம் மணமுடித்து வைப்போம்"}, {"w": 3, "t": "வெண்மையான கண்ணிகளை"}, {"w": 4, "t": "கண்ணழகிகளான"}, {"w": 5, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "கேட்பார்கள்"}, {"w": 2, "t": "அதில்/எல்லா"}, {"w": 3, "t": "for every (kind)"}, {"w": 4, "t": "பழங்களையும்"}, {"w": 5, "t": "நிம்மதியானவர்களாக"}, {"w": 6, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "சுவைக்க மாட்டார்கள்"}, {"w": 2, "t": "they will taste"}, {"w": 3, "t": "அதில்/மரணத்தை"}, {"w": 4, "t": "the death"}, {"w": 5, "t": "மரணத்தை தவிர"}, {"w": 6, "t": "the death"}, {"w": 7, "t": "முதல்"}, {"w": 8, "t": "இன்னும் அவன் அவர்களைப் பாதுகாத்தான்"}, {"w": 9, "t": "வேதனையை விட்டும்"}, {"w": 10, "t": "நரகத்தின்"}, {"w": 11, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "அருளினால்"}, {"w": 2, "t": "உமது இறைவனின்"}, {"w": 3, "t": "your Lord"}, {"w": 4, "t": "இதுதான்"}, {"w": 5, "t": "it"}, {"w": 6, "t": "மகத்தான வெற்றி"}, {"w": 7, "t": "the great"}, {"w": 8, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "இதை நாம் இலேசாக்கினோம்/உமது மொழியில்"}, {"w": 2, "t": "We have made it easy"}, {"w": 3, "t": "in your tongue"}, {"w": 4, "t": "அவர்கள் நல்லுபதேசம் பெறுவதற்காக"}, {"w": 5, "t": "take heed"}, {"w": 6, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "ஆகவே, நீர் எதிர்பார்த்திருப்பீராக!"}, {"w": 2, "t": "நிச்சயமாக அவர்களும்"}, {"w": 3, "t": "எதிர்பார்க்கின்றார்கள்"}, {"w": 4, "t": "(59)"}]}]}