{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "துதித்து தூய்மைப் படுத்துவீராக"}, {"w": 2, "t": "பெயரை"}, {"w": 3, "t": "உம் இறைவனின்"}, {"w": 4, "t": "மிக உயர்ந்தவனாகிய"}, {"w": 5, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவன்தான் படைத்தான்"}, {"w": 2, "t": "created"}, {"w": 3, "t": "இன்னும் ஒழுங்கு படுத்தினான்"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அவன்தான் நிர்ணயம் செய்தான்"}, {"w": 2, "t": "measured"}, {"w": 3, "t": "இன்னும் வழிகாட்டினான்"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவன்தான் வெளியாக்கினான்"}, {"w": 2, "t": "brings forth"}, {"w": 3, "t": "பசுமையான புல்லை"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இன்னும் அதை ஆக்கினான்"}, {"w": 2, "t": "சருகாக"}, {"w": 3, "t": "கருத்த (காய்ந்த)"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "உமக்குக் கற்பிப்போம்"}, {"w": 2, "t": "ஆகவே நீர் மறக்க மாட்டீர்"}, {"w": 3, "t": "you will forget"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "நாடியதை"}, {"w": 3, "t": "wills"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "நிச்சயமாக அவன்"}, {"w": 6, "t": "அறிவான்"}, {"w": 7, "t": "வெளிப்படையானதை"}, {"w": 8, "t": "இன்னும் மறைந்திருப்பதை"}, {"w": 9, "t": "is hidden"}, {"w": 10, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "உமக்கு இலகுவாக்குவோம்"}, {"w": 2, "t": "சொர்க்கப் பாதையை"}, {"w": 3, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "ஆகவே, அறிவுரை கூறுவீராக"}, {"w": 2, "t": "பலனளித்தால்"}, {"w": 3, "t": "benefits"}, {"w": 4, "t": "அறிவுரை"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அறிவுரை பெறுவார்"}, {"w": 2, "t": "எவர்"}, {"w": 3, "t": "பயப்படுகிறார்"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "இன்னும் அதைத் தவிர்த்துவிடுவான்"}, {"w": 2, "t": "பெரும் துர்ப்பாக்கியவான்"}, {"w": 3, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "எவன்"}, {"w": 2, "t": "பற்றி எரிவான்"}, {"w": 3, "t": "நெருப்பில்"}, {"w": 4, "t": "மாபெரும்"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "மரணிக்கவும் மாட்டான்"}, {"w": 3, "t": "he will die"}, {"w": 4, "t": "அதில்"}, {"w": 5, "t": "இன்னும் வாழவும் மாட்டான்"}, {"w": 6, "t": "will live"}, {"w": 7, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "வெற்றி பெற்றார்"}, {"w": 3, "t": "எவர்"}, {"w": 4, "t": "பரிசுத்தமடைந்தார்"}, {"w": 5, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "இன்னும் நினைவு கூர்ந்தார்"}, {"w": 2, "t": "பெயரை"}, {"w": 3, "t": "தன் இறைவனின்"}, {"w": 4, "t": "இன்னும் தொழுதார்"}, {"w": 5, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "தேர்ந்தெடுக்கிறீர்கள்"}, {"w": 3, "t": "வாழ்வை"}, {"w": 4, "t": "உலக(ம்)"}, {"w": 5, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "மறுமையோ"}, {"w": 2, "t": "மிகச் சிறந்தது"}, {"w": 3, "t": "இன்னும் என்றும் நிலையானது"}, {"w": 4, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இது"}, {"w": 3, "t": "வேதங்களிலும்"}, {"w": 4, "t": "the Scriptures"}, {"w": 5, "t": "முந்திய"}, {"w": 6, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "வேதங்களாகிய"}, {"w": 2, "t": "இப்றாஹீமுடைய"}, {"w": 3, "t": "இன்னும் மூஸாவுடைய"}, {"w": 4, "t": "(19)"}]}]}