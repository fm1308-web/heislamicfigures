{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "போது"}, {"w": 2, "t": "வானம்"}, {"w": 3, "t": "பிளந்துவிடும்"}, {"w": 4, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இன்னும் அது செவிசாய்த்தது"}, {"w": 2, "t": "தன் இறைவனுக்கு"}, {"w": 3, "t": "இன்னும் கீழ்ப்படிந்தது"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "பூமி"}, {"w": 3, "t": "விரிக்கப்படும்"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் எரிந்து(விடும்)"}, {"w": 2, "t": "தன்னில் உள்ளவற்றை"}, {"w": 3, "t": "(is) in it"}, {"w": 4, "t": "இன்னும் காலியாகிவிடும்"}, {"w": 5, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இன்னும் அது செவிசாய்த்து"}, {"w": 2, "t": "தன் இறைவனுக்கு"}, {"w": 3, "t": "இன்னும் கீழ்படிந்து"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "மனிதனே!"}, {"w": 2, "t": "mankind"}, {"w": 3, "t": "நிச்சயமாகநீ/சிரமத்தோடு முயற்சிப்பவன்"}, {"w": 4, "t": "(are) laboring"}, {"w": 5, "t": "பக்கம்"}, {"w": 6, "t": "உன் இறைவன்"}, {"w": 7, "t": "சிரமத்தோடு முயற்சித்தல்"}, {"w": 8, "t": "அடுத்து நீ அவனை சந்திப்பாய்"}, {"w": 9, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "ஆகவே, யார்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "கொடுக்கப்பட்டாரோ"}, {"w": 4, "t": "தன் பதிவேடு"}, {"w": 5, "t": "தன் வலக்கரத்தில்"}, {"w": 6, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவர் கணக்குக் கேட்கப்படுவார்"}, {"w": 2, "t": "his account will be taken"}, {"w": 3, "t": "கணக்கு"}, {"w": 4, "t": "இலகுவாகவே"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் திரும்புவார்"}, {"w": 2, "t": "பக்கம்"}, {"w": 3, "t": "தன் குடும்பத்தார்"}, {"w": 4, "t": "மகிழ்ச்சியானவராக"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் ஆக, யார்?"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "கொடுக்கப்பட்டானோ"}, {"w": 4, "t": "தன் பதிவேடு"}, {"w": 5, "t": "பின்னால்"}, {"w": 6, "t": "தன் முதுகுக்கு"}, {"w": 7, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவன் கூவுவான்"}, {"w": 2, "t": "he will call"}, {"w": 3, "t": "நாசமே"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் பொசுங்குவான்"}, {"w": 2, "t": "சயீர் என்ற நரகத்தில்"}, {"w": 3, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நிச்சயமாக அவன்"}, {"w": 2, "t": "இருந்தான்"}, {"w": 3, "t": "தன் குடும்பத்தில்"}, {"w": 4, "t": "his people"}, {"w": 5, "t": "மகிழ்ச்சியானவனாக"}, {"w": 6, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நிச்சயமாக அவன்"}, {"w": 2, "t": "எண்ணினான்"}, {"w": 3, "t": "திரும்பிவரவே மாட்டான் என"}, {"w": 4, "t": "never"}, {"w": 5, "t": "he would return"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஏனில்லை"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "அவனுடைய இறைவன்"}, {"w": 4, "t": "இருக்கிறான்"}, {"w": 5, "t": "அவனை"}, {"w": 6, "t": "உற்றுநோக்குபவனாக"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "ஆகவே சத்தியமிடுகிறேன்"}, {"w": 2, "t": "I swear"}, {"w": 3, "t": "செம்மேகத்தின்மேல்"}, {"w": 4, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இரவின் மீது சத்தியமாக"}, {"w": 2, "t": "ஒன்று சேர்த்தவை மீது சத்தியமாக"}, {"w": 3, "t": "it envelops"}, {"w": 4, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "சந்திரன் மீது சத்தியமாக"}, {"w": 2, "t": "அது முழுமையடையும் போது"}, {"w": 3, "t": "it becomes full"}, {"w": 4, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நிச்சயமாக பயணிக்கிறீர்கள்"}, {"w": 2, "t": "ஒரு நிலைக்கு"}, {"w": 3, "t": "ஒரு நிலையிலிருந்து"}, {"w": 4, "t": "stage"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "ஆகவே என்ன"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "அவர்கள் நம்பிக்கை கொள்வதில்லை"}, {"w": 4, "t": "they believe"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "இன்னும் ஓதப்பட்டால்"}, {"w": 2, "t": "is recited"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "அல்குர்ஆன்"}, {"w": 5, "t": "அவர்கள் சிரம் பணிவதில்லை"}, {"w": 6, "t": "they prostrate"}, {"w": 7, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "நிராகரிப்பாளர்கள்"}, {"w": 3, "t": "disbelieved"}, {"w": 4, "t": "பொய்ப்பிக்கின்றனர்"}, {"w": 5, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "மிக அறிந்தவன்"}, {"w": 3, "t": "அவர்கள் சேகரிப்பதை"}, {"w": 4, "t": "they keep within themselves"}, {"w": 5, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "ஆகவே நற்செய்தி கூறுவீராக அவர்களுக்கு"}, {"w": 2, "t": "வேதனையைக் கொண்டு"}, {"w": 3, "t": "துன்புறுத்தும்"}, {"w": 4, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நற்செயல்கள்"}, {"w": 6, "t": "அவர்களுக்கு"}, {"w": 7, "t": "நன்மை (கூலி)"}, {"w": 8, "t": "முடிவுறாத"}, {"w": 9, "t": "ending"}, {"w": 10, "t": "(25)"}]}]}