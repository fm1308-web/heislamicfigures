{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "வேகமாக வீசக்கூடிய காற்றுகள் மீது சத்தியமாக!"}, {"w": 2, "t": "dispersing"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "சுமையை சுமக்கின்ற மேகங்கள் மீது சத்தியமாக!"}, {"w": 2, "t": "a load"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "மென்மையாக செல்கின்ற கப்பல்கள் மீது சத்தியமாக!"}, {"w": 2, "t": "(with) ease"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "கட்டளைகளை பிரிப்பவர்கள் மீது சத்தியமாக!"}, {"w": 2, "t": "Command"}, {"w": 3, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நீங்கள் வாக்களிக்கப்படுவதெல்லாம்"}, {"w": 2, "t": "you are promised"}, {"w": 3, "t": "உண்மைதான்"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "கூலி கொடுக்கப்படுவது"}, {"w": 3, "t": "நிகழ்ந்தே தீரும்"}, {"w": 4, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "வானத்தின் மீது சத்தியமாக!"}, {"w": 2, "t": "அழகிய படைப்புடைய"}, {"w": 3, "t": "pathways"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நிச்சயமாக நீங்கள்"}, {"w": 2, "t": "பேச்சில் இருக்கின்றனர்"}, {"w": 3, "t": "a speech"}, {"w": 4, "t": "மாறுபட்ட"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "திருப்பப்படுகிறார்"}, {"w": 2, "t": "இதை விட்டும்"}, {"w": 3, "t": "எவர்"}, {"w": 4, "t": "திருப்பப்பட்டார்"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அழிந்து போகட்டும்"}, {"w": 2, "t": "பொய்யை கற்பனை செய்பவர்கள்"}, {"w": 3, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "மயக்கத்தில்"}, {"w": 4, "t": "flood"}, {"w": 5, "t": "மறதியாளர்களாக"}, {"w": 6, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவர்கள் கேட்கின்றனர்"}, {"w": 2, "t": "எப்போது"}, {"w": 3, "t": "நாள்"}, {"w": 4, "t": "கூலி கொடுக்கப்படும்"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நாளில்..."}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "நெருப்பின் மீது"}, {"w": 4, "t": "the Fire"}, {"w": 5, "t": "வேதனை செய்யப்படுகின்றனர்"}, {"w": 6, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "சுவையுங்கள்!"}, {"w": 2, "t": "உங்கள் வேதனையை"}, {"w": 3, "t": "இது நீங்கள் அவசரமாகத் தேடிக்கொண்டிருந்தது"}, {"w": 4, "t": "(is) what"}, {"w": 5, "t": "you were"}, {"w": 6, "t": "for it"}, {"w": 7, "t": "seeking to hasten"}, {"w": 8, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நிச்சயமாக இறையச்சமுள்ளவர்கள்"}, {"w": 2, "t": "the righteous"}, {"w": 3, "t": "சொர்க்கங்களில்"}, {"w": 4, "t": "Gardens"}, {"w": 5, "t": "இன்னும் நீரூற்றுகளில்"}, {"w": 6, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "பெற்றுக்கொள்வார்கள்"}, {"w": 2, "t": "அவர்களுக்கு கொடுத்ததை"}, {"w": 3, "t": "their Lord has given them"}, {"w": 4, "t": "அவர்களின் இறைவன்"}, {"w": 5, "t": "நிச்சயமாக அவர்கள்"}, {"w": 6, "t": "இருந்தார்கள்"}, {"w": 7, "t": "இதற்கு முன்னர்"}, {"w": 8, "t": "that"}, {"w": 9, "t": "நல்லவர்களாக"}, {"w": 10, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இருந்தார்கள்"}, {"w": 2, "t": "மிகக் குறைவாக"}, {"w": 3, "t": "இரவில்"}, {"w": 4, "t": "the night"}, {"w": 5, "t": "தூங்குபவர்களாக"}, {"w": 6, "t": "sleep"}, {"w": 7, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அதிகாலையில்"}, {"w": 2, "t": "அவர்கள் பாவமன்னிப்புத் தேடுவார்கள்"}, {"w": 3, "t": "would ask forgiveness"}, {"w": 4, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் அவர்களது செல்வங்களில்"}, {"w": 2, "t": "their wealth"}, {"w": 3, "t": "உரிமை"}, {"w": 4, "t": "யாசிப்பவருக்கு(ம்)"}, {"w": 5, "t": "இல்லாதவருக்கும்"}, {"w": 6, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இன்னும் பூமியில்"}, {"w": 2, "t": "the earth"}, {"w": 3, "t": "பல அத்தாட்சிகள்"}, {"w": 4, "t": "உறுதியாக நம்பிக்கை கொள்பவர்களுக்கு"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "இன்னும் உங்களிலும்"}, {"w": 2, "t": "yourselves"}, {"w": 3, "t": "நீங்கள் உற்று நோக்க மாட்டீர்களா?"}, {"w": 4, "t": "you see"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "இன்னும் வானத்தில்"}, {"w": 2, "t": "the heaven"}, {"w": 3, "t": "உங்கள் உணவும்"}, {"w": 4, "t": "நீங்கள் வாக்களிக்கப்படுவதும்"}, {"w": 5, "t": "you are promised"}, {"w": 6, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அதிபதியின் மீது சத்தியமாக"}, {"w": 2, "t": "வானம், பூமியுடைய"}, {"w": 3, "t": "and the earth"}, {"w": 4, "t": "நிச்சயமாக இது"}, {"w": 5, "t": "உண்மைதான்"}, {"w": 6, "t": "போன்றே"}, {"w": 7, "t": "நிச்சயமாக நீங்கள் பேசுவது"}, {"w": 8, "t": "you"}, {"w": 9, "t": "speak"}, {"w": 10, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "உமக்கு வந்ததா?"}, {"w": 2, "t": "reached you"}, {"w": 3, "t": "செய்தி"}, {"w": 4, "t": "விருந்தினர்களின்"}, {"w": 5, "t": "இப்ராஹிமுடைய"}, {"w": 6, "t": "கண்ணியமான(வர்கள்)"}, {"w": 7, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவர்கள் நுழைந்த போது"}, {"w": 2, "t": "they entered"}, {"w": 3, "t": "அவரிடம்"}, {"w": 4, "t": "அவர்கள் கூறினர்"}, {"w": 5, "t": "ஸலாம்"}, {"w": 6, "t": "கூறினார்"}, {"w": 7, "t": "“ஸலாம்”"}, {"w": 8, "t": "மக்கள்"}, {"w": 9, "t": "அறியாத"}, {"w": 10, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "திரும்பிச் சென்றார்"}, {"w": 2, "t": "தனது குடும்பத்தாரிடம்"}, {"w": 3, "t": "his household"}, {"w": 4, "t": "வந்தார்"}, {"w": 5, "t": "கொழுத்த காளைக் கன்றைக் கொண்டு"}, {"w": 6, "t": "fat"}, {"w": 7, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அதை நெருக்கமாக்கினார்"}, {"w": 2, "t": "அவர்கள் பக்கம்"}, {"w": 3, "t": "கூறினார்"}, {"w": 4, "t": "நீங்கள் சாப்பிட மாட்டீர்களா?"}, {"w": 5, "t": "you eat"}, {"w": 6, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "ஆகவே, உணர்ந்தார்"}, {"w": 2, "t": "அவர்களினால்"}, {"w": 3, "t": "பயத்தை"}, {"w": 4, "t": "கூறினார்கள்"}, {"w": 5, "t": "பயப்படாதீர்"}, {"w": 6, "t": "fear"}, {"w": 7, "t": "இன்னும் அவருக்கு நற்செய்தி கூறினார்கள்"}, {"w": 8, "t": "ஓர் ஆண் குழந்தையைக்கொண்டு"}, {"w": 9, "t": "கல்வியாளரான"}, {"w": 10, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "முன்னோக்கி வந்தால்"}, {"w": 2, "t": "அவருடைய மனைவி"}, {"w": 3, "t": "சப்தத்தோடு"}, {"w": 4, "t": "a loud voice"}, {"w": 5, "t": "இன்னும் அறைந்தார்"}, {"w": 6, "t": "தனது முகத்தை"}, {"w": 7, "t": "இன்னும் கூறினாள்"}, {"w": 8, "t": "கிழவி ஆயிற்றே"}, {"w": 9, "t": "மலடியான(வள்)"}, {"w": 10, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "அவ்வாறுதான்"}, {"w": 3, "t": "கூறினான்"}, {"w": 4, "t": "உமது இறைவன்"}, {"w": 5, "t": "நிச்சயமாக அவன்தான்"}, {"w": 6, "t": "[He]"}, {"w": 7, "t": "மகா ஞானவான்"}, {"w": 8, "t": "நன்கறிந்தவன்"}, {"w": 9, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "உங்கள் காரியம்தான் என்ன?"}, {"w": 3, "t": "(is) your mission"}, {"w": 4, "t": "தூதர்களே!"}, {"w": 5, "t": "O messengers"}, {"w": 6, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "நிச்சயமாக நாங்கள்"}, {"w": 3, "t": "அனுப்பப்பட்டுள்ளோம்"}, {"w": 4, "t": "மக்கள் பக்கம்"}, {"w": 5, "t": "a people"}, {"w": 6, "t": "குற்றவாளிகளான"}, {"w": 7, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "நாங்கள் எறிவதற்காக"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "கல்லை"}, {"w": 4, "t": "களிமண்ணினால்ஆன"}, {"w": 5, "t": "clay"}, {"w": 6, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "அடையாளமிடப்பட்ட"}, {"w": 2, "t": "உமது இறைவனிடம்"}, {"w": 3, "t": "by your Lord"}, {"w": 4, "t": "பாவிகளுக்காக"}, {"w": 5, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "ஆக, நாம் வெளியேற்றி விட்டோம்"}, {"w": 2, "t": "இருந்தவர்களை"}, {"w": 3, "t": "were"}, {"w": 4, "t": "அதில்"}, {"w": 5, "t": "நம்பிக்கையாளர்களாக"}, {"w": 6, "t": "the believers"}, {"w": 7, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "ஆனால் நாம் காணவில்லை"}, {"w": 2, "t": "We found"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "ஒரு வீட்டைத் தவிர"}, {"w": 5, "t": "a house"}, {"w": 6, "t": "முஸ்லிம்களுடைய"}, {"w": 7, "t": "the Muslims"}, {"w": 8, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "நாம் விட்டுள்ளோம்"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "ஓர் அத்தாட்சியை"}, {"w": 4, "t": "பயப்படுகின்றவர்களுக்கு"}, {"w": 5, "t": "fear"}, {"w": 6, "t": "தண்டனையை"}, {"w": 7, "t": "வலி தரக்கூடிய(து)"}, {"w": 8, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "இன்னும் மூஸாவிலும்"}, {"w": 2, "t": "Musa"}, {"w": 3, "t": "நாம் அவரை அனுப்பிய போது"}, {"w": 4, "t": "We sent him"}, {"w": 5, "t": "ஃபிர்அவ்னிடம்"}, {"w": 6, "t": "Firaun"}, {"w": 7, "t": "ஆதாரத்தைக் கொண்டு"}, {"w": 8, "t": "தெளிவான(து)"}, {"w": 9, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "விலகினான்"}, {"w": 2, "t": "தனது பலத்தினால்"}, {"w": 3, "t": "இன்னும் கூறினான்"}, {"w": 4, "t": "ஒரு சூனியக்காரர்(தான்)"}, {"w": 5, "t": "அல்லது"}, {"w": 6, "t": "ஒரு பைத்தியக்காரர்(தான்)"}, {"w": 7, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "அவனையும் நாம் பிடித்தோம்"}, {"w": 2, "t": "அவனுடைய ராணுவங்களையும்"}, {"w": 3, "t": "அவர்களை எறிந்தோம்/கடலில்"}, {"w": 4, "t": "into"}, {"w": 5, "t": "the sea"}, {"w": 6, "t": "அவனோ"}, {"w": 7, "t": "பழிப்புக்குள்ளானவன்"}, {"w": 8, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "இன்னும் ஆதிலும்"}, {"w": 2, "t": "Aad"}, {"w": 3, "t": "நாம் அனுப்பியபோது"}, {"w": 4, "t": "We sent"}, {"w": 5, "t": "அவர்கள் மீது"}, {"w": 6, "t": "மலட்டுக் காற்றை"}, {"w": 7, "t": "the barren"}, {"w": 8, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "அது விடாது"}, {"w": 2, "t": "it left"}, {"w": 3, "t": "எதையும்"}, {"w": 4, "t": "thing"}, {"w": 5, "t": "செல்கிறதோ"}, {"w": 6, "t": "அதன் மீது"}, {"w": 7, "t": "அதை ஆக்காமல்"}, {"w": 8, "t": "it made it"}, {"w": 9, "t": "பழைய மக்கிப்போன பொருளைப் போன்று"}, {"w": 10, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "இன்னும் சமூதிலும்"}, {"w": 2, "t": "Thamud"}, {"w": 3, "t": "சொல்லப்பட்ட போது"}, {"w": 4, "t": "was said"}, {"w": 5, "t": "அவர்களுக்கு"}, {"w": 6, "t": "சுகமாக இருங்கள் என்று"}, {"w": 7, "t": "வரை"}, {"w": 8, "t": "சிறிது காலம்"}, {"w": 9, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "பெருமை அடித்தனர்"}, {"w": 2, "t": "கட்டளையை ஏற்காமல்"}, {"w": 3, "t": "(the) Command"}, {"w": 4, "t": "தங்கள் இறைவனின்"}, {"w": 5, "t": "அவர்களைப் பிடித்தது"}, {"w": 6, "t": "இடிமுழக்கம்"}, {"w": 7, "t": "அவர்களோ"}, {"w": 8, "t": "எதிர்பார்த்துக் கொண்டிருந்தனர்"}, {"w": 9, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "இயலாமல் ஆகிவிட்டார்கள்"}, {"w": 2, "t": "they were able to"}, {"w": 3, "t": "நிற்பதற்கு"}, {"w": 4, "t": "stand"}, {"w": 5, "t": "இருக்கவில்லை"}, {"w": 6, "t": "they could"}, {"w": 7, "t": "பழிதீர்ப்பவர்களாகவும்"}, {"w": 8, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "இன்னும் மக்களையும்"}, {"w": 2, "t": "நூஹூடைய"}, {"w": 3, "t": "இதற்கு முன்னர்"}, {"w": 4, "t": "before"}, {"w": 5, "t": "நிச்சயமாக அவர்கள்"}, {"w": 6, "t": "இருந்தனர்"}, {"w": 7, "t": "மக்களாக"}, {"w": 8, "t": "பாவிகளான"}, {"w": 9, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "வானத்தை"}, {"w": 2, "t": "அதை நாம் உயர்த்தினோம்"}, {"w": 3, "t": "பலத்தால்"}, {"w": 4, "t": "நிச்சயமாக நாம்"}, {"w": 5, "t": "மிகவும் வசதி படைத்தவர்கள் ஆவோம்"}, {"w": 6, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "பூமியை"}, {"w": 2, "t": "அதை நாம் விரித்தோம்"}, {"w": 3, "t": "நாம் மிகச் சிறந்தவர்கள்"}, {"w": 4, "t": "விரிப்பவர்களில்"}, {"w": 5, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "ஒவ்வொன்றிலும்"}, {"w": 2, "t": "every"}, {"w": 3, "t": "thing"}, {"w": 4, "t": "படைத்தோம்"}, {"w": 5, "t": "இரண்டு ஜோடிகளை"}, {"w": 6, "t": "நீங்கள் நல்லுணர்வு பெறுவதற்காக"}, {"w": 7, "t": "remember"}, {"w": 8, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "ஆகவே விரண்டு ஓடுங்கள்"}, {"w": 2, "t": "அல்லாஹ்வின் பக்கம்"}, {"w": 3, "t": "Allah"}, {"w": 4, "t": "நிச்சயமாக நான்"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "அவனிடமிருந்து"}, {"w": 7, "t": "எச்சரிப்பாளர்"}, {"w": 8, "t": "தெளிவான(வர்)"}, {"w": 9, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "ஏற்படுத்தாதீர்கள்"}, {"w": 2, "t": "make"}, {"w": 3, "t": "அல்லாஹ்வுடன்"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "வேறு ஒரு கடவுளை"}, {"w": 6, "t": "another"}, {"w": 7, "t": "நிச்சயமாக நான்"}, {"w": 8, "t": "உங்களுக்கு"}, {"w": 9, "t": "அவனிடமிருந்து"}, {"w": 10, "t": "எச்