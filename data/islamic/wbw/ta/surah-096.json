{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "படிப்பீராக/பெயரால்"}, {"w": 2, "t": "in (the) name"}, {"w": 3, "t": "உம் இறைவனின்"}, {"w": 4, "t": "எவன்"}, {"w": 5, "t": "படைத்தான்"}, {"w": 6, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவன் படைத்தான்"}, {"w": 2, "t": "மனிதனை"}, {"w": 3, "t": "கருவிலிருந்து"}, {"w": 4, "t": "a clinging substance"}, {"w": 5, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "படிப்பீராக"}, {"w": 2, "t": "இன்னும் உம் இறைவன்"}, {"w": 3, "t": "பெரும் கண்ணியவான்"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "எவன்"}, {"w": 2, "t": "கற்பித்தான்"}, {"w": 3, "t": "எழுதுகோல் மூலம்"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "கற்பித்தான்"}, {"w": 2, "t": "மனிதனுக்கு"}, {"w": 3, "t": "அவன் அறியாததை"}, {"w": 4, "t": "not"}, {"w": 5, "t": "he knew"}, {"w": 6, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "மனிதன்"}, {"w": 4, "t": "வரம்பு மீறுகிறான்"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "தன்னை அவன் எண்ணியதால்"}, {"w": 2, "t": "he sees himself"}, {"w": 3, "t": "தேவையற்றவனாக"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "பக்கம்தான்"}, {"w": 3, "t": "உம் இறைவன்"}, {"w": 4, "t": "மீட்சி"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "பார்த்தீரா?"}, {"w": 2, "t": "தடுப்பவனை"}, {"w": 3, "t": "forbids"}, {"w": 4, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "ஓர் அடியாரை"}, {"w": 2, "t": "அவர்தொழும்போது"}, {"w": 3, "t": "he prays"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "பார்த்தீரா?"}, {"w": 2, "t": "அவர் இருந்தாலுமா"}, {"w": 3, "t": "he is"}, {"w": 4, "t": "இல்"}, {"w": 5, "t": "நேர்வழி"}, {"w": 6, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "அவர் ஏவினாலுமா"}, {"w": 3, "t": "நன்மையை"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "பார்த்தீரா?"}, {"w": 2, "t": "அவன் பொய்ப்பித்தால்"}, {"w": 3, "t": "he denies"}, {"w": 4, "t": "இன்னும் புறக்கணித்தால்"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவன் அறியவில்லையா?"}, {"w": 2, "t": "he know"}, {"w": 3, "t": "என்பதை/நிச்சயமாக"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "பார்க்கிறான்"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "அவன் விலகவில்லையெனில்"}, {"w": 3, "t": "not"}, {"w": 4, "t": "he desists"}, {"w": 5, "t": "கடுமையாகப் பிடிப்போம்"}, {"w": 6, "t": "நெற்றி முடியை"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "நெற்றி முடி"}, {"w": 2, "t": "பொய் கூறுகின்ற"}, {"w": 3, "t": "குற்றம் புரிகின்ற"}, {"w": 4, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "ஆகவே அவன் அழைக்கட்டும்"}, {"w": 2, "t": "தன் சபையோரை"}, {"w": 3, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நாம் அழைப்போம்"}, {"w": 2, "t": "நரகத்தின் காவலாளிகளை"}, {"w": 3, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "அவனுக்குக் கீழ்ப்படியாதீர்"}, {"w": 3, "t": "obey him"}, {"w": 4, "t": "இன்னும் சிரம் பணிவீராக"}, {"w": 5, "t": "இன்னும் நெருங்குவீராக"}, {"w": 6, "t": "(19)"}]}]}