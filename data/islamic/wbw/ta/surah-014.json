{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அலிஃப்; லாம்; றா."}, {"w": 2, "t": "ஒரு வேதம்"}, {"w": 3, "t": "இதை இறக்கினோம்"}, {"w": 4, "t": "உம்மீது"}, {"w": 5, "t": "நீர் வெளியேற்றுவதற்காக"}, {"w": 6, "t": "மக்களை"}, {"w": 7, "t": "இருள்களிலிருந்து"}, {"w": 8, "t": "the darkness[es]"}, {"w": 9, "t": "பக்கம்/ஒளியின்"}, {"w": 10, "t": "the light"}, {"w": 11, "t": "அனுமதி கொண்டு"}, {"w": 12, "t": "அவர்களுடைய இறைவனின்"}, {"w": 13, "t": "பக்கம்/பாதையின்"}, {"w": 14, "t": "the Path"}, {"w": 15, "t": "மிகைத்தவன்"}, {"w": 16, "t": "மகா புகழாளன்"}, {"w": 17, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "எத்தகையவன்"}, {"w": 3, "t": "அவனுக்கே"}, {"w": 4, "t": "வானங்களில் உள்ளவை"}, {"w": 5, "t": "(is) in"}, {"w": 6, "t": "the heavens"}, {"w": 7, "t": "பூமியில் உள்ளவை"}, {"w": 8, "t": "(is) in"}, {"w": 9, "t": "the earth"}, {"w": 10, "t": "கேடு உண்டாகுக!"}, {"w": 11, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 12, "t": "வேதனையின்"}, {"w": 13, "t": "the punishment"}, {"w": 14, "t": "கடினமானது"}, {"w": 15, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "விரும்புவார்கள்"}, {"w": 3, "t": "வாழ்வை"}, {"w": 4, "t": "உலகம்"}, {"w": 5, "t": "மறுமையை விட"}, {"w": 6, "t": "the Hereafter"}, {"w": 7, "t": "இன்னும் தடுப்பார்கள்"}, {"w": 8, "t": "பாதையை விட்டு"}, {"w": 9, "t": "(the) Path"}, {"w": 10, "t": "அல்லாஹ்வின்"}, {"w": 11, "t": "இன்னும் தேடுகின்றனர்/அதில்"}, {"w": 12, "t": "கோணலை/இவர்கள்"}, {"w": 13, "t": "those"}, {"w": 14, "t": "வழிகேட்டில்"}, {"w": 15, "t": "(are) far astray"}, {"w": 16, "t": "தூரமானது"}, {"w": 17, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நாம் அனுப்பவில்லை"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "எந்த ஒரு தூதரை"}, {"w": 4, "t": "Messenger"}, {"w": 5, "t": "தவிர/மொழியைக் கொண்டே"}, {"w": 6, "t": "with the language"}, {"w": 7, "t": "அவருடைய மக்களின்"}, {"w": 8, "t": "அவர் தெளிவுபடுத்துவதற்காக"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "ஆகவேவழிகெடுக்கிறான்"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "எவரை/நாடுவான்"}, {"w": 13, "t": "He wills"}, {"w": 14, "t": "இன்னும் நேர்வழி செலுத்துகிறான்"}, {"w": 15, "t": "எவரை/நாடுவான்"}, {"w": 16, "t": "He wills"}, {"w": 17, "t": "அவன்தான்"}, {"w": 18, "t": "மிகைத்தவன்"}, {"w": 19, "t": "மகா ஞானவான்"}, {"w": 20, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "திட்டமாக அனுப்பினோம்"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "மூஸாவை/நம் அத்தாட்சிகளைக் கொண்டு"}, {"w": 4, "t": "with Our Signs"}, {"w": 5, "t": "வெளியேற்று"}, {"w": 6, "t": "Bring out"}, {"w": 7, "t": "உம் சமுதாயத்தை"}, {"w": 8, "t": "இருள்களிலிருந்து"}, {"w": 9, "t": "the darkness[es]"}, {"w": 10, "t": "ஒளியின் பக்கம்"}, {"w": 11, "t": "the light"}, {"w": 12, "t": "இன்னும் ஞாபகமூட்டு அவர்களுக்கு"}, {"w": 13, "t": "அருட்கொடைகளை"}, {"w": 14, "t": "அல்லாஹ்வின்"}, {"w": 15, "t": "நிச்சயமாக/இதில்"}, {"w": 16, "t": "in"}, {"w": 17, "t": "that"}, {"w": 18, "t": "அத்தாட்சிகள்"}, {"w": 19, "t": "எல்லோருக்கும்"}, {"w": 20, "t": "மிக பொறுமையாளர்"}, {"w": 21, "t": "மிக நன்றியறிபவர்"}, {"w": 22, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கூறிய சமயம்"}, {"w": 2, "t": "said"}, {"w": 3, "t": "மூஸா"}, {"w": 4, "t": "தன் சமுதாயத்திற்கு"}, {"w": 5, "t": "நினைவு கூறுங்கள்"}, {"w": 6, "t": "அருளை"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "உங்கள் மீது"}, {"w": 9, "t": "போது"}, {"w": 10, "t": "உங்களை காப்பாற்றினான்"}, {"w": 11, "t": "இருந்து"}, {"w": 12, "t": "கூட்டம்"}, {"w": 13, "t": "ஃபிர்அவ்னுடைய"}, {"w": 14, "t": "சிரமம் தந்தார்கள்/உங்களுக்கு"}, {"w": 15, "t": "கடினமான வேதனையால்"}, {"w": 16, "t": "torment"}, {"w": 17, "t": "இன்னும் அறுத்தார்கள்"}, {"w": 18, "t": "ஆண் பிள்ளைகளை உங்கள்"}, {"w": 19, "t": "இன்னும் வாழவிட்டார்கள்"}, {"w": 20, "t": "பெண்(பிள்ளை)களை உங்கள்"}, {"w": 21, "t": "இன்னும் இதில்"}, {"w": 22, "t": "that"}, {"w": 23, "t": "ஒரு சோதனை"}, {"w": 24, "t": "இருந்து"}, {"w": 25, "t": "உங்கள் இறைவன்"}, {"w": 26, "t": "மகத்தானது"}, {"w": 27, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் அறிவித்த சமயம்"}, {"w": 2, "t": "proclaimed"}, {"w": 3, "t": "உங்கள் இறைவன்"}, {"w": 4, "t": "நீங்கள்நன்றி செலுத்தினால்"}, {"w": 5, "t": "you are thankful"}, {"w": 6, "t": "அதிகப்படுத்துவேன்/ உங்களுக்கு"}, {"w": 7, "t": "நீங்கள் நிராகரித்தால்"}, {"w": 8, "t": "you are ungrateful"}, {"w": 9, "t": "நிச்சயமாக"}, {"w": 10, "t": "என் வேதனை"}, {"w": 11, "t": "கடுமையானதுதான்"}, {"w": 12, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "கூறினார்/மூஸா"}, {"w": 2, "t": "Musa"}, {"w": 3, "t": "நீங்கள் நிராகரித்தால்"}, {"w": 4, "t": "you disbelieve"}, {"w": 5, "t": "நீங்கள்/இன்னும் எவர்"}, {"w": 6, "t": "and whoever"}, {"w": 7, "t": "பூமியில்"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "அனைவரும்"}, {"w": 10, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 11, "t": "Allah"}, {"w": 12, "t": "நிறைவானவன்"}, {"w": 13, "t": "மகா புகழாளன்"}, {"w": 14, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "உங்களுக்கு வரவில்லையா?"}, {"w": 2, "t": "come to you"}, {"w": 3, "t": "சரித்திரம்"}, {"w": 4, "t": "எவர்கள்"}, {"w": 5, "t": "உங்களுக்கு முன்னர்"}, {"w": 6, "t": "(were) before you"}, {"w": 7, "t": "மக்கள்"}, {"w": 8, "t": "நூஹூடைய"}, {"w": 9, "t": "இன்னும் ஆது"}, {"w": 10, "t": "ஸமூது"}, {"w": 11, "t": "இன்னும் எவர்கள்"}, {"w": 12, "t": "அவர்களுக்குப் பின்னர்"}, {"w": 13, "t": "(were) after them"}, {"w": 14, "t": "அறியமாட்டார்/அவர்களை"}, {"w": 15, "t": "knows them"}, {"w": 16, "t": "தவிர"}, {"w": 17, "t": "அல்லாஹ்"}, {"w": 18, "t": "வந்தா(ர்க)ள்/அவர்களிடம்"}, {"w": 19, "t": "தூதர்கள்/ அவர்களுடைய"}, {"w": 20, "t": "தெளிவான சான்றுகளைக் கொண்டு"}, {"w": 21, "t": "திருப்பினர்"}, {"w": 22, "t": "கைகளை/தங்கள்"}, {"w": 23, "t": "வாய்களின் பக்கமே/தங்கள்"}, {"w": 24, "t": "their mouths"}, {"w": 25, "t": "இன்னும் கூறினர்"}, {"w": 26, "t": "நிச்சயமாக நாங்கள்"}, {"w": 27, "t": "நிராகரித்தோம்"}, {"w": 28, "t": "எதைக் கொண்டு"}, {"w": 29, "t": "நீங்கள் அனுப்பப்பட்டீர்களோ"}, {"w": 30, "t": "அதைக் கொண்டு"}, {"w": 31, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 32, "t": "சந்தேகத்தில்"}, {"w": 33, "t": "doubt"}, {"w": 34, "t": "எதில்/அழைக்கிறீர்கள்/எங்களை"}, {"w": 35, "t": "you invite us"}, {"w": 36, "t": "அதன் பக்கம்"}, {"w": 37, "t": "ஆழமான சந்தேகம்"}, {"w": 38, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "கூறினா(ர்க)ள்"}, {"w": 2, "t": "தூதர்கள்/ அவர்களுடைய"}, {"w": 3, "t": "அல்லாஹ்வின் விஷயத்திலா?"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "சந்தேகம்"}, {"w": 6, "t": "படைப்பாளனாகிய"}, {"w": 7, "t": "வானங்கள்"}, {"w": 8, "t": "இன்னும் பூமி"}, {"w": 9, "t": "அழைக்கிறான்/ உங்களை"}, {"w": 10, "t": "மன்னிப்பதற்காக"}, {"w": 11, "t": "உங்களுக்கு"}, {"w": 12, "t": "உங்கள் குற்றங்களை"}, {"w": 13, "t": "your sins"}, {"w": 14, "t": "இன்னும் விட்டு வைப்பதற்கு உங்களை"}, {"w": 15, "t": "வரை/ஒரு காலம்"}, {"w": 16, "t": "a term"}, {"w": 17, "t": "குறிக்கப்பட்டது"}, {"w": 18, "t": "கூறினர்"}, {"w": 19, "t": "நீங்கள் இல்லை"}, {"w": 20, "t": "you"}, {"w": 21, "t": "தவிர/மனிதர்களே"}, {"w": 22, "t": "a human"}, {"w": 23, "t": "எங்களைப் போன்ற"}, {"w": 24, "t": "நாடுகிறீர்கள்"}, {"w": 25, "t": "நீங்கள் தடுக்க/எங்களை"}, {"w": 26, "t": "hinder us"}, {"w": 27, "t": "எவற்றை விட்டு"}, {"w": 28, "t": "வணங்கிக் கொண்டிருந்தார்"}, {"w": 29, "t": "worship"}, {"w": 30, "t": "மூதாதைகள்/எங்கள்"}, {"w": 31, "t": "ஆகவே வாருங்கள்/நம்மிடம்"}, {"w": 32, "t": "ஆதாரத்தைக் கொண்டு"}, {"w": 33, "t": "தெளிவானது"}, {"w": 34, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "கூறினா(ர்க)ள்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "தூதர்கள்/ அவர்களுடைய"}, {"w": 4, "t": "இல்லை/நாங்கள்"}, {"w": 5, "t": "we (are)"}, {"w": 6, "t": "தவிர"}, {"w": 7, "t": "மனிதர்களே"}, {"w": 8, "t": "உங்களைப் போன்ற"}, {"w": 9, "t": "எனினும்"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "அருள் புரிகிறான்"}, {"w": 12, "t": "மீது"}, {"w": 13, "t": "எவர்/நாடுவான்"}, {"w": 14, "t": "He wills"}, {"w": 15, "t": "தன் அடியார்களில்"}, {"w": 16, "t": "His slaves"}, {"w": 17, "t": "முடியாது/எங்களுக்கு"}, {"w": 18, "t": "is"}, {"w": 19, "t": "for us"}, {"w": 20, "t": "நாம் வருவது/உங்களிடம்"}, {"w": 21, "t": "we bring you"}, {"w": 22, "t": "ஓர் ஆதாரத்தைக் கொண்டு/தவிர"}, {"w": 23, "t": "except"}, {"w": 24, "t": "அனுமதி கொண்டே"}, {"w": 25, "t": "அல்லாஹ்வுடைய"}, {"w": 26, "t": "அல்லாஹ்வின் மீதே"}, {"w": 27, "t": "Allah"}, {"w": 28, "t": "நம்பிக்கை வைக்கட்டும்"}, {"w": 29, "t": "நம்பிக்கையாளர்கள்"}, {"w": 30, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "எங்களுக்கென்ன?"}, {"w": 2, "t": "(is) for us"}, {"w": 3, "t": "நாங்கள் நம்பிக்கை வைக்காதிருக்க"}, {"w": 4, "t": "we put our trust"}, {"w": 5, "t": "மீது"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "நேர்வழிபடுத்தினான்/எங்களை"}, {"w": 8, "t": "He has guided us"}, {"w": 9, "t": "எங்கள் பாதைகளில்"}, {"w": 10, "t": "நிச்சயமாக பொறுப்போம்"}, {"w": 11, "t": "நீங்கள் துன்புறுத்துவதில் எங்களை"}, {"w": 12, "t": "what"}, {"w": 13, "t": "harm you may cause us"}, {"w": 14, "t": "அல்லாஹ் மீதே"}, {"w": 15, "t": "Allah"}, {"w": 16, "t": "ஆகவே நம்பிக்கை வைக்கட்டும்"}, {"w": 17, "t": "நம்பிக்கை வைப்பவர்கள்"}, {"w": 18, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "கூறினார்(கள்)"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "நிராகரித்தனர்"}, {"w": 4, "t": "தங்கள் தூதர்களிடம்"}, {"w": 5, "t": "நிச்சயமாக வெளியேற்றுவோம்/உங்களை"}, {"w": 6, "t": "எங்கள் பூமியிலிருந்து"}, {"w": 7, "t": "our land"}, {"w": 8, "t": "அல்லது"}, {"w": 9, "t": "நீங்கள் நிச்சயமாக திரும்பிடவேண்டும்"}, {"w": 10, "t": "எங்கள் மார்க்கத்தில்"}, {"w": 11, "t": "our religion"}, {"w": 12, "t": "ஆகவே வஹீ  அறிவித்தான்"}, {"w": 13, "t": "அவர்களுக்கு"}, {"w": 14, "t": "இறைவன்/அவர்களுடைய"}, {"w": 15, "t": "நிச்சயமாக அழிப்போம்"}, {"w": 16, "t": "அநியாயக்காரர்களை"}, {"w": 17, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நிச்சயமாக குடி அமர்த்துவோம்/உங்களை"}, {"w": 2, "t": "பூமியில்"}, {"w": 3, "t": "பின்னர்"}, {"w": 4, "t": "பின்னர் அவர்களுக்கு"}, {"w": 5, "t": "இது"}, {"w": 6, "t": "எவருக்கு"}, {"w": 7, "t": "பயந்தார்"}, {"w": 8, "t": "என் முன்னால் நிற்பதை"}, {"w": 9, "t": "இன்னும் பயந்தார்"}, {"w": 10, "t": "என் எச்சரிக்கையை"}, {"w": 11, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஆகவே வெற்றிபெற முயற்சித்தார்கள்"}, {"w": 2, "t": "அழிந்தார்(கள்)"}, {"w": 3, "t": "எல்லோரும்"}, {"w": 4, "t": "பிடிவாதக்காரர்(கள்)"}, {"w": 5, "t": "வம்பர்(கள்)"}, {"w": 6, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவனுக்கு பின்புறத்தில்"}, {"w": 2, "t": "Ahead"}, {"w": 3, "t": "நரகம்"}, {"w": 4, "t": "இன்னும் புகட்டப்படுவான்"}, {"w": 5, "t": "இருந்து"}, {"w": 6, "t": "நீர்"}, {"w": 7, "t": "சீழ்"}, {"w": 8, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அள்ளிக் குடிப்பான்/அதை"}, {"w": 2, "t": "இலகுவாக குடித்து விடமாட்டான்/அதை"}, {"w": 3, "t": "he will be near"}, {"w": 4, "t": "(to) swallowing it"}, {"w": 5, "t": "வரும்/அவனுக்கு"}, {"w": 6, "t": "மரணம்"}, {"w": 7, "t": "ஒவ்வொரு இடத்திலிருந்தும்"}, {"w": 8, "t": "every"}, {"w": 9, "t": "side"}, {"w": 10, "t": "இல்லை/அவன்"}, {"w": 11, "t": "he"}, {"w": 12, "t": "இறந்து விடுபவனாக"}, {"w": 13, "t": "அவனுக்குப்பின்னால்"}, {"w": 14, "t": "And ahead of him"}, {"w": 15, "t": "வேதனை"}, {"w": 16, "t": "கடினமானது"}, {"w": 17, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "உதாரணம்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "நிராகரித்தனர்"}, {"w": 4, "t": "தங்கள் இறைவனை"}, {"w": 5, "t": "அவர்களுடைய செயல்கள்"}, {"w": 6, "t": "சாம்பல்"}, {"w": 7, "t": "கடுமையாக அடித்துச் சென்றது"}, {"w": 8, "t": "அதை"}, {"w": 9, "t": "காற்று"}, {"w": 10, "t": "காலத்தில்"}, {"w": 11, "t": "a day"}, {"w": 12, "t": "புயல்"}, {"w": 13, "t": "அவர்கள் சக்தி பெறமாட்டார்கள்"}, {"w": 14, "t": "control (they have)"}, {"w": 15, "t": "அவர்கள் செய்ததில்"}, {"w": 16, "t": "they have earned"}, {"w": 17, "t": "எதையும்"}, {"w": 18, "t": "anything"}, {"w": 19, "t": "இதுதான்"}, {"w": 20, "t": "[it]"}, {"w": 21, "t": "வழிகேடு"}, {"w": 22, "t": "தூரமானது"}, {"w": 23, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நீர் கவனிக்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "படைத்துள்ளான்"}, {"w": 6, "t": "வானங்களை"}, {"w": 7, "t": "இன்னும் பூமியை"}, {"w": 8, "t": "உண்மையைக் கொண்டு"}, {"w": 9, "t": "அவன் நாடினால்"}, {"w": 10, "t": "He wills"}, {"w": 11, "t": "போக்கி விடுவான்/உங்களை"}, {"w": 12, "t": "இன்னும் வருவான்"}, {"w": 13, "t": "படைப்பைக் கொண்டு"}, {"w": 14, "t": "புதியது"}, {"w": 15, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இல்லை/அது"}, {"w": 2, "t": "(is) that"}, {"w": 3, "t": "மீது"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "சிரமமானதாக"}, {"w": 6, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "வெளிப்படுவார்கள்"}, {"w": 2, "t": "அல்லாஹ்விற்கு முன்"}, {"w": 3, "t": "அனைவரும்"}, {"w": 4, "t": "கூறுவார்(கள்)"}, {"w": 5, "t": "பலவீனர்கள்"}, {"w": 6, "t": "எவர்களுக்கு"}, {"w": 7, "t": "பெருமையடித்தனர்"}, {"w": 8, "t": "நிச்சயமாக நாங்கள்"}, {"w": 9, "t": "இருந்தோம்"}, {"w": 10, "t": "உங்களை"}, {"w": 11, "t": "பின்பற்றுபவர்களாக"}, {"w": 12, "t": "ஆகவே ?/நீங்கள்"}, {"w": 13, "t": "you (be)"}, {"w": 14, "t": "தடுப்பீர்கள்"}, {"w": 15, "t": "எங்களை விட்டு"}, {"w": 16, "t": "வேதனையிலிருந்து"}, {"w": 17, "t": "(the) punishment"}, {"w": 18, "t": "அல்லாஹ்வின்"}, {"w": 19, "t": "எதையும்"}, {"w": 20, "t": "anything"}, {"w": 21, "t": "கூறினர்"}, {"w": 22, "t": "வழிகாட்டினால்"}, {"w": 23, "t": "Allah had guided us"}, {"w": 24, "t": "அல்லாஹ்"}, {"w": 25, "t": "வழிகாட்டுவோம் உங்களுக்கு"}, {"w": 26, "t": "சமமே"}, {"w": 27, "t": "நம் மீது"}, {"w": 28, "t": "நாம் பதட்டப்பட்டால் என்ன?"}, {"w": 29, "t": "அல்லது"}, {"w": 30, "t": "சகித்தோம்"}, {"w": 31, "t": "இல்லை/நமக்கு"}, {"w": 32, "t": "(is) for us"}, {"w": 33, "t": "அறவே"}, {"w": 34, "t": "தப்புமிடம்"}, {"w": 35, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "கூறுவான்"}, {"w": 2, "t": "ஷைத்தான்"}, {"w": 3, "t": "முடிக்கப்பட்டபோது"}, {"w": 4, "t": "has been decided"}, {"w": 5, "t": "காரியம்"}, {"w": 6, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "வாக்களித்தான் உங்களுக்கு"}, {"w": 9, "t": "வாக்கை/ உண்மையானது"}, {"w": 10, "t": "(of) truth"}, {"w": 11, "t": "நான் வாக்களித்தேன்/உங்களுக்கு"}, {"w": 12, "t": "நான் வஞ்சித்தேன்/உங்களை"}, {"w": 13, "t": "இல்லை"}, {"w": 14, "t": "I had"}, {"w": 15, "t": "எனக்கு"}, {"w": 16, "t": "அறவே/உங்கள் மீது"}, {"w": 17, "t": "any"}, {"w": 18, "t": "அதிகாரம்"}, {"w": 19, "t": "எனினும்/உங்களை அழைத்தேன்"}, {"w": 20, "t": "that"}, {"w": 21, "t": "I invited you"}, {"w": 22, "t": "பதில் தந்தீர்கள்"}, {"w": 23, "t": "எனக்கு"}, {"w": 24, "t": "ஆகவே, என்னை நிந்திக்காதீர்கள்"}, {"w": 25, "t": "blame me"}, {"w": 26, "t": "நிந்தியுங்கள்"}, {"w": 27, "t": "உங்களையே"}, {"w": 28, "t": "நான் இல்லை"}, {"w": 29, "t": "(can) I"}, {"w": 30, "t": "உங்களுக்கு உதவுபவனாக"}, {"w": 31, "t": "இல்லை/நீங்கள்"}, {"w": 32, "t": "you (can)"}, {"w": 33, "t": "உதவுபவர்களாக/எனக்கு"}, {"w": 34, "t": "நிச்சயமாக நான்"}, {"w": 35, "t": "நிராகரித்தேன்"}, {"w": 36, "t": "நீங்கள் இணை ஆக்கியதை/ என்னை"}, {"w": 37, "t": "your association of me (with Allah)"}, {"w": 38, "t": "முன்னரே"}, {"w": 39, "t": "before"}, {"w": 40, "t": "நிச்சயமாக"}, {"w": 41, "t": "அணியாயக்காரர்கள்"}, {"w": 42, "t": "அவர்களுக்கு"}, {"w": 43, "t": "வேதனை"}, {"w": 44, "t": "துன்புறுத்தக் கூடியது"}, {"w": 45, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "புகுத்தப்படுவார்(கள்)"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 4, "t": "இன்னும் செய்தனர்"}, {"w": 5, "t": "நன்மைகளை"}, {"w": 6, "t": "சொர்க்கங்களில்"}, {"w": 7, "t": "ஓடும்"}, {"w": 8, "t": "அவற்றின் கீழ்"}, {"w": 9, "t": "underneath it"}, {"w": 10, "t": "நதிகள்"}, {"w": 11, "t": "நிரந்தரமானவர்களாக"}, {"w": 12, "t": "அதில்"}, {"w": 13, "t": "அனுமதிப்படி"}, {"w": 14, "t": "தங்கள் இறைவன்"}, {"w": 15, "t": "அவர்களின் முகமன்"}, {"w": 16, "t": "அதில்"}, {"w": 17, "t": "ஸலாம்"}, {"w": 18, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "நீர் கவனிக்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "எவ்வாறு?"}, {"w": 4, "t": "விவரித்தான்"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "ஓர் உதாரணத்தை"}, {"w": 7, "t": "ஒரு வாக்கியத்திற்கு"}, {"w": 8, "t": "நல்லது"}, {"w": 9, "t": "ஒரு மரத்திற்கு ஒப்பாக"}, {"w": 10, "t": "நல்லது/அதன் வேர்"}, {"w": 11, "t": "its root"}, {"w": 12, "t": "உறுதியானது"}, {"w": 13, "t": "இன்னும் அதன் கிளை"}, {"w": 14, "t": "வானத்தில்"}, {"w": 15, "t": "the sky"}, {"w": 16, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "கொடுக்கிறது"}, {"w": 2, "t": "தன் கனிகளை"}, {"w": 3, "t": "எல்லாக் காலத்திலும்"}, {"w": 4, "t": "time"}, {"w": 5, "t": "அனுமதி கொண்டு"}, {"w": 6, "t": "தன் இறைவனின்"}, {"w": 7, "t": "இன்னும் விவரிக்கிறான்"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "உதாரணங்களை"}, {"w": 10, "t": "மனிதர்களுக்கு"}, {"w": 11, "t": "அவர்கள் நல்லுபதேசம் பெறுவதற்காக"}, {"w": 12, "t": "remember"}, {"w": 13, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "இன்னும் உதாரணம்"}, {"w": 2, "t": "வாசகத்திற்கு"}, {"w": 3, "t": "கெட்டது"}, {"w": 4, "t": "மரத்திற்கு ஒப்பாகும்"}, {"w": 5, "t": "கெட்டது"}, {"w": 6, "t": "அறுபட்டது"}, {"w": 7, "t": "இருந்து"}, {"w": 8, "t": "மேல்"}, {"w": 9, "t": "பூமியின்"}, {"w": 10, "t": "இல்லை/அதற்கு"}, {"w": 11, "t": "for it"}, {"w": 12, "t": "அறவே"}, {"w": 13, "t": "எந்த உறுதி"}, {"w": 14, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "உறுதிப்படுத்துகிறான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "எவர்களை"}, {"w": 4, "t": "நம்பிக்கை கொண்டார்கள்"}, {"w": 5, "t": "சொல்லைக் கொண்டு"}, {"w": 6, "t": "உறுதியானது"}, {"w": 7, "t": "வாழ்வில்"}, {"w": 8, "t": "the life"}, {"w": 9, "t": "உலக(ம்)"}, {"w": 10, "t": "இன்னும் மறுமையில்"}, {"w": 11, "t": "the Hereafter"}, {"w": 12, "t": "வழிகெடுக்கிறான்"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "அநியாயக்காரர்கள்"}, {"w": 15, "t": "இன்னும் செய்கிறான்"}, {"w": 16, "t": "அல்லாஹ்"}, {"w": 17, "t": "தான் நாடுவதை"}, {"w": 18, "t": "He wills"}, {"w": 19, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நீர் பார்க்கவில்லையா?"}, {"w": 2, "t": "you seen"}, {"w": 3, "t": "பக்கம்"}, {"w": 4, "t": "எவர்கள்"}, {"w": 5, "t": "மாற்றினார்கள்"}, {"w": 6, "t": "அருளை"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "நிராகரிப்பால்"}, {"w": 9, "t": "இன்னும் தங்க வைத்தார்கள்"}, {"w": 10, "t": "தங்கள் சமுதாயத்தை"}, {"w": 11, "t": "அழிவு இல்லத்தில்"}, {"w": 12, "t": "(of) destruction"}, {"w": 13, "t": "(28)"}]}, {"ayah":