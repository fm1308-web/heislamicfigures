": 1, "t": "இன்னும் அய்யூபை நினைவு கூர்வீராக"}, {"w": 2, "t": "அழைத்தபோது"}, {"w": 3, "t": "he called"}, {"w": 4, "t": "தன் இறைவனை"}, {"w": 5, "t": "நிச்சயமாக நான்"}, {"w": 6, "t": "என்னை தொட்டுவிட்டன"}, {"w": 7, "t": "தீங்குகள்"}, {"w": 8, "t": "நீயோ"}, {"w": 9, "t": "மகா கருணையாளன்"}, {"w": 10, "t": "கருணையாளர்களில்"}, {"w": 11, "t": "(83)"}]}, {"ayah": 84, "words": [{"w": 1, "t": "ஆகவே, நாம் பதிலளித்தோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "அகற்றினோம்"}, {"w": 4, "t": "அவருக்கு இருந்த"}, {"w": 5, "t": "(was) on him"}, {"w": 6, "t": "தீங்குகளை"}, {"w": 7, "t": "(the) adversity"}, {"w": 8, "t": "இன்னும் அவருக்கு வழங்கினோம்"}, {"w": 9, "t": "அவருடைய குடும்பத்தை"}, {"w": 10, "t": "அவர்கள் போன்றவர்களை"}, {"w": 11, "t": "அவர்களுடன்"}, {"w": 12, "t": "கருணையாக"}, {"w": 13, "t": "நம் புறத்திலிருந்து"}, {"w": 14, "t": "from Ourselves"}, {"w": 15, "t": "இன்னும் நினைவூட்டலாகும்"}, {"w": 16, "t": "வணக்கசாலிகளுக்கு"}, {"w": 17, "t": "(84)"}]}, {"ayah": 85, "words": [{"w": 1, "t": "இன்னும் இஸ்மாயீலை நினைவு கூர்வீராக"}, {"w": 2, "t": "இத்ரீஸையும்"}, {"w": 3, "t": "துல்கிஃப்லையும்"}, {"w": 4, "t": "and Dhul-Kifl"}, {"w": 5, "t": "எல்லோரும்"}, {"w": 6, "t": "பொறுமையாளர்களில் உள்ளவர்கள்"}, {"w": 7, "t": "the patient ones"}, {"w": 8, "t": "(85)"}]}, {"ayah": 86, "words": [{"w": 1, "t": "இவர்களை நுழைத்துக் கொண்டோம்"}, {"w": 2, "t": "நமது அருளில்"}, {"w": 3, "t": "Our Mercy"}, {"w": 4, "t": "நிச்சயமாக இவர்கள்"}, {"w": 5, "t": "நல்லவர்களில் உள்ளவர்கள்"}, {"w": 6, "t": "the righteous"}, {"w": 7, "t": "(86)"}]}, {"ayah": 87, "words": [{"w": 1, "t": "மீனுடையவரை நினைவு கூர்வீராக"}, {"w": 2, "t": "And Dhun-Nun"}, {"w": 3, "t": "அவர் சென்றபோது"}, {"w": 4, "t": "he went"}, {"w": 5, "t": "கோபித்தவராக"}, {"w": 6, "t": "எண்ணினார்"}, {"w": 7, "t": "நெருக்கடியை கொடுக்கவே மாட்டோம்"}, {"w": 8, "t": "never"}, {"w": 9, "t": "We would decree"}, {"w": 10, "t": "அவருக்கு"}, {"w": 11, "t": "அவர் அழைத்தார்"}, {"w": 12, "t": "இருள்களில் இருந்தவராக"}, {"w": 13, "t": "the darkness(es)"}, {"w": 14, "t": "அறவே இல்லை"}, {"w": 15, "t": "(There is) no"}, {"w": 16, "t": "வணக்கத்திற்குரியவன்"}, {"w": 17, "t": "தவிர"}, {"w": 18, "t": "உன்னை"}, {"w": 19, "t": "நீ மகா பரிசுத்தமானவன்"}, {"w": 20, "t": "நிச்சயமாக நான்"}, {"w": 21, "t": "சேர்ந்து விட்டேன்"}, {"w": 22, "t": "அநியாயக்காரர்களில்"}, {"w": 23, "t": "the wrongdoers"}, {"w": 24, "t": "(87)"}]}, {"ayah": 88, "words": [{"w": 1, "t": "நாம் பதிலளித்தோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "அவரை நாம் பாதுகாத்தோம்"}, {"w": 4, "t": "துக்கத்திலிருந்து"}, {"w": 5, "t": "the distress"}, {"w": 6, "t": "இப்படித்தான்"}, {"w": 7, "t": "நாம் பாதுகாப்போம்"}, {"w": 8, "t": "நம்பிக்கையாளர்களை"}, {"w": 9, "t": "(88)"}]}, {"ayah": 89, "words": [{"w": 1, "t": "இன்னும் ஸகரிய்யாவை நினைவுகூர்வீராக"}, {"w": 2, "t": "அவர் அழைத்தபோது"}, {"w": 3, "t": "he called"}, {"w": 4, "t": "தன் இறைவனை"}, {"w": 5, "t": "என் இறைவா"}, {"w": 6, "t": "என்னை விட்டுவிடாதே"}, {"w": 7, "t": "leave me"}, {"w": 8, "t": "ஒருத்தனாக"}, {"w": 9, "t": "நீதான்"}, {"w": 10, "t": "மிகச் சிறந்தவன்"}, {"w": 11, "t": "வாரிசுகளில்"}, {"w": 12, "t": "(89)"}]}, {"ayah": 90, "words": [{"w": 1, "t": "நாம் பதிலளித்தோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "இன்னும் வழங்கினோம்"}, {"w": 4, "t": "அவருக்கு"}, {"w": 5, "t": "யஹ்யாவை"}, {"w": 6, "t": "இன்னும் சீர்படுத்தினோம்"}, {"w": 7, "t": "அவருக்கு"}, {"w": 8, "t": "அவருடைய மனைவியை"}, {"w": 9, "t": "நிச்சயமாக அவர்கள்"}, {"w": 10, "t": "இருந்தனர்"}, {"w": 11, "t": "விரைகின்றவர்களாக"}, {"w": 12, "t": "நன்மைகளில்"}, {"w": 13, "t": "good deeds"}, {"w": 14, "t": "இன்னும் நம்மை அழைக்கின்றவர்களாக"}, {"w": 15, "t": "ஆர்வத்துடனும்"}, {"w": 16, "t": "பயத்துடனும்"}, {"w": 17, "t": "இன்னும் இருந்தனர்"}, {"w": 18, "t": "நம்மிடம்"}, {"w": 19, "t": "பணிவுள்ளவர்களாக"}, {"w": 20, "t": "(90)"}]}, {"ayah": 91, "words": [{"w": 1, "t": "இன்னும் எவள்"}, {"w": 2, "t": "பாதுகாத்துக் கொண்டாள்"}, {"w": 3, "t": "தனது மறைவிடத்தை"}, {"w": 4, "t": "நாம் ஊதினோம்"}, {"w": 5, "t": "அவளில்"}, {"w": 6, "t": "நமது உயிரிலிருந்து"}, {"w": 7, "t": "Our Spirit"}, {"w": 8, "t": "இன்னும் அவளைஆக்கினோம்"}, {"w": 9, "t": "அவளுடைய மகனையும்"}, {"w": 10, "t": "ஓர் அத்தாட்சியாக"}, {"w": 11, "t": "அகிலத்தார்களுக்கு"}, {"w": 12, "t": "(91)"}]}, {"ayah": 92, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இதுதான்"}, {"w": 3, "t": "உங்களது"}, {"w": 4, "t": "ஒரே மார்க்கம்"}, {"w": 5, "t": "one"}, {"w": 6, "t": "நான்தான்"}, {"w": 7, "t": "உங்கள் இறைவன்"}, {"w": 8, "t": "ஆகவே, என்னை வணங்குங்கள்"}, {"w": 9, "t": "(92)"}]}, {"ayah": 93, "words": [{"w": 1, "t": "பிரிந்து விட்டனர்"}, {"w": 2, "t": "காரியத்தில் தங்கள்"}, {"w": 3, "t": "தங்களுக்கு மத்தியில்"}, {"w": 4, "t": "எல்லோரும்"}, {"w": 5, "t": "நம்மிடமே"}, {"w": 6, "t": "திரும்புவார்கள்"}, {"w": 7, "t": "(93)"}]}, {"ayah": 94, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "செய்வாரோ"}, {"w": 3, "t": "நற்காரியங்களை"}, {"w": 4, "t": "[the] righteous deeds"}, {"w": 5, "t": "தான் நம்பிக்கையாளராக இருந்து"}, {"w": 6, "t": "(is) a believer"}, {"w": 7, "t": "மறுக்கப்படாது/முயற்சியை/அவருடைய"}, {"w": 8, "t": "(will be) rejected"}, {"w": 9, "t": "[of] his effort"}, {"w": 10, "t": "நிச்சயமாக நாம்"}, {"w": 11, "t": "அதை"}, {"w": 12, "t": "பதிவு செய்கிறோம்"}, {"w": 13, "t": "(94)"}]}, {"ayah": 95, "words": [{"w": 1, "t": "விதிக்கப்பட்டுவிட்டது"}, {"w": 2, "t": "மீது"}, {"w": 3, "t": "ஊர் (மக்கள்)"}, {"w": 4, "t": "நாம் அழித்து விட்டோம்/அதை"}, {"w": 5, "t": "நிச்சயமாக அவர்கள்"}, {"w": 6, "t": "திரும்பவே மாட்டார்கள்"}, {"w": 7, "t": "will return"}, {"w": 8, "t": "(95)"}]}, {"ayah": 96, "words": [{"w": 1, "t": "இறுதியாக"}, {"w": 2, "t": "திறக்கப்பட்டால்"}, {"w": 3, "t": "has been opened"}, {"w": 4, "t": "யஃஜூஜ்"}, {"w": 5, "t": "இன்னும் மஃஜூஜ்"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "எல்லா இடத்திலிருந்து"}, {"w": 8, "t": "every"}, {"w": 9, "t": "உயரமான"}, {"w": 10, "t": "விரைந்து வருவார்கள்"}, {"w": 11, "t": "(96)"}]}, {"ayah": 97, "words": [{"w": 1, "t": "சமீபமாகிவிடும்"}, {"w": 2, "t": "வாக்கு"}, {"w": 3, "t": "உண்மையான"}, {"w": 4, "t": "அப்போது"}, {"w": 5, "t": "[it]"}, {"w": 6, "t": "கூர்மையாகிவிடும்"}, {"w": 7, "t": "பார்வைகள்"}, {"w": 8, "t": "நிராகரித்தவர்களின்"}, {"w": 9, "t": "disbelieved"}, {"w": 10, "t": "எங்கள் நாசமே"}, {"w": 11, "t": "திட்டமாக"}, {"w": 12, "t": "இருந்து விட்டோம்"}, {"w": 13, "t": "அலட்சியத்தில்"}, {"w": 14, "t": "heedlessness"}, {"w": 15, "t": "இதை விட்டு"}, {"w": 16, "t": "this"}, {"w": 17, "t": "மாறாக"}, {"w": 18, "t": "இருந்தோம்"}, {"w": 19, "t": "அநியாயக்காரர்களாக"}, {"w": 20, "t": "(97)"}]}, {"ayah": 98, "words": [{"w": 1, "t": "நிச்சயமாக நீங்களும்"}, {"w": 2, "t": "நீங்கள் வணங்குகின்றவையும்"}, {"w": 3, "t": "you worship"}, {"w": 4, "t": "அல்லாஹ்வையன்றி"}, {"w": 5, "t": "besides Allah"}, {"w": 6, "t": "besides Allah"}, {"w": 7, "t": "எறியப்படுபவை"}, {"w": 8, "t": "நரகத்தில்"}, {"w": 9, "t": "நீங்கள் அதில்"}, {"w": 10, "t": "to it"}, {"w": 11, "t": "நுழைவீர்கள்"}, {"w": 12, "t": "(98)"}]}, {"ayah": 99, "words": [{"w": 1, "t": "இருந்திருந்தால் இவை"}, {"w": 2, "t": "were"}, {"w": 3, "t": "these"}, {"w": 4, "t": "கடவுள்களாக"}, {"w": 5, "t": "அதில் நுழைந்திருக்க மாட்டார்கள்"}, {"w": 6, "t": "they (would) have come to it"}, {"w": 7, "t": "எல்லோரும்"}, {"w": 8, "t": "அதில்"}, {"w": 9, "t": "நிரந்தரமாக தங்கக்கூடியவர்கள்"}, {"w": 10, "t": "(99)"}]}, {"ayah": 100, "words": [{"w": 1, "t": "அவர்களுக்கு"}, {"w": 2, "t": "அதில் உண்டு"}, {"w": 3, "t": "மூச்சு வெளியேறுதல்"}, {"w": 4, "t": "இன்னும் அவர்கள்"}, {"w": 5, "t": "அதில்"}, {"w": 6, "t": "செவியுறமாட்டார்கள்"}, {"w": 7, "t": "will hear"}, {"w": 8, "t": "(100)"}]}, {"ayah": 101, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்/ முந்திவிட்டது"}, {"w": 3, "t": "has gone forth"}, {"w": 4, "t": "அவர்களுக்கு"}, {"w": 5, "t": "நம்மிடமிருந்து"}, {"w": 6, "t": "நற்பாக்கியம்"}, {"w": 7, "t": "அவர்கள்"}, {"w": 8, "t": "அதிலிருந்து"}, {"w": 9, "t": "தூரமாக் கப்பட்டவர்கள்"}, {"w": 10, "t": "(101)"}]}, {"ayah": 102, "words": [{"w": 1, "t": "செவியுறமாட்டார்கள்"}, {"w": 2, "t": "they will hear"}, {"w": 3, "t": "அதனுடைய சப்தத்தை"}, {"w": 4, "t": "அவர்கள்"}, {"w": 5, "t": "விரும்பியவற்றில்"}, {"w": 6, "t": "what"}, {"w": 7, "t": "desire"}, {"w": 8, "t": "தங்களது உள்ளங்கள்"}, {"w": 9, "t": "நிரந்தரமாக இருப்பார்கள்"}, {"w": 10, "t": "(102)"}]}, {"ayah": 103, "words": [{"w": 1, "t": "அவர்களை கவலைக்குள்ளாக்காது"}, {"w": 2, "t": "will grieve them"}, {"w": 3, "t": "திடுக்கம்"}, {"w": 4, "t": "மிகப்பெரிய"}, {"w": 5, "t": "அவர்களை வரவேற்பார்கள்"}, {"w": 6, "t": "வானவர்கள்"}, {"w": 7, "t": "இது"}, {"w": 8, "t": "உங்கள் நாள்"}, {"w": 9, "t": "எது/இருந்தீர்கள்"}, {"w": 10, "t": "you were"}, {"w": 11, "t": "நீங்கள் வாக்களிக்கப்படுவீர்கள்"}, {"w": 12, "t": "(103)"}]}, {"ayah": 104, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "நாம் சுருட்டுவோம்"}, {"w": 3, "t": "வானத்தை"}, {"w": 4, "t": "சுருட்டுவதைப் போன்று"}, {"w": 5, "t": "ஏடுகளை"}, {"w": 6, "t": "புத்தகங்களின் மீது"}, {"w": 7, "t": "போன்றே"}, {"w": 8, "t": "நாம் தொடங்கியது"}, {"w": 9, "t": "முதலாவதை"}, {"w": 10, "t": "படைப்பின்"}, {"w": 11, "t": "அதை திருப்பி விடுவோம்"}, {"w": 12, "t": "இது வாக்காகும்"}, {"w": 13, "t": "நம்மீது கடமையான"}, {"w": 14, "t": "நிச்சயமாக நாம்"}, {"w": 15, "t": "இருக்கிறோம்"}, {"w": 16, "t": "செய்பவர்களாகவே"}, {"w": 17, "t": "(104)"}]}, {"ayah": 105, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் எழுதினோம்"}, {"w": 3, "t": "வேதங்களில்"}, {"w": 4, "t": "the Scripture"}, {"w": 5, "t": "பின்னர்"}, {"w": 6, "t": "after"}, {"w": 7, "t": "எழுதப்பட்டதற்கு"}, {"w": 8, "t": "நிச்சயமாக"}, {"w": 9, "t": "பூமி"}, {"w": 10, "t": "அதை அனந்தரமாக அடைவார்கள்"}, {"w": 11, "t": "எனது அடியார்கள்"}, {"w": 12, "t": "நல்ல"}, {"w": 13, "t": "(105)"}]}, {"ayah": 106, "words": [{"w": 1, "t": "நிச்சயமாக இதில்"}, {"w": 2, "t": "in"}, {"w": 3, "t": "this"}, {"w": 4, "t": "அறிவுரை இருக்கிறது"}, {"w": 5, "t": "மக்களுக்கு"}, {"w": 6, "t": "வணங்குகின்ற"}, {"w": 7, "t": "(106)"}]}, {"ayah": 107, "words": [{"w": 1, "t": "உம்மை அனுப்பவில்லை"}, {"w": 2, "t": "We have sent you"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "ஓர் அருளாகவே"}, {"w": 5, "t": "அகிலத்தார்களுக்கு"}, {"w": 6, "t": "(107)"}]}, {"ayah": 108, "words": [{"w": 1, "t": "நீர் கூறுவீராக"}, {"w": 2, "t": "வஹீ  அறிவிக்கப்படுவதெல்லாம்"}, {"w": 3, "t": "it is revealed"}, {"w": 4, "t": "எனக்கு"}, {"w": 5, "t": "நிச்சயமாக உங்கள் கடவுள் எல்லாம்"}, {"w": 6, "t": "your god"}, {"w": 7, "t": "ஒரு கடவுள்"}, {"w": 8, "t": "ஒரே"}, {"w": 9, "t": "?"}, {"w": 10, "t": "நீங்கள்"}, {"w": 11, "t": "முற்றிலும் கட்டுப்பட்டு கீழ்ப்படிந்து நடப்பீர்கள்"}, {"w": 12, "t": "(108)"}]}, {"ayah": 109, "words": [{"w": 1, "t": "அவர்கள் விலகிச் சென்றால்"}, {"w": 2, "t": "they turn away"}, {"w": 3, "t": "நீர் கூறிவிடுவீராக"}, {"w": 4, "t": "உங்களுக்கு நான் அறிவித்து விட்டேன்"}, {"w": 5, "t": "மிகத் தெளிவாக"}, {"w": 6, "t": "equally"}, {"w": 7, "t": "நான் அறியமாட்டேன்"}, {"w": 8, "t": "I know"}, {"w": 9, "t": "சமீபமாக உள்ளதா"}, {"w": 10, "t": "அல்லது"}, {"w": 11, "t": "தூரமாக உள்ளதா"}, {"w": 12, "t": "நீங்கள் வாக்களிக்கப்பட்டது"}, {"w": 13, "t": "you are promised"}, {"w": 14, "t": "(109)"}]}, {"ayah": 110, "words": [{"w": 1, "t": "நிச்சயமாக அவன்"}, {"w": 2, "t": "அறிவான்"}, {"w": 3, "t": "வெளிப்படையானதை"}, {"w": 4, "t": "பேச்சில்"}, {"w": 5, "t": "[the] speech"}, {"w": 6, "t": "இன்னும் அவன் அறிவான்"}, {"w": 7, "t": "நீங்கள் மறைப்பதை(யும்)"}, {"w": 8, "t": "you conceal"}, {"w": 9, "t": "(110)"}]}, {"ayah": 111, "words": [{"w": 1, "t": "நான்அறியமாட்டேன்"}, {"w": 2, "t": "I know"}, {"w": 3, "t": "அது இருக்கலாம்"}, {"w": 4, "t": "சோதனையாகவும்"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "இன்பமாகவும்"}, {"w": 7, "t": "வரை"}, {"w": 8, "t": "ஒரு நேரம்"}, {"w": 9, "t": "(111)"}]}, {"ayah": 112, "words": [{"w": 1, "t": "கூறினார்கள்"}, {"w": 2, "t": "என் இறைவா"}, {"w": 3, "t": "தீர்ப்பளிப்பாயாக"}, {"w": 4, "t": "சத்தியத்தைக் கொண்டு"}, {"w": 5, "t": "எங்கள் இறைவன்"}, {"w": 6, "t": "பேரருளாளன்"}, {"w": 7, "t": "அவனிடமே உதவி தேடப்படுகிறது"}, {"w": 8, "t": "எதிராக"}, {"w": 9, "t": "நீங்கள் வர்ணிப்பதற்கு"}, {"w": 10, "t": "you attribute"}, {"w": 11, "t": "(112)"}]}]}