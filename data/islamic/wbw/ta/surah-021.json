"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "மாறாக"}, {"w": 3, "t": "உங்களுக்கும் இறைவன்"}, {"w": 4, "t": "இறைவன்தான்"}, {"w": 5, "t": "வானங்கள்"}, {"w": 6, "t": "இன்னும் பூமியின்"}, {"w": 7, "t": "எப்படிப்பட்டவன்"}, {"w": 8, "t": "அவற்றைப்படைத்தான்"}, {"w": 9, "t": "நானும் ஒருவன்"}, {"w": 10, "t": "இதற்கு"}, {"w": 11, "t": "that"}, {"w": 12, "t": "சாட்சி கூறுபவர்களில்"}, {"w": 13, "t": "the witnesses"}, {"w": 14, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "அல்லாஹ்வின் மீது சத்தியமாக"}, {"w": 2, "t": "நிச்சயமாக நான் சதி செய்வேன்"}, {"w": 3, "t": "உங்கள் சிலைகளுக்கு"}, {"w": 4, "t": "பின்னர்"}, {"w": 5, "t": "நீங்கள் திரும்பிச் சென்ற"}, {"w": 6, "t": "you go away"}, {"w": 7, "t": "turning (your) backs"}, {"w": 8, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "அவற்றை ஆக்கிவிட்டார்"}, {"w": 2, "t": "சிறுசிறு துண்டுகளாக"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "பெரிய சிலை"}, {"w": 5, "t": "அவர்களுக்குரிய"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "அதனளவில்"}, {"w": 8, "t": "திரும்ப வருவதற்காக"}, {"w": 9, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "யார்?/செய்தார்"}, {"w": 3, "t": "(has) done"}, {"w": 4, "t": "இதை"}, {"w": 5, "t": "எனவே கடவுள்களுக்கு"}, {"w": 6, "t": "நிச்சயமாக அவர்"}, {"w": 7, "t": "அநியாயக்காரர்களில் ஒருவர் ஆவார்"}, {"w": 8, "t": "the wrongdoers"}, {"w": 9, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "நாங்கள் செவியுற்றோம்"}, {"w": 3, "t": "ஒரு வாலிபரை"}, {"w": 4, "t": "விமர்சிக்கின்றார் அவற்றை"}, {"w": 5, "t": "சொல்லப்படும்"}, {"w": 6, "t": "அவருக்கு"}, {"w": 7, "t": "இப்றாஹீம்"}, {"w": 8, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "கொண்டு வாருங்கள்"}, {"w": 3, "t": "அவரை"}, {"w": 4, "t": "கண்களுக்கு முன்"}, {"w": 5, "t": "(the) eyes"}, {"w": 6, "t": "மக்களின்"}, {"w": 7, "t": "அவர்கள் பார்ப்பதற்காக"}, {"w": 8, "t": "bear witness"}, {"w": 9, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "கூறினர்"}, {"w": 2, "t": "நீர்தான்"}, {"w": 3, "t": "செய்தீரா"}, {"w": 4, "t": "இதை"}, {"w": 5, "t": "எங்கள் கடவுள்களுடன்"}, {"w": 6, "t": "இப்றாஹீமே"}, {"w": 7, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "மாறாக"}, {"w": 3, "t": "இதை செய்தது"}, {"w": 4, "t": "பெரிய சிலைதான் அவற்றில்"}, {"w": 5, "t": "அவை"}, {"w": 6, "t": "ஆகவே கேளுங்கள் அவற்றிடம்"}, {"w": 7, "t": "இருந்தால்"}, {"w": 8, "t": "they (can)"}, {"w": 9, "t": "பேசுபவர்களாக"}, {"w": 10, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "அவர்கள் திரும்பினர்"}, {"w": 2, "t": "பக்கமே"}, {"w": 3, "t": "தங்கள்"}, {"w": 4, "t": "கூறினர்"}, {"w": 5, "t": "நிச்சயமாக நீங்கள்தான்"}, {"w": 6, "t": "[you]"}, {"w": 7, "t": "அநியாயக்காரர்கள்"}, {"w": 8, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "மாறினர்"}, {"w": 3, "t": "அவர்கள் தலைகீழாக"}, {"w": 4, "t": "their heads"}, {"w": 5, "t": "திட்டவட்டமாக"}, {"w": 6, "t": "நீர் அறிவீர்"}, {"w": 7, "t": "இவை பேசாது என்பதை"}, {"w": 8, "t": "these"}, {"w": 9, "t": "(can) speak"}, {"w": 10, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "வணங்குகிறீர்களா?"}, {"w": 3, "t": "அன்றி"}, {"w": 4, "t": "besides"}, {"w": 5, "t": "அல்லாஹ்வை"}, {"w": 6, "t": "எவற்றை/பலனளிக்காது/உங்களுக்கு/அறவே"}, {"w": 7, "t": "(does) not"}, {"w": 8, "t": "benefit you"}, {"w": 9, "t": "(in) anything"}, {"w": 10, "t": "இன்னும் உங்களுக்கு தீங்கிழைக்காது"}, {"w": 11, "t": "harms you"}, {"w": 12, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "சீச்சி"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "இன்னும் நீங்கள் வணங்குபவர்களுக்கு"}, {"w": 4, "t": "you worship"}, {"w": 5, "t": "அன்றி"}, {"w": 6, "t": "besides"}, {"w": 7, "t": "அல்லாஹ்வை"}, {"w": 8, "t": "நிச்சயமாக சிந்தித்து புரியமாட்டீர்களா?"}, {"w": 9, "t": "you use reason"}, {"w": 10, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "அவரை எரித்து விடுங்கள்"}, {"w": 3, "t": "இன்னும் உதவி செய்யுங்கள்"}, {"w": 4, "t": "உங்கள் கடவுள்களுக்கு"}, {"w": 5, "t": "நீங்கள் இருந்தால்"}, {"w": 6, "t": "you are"}, {"w": 7, "t": "(உதவி)செய்பவர்களாக"}, {"w": 8, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "நாம் கூறினோம்"}, {"w": 2, "t": "நெருப்பே"}, {"w": 3, "t": "ஆகிவிடு"}, {"w": 4, "t": "குளிர்ச்சியாகவும்"}, {"w": 5, "t": "பாதுகாப்பாகவும்"}, {"w": 6, "t": "இப்றாஹீமுக்கு"}, {"w": 7, "t": "Ibrahim"}, {"w": 8, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "அவருக்கு நாடினர்"}, {"w": 2, "t": "for him"}, {"w": 3, "t": "ஒரு சூழ்ச்சியை"}, {"w": 4, "t": "அவர்களையே ஆக்கிவிட்டோம்"}, {"w": 5, "t": "நஷ்டவாளிகளாக"}, {"w": 6, "t": "(70)"}]}, {"ayah": 71, "words": [{"w": 1, "t": "இன்னும் நாம் பாதுகாத்தோம்/அவரை"}, {"w": 2, "t": "லூத்தையும்"}, {"w": 3, "t": "பக்கம்"}, {"w": 4, "t": "பூமியின்"}, {"w": 5, "t": "அருள்வளம் புரிந்த"}, {"w": 6, "t": "We (had) blessed"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "அகிலத்தார்களுக்கு"}, {"w": 9, "t": "(71)"}]}, {"ayah": 72, "words": [{"w": 1, "t": "நாம் வழங்கினோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "இஸ்ஹாக்கையும்"}, {"w": 4, "t": "யஃகூபையும்"}, {"w": 5, "t": "கொடையாக"}, {"w": 6, "t": "அனைவரையும்"}, {"w": 7, "t": "ஆக்கினோம்"}, {"w": 8, "t": "நல்லவர்களாக"}, {"w": 9, "t": "(72)"}]}, {"ayah": 73, "words": [{"w": 1, "t": "இன்னும் அவர்களை ஆக்கினோம்"}, {"w": 2, "t": "தலைவர்களாக"}, {"w": 3, "t": "நேர்வழி காட்டுகின்றார்கள்"}, {"w": 4, "t": "நமது கட்டளையின்படி"}, {"w": 5, "t": "இன்னும் நாம் வஹீ  அறிவித்தோம்"}, {"w": 6, "t": "அவர்களுக்கு"}, {"w": 7, "t": "செய்வதற்கும்"}, {"w": 8, "t": "நன்மைகளை"}, {"w": 9, "t": "இன்னும் நிலைநிறுத்துவதற்கு"}, {"w": 10, "t": "தொழுகையை"}, {"w": 11, "t": "இன்னும் கொடுப்பதற்கு"}, {"w": 12, "t": "ஸகாத்தை"}, {"w": 13, "t": "அவர்கள் இருந்தார்கள்"}, {"w": 14, "t": "நம்மை"}, {"w": 15, "t": "வணங்குபவர்களாக"}, {"w": 16, "t": "(73)"}]}, {"ayah": 74, "words": [{"w": 1, "t": "இன்னும் லூத்தை நினைவு கூர்வீராக!"}, {"w": 2, "t": "அவருக்கு நாம் கொடுத்தோம்"}, {"w": 3, "t": "தீர்ப்பளிக்கின்ற ஆற்றலை(யும்)"}, {"w": 4, "t": "கல்வி ஞானத்தையும்"}, {"