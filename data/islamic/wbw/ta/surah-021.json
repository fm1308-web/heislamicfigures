{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நெருங்கிவிட்டது"}, {"w": 2, "t": "மக்களுக்கு"}, {"w": 3, "t": "அவர்களின் விசாரணை"}, {"w": 4, "t": "அவர்களோ"}, {"w": 5, "t": "அலட்சியத்தில்"}, {"w": 6, "t": "heedlessness"}, {"w": 7, "t": "புறக்கணிக்கின்றனர்"}, {"w": 8, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவர்களுக்கு வராது"}, {"w": 2, "t": "comes to them"}, {"w": 3, "t": "அறிவுரை ஏதும்"}, {"w": 4, "t": "a Reminder"}, {"w": 5, "t": "அவர்களுடைய இறைவனிடமிருந்து"}, {"w": 6, "t": "their Lord"}, {"w": 7, "t": "புதிய"}, {"w": 8, "t": "தவிர"}, {"w": 9, "t": "அதை அவர்கள் செவிமடுத்தே"}, {"w": 10, "t": "அவர்கள்"}, {"w": 11, "t": "விளையாடுபவர்களாக"}, {"w": 12, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அலட்சியம் செய்கின்றன"}, {"w": 2, "t": "அவர்களது உள்ளங்கள்"}, {"w": 3, "t": "பகிரங்கப்படுத்திக் கொண்டனர்"}, {"w": 4, "t": "பேச்சை"}, {"w": 5, "t": "அநியாயக்காரர்கள்"}, {"w": 6, "t": "[they] wronged"}, {"w": 7, "t": "இவர் இல்லை"}, {"w": 8, "t": "this"}, {"w": 9, "t": "மனிதரே தவிர"}, {"w": 10, "t": "a human being"}, {"w": 11, "t": "உங்களைப் போன்ற"}, {"w": 12, "t": "ஏற்றுக்கொள்கிறீர்களா"}, {"w": 13, "t": "சூனியத்தை"}, {"w": 14, "t": "நீங்கள்"}, {"w": 15, "t": "அறிந்துகொண்டே"}, {"w": 16, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவன்"}, {"w": 3, "t": "அறிகிறான்"}, {"w": 4, "t": "பேச்சுகளை"}, {"w": 5, "t": "வானத்திலும்"}, {"w": 6, "t": "the heavens"}, {"w": 7, "t": "பூமியிலும்"}, {"w": 8, "t": "அவன்தான் நன்கு செவியுறுபவன்"}, {"w": 9, "t": "(is) the All-Hearer"}, {"w": 10, "t": "நன்கு அறிபவன்"}, {"w": 11, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "கூறினர்"}, {"w": 3, "t": "பயமுறுத்துகின்ற"}, {"w": 4, "t": "கனவுகள்"}, {"w": 5, "t": "மாறாக"}, {"w": 6, "t": "இதை இட்டுக்கட்டுகிறார்"}, {"w": 7, "t": "மாறாக"}, {"w": 8, "t": "இவர்"}, {"w": 9, "t": "ஒரு கவிஞர்"}, {"w": 10, "t": "ஆகவே எங்களிடம் கொண்டு வரட்டும்"}, {"w": 11, "t": "ஓர் அத்தாட்சியை"}, {"w": 12, "t": "போன்று"}, {"w": 13, "t": "அனுப்பப்பட்டது"}, {"w": 14, "t": "முந்தியவர்கள்"}, {"w": 15, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நம்பிக்கை கொள்ளவில்லை"}, {"w": 2, "t": "believed"}, {"w": 3, "t": "இவர்களுக்கு முன்னர்"}, {"w": 4, "t": "எந்த சமுதாயமும்"}, {"w": 5, "t": "town"}, {"w": 6, "t": "ஆகவே, அவர்களை அழித்தோம்"}, {"w": 7, "t": "?/எனவே, இவர்கள்"}, {"w": 8, "t": "நம்பிக்கை கொண்டு விடுவார்கள்"}, {"w": 9, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நாம் அனுப்பவில்லை"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "உமக்கு முன்னர்"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "ஆடவர்களை"}, {"w": 6, "t": "வஹீ அறிவிப்போம்"}, {"w": 7, "t": "அவர்களுக்கு"}, {"w": 8, "t": "ஆகவே, கேட்டறிந்து கொள்ளுங்கள்"}, {"w": 9, "t": "வேதத்தையுடையவர்களிடம்"}, {"w": 10, "t": "(of) the Reminder"}, {"w": 11, "t": "நீங்கள் இருந்தால்"}, {"w": 12, "t": "you"}, {"w": 13, "t": "அறியாதவர்களாக"}, {"w": 14, "t": "know"}, {"w": 15, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நாம் அவர்களை ஆக்கவில்லை"}, {"w": 2, "t": "We made them"}, {"w": 3, "t": "உடல்களாக"}, {"w": 4, "t": "சாப்பிடாத"}, {"w": 5, "t": "eating"}, {"w": 6, "t": "உணவு"}, {"w": 7, "t": "இன்னும் இருக்கவில்லை"}, {"w": 8, "t": "they were"}, {"w": 9, "t": "நிரந்தர தன்மை உள்ளவர்களாக"}, {"w": 10, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம் அவர்களுக்கு உண்மைப்படுத்தினோம்"}, {"w": 3, "t": "வாக்கை"}, {"w": 4, "t": "நாம் பாதுகாத்தோம்"}, {"w": 5, "t": "நாம் நாடியவர்களையும்"}, {"w": 6, "t": "We willed"}, {"w": 7, "t": "நாம் அழித்தோம்"}, {"w": 8, "t": "வரம்பு மீறியவர்களை"}, {"w": 9, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "இறக்கி இருக்கிறோம்"}, {"w": 3, "t": "உங்களுக்கு"}, {"w": 4, "t": "ஒரு வேதத்தை"}, {"w": 5, "t": "அதில்/உங்களைப் பற்றிய சிறப்பு இருக்கிறது"}, {"w": 6, "t": "(is) your mention"}, {"w": 7, "t": "நீங்கள் சிந்தித்து புரிய வேண்டாமா?"}, {"w": 8, "t": "you use reason"}, {"w": 9, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "நாம் அழித்தோம்"}, {"w": 3, "t": "பல ஊர்களை"}, {"w": 4, "t": "a town"}, {"w": 5, "t": "அவை இருந்தன"}, {"w": 6, "t": "தீயவையாக"}, {"w": 7, "t": "உருவாக்கினோம்"}, {"w": 8, "t": "அவற்றுக்குப் பின்னர்"}, {"w": 9, "t": "வேறு மக்களை"}, {"w": 10, "t": "another people"}, {"w": 11, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவர்கள் உணர்ந்தபோது"}, {"w": 2, "t": "they perceived"}, {"w": 3, "t": "நமது வேதனையை"}, {"w": 4, "t": "அப்போது அவர்கள்"}, {"w": 5, "t": "they"}, {"w": 6, "t": "அதிலிருந்து"}, {"w": 7, "t": "விரைந்து ஓடினர்"}, {"w": 8, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "விரைந்து ஓடாதீர்கள்"}, {"w": 2, "t": "Flee not"}, {"w": 3, "t": "திரும்புங்கள்"}, {"w": 4, "t": "எதன் பக்கம்"}, {"w": 5, "t": "what"}, {"w": 6, "t": "நீங்கள் பெரும் இன்பம் கொடுக்கப்பட்டீர்கள்"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "உங்கள் இல்லங்களின்"}, {"w": 9, "t": "நீங்கள் விசாரிக்கப்படுவீர்கள்"}, {"w": 10, "t": "be questioned"}, {"w": 11, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "எங்கள் நாசமே"}, {"w": 3, "t": "நிச்சயமாக நாங்கள் இருந்தோம்"}, {"w": 4, "t": "we were"}, {"w": 5, "t": "அநியாயக்காரர்களாக"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நீடித்திருந்தது"}, {"w": 2, "t": "ceased"}, {"w": 3, "t": "அதுவே"}, {"w": 4, "t": "அவர்களது கூப்பாடாக"}, {"w": 5, "t": "இறுதியாக"}, {"w": 6, "t": "அவர்களை நாம் ஆக்கிவிட்டோம்"}, {"w": 7, "t": "வெட்டப்பட்டவர்களாக"}, {"w": 8, "t": "அழிந்தவர்களாக"}, {"w": 9, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "நாம் படைக்கவில்லை"}, {"w": 2, "t": "We created"}, {"w": 3, "t": "வானத்தையும்"}, {"w": 4, "t": "பூமியையும்"}, {"w": 5, "t": "அவ்விரண்டுக்கும் இடையில் உள்ளவற்றையும்"}, {"w": 6, "t": "(is) between them"}, {"w": 7, "t": "விளையாடுபவர்களாக"}, {"w": 8, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நாம் நாடி இருந்தால்"}, {"w": 2, "t": "We intended"}, {"w": 3, "t": "நாம் ஏற்படுத்திக் கொள்ள"}, {"w": 4, "t": "We take"}, {"w": 5, "t": "வேடிக்கையை"}, {"w": 6, "t": "அதை ஏற்படுத்திக் கொண்டிருப்போம்"}, {"w": 7, "t": "நம்மிடமிருந்தே"}, {"w": 8, "t": "Us"}, {"w": 9, "t": "நாம் இல்லை"}, {"w": 10, "t": "We were"}, {"w": 11, "t": "செய்பவர்களாக"}, {"w": 12, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "எறிகிறோம்"}, {"w": 3, "t": "சத்தியத்தை"}, {"w": 4, "t": "அசத்தியத்தின் மீது"}, {"w": 5, "t": "[the] falsehood"}, {"w": 6, "t": "அது அதை உடைத்து விடுகிறது"}, {"w": 7, "t": "அப்போது"}, {"w": 8, "t": "அது"}, {"w": 9, "t": "அழிந்து விடுகிறது"}, {"w": 10, "t": "உங்களுக்கு"}, {"w": 11, "t": "நாசம்தான்"}, {"w": 12, "t": "வர்ணிப்பதால்"}, {"w": 13, "t": "you ascribe"}, {"w": 14, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவனுக்கே"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "வானங்களிலும்"}, {"w": 4, "t": "the heavens"}, {"w": 5, "t": "பூமியிலும்"}, {"w": 6, "t": "இன்னும் எவர்கள்"}, {"w": 7, "t": "அவனிடம்"}, {"w": 8, "t": "பெருமையடிக்க மாட்டார்கள்"}, {"w": 9, "t": "they are arrogant"}, {"w": 10, "t": "அவனை வணங்குவதைவிட்டு"}, {"w": 11, "t": "worship Him"}, {"w": 12, "t": "இன்னும் சோர்வடைய மாட்டார்கள்"}, {"w": 13, "t": "they tire"}, {"w": 14, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அவர்கள் துதிக்கின்றனர்"}, {"w": 2, "t": "இரவு"}, {"w": 3, "t": "பகலாக"}, {"w": 4, "t": "பலவீனப்படுவதில்லை"}, {"w": 5, "t": "they slacken"}, {"w": 6, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "எடுத்துக் கொண்டார்களா?"}, {"w": 2, "t": "(have) they taken"}, {"w": 3, "t": "கடவுள்களை"}, {"w": 4, "t": "பூமியில்"}, {"w": 5, "t": "the earth"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "உயிர்ப்பிக்கின்ற கடவுள்களை"}, {"w": 8, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "இருந்திருந்தால்"}, {"w": 2, "t": "(there) were"}, {"w": 3, "t": "அவை இரண்டிலும்"}, {"w": 4, "t": "கடவுள்கள்"}, {"w": 5, "t": "அல்லாஹ்வைத் தவிர"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "அவை இரண்டும் சீரழிந்து இருக்கும்"}, {"w": 8, "t": "மகாத் தூயவன்"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "அதிபதியான"}, {"w": 11, "t": "அர்ஷுடைய"}, {"w": 12, "t": "விட்டு"}, {"w": 13, "t": "அவர்கள் வர்ணிப்பதை"}, {"w": 14, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அவன் கேள்வி கேட்கப்பட மாட்டான்"}, {"w": 2, "t": "He (can) be questioned"}, {"w": 3, "t": "பற்றி"}, {"w": 4, "t": "அவன் செய்வதை"}, {"w": 5, "t": "அவர்கள்தான்"}, {"w": 6, "t": "கேள்வி கேட்கப்படுவார்கள்"}, {"w": 7, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவர்கள் எடுத்துக் கொண்டார்களா?"}, {"w": 2, "t": "(have) they taken"}, {"w": 3, "t": "அவனையன்றி"}, {"w": 4, "t": "besides Him"}, {"w": 5, "t": "கடவுள்களை"}, {"w": 6, "t": "கூறுவீராக"}, {"w": 7, "t": "கொண்டு வாருங்கள்"}, {"w": 8, "t": "உங்கள் ஆதாரத்தை"}, {"w": 9, "t": "இது"}, {"w": 10, "t": "பேச்சாகும்"}, {"w": 11, "t": "என்னுடன் உள்ளவர்களைப் பற்றி"}, {"w": 12, "t": "(are) with me"}, {"w": 13, "t": "இன்னும் பேச்சாகும்"}, {"w": 14, "t": "எனக்கு முன் உள்ளவர்களைப் பற்றி"}, {"w": 15, "t": "(were) before me"}, {"w": 16, "t": "மாறாக"}, {"w": 17, "t": "அவர்களில் அதிகமானவர்கள்"}, {"w": 18, "t": "அறியமாட்டார்கள்"}, {"w": 19, "t": "know"}, {"w": 20, "t": "சத்தியத்தை"}, {"w": 21, "t": "ஆகவே, அவர்கள்"}, {"w": 22, "t": "புறக்கணிக்கிறார்கள்"}, {"w": 23, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நாம் அனுப்பவில்லை"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "உமக்கு முன்னர்"}, {"w": 4, "t": "before you"}, {"w": 5, "t": "எந்த தூதரையும்"}, {"w": 6, "t": "Messenger"}, {"w": 7, "t": "தவிர"}, {"w": 8, "t": "நாம் வஹீ  அறிவித்தே(£ம்)"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "நிச்சயமாக விஷயமாவது"}, {"w": 11, "t": "அறவே இல்லை"}, {"w": 12, "t": "வணக்கத்திற்குரியவன்"}, {"w": 13, "t": "என்னைத் தவிர"}, {"w": 14, "t": "Me"}, {"w": 15, "t": "ஆகவே, என்னையே வணங்குங்கள்"}, {"w": 16, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அவர்கள் கூறுகின்றனர்"}, {"w": 2, "t": "எடுத்துக் கொண்டான்"}, {"w": 3, "t": "பேரருளாளன்"}, {"w": 4, "t": "ஒரு குழந்தையை"}, {"w": 5, "t": "அவன் மகா தூயவன்"}, {"w": 6, "t": "மாறாக"}, {"w": 7, "t": "அடியார்கள்"}, {"w": 8, "t": "அவனுடைய கண்ணியமான"}, {"w": 9, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அவர்க