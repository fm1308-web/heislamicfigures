{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "ஹா மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அய்ன் சீன் காஃப்"}, {"w": 2, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "வஹீ  அறிவித்தான்"}, {"w": 3, "t": "உமக்கும்"}, {"w": 4, "t": "உமக்கு முன்னுள்ளவர்களுக்கும்"}, {"w": 5, "t": "those"}, {"w": 6, "t": "before you "}, {"w": 7, "t": "before you "}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "மிகைத்தவனும்"}, {"w": 10, "t": "மகா ஞானவானும்"}, {"w": 11, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவனுக்குத்தான்"}, {"w": 2, "t": "வானங்களில் உள்ளவையும்"}, {"w": 3, "t": "(is) in"}, {"w": 4, "t": "the heavens"}, {"w": 5, "t": "பூமியில்உள்ளவையும்"}, {"w": 6, "t": "(is) in"}, {"w": 7, "t": "the earth"}, {"w": 8, "t": "அவன்தான்"}, {"w": 9, "t": "மிக உயர்ந்தவன்"}, {"w": 10, "t": "மிக மகத்தானவன்"}, {"w": 11, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நெருங்கி விடுகின்றன"}, {"w": 2, "t": "வானங்கள்"}, {"w": 3, "t": "(அவை) பிளந்துவிடுவதற்கு"}, {"w": 4, "t": "அவற்றுக்கு மேல் உள்ள"}, {"w": 5, "t": "above them"}, {"w": 6, "t": "வானவர்கள்"}, {"w": 7, "t": "துதிக்கின்றனர்"}, {"w": 8, "t": "புகழ்ந்து"}, {"w": 9, "t": "தங்கள் இறைவனை"}, {"w": 10, "t": "இன்னும் பாவமன்னிப்புக் கேட்கின்றனர்"}, {"w": 11, "t": "பூமியில் உள்ளவர்களுக்காக"}, {"w": 12, "t": "on"}, {"w": 13, "t": "the earth"}, {"w": 14, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 15, "t": "நிச்சயமாக அல்லாஹ்தான்"}, {"w": 16, "t": "Allah"}, {"w": 17, "t": "He"}, {"w": 18, "t": "மகா மன்னிப்பாளன்"}, {"w": 19, "t": "மகாக் கருணையாளன்"}, {"w": 20, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "அவர்கள் எடுத்துக் கொண்டார்களோ"}, {"w": 3, "t": "அவனையன்றி"}, {"w": 4, "t": "besides"}, {"w": 5, "t": "உதவியாளர்களாக"}, {"w": 6, "t": "அல்லாஹ்தான்"}, {"w": 7, "t": "கண்காணிப்பவன்"}, {"w": 8, "t": "அவர்கள் மீது"}, {"w": 9, "t": "நீர் இல்லை"}, {"w": 10, "t": "you"}, {"w": 11, "t": "அவர்கள் மீது"}, {"w": 12, "t": "பொறுப்பாளர்"}, {"w": 13, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "வஹீ  அறிவித்தோம்"}, {"w": 3, "t": "உமக்கு"}, {"w": 4, "t": "குர்ஆனை"}, {"w": 5, "t": "அரபி மொழியில்"}, {"w": 6, "t": "நீர் எச்சரிப்பதற்காக"}, {"w": 7, "t": "மக்காவாசிகளை"}, {"w": 8, "t": "(of) the towns"}, {"w": 9, "t": "இன்னும் அதைச் சுற்றி உள்ளவர்களை"}, {"w": 10, "t": "(is) around it"}, {"w": 11, "t": "இன்னும் நீர் எச்சரிப்பதற்காக"}, {"w": 12, "t": "மறுமை நாளைப் பற்றி"}, {"w": 13, "t": "ஒன்று சேர்க்கப்படும்"}, {"w": 14, "t": "அறவே சந்தேகம் இல்லை"}, {"w": 15, "t": "doubt"}, {"w": 16, "t": "அதில்/ஓர் அணி"}, {"w": 17, "t": "A party"}, {"w": 18, "t": "சொர்க்கத்தில்"}, {"w": 19, "t": "Paradise"}, {"w": 20, "t": "இன்னும் ஓர் அணி"}, {"w": 21, "t": "நரகத்தில்"}, {"w": 22, "t": "the Blazing Fire"}, {"w": 23, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நாடியிருந்தால்"}, {"w": 2, "t": "Allah willed"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "அவர்களை ஆக்கியிருப்பான்"}, {"w": 5, "t": "மார்க்கமுடையவர்களாக"}, {"w": 6, "t": "ஒரே ஒரு"}, {"w": 7, "t": "என்றாலும்"}, {"w": 8, "t": "நுழைக்கின்றான்"}, {"w": 9, "t": "தான் நாடியவர்களை"}, {"w": 10, "t": "He wills"}, {"w": 11, "t": "தனது அருளில்"}, {"w": 12, "t": "His Mercy"}, {"w": 13, "t": "அநியாயக்காரர்கள்"}, {"w": 14, "t": "அவர்களுக்கு இல்லை"}, {"w": 15, "t": "for them"}, {"w": 16, "t": "எந்த பாதுகாவலரும்"}, {"w": 17, "t": "protector"}, {"w": 18, "t": "எந்த உதவியாளரும் இல்லை"}, {"w": 19, "t": "any helper"}, {"w": 20, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவர்கள் எடுத்துக் கொண்டார்களா?"}, {"w": 2, "t": "have they taken"}, {"w": 3, "t": "அவனையன்றி"}, {"w": 4, "t": "besides Him"}, {"w": 5, "t": "பாதுகாவலர்களை"}, {"w": 6, "t": "அல்லாஹ்தான்"}, {"w": 7, "t": "He"}, {"w": 8, "t": "பாதுகாவலன்"}, {"w": 9, "t": "இன்னும் அவன்தான்"}, {"w": 10, "t": "உயிர்ப்பிப்பான்"}, {"w": 11, "t": "இறந்தவர்களை"}, {"w": 12, "t": "இன்னும் அவன்"}, {"w": 13, "t": "எல்லாவற்றின் மீதும்"}, {"w": 14, "t": "every"}, {"w": 15, "t": "thing"}, {"w": 16, "t": "பேராற்றலுடையவன்"}, {"w": 17, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "எது/முரண்படுகிறீர்களோ/அதில்"}, {"w": 2, "t": "you differ"}, {"w": 3, "t": "in it"}, {"w": 4, "t": "எந்த ஒரு விஷயம்"}, {"w": 5, "t": "a thing"}, {"w": 6, "t": "அதன் இறுதி தீர்ப்பு"}, {"w": 7, "t": "அல்லாஹ்வின் பக்கம்தான்"}, {"w": 8, "t": "Allah"}, {"w": 9, "t": "அந்த அல்லாஹ்தான்"}, {"w": 10, "t": "(is) Allah"}, {"w": 11, "t": "என் இறைவன்"}, {"w": 12, "t": "அவன் மீதே"}, {"w": 13, "t": "நம்பிக்கை வைத்துள்ளேன்"}, {"w": 14, "t": "இன்னும் அவன் பக்கமே"}, {"w": 15, "t": "திரும்புகின்றேன்"}, {"w": 16, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "படைத்தவன்"}, {"w": 2, "t": "வானங்களையும்"}, {"w": 3, "t": "பூமியையும்"}, {"w": 4, "t": "ஏற்படுத்தினான்"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "உங்களிலிருந்தே"}, {"w": 7, "t": "yourselves"}, {"w": 8, "t": "ஜோடிகளை(யும்)"}, {"w": 9, "t": "இன்னும் கால்நடைகளில்"}, {"w": 10, "t": "the cattle"}, {"w": 11, "t": "ஜோடிகளை(யும்)"}, {"w": 12, "t": "படைக்கின்றான் உங்களை"}, {"w": 13, "t": "அதில்/இல்லை"}, {"w": 14, "t": "(There) is not"}, {"w": 15, "t": "அவனைப் போன்று"}, {"w": 16, "t": "எதுவும்/அவன்தான்"}, {"w": 17, "t": "and He"}, {"w": 18, "t": "நன்கு செவியுறுபவன்"}, {"w": 19, "t": "நன்கு பார்ப்பவன்"}, {"w": 20, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவனுக்கே உரியன"}, {"w": 2, "t": "சாவிகள்"}, {"w": 3, "t": "வானங்கள்"}, {"w": 4, "t": "இன்னும் பூமி"}, {"w": 5, "t": "விரிவாக்குகின்றான்"}, {"w": 6, "t": "வாழ்வாதாரத்தை"}, {"w": 7, "t": "தான் நாடியவர்களுக்கு"}, {"w": 8, "t": "He wills"}, {"w": 9, "t": "இன்னும் சுருக்குகின்றான்"}, {"w": 10, "t": "நிச்சயமாக அவன்"}, {"w": 11, "t": "எல்லாவற்றையும்"}, {"w": 12, "t": "thing"}, {"w": 13, "t": "நன்கறிந்தவன் ஆவான்"}, {"w": 14, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "சட்டமாக்கினான்"}, {"w": 2, "t": "உங்களுக்கு(ம்)"}, {"w": 3, "t": "மார்க்கத்தில்"}, {"w": 4, "t": "the religion"}, {"w": 5, "t": "எதை"}, {"w": 6, "t": "உபதேசித்தானோ"}, {"w": 7, "t": "அதையே"}, {"w": 8, "t": "நூஹூக்கு"}, {"w": 9, "t": "இன்னும் எதை"}, {"w": 10, "t": "நாம் வஹீ  அறிவித்தோமோ/உமக்கு"}, {"w": 11, "t": "to you"}, {"w": 12, "t": "இன்னும் எது/நாம் உபதேசித்தோமோ"}, {"w": 13, "t": "We enjoined"}, {"w": 14, "t": "அதை"}, {"w": 15, "t": "இப்ராஹீம்"}, {"w": 16, "t": "இன்னும் மூஸா"}, {"w": 17, "t": "இன்னும் ஈஸா(விற்கு)"}, {"w": 18, "t": "நிலை நிறுத்துங்கள்!"}, {"w": 19, "t": "establish"}, {"w": 20, "t": "இந்த மார்க்கத்தை"}, {"w": 21, "t": "நீங்கள் பிரிந்து விடாதீர்கள்!"}, {"w": 22, "t": "be divided"}, {"w": 23, "t": "அதில்/மிக பாரமாக ஆகிவிட்டது"}, {"w": 24, "t": "Is difficult"}, {"w": 25, "t": "இணைவைப்பவர்களுக்கு"}, {"w": 26, "t": "the polytheists"}, {"w": 27, "t": "எது/ அழைக்கின்றீரோ"}, {"w": 28, "t": "எது/ அழைக்கின்றீரோ அவர்களை"}, {"w": 29, "t": "அதன் பக்கம்"}, {"w": 30, "t": "அல்லாஹ்"}, {"w": 31, "t": "தேர்ந்தெடுக்கின்றான்"}, {"w": 32, "t": "தன் பக்கம்"}, {"w": 33, "t": "தான் நாடுகின்றவர்களை"}, {"w": 34, "t": "He wills"}, {"w": 35, "t": "இன்னும் வழி காட்டுகின்றான்"}, {"w": 36, "t": "தன் பக்கம்"}, {"w": 37, "t": "திரும்புகின்றவர்களுக்கு"}, {"w": 38, "t": "turns"}, {"w": 39, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவர்கள் பல பிரிவுகளாக பிரியவில்லை"}, {"w": 2, "t": "they became divided"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "வந்ததன் பின்னரே"}, {"w": 5, "t": "after"}, {"w": 6, "t": "[what]"}, {"w": 7, "t": "தங்களிடம்"}, {"w": 8, "t": "கல்வி"}, {"w": 9, "t": "பொறாமையினால்தான்"}, {"w": 10, "t": "தங்களுக்கு மத்தியில்"}, {"w": 11, "t": "இருக்கவில்லை என்றால்"}, {"w": 12, "t": "ஒரு வாக்கு"}, {"w": 13, "t": "முந்தி(யது)"}, {"w": 14, "t": "உமது இறைவன் புறத்தில் இருந்து"}, {"w": 15, "t": "your Lord"}, {"w": 16, "t": "ஒரு தவணை வரை"}, {"w": 17, "t": "a term"}, {"w": 18, "t": "குறிப்பிட்ட"}, {"w": 19, "t": "தீர்ப்பளிக்கப்பட்டிருக்கும்"}, {"w": 20, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 21, "t": "நிச்சயமாக"}, {"w": 22, "t": "கொடுக்கப்பட்டவர்கள்"}, {"w": 23, "t": "were made to inherit"}, {"w": 24, "t": "வேதம்"}, {"w": 25, "t": "பின்னர்"}, {"w": 26, "t": "பின்னர் இவர்களுக்கு"}, {"w": 27, "t": "சந்தேகத்தில்"}, {"w": 28, "t": "doubt"}, {"w": 29, "t": "அதில்"}, {"w": 30, "t": "பெரிய"}, {"w": 31, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "இதன் பக்கமே"}, {"w": 2, "t": "நீர் அழைப்பீராக"}, {"w": 3, "t": "இன்னும் நீர் நிலையாக நீடித்து இருப்பீராக"}, {"w": 4, "t": "நீர் கட்டளையிடப்பட்டது போன்றே"}, {"w": 5, "t": "you are commanded"}, {"w": 6, "t": "நீர் பின்பற்றாதீர்"}, {"w": 7, "t": "follow"}, {"w": 8, "t": "மன விருப்பங்களை அவர்களின்"}, {"w": 9, "t": "இன்னும் நீர் கூறுவிராக"}, {"w": 10, "t": "நான் நம்பிக்கை கொண்டேன்"}, {"w": 11, "t": "இறக்கியதை"}, {"w": 12, "t": "Allah has sent down"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "வேதங்களில் இருந்து"}, {"w": 15, "t": "(the) Book"}, {"w": 16, "t": "பணிக்கப்பட்டுள்ளேன்"}, {"w": 17, "t": "நீதமாக நடக்க வேண்டும் என்று"}, {"w": 18, "t": "உங்களுக்கு மத்தியில்"}, {"w": 19, "t": "அல்லாஹ்தான்"}, {"w": 20, "t": "இன்னும் உங்களுக்கு"}, {"w": 21, "t": "இன்னும் உங்கள் அமல்கள்"}, {"w": 22, "t": "எங்களுக்கு"}, {"w": 23, "t": "எங்கள் அமல்கள்"}, {"w": 24, "t": "இன்னும் உங்களுக்கு"}, {"w": 25, "t": "உங்கள் அமல்கள்"}, {"w": 26, "t": "சண்டை வேண்டாம்"}, {"w": 27, "t": "argument"}, {"w": 28, "t": "நமக்கு மத்தியிலும்"}, {"w": 29, "t": "உங்களுக்கு மத்தியிலும்"}, {"w": 30, "t": "அல்லாஹ்தான்"}, {"w": 31, "t": "ஒன்று சேர்ப்பான்"}, {"w": 32, "t": "நமக்கு மத்தியில்"}, {"w": 33, "t": "அவன் பக்கமே"}, {"w": 34, "t": "மீளுமிடம்"}, {"w": 35, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "எவர்கள் தர்க்கம் செய்கின்றார்களோ"}, {"w": 2, "t": "argue"}, {"w": 3, "t": "அல்லாஹ்வின் விஷயத்தில்"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "பின்னர்"}, {"w": 6, "t": "after"}, {"w": 7, "t": "ஏற்றுக்கொண்டதன்"}, {"w": 8, "t": "response has been made to Him"}, {"w": 9, "t": "அவனை"}, {"w": 10, "t": "அவர்களின்வாதங்கள்"}, {"w": 11, "t": "வீணானதே!"}, {"w": 12, "t": "அல்லாஹ்விடம்"}, {"w": 13, "t": "their Lord"}, {"w": 14, "t": "இன்னும் அவர்கள் மீது இறங்கும்/கோபம்"}, {"w": 15, "t": "(is) wrath"}, {"w": 16, "t": "இன்னும் அவர்களுக்கு உண்டு"}, {"w": 17, "t": "வேதனையும்"}, {"w": 18, "t": "கடுமையான"}, {"w": 19, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அல்லாஹ்/ எப்படிப்பட்டவன்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "இறக்கினான்"}, {"w": 4, "t": "வேதத்தையும்"}, {"w": 5, "t": "சத்தியத்துடன்"}, {"w": 6, "t": "தராசையும்"}, {"w": 7, "t": "உமக்கு எது அறிவிக்கும்?"}, {"w": 8, "t": "will make you know"}, {"w": 9, "t": "மறுமை"}, {"w": 10, "t": "the Hour"}, {"w": 11, "t": "மிக சமீபமானது"}, {"w": 12, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவசரமாகத் தேடுகின்றனர்/அதை"}, {"w": 2, "t": "[of] it"}, {"w": 3, "t": "நம்பிக்கை கொள்ளாதவர்கள்/அதை"}, {"w": 4, "t": "(do) not"}, {"w": 5, "t": "believe"}, {"w": 6, "t": "in it"}, {"w": 7, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 8, "t": "believe"}, {"w": 9, "t": "பயப்படுகின்றனர்"}, {"w": 10, "t": "அதை"}, {"w": 11, "t": "இன்னும் அறிவார்கள்"}, {"w": 12, "t": "நிச்சயமாக அது"}, {"w": 13, "t": "உண்மைதான்"}, {"w": 14, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 15, "t": "நிச்சயமாக தர்க்கிப்பவர்கள்"}, {"w": 16, "t": "those who"}, {"w": 17, "t": "dispute"}, {"w": 18, "t": "மறுமை விஷயத்தில்"}, {"w": 19, "t": "the Hour"}, {"w": 20, "t": "வழிகேட்டில்தான்"}, {"w": 21, "t": "error"}, {"w": 22, "t": "வெகு தூரமான"}, {"w": 23, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "மிக கருணையும் தயவும் உடையவன்"}, {"w": 3, "t": "தன் அடியார்கள் மீது"}, {"w": 4, "t": "உணவளிக்கின்றான்"}, {"w": 5, "t": "தான் நாடுகின்றவர்களுக்கு"}, {"w": 6, "t": "He wills"}, {"w": 7, "t": "அவன்தான்"}, {"w": 8, "t": "மிக வலிமை உள்ளவன்"}, {"w": 9, "t": "மிகைத்தவன்"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "இருப்பாரோ"}, {"w": 3, "t": "நாடுகின்றவராக"}, {"w": 4, "t": "விளைச்சலை"}, {"w": 5, "t": "மறுமையின்"}, {"w": 6, "t": "நாம் அதிகப்படுத்துவோம்"}, {"w": 7, "t": "அவருக்கு"}, {"w": 8, "t": "அவருடைய விளைச்சலில்"}, {"w": 9, "t": "his harvest"}, {"w": 10, "t": "இன்னும் யார்/இருப்பாரோ"}, {"w": 11, "t": "is"}, {"w": 12, "t": "நாடுகின்றவராக"}, {"w": 13, "t": "விளைச்சலை"}, {"w": 14, "t": "உலகத்தின்"}, {"w": 15, "t": "அவருக்கு நாம் கொடுப்போம்"}, {"w": 16, "t": "அதில் இருந்து"}, {"w": 17, "t": "இல்லை/அவருக்கு"}, {"w": 18, "t": "for him"}, {"w": 19, "t": "மறுமையில்"}, {"w": 20, "t": "the Hereafter"}, {"w": 21, "t": "எவ்வித பங்கும்"}, {"w": 22, "t": "share"}, {"w": 23, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "இவர்களுக்கு உண்டா?"}, {"w": 2, "t": "for them"}, {"w": 3, "t": "இணைதெய்வங்களும்"}, {"w": 4, "t": "சட்டமாக்(கு)கி(ன்ற)னர்"}, {"w": 5, "t": "இவர்களுக்கு"}, {"w": 6, "t": "மார்க்கத்தில்"}, {"w": 7, "t": "the religion"}, {"w": 8, "t": "எதை/அனுமதிக்கவில்லையோ"}, {"w": 9, "t": "not"}, {"w": 10, "t": "Allah has given permission of it"}, {"w": 11, "t": "அதை"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "தீர்ப்பின் வாக்கு மட்டும்/இல்லை என்றால்"}, {"w": 14, "t": "(for) a word"}, {"w": 15, "t": "decisive"}, {"w": 16, "t": "தீர்ப்பளிக்கப்பட்டிருக்கும்"}, {"w": 17, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 18, "t": "நிச்சயமாக"}, {"w": 19, "t": "அநியாயக்காரர்கள்"}, {"w": 20, "t": "அவர்களுக்கு உண்டு"}, {"w": 21, "t": "வேதனை"}, {"w": 22, "t": "வலி தரக்கூடியது"}, {"w": 23, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நீர் பார்ப்பீர்!"}, {"w": 2, "t": "அநியாயக்காரர்களை"}, {"w": 3, "t": "பயந்தவர்களாக"}, {"w": 4, "t": "அவர்கள் செய்தவற்றின் காரணமாக"}, {"w": 5, "t": "they earned"}, {"w": 6, "t": "அது நிகழ்ந்தே தீரும்"}, {"w": 7, "t": "(will) befall"}, {"w": 8, "t": "அவர்களுக்கு"}, {"w": 9, "t": "எவர்கள்"}, {"w": 10, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 11, "t": "இன்னும் செய்தார்கள்"}, {"w": 12, "t": "நன்மைகளை"}, {"w": 13, "t": "சோலைகளில்"}, {"w": 14, "t": "flowering meadows"}, {"w": 15, "t": "சொர்க்கங்களின்"}, {"w": 16, "t": "அவர்களுக்கு உண்டு"}, {"w": 17, "t": "அவர்கள் நாடுகின்றவை"}, {"w": 18, "t": "they wish"}, {"w": 19, "t": "அவர்களின் இறைவனிடம்"}, {"w": 20, "t": "their Lord"}, {"w": 21, "t": "இதுதான்"}, {"w": 22, "t": "it"}, {"w": 23, "t": "சிறப்பாகும்"}, {"w": 24, "t": "மிகப் பெரிய"}, {"w": 25, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "எது/நற்செய்தி கூறுகின்றான்"}, {"w": 3, "t": "Allah gives glad tidings"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "தன் அடியார்களுக்கு"}, {"w": 6, "t": "எவர்கள்"}, {"w": 7, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 8, "t": "இன்னும் செய்தார்கள்"}, {"w": 9, "t": "நன்மைகளை"}, {"w": 10, "t": "கூறுவீராக!"}, {"w": 11, "t": "நான் உங்களிடத்தில் கேட்கவில்லை"}, {"w": 12, "t": "I ask you"}, {"w": 13, "t": "இதற்காக"}, {"w": 14, "t": "எந்த கூலியையும்"}, {"w": 15, "t": "அன்பைத் தவிர"}, {"w": 16, "t": "the love"}, {"w": 17, "t": "உறவினால் உள்ள"}, {"w": 18, "t": "the relatives"}, {"w": 19, "t": "யார் செய்வாரோ"}, {"w": 20, "t": "earns"}, {"w": 21, "t": "அழகிய அமலை"}, {"w": 22, "t": "அதிகப்படுத்துவோம்"}, {"w": 23, "t": "அவருக்கு/அதில்"}, {"w": 24, "t": "therein"}, {"w": 25, "t": "அழகை"}, {"w": 26, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 27, "t": "Allah"}, {"w": 28, "t": "மகா மன்னிப்பாளன்"}, {"w": 29, "t": "நன்றியறிபவன்"}, {"w": 30, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "கூறுகிறார்களா?"}, {"w": 2, "t": "(do) they say"}, {"w": 3, "t": "இட்டுக்கட்டினார்"}, {"w": 4, "t": "அல்லாஹ்வின் மீது"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "பொய்யை"}, {"w": 7, "t": "நாடினால்"}, {"w": 8, "t": "Allah willed"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "முத்திரையிட்டு விடுவான்"}, {"w": 11, "t": "உமது உள்ளத்தின் மீது"}, {"w": 12, "t": "your heart"}, {"w": 13, "t": "இன்னும் அழித்துவிடுவான்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "பொய்யை"}, {"w": 16, "t": "இன்னும் உறுதிப்படுத்துவான்"}, {"w": 17, "t": "சத்தியத்தை"}, {"w": 18, "t": "தனது கட்டளைகளைக் கொண்டு"}, {"w": 19, "t": "நிச்சயமாக அவன்"}, {"w": 20, "t": "நன்கறிந்தவன்"}, {"w": 21, "t": "நெஞ்சங்களில் உள்ளதை"}, {"w": 22, "t": "(is in) the breasts"}, {"w": 23, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவன்/ எப்படிப்பட்டவன்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "ஏற்றுக்கொள்கிறான்"}, {"w": 4, "t": "திருந்துவதை"}, {"w": 5, "t": "தனது அடியார்களிடமிருந்து"}, {"w": 6, "t": "His slaves"}, {"w": 7, "t": "இன்னும் மன்னிக்கிறான்"}, {"w": 8, "t": "பாவங்களை"}, {"w": 9, "t": "the evil"}, {"w": 10, "t": "இன்னும் நன்கறிகின்றான்"}, {"w": 11, "t": "நீங்கள் செய்வதை"}, {"w": 12, "t": "you do"}, {"w": 13, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "இன்னும் பதில் அளிக்கின்றான்"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நன்மைகளை"}, {"w": 6, "t": "இன்னும் அதிகம் கொடுப்பான் அவர்களுக்கு"}, {"w": 7, "t": "தனது அருளால்"}, {"w": 8, "t": "His Bounty"}, {"w": 9, "t": "நிராகரிப்பாளர்கள்"}, {"w": 10, "t": "அவர்களுக்கு உண்டு"}, {"w": 11, "t": "வேதனை"}, {"w": 12, "t": "கடுமையான(து)"}, {"w": 13, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "விசாலமாக்கினால்"}, {"w": 2, "t": "Allah extends"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "வாழ்வாதாரத்தை"}, {"w": 5, "t": "தனது அடியார்களுக்கு"}, {"w": 6, "t": "அவர்கள் எல்லை மீறி விடுவார்கள்"}, {"w": 7, "t": "பூமியில்"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "என்றாலும்"}, {"w": 10, "t": "இறக்குகின்றான்"}, {"w": 11, "t": "அளவுடன்"}, {"w": 12, "t": "தான் நாடியதை"}, {"w": 13, "t": "He wills"}, {"w": 14, "t": "நிச்சயமாக அவன்"}, {"w": 15, "t": "தன் அடியார்களை"}, {"w": 16, "t": "ஆழ்ந்தறிபவன்"}, {"w": 17, "t": "உற்று நோக்குபவன்"}, {"w": 18, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "அவன்தான்"}, {"w": 2, "t": "எப்படிப்பட்டவன்"}, {"w": 3, "t": "இறக்குகின்றான்"}, {"w": 4, "t": "மழையை"}, {"w": 5, "t": "அவர்கள் நிராசை அடைந்த பின்னர்"}, {"w": 6, "t": "after"}, {"w": 7, "t": "[what]"}, {"w": 8, "t": "they have despaired"}, {"w": 9, "t": "இன்னும் பரப்புகின்றான்"}, {"w": 10, "t": "தனது அருளை"}, {"w": 11, "t": "அவன்தான்"}, {"w": 12, "t": "பாதுகாவலன்"}, {"w": 13, "t": "மகா புகழாளன்"}, {"w": 14, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அவனது அத்தாட்சிகளில்"}, {"w": 2, "t": "His Signs"}, {"w": 3, "t": "படைத்திருப்பது"}, {"w": 4, "t": "வானங்களையும் பூமியையும்"}, {"w": 5, "t": "and the earth"}, {"w": 6, "t": "இன்னும் எவற்றை/பரத்தி இருக்கின்றானோ"}, {"w": 7, "t": "He has dispersed"}, {"w": 8, "t": "அவ்விரண்டில்"}, {"w": 9, "t": "உயிரினங்களில் இருந்து"}, {"w": 10, "t": "(the) creatures"}, {"w": 11, "t": "அவன் அவர்களை ஒன்று சேர்ப்பதற்கு"}, {"w": 12, "t": "(is) over"}, {"w": 13, "t": "their gathering"}, {"w": 14, "t": "அவன் நாடுகின்றபோது"}, {"w": 15, "t": "He wills"}, {"w": 16, "t": "பேராற்றலுடையவன்"}, {"w": 17, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "எது/உங்களுக்கு ஏற்பட்டதோ"}, {"w": 2, "t": "befalls you"}, {"w": 3, "t": "சோதனைகளில்"}, {"w": 4, "t": "(the) misfortune"}, {"w": 5, "t": "செய்தவற்றினால்தான்"}, {"w": 6, "t": "have earned"}, {"w": 7, "t": "உங்கள் கரங்கள்"}, {"w": 8, "t": "இன்னும் மன்னித்துவிடுகிறான்"}, {"w": 9, "t": "அதிகமான தவறுகளை"}, {"w": 10, "t": "much"}, {"w": 11, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நீங்கள் தப்பித்துவிட முடியாது"}, {"w": 2, "t": "you"}, {"w": 3, "t": "(can) escape"}, {"w": 4, "t": "இந்த பூமியில்"}, {"w": 5, "t": "the earth"}, {"w": 6, "t": "இன்னும் உங்களுக்குஇல்லை"}, {"w": 7, "t": "for you"}, {"w": 8, "t": "அல்லாஹ்வையன்றி"}, {"w": 9, "t": "besides"}, {"w": 10, "t": "Allah"}, {"w": 11, "t": "எந்த பாதுகாவலரும்"}, {"w": 12, "t": "protector"}, {"w": 13, "t": "எந்த உதவியாளரும் இல்லை"}, {"w": 14, "t": "any helper"}, {"w": 15, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அவனுடைய அத்தாட்சிகளில் உள்ளவைதான்"}, {"w": 2, "t": "His Signs"}, {"w": 3, "t": "மிதந்து செல்லக்கூடிய கப்பல்கள்"}, {"w": 4, "t": "கடலில்"}, {"w": 5, "t": "the sea"}, {"w": 6, "t": "மலைகளைப் போன்று"}, {"w": 7, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "அவன் நாடினால்"}, {"w": 2, "t": "He wills"}, {"w": 3, "t": "அமைதியாக்கி விடுவான்"}, {"w": 4, "t": "காற்றுகளை"}, {"w": 5, "t": "ஆகிவிடும்"}, {"w": 6, "t": "அசையாமல் நிற்கக்கூடியதாக"}, {"w": 7, "t": "அதன் மீதே"}, {"w": 8, "t": "its back"}, {"w": 9, "t": "நிச்சயமாக"}, {"w": 10, "t": "இதில் இருக்கின்றன"}, {"w": 11, "t": "that"}, {"w": 12, "t": "பல அத்தாட்சிகள்"}, {"w": 13, "t": "எல்லோருக்கும்"}, {"w": 14, "t": "பெரும் பொறுமையாளர்கள்"}, {"w": 15, "t": "நன்றி உள்ளவர்கள்"}, {"w": 16, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "அவற்றை அவன் அழித்து விடுவான்"}, {"w": 3, "t": "அவர்கள் செய்தவற்றின் காரணமாக"}, {"w": 4, "t": "they have earned"}, {"w": 5, "t": "இன்னும் மன்னித்து விடுகிறான்"}, {"w": 6, "t": "அதிகமான தவறுகளை"}, {"w": 7, "t": "much"}, {"w": 8, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "அவன் நன்கறிவான்"}, {"w": 2, "t": "தர்க்கிப்பவர்களை"}, {"w": 3, "t": "dispute"}, {"w": 4, "t": "நமது வசனங்களில்"}, {"w": 5, "t": "Our Signs"}, {"w": 6, "t": "அவர்களுக்கு இல்லை"}, {"w": 7, "t": "for them"}, {"w": 8, "t": "தப்பிக்கும் இடம் ஏதும்"}, {"w": 9, "t": "place of refuge"}, {"w": 10, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "நீங்கள் கொடுக்கப்பட்டுள்ள எல்லாம்"}, {"w": 2, "t": "you are given"}, {"w": 3, "t": "பொருள்கள்"}, {"w": 4, "t": "a thing"}, {"w": 5, "t": "இன்பமாகும்"}, {"w": 6, "t": "வாழ்க்கையின்"}, {"w": 7, "t": "இவ்வுலக"}, {"w": 8, "t": "எது உள்ளதோ"}, {"w": 9, "t": "அல்லாஹ்விடம்"}, {"w": 10, "t": "Allah"}, {"w": 11, "t": "மிகச் சிறந்தது(ம்)"}, {"w": 12, "t": "மிக நிரந்தரமானது(ம்)"}, {"w": 13, "t": "நம்பிக்கை கொண்டவர்களுக்கு"}, {"w": 14, "t": "believe"}, {"w": 15, "t": "இன்னும் தங்கள் இறைவனையே"}, {"w": 16, "t": "their Lord"}, {"w": 17, "t": "சார்ந்திருப்பார்கள்"}, {"w": 18, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இன்னும் /எவர்கள்/விலகிவிடுவார்கள்"}, {"w": 2, "t": "avoid"}, {"w": 3, "t": "பெரும் பாவங்களை விட்டும்"}, {"w": 4, "t": "sins"}, {"w": 5, "t": "மானக்கேடான விஷயங்களை விட்டும்"}, {"w": 6, "t": "அவர்கள் கோபப்படும்போது"}, {"w": 7, "t": "and when"}, {"w": 8, "t": "they are angry"}, {"w": 9, "t": "they"}, {"w": 10, "t": "மன்னித்து விடுவார்கள்"}, {"w": 11, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "இன்னும் எவர்கள்"}, {"w": 2, "t": "பதில் அளிப்பார்கள்"}, {"w": 3, "t": "தங்கள் இறைவனுக்கு"}, {"w": 4, "t": "இன்னும் நிலைநிறுத்துவார்கள்"}, {"w": 5, "t": "தொழுகையை"}, {"w": 6, "t": "இன்னும் அவர்களது காரியம்"}, {"w": 7, "t": "ஆலோசிக்கப்படும்"}, {"w": 8, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 9, "t": "இன்னும் அவர்களுக்கு நாம் கொடுத்தவற்றில் இருந்து"}, {"w": 10, "t": "We have provided them"}, {"w": 11, "t": "தர்மம் கொடுப்பார்கள்"}, {"w": 12, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "இன்னும் எவர்கள்"}, {"w": 2, "t": "அவர்களுக்கு நிகழ்ந்தால்"}, {"w": 3, "t": "strikes them"}, {"w": 4, "t": "அநியாயம்"}, {"w": 5, "t": "அவர்கள் பழிவாங்குவார்கள்"}, {"w": 6, "t": "defend themselves"}, {"w": 7, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "தண்டனை"}, {"w": 2, "t": "தீமையின்"}, {"w": 3, "t": "தீமைதான்"}, {"w": 4, "t": "அது போன்ற"}, {"w": 5, "t": "யார்/மன்னிப்பாரோ"}, {"w": 6, "t": "pardons"}, {"w": 7, "t": "இன்னும் சமாதானம் செய்வாரோ"}, {"w": 8, "t": "அவரது கூலி"}, {"w": 9, "t": "அல்லாஹ்வின் மீது"}, {"w": 10, "t": "Allah"}, {"w": 11, "t": "நிச்சயமாக அவன்"}, {"w": 12, "t": "நேசிக்க மாட்டான்"}, {"w": 13, "t": "like"}, {"w": 14, "t": "அநியாயக்காரர்களை"}, {"w": 15, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "பழிவாங்குவாரோ"}, {"w": 3, "t": "தனக்கு அநீதி இழைக்கப்பட்ட பின்னர்"}, {"w": 4, "t": "he has been wronged"}, {"w": 5, "t": "அவர்கள் மீது இல்லை"}, {"w": 6, "t": "not"}, {"w": 7, "t": "(is) against them"}, {"w": 8, "t": "எவ்வித குற்றமும்"}, {"w": 9, "t": "way"}, {"w": 10, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "குற்றமெல்லாம்"}, {"w": 2, "t": "the way"}, {"w": 3, "t": "அநியாயம் செய்பவர்கள் மீதும்"}, {"w": 4, "t": "those who"}, {"w": 5, "t": "oppress"}, {"w": 6, "t": "மக்களுக்கு"}, {"w": 7, "t": "இன்னும் வரம்பு மீறுகிறார்கள்"}, {"w": 8, "t": "பூமியில்"}, {"w": 9, "t": "the earth"}, {"w": 10, "t": "அநியாயமாக"}, {"w": 11, "t": "right"}, {"w": 12, "t": "அவர்களுக்கு உண்டு"}, {"w": 13, "t": "for them"}, {"w": 14, "t": "வேதனை"}, {"w": 15, "t": "வலிதரக்கூடியது"}, {"w": 16, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "யார் பொறுமையாக இருப்பாரோ"}, {"w": 2, "t": "(is) patient"}, {"w": 3, "t": "இன்னும் மன்னிப்பாரோ"}, {"w": 4, "t": "நிச்சயமாக அது"}, {"w": 5, "t": "that"}, {"w": 6, "t": "மிக வீரமான காரியங்களில் உள்ளதாகும்"}, {"w": 7, "t": "matters of determination"}, {"w": 8, "t": "matters of determination"}, {"w": 9, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "யாரை"}, {"w": 2, "t": "வழிகெடுத்தானோ"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "இல்லை"}, {"w": 5, "t": "அவனுக்கு"}, {"w": 6, "t": "எந்தப் பாதுகாவலரும்"}, {"w": 7, "t": "protector"}, {"w": 8, "t": "அவனுக்குப் பிறகு"}, {"w": 9, "t": "after Him"}, {"w": 10, "t": "நீர் காண்பீர்!"}, {"w": 11, "t": "பாவிகளை"}, {"w": 12, "t": "அவர்கள் பார்க்கும் போது"}, {"w": 13, "t": "they see"}, {"w": 14, "t": "வேதனையை"}, {"w": 15, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 16, "t": "திரும்புவதற்கு உண்டா?"}, {"w": 17, "t": "(there) for"}, {"w": 18, "t": "return"}, {"w": 19, "t": "ஏதேனும் வழி"}, {"w": 20, "t": "way"}, {"w": 21, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நீர் காண்பீர்/அவர்களை"}, {"w": 2, "t": "சமர்ப்பிக்கப்படுவர்களாக"}, {"w": 3, "t": "அதன் முன்"}, {"w": 4, "t": "தலைகுனிந்தவர்களாக"}, {"w": 5, "t": "இழிவினால்"}, {"w": 6, "t": "disgrace"}, {"w": 7, "t": "அவர்கள் பார்ப்பார்கள்"}, {"w": 8, "t": "பார்வையால்"}, {"w": 9, "t": "a glance"}, {"w": 10, "t": "திருட்டு"}, {"w": 11, "t": "இன்னும் கூறுவார்கள்"}, {"w": 12, "t": "நம்பிக்கையாளர்கள்"}, {"w": 13, "t": "believed"}, {"w": 14, "t": "நிச்சயமாக"}, {"w": 15, "t": "நஷ்டவாளிகள்"}, {"w": 16, "t": "நஷ்டமிழைத்தவர்கள்தான்"}, {"w": 17, "t": "lost"}, {"w": 18, "t": "தங்களுக்கு(ம்)"}, {"w": 19, "t": "தங்கள்குடும்பத்திற்கும்"}, {"w": 20, "t": "மறுமை நாளில்"}, {"w": 21, "t": "(of) the Resurrection"}, {"w": 22, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 23, "t": "நிச்சயமாக"}, {"w": 24, "t": "அநியாயக்காரர்கள்"}, {"w": 25, "t": "வேதனையில்"}, {"w": 26, "t": "a punishment"}, {"w": 27, "t": "நிலையான"}, {"w": 28, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "இருக்க மாட்டார்கள்"}, {"w": 2, "t": "will be"}, {"w": 3, "t": "அவர்களுக்கு"}, {"w": 4, "t": "பாதுகாவலர்கள் யாரும்"}, {"w": 5, "t": "protector"}, {"w": 6, "t": "அவர்களுக்கு உதவுகின்ற(னர்)"}, {"w": 7, "t": "அல்லாஹ்வையன்றி"}, {"w": 8, "t": "besides"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "யாரை"}, {"w": 11, "t": "வழிகெடுப்பானோ"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "அவருக்கு இல்லை"}, {"w": 14, "t": "for him"}, {"w": 15, "t": "எந்த வழியும்"}, {"w": 16, "t": "way"}, {"w": 17, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "நீங்கள்பதில் அளியுங்கள்!"}, {"w": 2, "t": "உங்கள் இறைவனுக்கு"}, {"w": 3, "t": "முன்"}, {"w": 4, "t": "before"}, {"w": 5, "t": "வருவதற்கு"}, {"w": 6, "t": "comes"}, {"w": 7, "t": "ஒரு நாள்"}, {"w": 8, "t": "அறவே தடுத்துவிட முடியாது"}, {"w": 9, "t": "averting"}, {"w": 10, "t": "அதை"}, {"w": 11, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 12, "t": "Allah"}, {"w": 13, "t": "உங்களுக்கு இருக்காது"}, {"w": 14, "t": "(is) for you"}, {"w": 15, "t": "ஒதுங்குமிடம் எதுவும்"}, {"w": 16, "t": "refuge"}, {"w": 17, "t": "அந்நாளில்"}, {"w": 18, "t": "இன்னும் உங்களுக்கு இருக்க மாட்டார்"}, {"w": 19, "t": "for you"}, {"w": 20, "t": "தடுப்பவர் யாரும்"}, {"w": 21, "t": "denial"}, {"w": 22, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "அவர்கள் புறக்கணித்தால்"}, {"w": 2, "t": "they turn away"}, {"w": 3, "t": "நாம் உம்மை அனுப்பவில்லை"}, {"w": 4, "t": "We have sent you"}, {"w": 5, "t": "அவர்கள் மீது"}, {"w": 6, "t": "கண்காணிப்பவராக"}, {"w": 7, "t": "உம்மீது கடமை இல்லை"}, {"w": 8, "t": "(is) on you"}, {"w": 9, "t": "தவிர"}, {"w": 10, "t": "எடுத்துரைப்பதை"}, {"w": 11, "t": "நிச்சயமாக நாம்"}, {"w": 12, "t": "சுவைக்க வைத்தால்"}, {"w": 13, "t": "We cause to taste"}, {"w": 14, "t": "மனிதர்களுக்கு"}, {"w": 15, "t": "நம்மிடமிருந்து"}, {"w": 16, "t": "ஓர் அருளை"}, {"w": 17, "t": "அவர்கள் மகிழ்ச்சியடைகிறார்(கள்)"}, {"w": 18, "t": "அதனால்"}, {"w": 19, "t": "அவர்களுக்கு ஏற்பட்டால்"}, {"w": 20, "t": "befalls them"}, {"w": 21, "t": "ஒரு தீங்கு"}, {"w": 22, "t": "முற்படுத்தியதால்"}, {"w": 23, "t": "have sent forth"}, {"w": 24, "t": "அவர்களின் கரங்கள்"}, {"w": 25, "t": "நிச்சயமாக மனிதன்"}, {"w": 26, "t": "[the] man"}, {"w": 27, "t": "மிகப்பெரிய நிராகரிப்பாளன்"}, {"w": 28, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அல்லாஹ்விற்கே"}, {"w": 2, "t": "ஆட்சி"}, {"w": 3, "t": "வானங்கள்"}, {"w": 4, "t": "இன்னும் பூமி(யின்)"}, {"w": 5, "t": "படைக்கின்றான்"}, {"w": 6, "t": "தான் நாடுவதை"}, {"w": 7, "t": "He wills"}, {"w": 8, "t": "வழங்குகின்றான்"}, {"w": 9, "t": "தான் நாடியவர்களுக்கு"}, {"w": 10, "t": "He wills"}, {"w": 11, "t": "பெண் பிள்ளைகளை"}, {"w": 12, "t": "இன்னும் வழங்குகின்றான்"}, {"w": 13, "t": "தான் நாடியவர்களுக்கு"}, {"w": 14, "t": "He wills"}, {"w": 15, "t": "ஆண் பிள்ளைகளை"}, {"w": 16, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "அல்லது"}, {"w": 2, "t": "அவர்களுக்கு கலந்து கொடுக்கின்றான்"}, {"w": 3, "t": "ஆண் பிள்ளைகளை"}, {"w": 4, "t": "இன்னும் பெண் பிள்ளைகளை"}, {"w": 5, "t": "இன்னும் ஆக்குகின்றான்"}, {"w": 6, "t": "தான் நாடுகின்றவர்களை"}, {"w": 7, "t": "He wills"}, {"w": 8, "t": "மலடுகளாக"}, {"w": 9, "t": "நிச்சயமாக அவன்"}, {"w": 10, "t": "நன்கறிந்தவன்"}, {"w": 11, "t": "பேராற்றலுடையவன்"}, {"w": 12, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "முடியாது"}, {"w": 2, "t": "is"}, {"w": 3, "t": "ஒரு மனிதருக்கு"}, {"w": 4, "t": "அவரிடம் நேரடியாகபேசுவது"}, {"w": 5, "t": "Allah should speak to him"}, {"w": 6, "t": "அல்லாஹ்"}, {"w": 7, "t": "தவிர/வஹீ  அறிவிப்பதன் மூலம்"}, {"w": 8, "t": "(by) revelation"}, {"w": 9, "t": "அல்லது"}, {"w": 10, "t": "பின்னால் இருந்து"}, {"w": 11, "t": "behind"}, {"w": 12, "t": "திரைக்கு"}, {"w": 13, "t": "அல்லது"}, {"w": 14, "t": "அனுப்புவான்"}, {"w": 15, "t": "ஒரு தூதரை"}, {"w": 16, "t": "வஹீ  அறிவிப்பான்"}, {"w": 17, "t": "தனது உத்தரவின்படி"}, {"w": 18, "t": "தான் நாடுவதை"}, {"w": 19, "t": "He wills"}, {"w": 20, "t": "நிச்சயமாக அவன்"}, {"w": 21, "t": "மிக உயர்ந்தவன்"}, {"w": 22, "t": "மகா ஞானவான்"}, {"w": 23, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "இவ்வாறுதான்"}, {"w": 2, "t": "வஹீ  அறிவித்தோம்"}, {"w": 3, "t": "உமக்கு"}, {"w": 4, "t": "அருளாக"}, {"w": 5, "t": "நமதுகட்டளையினால்"}, {"w": 6, "t": "Our Command"}, {"w": 7, "t": "நீர் இருக்கவில்லை"}, {"w": 8, "t": "(did) you"}, {"w": 9, "t": "அறிந்தவராக"}, {"w": 10, "t": "வேதம் என்றால் என்ன"}, {"w": 11, "t": "the Book (is)"}, {"w": 12, "t": "ஈமான் என்றால் என்ன"}, {"w": 13, "t": "the faith"}, {"w": 14, "t": "எனினும்"}, {"w": 15, "t": "நாம் இதை ஆக்கினோம்"}, {"w": 16, "t": "ஓர் ஒளியாக"}, {"w": 17, "t": "நாம் நேர்வழி காட்டுகின்றோம்"}, {"w": 18, "t": "இதன் மூலம்"}, {"w": 19, "t": "நாம் நாடுகின்றவர்களுக்கு"}, {"w": 20, "t": "We will"}, {"w": 21, "t": "நமது அடியார்களில்"}, {"w": 22, "t": "Our slaves"}, {"w": 23, "t": "நிச்சயமாக நீர்"}, {"w": 24, "t": "நேர்வழி காட்டுகின்றீர்"}, {"w": 25, "t": "பக்கம்"}, {"w": 26, "t": "பாதையின்"}, {"w": 27, "t": "நேரான"}, {"w": 28, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "பாதையின் பக்கம்"}, {"w": 2, "t": "அல்லாஹ்வின்"}, {"w": 3, "t": "எப்படிப்பட்டவன்"}, {"w": 4, "t": "அவனுக்கே"}, {"w": 5, "t": "வானங்களில் உள்ளவை"}, {"w": 6, "t": "(is) in"}, {"w": 7, "t": "the heavens"}, {"w": 8, "t": "இன்னும் பூமியில் உள்ளவை(யும்)"}, {"w": 9, "t": "(is) in"}, {"w": 10, "t": "the earth"}, {"w": 11, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 12, "t": "அல்லாஹ்வின் பக்கமே"}, {"w": 13, "t": "Allah"}, {"w": 14, "t": "திரும்புகின்றன"}, {"w": 15, "t": "காரியங்கள்"}, {"w": 16, "t": "(53)"}]}]}