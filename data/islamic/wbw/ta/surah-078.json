{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "எதைப் பற்றி"}, {"w": 2, "t": "விசாரித்துக் கொள்கிறார்கள்"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "செய்தியைப் பற்றி"}, {"w": 2, "t": "the News"}, {"w": 3, "t": "மகத்தான(து)"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "எது/அவர்கள்"}, {"w": 2, "t": "they"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "முரண்பட்டவர்கள்"}, {"w": 5, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "(விரைவில்) அறிவார்கள்"}, {"w": 3, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "அவ்வாறல்ல"}, {"w": 3, "t": "(விரைவில்) அறிவார்கள்"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நாம் ஆக்கவில்லையா"}, {"w": 2, "t": "We made"}, {"w": 3, "t": "பூமியை"}, {"w": 4, "t": "விரிப்பாக"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் மலைகளை"}, {"w": 2, "t": "முளைக்கோல்களாக"}, {"w": 3, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் உங்களைப் படைத்தோம்"}, {"w": 2, "t": "ஜோடிகளாக"}, {"w": 3, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் ஆக்கினோம்"}, {"w": 2, "t": "உங்கள் நித்திரையை"}, {"w": 3, "t": "ஓய்வாக"}, {"w": 4, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் ஆக்கினோம்"}, {"w": 2, "t": "இரவை"}, {"w": 3, "t": "ஆடையாக"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "இன்னும் ஆக்கினோம்"}, {"w": 2, "t": "பகலை"}, {"w": 3, "t": "வாழ்வாக"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் அமைத்தோம்"}, {"w": 2, "t": "உங்களுக்கு மேல்"}, {"w": 3, "t": "ஏழு வானங்களை"}, {"w": 4, "t": "பலமான"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இன்னும் ஆக்கினோம்"}, {"w": 2, "t": "விளக்கை"}, {"w": 3, "t": "பிரகாசிக்கக்கூடிய"}, {"w": 4, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் இறக்கினோம்"}, {"w": 2, "t": "கார் மேகங்களிலிருந்து"}, {"w": 3, "t": "the rain clouds"}, {"w": 4, "t": "(மழை) நீரை"}, {"w": 5, "t": "தொடர்ச்சியாக பொழியக்கூடிய"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நாம் உற்பத்தி செய்வதற்காக"}, {"w": 2, "t": "அதன் மூலம்"}, {"w": 3, "t": "தானியத்தை"}, {"w": 4, "t": "இன்னும் தாவரத்தை"}, {"w": 5, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இன்னும் தோட்டங்களை"}, {"w": 2, "t": "அடர்த்தியான"}, {"w": 3, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "தீர்ப்பு நாள்"}, {"w": 3, "t": "(of) the Judgment"}, {"w": 4, "t": "இருக்கிறது"}, {"w": 5, "t": "(நேரம்) குறிப்பிடப்பட்ட காலமாக"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "ஊதப் படுகின்ற நாளில்"}, {"w": 2, "t": "(in which) shall be blown"}, {"w": 3, "t": "‘சூர்’ல்"}, {"w": 4, "t": "the trumpet"}, {"w": 5, "t": "ஆகவே வருவீர்கள்"}, {"w": 6, "t": "கூட்டங்களாக"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் திறக்கப்படும்"}, {"w": 2, "t": "வானம்"}, {"w": 3, "t": "அது மாறிவிடும்"}, {"w": 4, "t": "வழிகளாக"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இன்னும் அகற்றப்பட்டுவிடும்"}, {"w": 2, "t": "மலைகள்"}, {"w": 3, "t": "அது மாறிவிடும்"}, {"w": 4, "t": "கானல் நீராக"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "நிச்சயமாக நரகம்"}, {"w": 2, "t": "Hell"}, {"w": 3, "t": "இருக்கிறது"}, {"w": 4, "t": "எதிர் பார்க்கக்கூடியதாக"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "வரம்பு மீறியவர்களை"}, {"w": 2, "t": "தங்குமிடமாக"}, {"w": 3, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "தங்கக்கூடியவர்களாக"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "நீண்ட காலங்கள்"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "சுவைக்க மாட்டார்கள்"}, {"w": 2, "t": "they will taste"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "குளிர்ச்சியை"}, {"w": 5, "t": "இன்னும் இல்லை"}, {"w": 6, "t": "ஒரு பானத்தை"}, {"w": 7, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "தவிர/கொதி நீரை"}, {"w": 2, "t": "scalding water"}, {"w": 3, "t": "இன்னும் சீழ் சலத்தை"}, {"w": 4, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூலியாக"}, {"w": 2, "t": "தகுந்த"}, {"w": 3, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "இருந்தார்கள்"}, {"w": 3, "t": "ஆதரவு வைக்காதவர்களாக"}, {"w": 4, "t": "expecting"}, {"w": 5, "t": "விசாரிக்கப்படுவதை"}, {"w": 6, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இன்னும் பொய்ப்பித்தார்கள்"}, {"w": 2, "t": "நம் வசனங்களை"}, {"w": 3, "t": "அதிகமாகப் பொய்ப்பித்தல்"}, {"w": 4, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "இன்னும் எல்லாவற்றையும்"}, {"w": 2, "t": "thing"}, {"w": 3, "t": "அவற்றைப் பதிவு செய்தோம்"}, {"w": 4, "t": "எழுதி"}, {"w": 5, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "ஆகவே சுவையுங்கள்"}, {"w": 2, "t": "அதிகப்படுத்தவே மாட்டோம்"}, {"w": 3, "t": "அதிகப்படுத்தவே மாட்டோம் உங்களுக்கு"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "வேதனையை"}, {"w": 6, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "அல்லாஹ்வை அஞ்சுபவர்களுக்கு"}, {"w": 3, "t": "வெற்றி"}, {"w": 4, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "தோட்டங்கள்"}, {"w": 2, "t": "இன்னும் திராட்சைகள்"}, {"w": 3, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "இன்னும் மார்பு நிமிர்ந்த கன்னிகள்"}, {"w": 2, "t": "சம வயதுடைய(வர்கள்)"}, {"w": 3, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இன்னும் கிண்ணம்"}, {"w": 2, "t": "நிரம்பிய"}, {"w": 3, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "செவியுறமாட்டார்கள்"}, {"w": 2, "t": "they will hear"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "வீண் பேச்சை"}, {"w": 5, "t": "இன்னும் பொய்ப்பிப்பதை"}, {"w": 6, "t": "any falsehood"}, {"w": 7, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "கூலியாக"}, {"w": 2, "t": "உமது இறைவனிடமிருந்து"}, {"w": 3, "t": "your Lord"}, {"w": 4, "t": "கொடையாக"}, {"w": 5, "t": "கணக்கிடப்பட்ட"}, {"w": 6, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "அதிபதியாகிய"}, {"w": 2, "t": "வானங்கள்"}, {"w": 3, "t": "இன்னும் பூமி"}, {"w": 4, "t": "இன்னும் அவ்விரண்டிற்கும் மத்தியிலுள்ளவற்றின்"}, {"w": 5, "t": "(is) between both of them"}, {"w": 6, "t": "பேரருளாளனாகிய"}, {"w": 7, "t": "சக்தி பெறமாட்டார்கள்/ உரிமை பெறமாட்டார்கள்"}, {"w": 8, "t": "they have power"}, {"w": 9, "t": "அவனிடம்"}, {"w": 10, "t": "பேசுவதற்கு"}, {"w": 11, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "நிற்கின்ற"}, {"w": 3, "t": "ஜிப்ரீல்"}, {"w": 4, "t": "இன்னும் வானவர்கள்"}, {"w": 5, "t": "வரிசையாக"}, {"w": 6, "t": "பேசமாட்டார்கள்"}, {"w": 7, "t": "they will speak"}, {"w": 8, "t": "தவிர/எவர்"}, {"w": 9, "t": "(one) who "}, {"w": 10, "t": "அனுமதித்தான்"}, {"w": 11, "t": "அவருக்கு"}, {"w": 12, "t": "பேரருளாளன்"}, {"w": 13, "t": "இன்னும் கூறுவார்"}, {"w": 14, "t": "சரியானதையே"}, {"w": 15, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "அதுதான்"}, {"w": 2, "t": "நாள்"}, {"w": 3, "t": "உண்மையான"}, {"w": 4, "t": "ஆகவே யார்"}, {"w": 5, "t": "நாடுவாரோ"}, {"w": 6, "t": "ஆக்கிக்கொள்வார்"}, {"w": 7, "t": "தம் இறைவனருகில்"}, {"w": 8, "t": "his Lord"}, {"w": 9, "t": "தங்குமிடத்தை"}, {"w": 10, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "உங்களை எச்சரித்தோம்"}, {"w": 3, "t": "ஒரு வேதனையைப் பற்றி"}, {"w": 4, "t": "சமீபமான"}, {"w": 5, "t": "நாளில்"}, {"w": 6, "t": "பார்க்கின்ற"}, {"w": 7, "t": "மனிதன்"}, {"w": 8, "t": "முற்படுத்தியவற்றை"}, {"w": 9, "t": "have sent forth"}, {"w": 10, "t": "தனது இரு கரங்கள்"}, {"w": 11, "t": "இன்னும் கூறுவான்"}, {"w": 12, "t": "நிராகரிப்பாளன்"}, {"w": 13, "t": "நான் ஆகவேண்டுமே"}, {"w": 14, "t": "I were"}, {"w": 15, "t": "மண்ணாக"}, {"w": 16, "t": "(40)"}]}]}