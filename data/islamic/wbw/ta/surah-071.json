{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அனுப்பினோம்/நூஹை"}, {"w": 3, "t": "Nuh"}, {"w": 4, "t": "அவருடைய மக்களின் பக்கம்"}, {"w": 5, "t": "his people"}, {"w": 6, "t": "ஏனெனில், நீர் எச்சரிப்பீராக!"}, {"w": 7, "t": "Warn"}, {"w": 8, "t": "உமது மக்களை"}, {"w": 9, "t": "முன்னர்"}, {"w": 10, "t": "before"}, {"w": 11, "t": "அவர்களுக்கு வருவதற்கு"}, {"w": 12, "t": "comes to them"}, {"w": 13, "t": "தண்டனை"}, {"w": 14, "t": "வலி தரக்கூடிய"}, {"w": 15, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் மக்களே!"}, {"w": 3, "t": "நிச்சயமாக நான்"}, {"w": 4, "t": "உங்களுக்கு"}, {"w": 5, "t": "எச்சரிப்பாளர்"}, {"w": 6, "t": "தெளிவான"}, {"w": 7, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அதாவது, நீங்கள் வணங்குங்கள்!"}, {"w": 2, "t": "Worship"}, {"w": 3, "t": "அல்லாஹ்வை"}, {"w": 4, "t": "இன்னும் அவனை அஞ்சுங்கள்"}, {"w": 5, "t": "இன்னும் எனக்கு கீழ்ப்படியுங்கள்!"}, {"w": 6, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவன் மன்னிப்பான்"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "உங்கள் பாவங்களை"}, {"w": 4, "t": "your sins"}, {"w": 5, "t": "இன்னும் அவன் உங்களுக்கு அவகாசம் அளிப்பான்"}, {"w": 6, "t": "தவணை வரை"}, {"w": 7, "t": "a term"}, {"w": 8, "t": "குறிப்பிட்ட"}, {"w": 9, "t": "நிச்சயமாக"}, {"w": 10, "t": "தவணை"}, {"w": 11, "t": "அல்லாஹ்வின்"}, {"w": 12, "t": "வந்துவிட்டால்"}, {"w": 13, "t": "it comes"}, {"w": 14, "t": "அது பிற்படுத்தப்படாது"}, {"w": 15, "t": "is delayed"}, {"w": 16, "t": "நீங்கள் அறிபவர்களாக இருக்க வேண்டுமே!"}, {"w": 17, "t": "you"}, {"w": 18, "t": "know"}, {"w": 19, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் இறைவா!"}, {"w": 3, "t": "நிச்சயமாக நான்"}, {"w": 4, "t": "அழைத்தேன்"}, {"w": 5, "t": "எனது மக்களை"}, {"w": 6, "t": "இரவிலும்"}, {"w": 7, "t": "பகலிலும்"}, {"w": 8, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "அதிகப்படுத்தவில்லை"}, {"w": 2, "t": "அதிகப்படுத்தவில்லை அவர்களுக்கு"}, {"w": 3, "t": "எனது அழைப்பு"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "விரண்டோடுவதை"}, {"w": 6, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "அவர்களை அழைத்த போதெல்லாம்"}, {"w": 3, "t": "I invited them"}, {"w": 4, "t": "நீ மன்னிப்பதற்காக"}, {"w": 5, "t": "அவர்களை"}, {"w": 6, "t": "ஆக்கிக் கொண்டனர்"}, {"w": 7, "t": "தங்கள் விரல்களை"}, {"w": 8, "t": "தங்கள் காதுகளில்"}, {"w": 9, "t": "their ears"}, {"w": 10, "t": "இன்னும் மூடிக்கொண்டனர்"}, {"w": 11, "t": "தங்கள் ஆடைகளால்"}, {"w": 12, "t": "இன்னும் பிடிவாதம் பிடித்தனர்"}, {"w": 13, "t": "இன்னும் பெருமையடித்தனர்"}, {"w": 14, "t": "பெருமையடித்தல்"}, {"w": 15, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "பிறகு/நிச்சயமாக நான்"}, {"w": 2, "t": "indeed, I"}, {"w": 3, "t": "அவர்களை அழைத்தேன்"}, {"w": 4, "t": "உரக்க"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "வெளிப்படையாகப் பேசினேன்"}, {"w": 4, "t": "அவர்களிடம்"}, {"w": 5, "t": "இன்னும் இரகசியமாகப் பேசினேன்"}, {"w": 6, "t": "அவர்களிடம்"}, {"w": 7, "t": "தனியாக, இரகசியமாக பேசுதல்"}, {"w": 8, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நான் கூறினேன்"}, {"w": 2, "t": "நீங்கள் பாவமன்னிப்புக் கேளுங்கள்!"}, {"w": 3, "t": "உங்கள் இறைவனிடம்"}, {"w": 4, "t": "நிச்சயமாக அவன்"}, {"w": 5, "t": "இருக்கின்றான்"}, {"w": 6, "t": "மகா மன்னிப்பாளனாக"}, {"w": 7, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவன் அனுப்புவான்"}, {"w": 2, "t": "மழையை"}, {"w": 3, "t": "உங்களுக்கு"}, {"w": 4, "t": "தாரை தாரையாக"}, {"w": 5, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் உங்களுக்கு உதவுவான்"}, {"w": 2, "t": "செல்வங்களாலும்"}, {"w": 3, "t": "ஆண் பிள்ளைகளாலும்"}, {"w": 4, "t": "இன்னும் ஏற்படுத்துவான்"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "தோட்டங்களை"}, {"w": 7, "t": "இன்னும் ஏற்படுத்துவான்"}, {"w": 8, "t": "உங்களுக்கு"}, {"w": 9, "t": "நதிகளை"}, {"w": 10, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "உங்களுக்கு என்ன?"}, {"w": 2, "t": "(is) for you"}, {"w": 3, "t": "நீங்கள் பயப்படுவதில்லை"}, {"w": 4, "t": "you attribute"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "கண்ணியத்தை"}, {"w": 7, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "அவன் உங்களை படைத்தான்"}, {"w": 3, "t": "பல நிலைகளாக"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நீங்கள் பார்க்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "எப்படி"}, {"w": 4, "t": "படைத்தான்"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "ஏழு"}, {"w": 7, "t": "வானங்களை"}, {"w": 8, "t": "அடுக்கடுக்காக"}, {"w": 9, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இன்னும் அவன் ஆக்கினான்"}, {"w": 2, "t": "சந்திரனை"}, {"w": 3, "t": "அவற்றில்"}, {"w": 4, "t": "ஒளியாக"}, {"w": 5, "t": "இன்னும் ஆக்கினான்"}, {"w": 6, "t": "சூரியனை"}, {"w": 7, "t": "விளக்காக"}, {"w": 8, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "உங்களை முளைக்க வைத்தான்"}, {"w": 3, "t": "பூமியில் இருந்து"}, {"w": 4, "t": "the earth"}, {"w": 5, "t": "முளைக்க வைத்தல்"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "அவன் உங்களை மீட்பான்"}, {"w": 3, "t": "அதில்தான்"}, {"w": 4, "t": "இன்னும் அவன் உங்களை வெளியேற்றுவான்"}, {"w": 5, "t": "வெளியேற்றுதல்"}, {"w": 6, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "ஆக்கினான்"}, {"w": 3, "t": "உங்களுக்கு"}, {"w": 4, "t": "பூமியை"}, {"w": 5, "t": "விரிப்பாக"}, {"w": 6, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நீங்கள் செல்வதற்காக"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "பல பாதைகளில்"}, {"w": 4, "t": "விசாலமான"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "நூஹ்"}, {"w": 3, "t": "என் இறைவா!"}, {"w": 4, "t": "நிச்சயமாக அவர்கள்"}, {"w": 5, "t": "எனக்கு மாறுசெய்தனர்"}, {"w": 6, "t": "இன்னும் பின்பற்றினர்"}, {"w": 7, "t": "எவன்/அதிகப்படுத்தவில்லையோ/அவனுக்கு"}, {"w": 8, "t": "(did) not"}, {"w": 9, "t": "increase him"}, {"w": 10, "t": "அவனுடைய செல்வமும்"}, {"w": 11, "t": "இன்னும் அவனுடைய பிள்ளையும்"}, {"w": 12, "t": "நஷ்டத்தைத் தவிர"}, {"w": 13, "t": "(in) loss"}, {"w": 14, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "இன்னும் சூழ்ச்சி செய்தார்கள்"}, {"w": 2, "t": "சூழ்ச்சி"}, {"w": 3, "t": "மிகப் பெரிய"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "இன்னும் கூறினார்கள்"}, {"w": 2, "t": "நீங்கள் விட்டுவிடாதீர்கள்"}, {"w": 3, "t": "leave"}, {"w": 4, "t": "உங்கள் தெய்வங்களை"}, {"w": 5, "t": "இன்னும் விட்டுவிடாதீர்கள்"}, {"w": 6, "t": "leave"}, {"w": 7, "t": "வத்து/இன்னும் சுவாஃ"}, {"w": 8, "t": "and not"}, {"w": 9, "t": "Suwa"}, {"w": 10, "t": "இன்னும் யகூஸ்"}, {"w": 11, "t": "Yaguth"}, {"w": 12, "t": "இன்னும் யவூக்"}, {"w": 13, "t": "இன்னும் நஸ்ர்"}, {"w": 14, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "அவர்கள் வழி கெடுத்தனர்"}, {"w": 3, "t": "பலரை"}, {"w": 4, "t": "நீ அதிகப்படுத்தாதே!"}, {"w": 5, "t": "increase"}, {"w": 6, "t": "அநியாயக்காரர்களுக்கு"}, {"w": 7, "t": "வழிகேட்டைத் தவிர"}, {"w": 8, "t": "(in) error"}, {"w": 9, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவர்களுடைய பாவங்களால்"}, {"w": 2, "t": "their sins"}, {"w": 3, "t": "அவர்கள் மூழ்கடிக்கப்பட்டார்கள்"}, {"w": 4, "t": "பிறகு, நுழைக்கப்பட்டார்கள்"}, {"w": 5, "t": "நரகத்தில்"}, {"w": 6, "t": "அவர்கள் காணவில்லை"}, {"w": 7, "t": "they found"}, {"w": 8, "t": "தங்களுக்கு"}, {"w": 9, "t": "அல்லாஹ்வையன்றி"}, {"w": 10, "t": "besides"}, {"w": 11, "t": "Allah"}, {"w": 12, "t": "உதவியாளர்களை"}, {"w": 13, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூறினார்"}, {"w": 2, "t": "நூஹ்"}, {"w": 3, "t": "என் இறைவா!"}, {"w": 4, "t": "நீ விட்டு விடாதே!"}, {"w": 5, "t": "leave"}, {"w": 6, "t": "பூமியில்"}, {"w": 7, "t": "the earth"}, {"w": 8, "t": "நிராகரிப்பாளர்களில்"}, {"w": 9, "t": "(of) the disbelievers"}, {"w": 10, "t": "வசிக்கின்ற எவரையும்"}, {"w": 11, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நிச்சயமாக நீ"}, {"w": 2, "t": "அவர்களை விட்டு விட்டால்"}, {"w": 3, "t": "You leave them"}, {"w": 4, "t": "வழிகெடுத்து விடுவார்கள்"}, {"w": 5, "t": "உனது அடியார்களை"}, {"w": 6, "t": "இன்னும் பெற்றெடுக்க மாட்டார்கள்"}, {"w": 7, "t": "they will beget"}, {"w": 8, "t": "தவிர"}, {"w": 9, "t": "பாவியை"}, {"w": 10, "t": "மிகப் பெரிய நிராகரிப்பாளனை"}, {"w": 11, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "என் இறைவா!"}, {"w": 2, "t": "என்னை(யும்) மன்னிப்பாயாக!"}, {"w": 3, "t": "me"}, {"w": 4, "t": "என் பெற்றோரையும்"}, {"w": 5, "t": "நுழைந்து விட்டவரையும்"}, {"w": 6, "t": "enters"}, {"w": 7, "t": "என் வீட்டில்"}, {"w": 8, "t": "நம்பிக்கையாளராக"}, {"w": 9, "t": "நம்பிக்கை கொண்ட ஆண்களையும்"}, {"w": 10, "t": "நம்பிக்கை கொண்ட பெண்களையும்"}, {"w": 11, "t": "அதிகப்படுத்தாதே!"}, {"w": 12, "t": "increase"}, {"w": 13, "t": "அநியாயக்காரர்களுக்கு"}, {"w": 14, "t": "அழிவைத் தவிர"}, {"w": 15, "t": "(in) destruction"}, {"w": 16, "t": "(28)"}]}]}