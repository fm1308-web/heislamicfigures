{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "நபியே!"}, {"w": 2, "t": "Prophet"}, {"w": 3, "t": "நீங்கள் விவாகரத்து செய்தால்"}, {"w": 4, "t": "you divorce"}, {"w": 5, "t": "பெண்களை"}, {"w": 6, "t": "அவர்களை விவாகரத்து செய்யுங்கள்"}, {"w": 7, "t": "அவர்கள் இத்தா இருக்க வேண்டியதை கணக்கிட்டு"}, {"w": 8, "t": "இன்னும் சரியாக கணக்கிடுங்கள்"}, {"w": 9, "t": "இத்தாவை"}, {"w": 10, "t": "இன்னும் அஞ்சுங்கள்"}, {"w": 11, "t": "அல்லாஹ்வை"}, {"w": 12, "t": "உங்கள் இறைவனாகிய"}, {"w": 13, "t": "அவர்களை வெளியேற்றாதீர்கள்"}, {"w": 14, "t": "expel them"}, {"w": 15, "t": "அவர்களின் இல்லங்களில் இருந்து"}, {"w": 16, "t": "their houses"}, {"w": 17, "t": "இன்னும் அவர்களும் வெளியேற வேண்டாம்"}, {"w": 18, "t": "they should leave"}, {"w": 19, "t": "அவர்கள் செய்தாலே தவிர"}, {"w": 20, "t": "that"}, {"w": 21, "t": "they commit"}, {"w": 22, "t": "தீய செயலை"}, {"w": 23, "t": "தெளிவான"}, {"w": 24, "t": "இவை"}, {"w": 25, "t": "சட்டங்களாகும்"}, {"w": 26, "t": "அல்லாஹ்வின்"}, {"w": 27, "t": "எவர்/மீறுவாரோ"}, {"w": 28, "t": "transgresses"}, {"w": 29, "t": "சட்டங்களை"}, {"w": 30, "t": "அல்லாஹ்வின்"}, {"w": 31, "t": "திட்டமாக"}, {"w": 32, "t": "அநீதி இழைத்துக் கொண்டார்"}, {"w": 33, "t": "தனக்குத் தானே"}, {"w": 34, "t": "நீர் அறியமாட்டீர்"}, {"w": 35, "t": "you know"}, {"w": 36, "t": "அல்லாஹ் ஏற்படுத்தலாம்"}, {"w": 37, "t": "Allah"}, {"w": 38, "t": "will bring about"}, {"w": 39, "t": "இதற்குப் பின்னர்"}, {"w": 40, "t": "that"}, {"w": 41, "t": "ஒரு காரியத்தை"}, {"w": 42, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவர்கள் அடைந்து விட்டால்"}, {"w": 2, "t": "they have reached"}, {"w": 3, "t": "தங்கள் தவணையை"}, {"w": 4, "t": "தடுத்து வையுங்கள் அவர்களை"}, {"w": 5, "t": "நல்ல முறையில்"}, {"w": 6, "t": "அல்லது"}, {"w": 7, "t": "நீங்கள் பிரிந்து விடுங்கள் அவர்களை"}, {"w": 8, "t": "நல்ல முறையில்"}, {"w": 9, "t": "இன்னும் சாட்சியாக்குங்கள்"}, {"w": 10, "t": "நீதமான இருவரை"}, {"w": 11, "t": "just"}, {"w": 12, "t": "உங்களில்"}, {"w": 13, "t": "இன்னும் நிலை நிறுத்துங்கள்"}, {"w": 14, "t": "சாட்சியத்தை"}, {"w": 15, "t": "அல்லாஹ்விற்காக"}, {"w": 16, "t": "இவை"}, {"w": 17, "t": "உபதேசிக்கப் படுகின்றார்"}, {"w": 18, "t": "இவற்றின் மூலம்"}, {"w": 19, "t": "எவர்/நம்பிக்கை கொண்டிருப்பாரோ"}, {"w": 20, "t": "[is]"}, {"w": 21, "t": "believes"}, {"w": 22, "t": "அல்லாஹ்வையும்"}, {"w": 23, "t": "மறுமை நாளையும்"}, {"w": 24, "t": "the Last"}, {"w": 25, "t": "எவர்"}, {"w": 26, "t": "அஞ்சுவாரோ"}, {"w": 27, "t": "அல்லாஹ்வை"}, {"w": 28, "t": "ஏற்படுத்துவான்"}, {"w": 29, "t": "அவருக்கு"}, {"w": 30, "t": "ஒரு தீர்வை"}, {"w": 31, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் அவருக்கு உணவளிப்பான்"}, {"w": 2, "t": "விதத்தில் இருந்து"}, {"w": 3, "t": "where"}, {"w": 4, "t": "அவர் எண்ணாத"}, {"w": 5, "t": "he thinks"}, {"w": 6, "t": "எவர் நம்பிக்கை வைப்பாரோ"}, {"w": 7, "t": "puts his trust"}, {"w": 8, "t": "அல்லாஹ்வின் மீது"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "அவனே"}, {"w": 11, "t": "அவருக்குப் போதுமானவன்"}, {"w": 12, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 13, "t": "Allah"}, {"w": 14, "t": "நிறைவேற்றுவான்"}, {"w": 15, "t": "தனது காரியத்தை"}, {"w": 16, "t": "திட்டமாக"}, {"w": 17, "t": "ஏற்படுத்தினான்"}, {"w": 18, "t": "அல்லாஹ்"}, {"w": 19, "t": "ஒவ்வொன்றுக்கும்"}, {"w": 20, "t": "thing"}, {"w": 21, "t": "ஓர் அளவை"}, {"w": 22, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நிராசை அடைந்து விட்டனரோ"}, {"w": 3, "t": "மாதவிடாயிலிருந்து"}, {"w": 4, "t": "the menstruation"}, {"w": 5, "t": "உங்கள் பெண்களில்"}, {"w": 6, "t": "your women"}, {"w": 7, "t": "நீங்கள் சந்தேகித்தால்"}, {"w": 8, "t": "you doubt"}, {"w": 9, "t": "அவர்களின் இத்தா"}, {"w": 10, "t": "மூன்று"}, {"w": 11, "t": "மாதங்களாகும்"}, {"w": 12, "t": "எவர்கள்"}, {"w": 13, "t": "அவர்கள் மாதவிடாய் வரவில்லை"}, {"w": 14, "t": "[they] menstruated"}, {"w": 15, "t": "கர்ப்பமுடைய பெண்கள்"}, {"w": 16, "t": "pregnant"}, {"w": 17, "t": "அவர்களின் தவணை"}, {"w": 18, "t": "அவர்கள் பெற்றெடுப்பதாகும்"}, {"w": 19, "t": "they deliver"}, {"w": 20, "t": "தங்கள் கர்ப்பத்தை"}, {"w": 21, "t": "எவர்"}, {"w": 22, "t": "அஞ்சுவாரோ"}, {"w": 23, "t": "அல்லாஹ்வை"}, {"w": 24, "t": "ஏற்படுத்துவான்"}, {"w": 25, "t": "அவருக்கு"}, {"w": 26, "t": "அவரின் காரியத்தில்"}, {"w": 27, "t": "his affair"}, {"w": 28, "t": "இலகுவை"}, {"w": 29, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இது/கட்டளையாகும்"}, {"w": 2, "t": "(is the) Command"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "இதை இறக்கி இருக்கின்றான்"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "எவர்/அஞ்சுவாரோ"}, {"w": 7, "t": "fears"}, {"w": 8, "t": "அல்லாஹ்வை"}, {"w": 9, "t": "அவன் போக்குவான்"}, {"w": 10, "t": "அவரை விட்டும்"}, {"w": 11, "t": "அவரின் பாவங்களை"}, {"w": 12, "t": "இன்னும் பெரிதாக்குவான்"}, {"w": 13, "t": "அவருக்கு/கூலியை"}, {"w": 14, "t": "(his) reward"}, {"w": 15, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "அவர்களை தங்க வையுங்கள்"}, {"w": 2, "t": "நீங்கள் தங்கும் இடத்தில்"}, {"w": 3, "t": "where"}, {"w": 4, "t": "you dwell"}, {"w": 5, "t": "உங்கள் வசதிக்கேற்ப"}, {"w": 6, "t": "your means"}, {"w": 7, "t": "தீங்கு செய்யாதீர்கள்"}, {"w": 8, "t": "தீங்கு செய்யாதீர்கள் அவர்களுக்கு"}, {"w": 9, "t": "நீங்கள் நெருக்கடியை ஏற்படுத்துவதற்காக"}, {"w": 10, "t": "அவர்கள் மீது"}, {"w": 11, "t": "அவர்கள் இருந்தால்"}, {"w": 12, "t": "they are"}, {"w": 13, "t": "கர்ப்பம் உள்ள பெண்களாக"}, {"w": 14, "t": "pregnant"}, {"w": 15, "t": "செலவு செய்யுங்கள்"}, {"w": 16, "t": "அவர்களுக்கு"}, {"w": 17, "t": "வரை"}, {"w": 18, "t": "அவர்கள் பெற்றெடுக்கின்ற"}, {"w": 19, "t": "தங்கள் கர்ப்பத்தை"}, {"w": 20, "t": "அவர்கள் பாலூட்டினால்"}, {"w": 21, "t": "they suckle"}, {"w": 22, "t": "உங்களுக்காக"}, {"w": 23, "t": "அவர்களுக்கு கொடுங்கள்"}, {"w": 24, "t": "அவர்களின் ஊதியங்களை"}, {"w": 25, "t": "ஒருவருக்கொருவர் ஏற்றுக் கொள்ளுங்கள்"}, {"w": 26, "t": "உங்களுக்கு மத்தியில்"}, {"w": 27, "t": "நல்லதை"}, {"w": 28, "t": "நீங்கள் சிரமமாகக் கருதினால்"}, {"w": 29, "t": "you disagree"}, {"w": 30, "t": "பாலூட்டுவாள்"}, {"w": 31, "t": "அவருக்காக"}, {"w": 32, "t": "வேறு ஒரு பெண்"}, {"w": 33, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "செலவு செய்யட்டும்"}, {"w": 2, "t": "வசதியுடையவர்"}, {"w": 3, "t": "(of) ample means"}, {"w": 4, "t": "தனது வசதியிலிருந்து"}, {"w": 5, "t": "his ample means"}, {"w": 6, "t": "எவர் ஒருவர்"}, {"w": 7, "t": "நெருக்கடியாக இருக்கின்றதோ"}, {"w": 8, "t": "அவர் மீது"}, {"w": 9, "t": "அவருடைய வாழ்வாதாரம்"}, {"w": 10, "t": "அவர்கள் செலவு செய்யட்டும்"}, {"w": 11, "t": "தனக்கு கொடுத்ததில் இருந்து"}, {"w": 12, "t": "he has been given"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "சிரமம் கொடுக்க மாட்டான்"}, {"w": 15, "t": "burden"}, {"w": 16, "t": "அல்லாஹ்"}, {"w": 17, "t": "ஓர் ஆன்மாவிற்கு"}, {"w": 18, "t": "தவிர"}, {"w": 19, "t": "அவன் அதற்கு கொடுத்ததை"}, {"w": 20, "t": "He has given it"}, {"w": 21, "t": "ஏற்படுத்துவான்"}, {"w": 22, "t": "அல்லாஹ்"}, {"w": 23, "t": "பின்னர்"}, {"w": 24, "t": "சிரமத்திற்கு"}, {"w": 25, "t": "இலகுவை"}, {"w": 26, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "எத்தனையோ"}, {"w": 2, "t": "ஊர்கள்/மீறின"}, {"w": 3, "t": "a town"}, {"w": 4, "t": "rebelled"}, {"w": 5, "t": "கட்டளையையும்"}, {"w": 6, "t": "(the) Command"}, {"w": 7, "t": "தமது இறைவனின்"}, {"w": 8, "t": "இன்னும் தமது தூதரின்"}, {"w": 9, "t": "நாம் அவற்றை விசாரித்தோம்"}, {"w": 10, "t": "விசாரணையால்"}, {"w": 11, "t": "கடுமையான"}, {"w": 12, "t": "இன்னும் அவற்றை வேதனை செய்தோம்"}, {"w": 13, "t": "மோசமான தண்டனையால்"}, {"w": 14, "t": "terrible"}, {"w": 15, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவை சுவைத்தன"}, {"w": 2, "t": "கெட்ட முடிவை"}, {"w": 3, "t": "தமது காரியத்தின்"}, {"w": 4, "t": "இன்னும் ஆகிவிட்டது"}, {"w": 5, "t": "முடிவு"}, {"w": 6, "t": "அவற்றின் காரியத்தின்"}, {"w": 7, "t": "மிக நஷ்டமாகவே"}, {"w": 8, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "தயார் செய்துள்ளான்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "அவர்களுக்கு"}, {"w": 4, "t": "தண்டனையை"}, {"w": 5, "t": "கடுமையான"}, {"w": 6, "t": "ஆகவே, அஞ்சுங்கள்"}, {"w": 7, "t": "அல்லாஹ்வை"}, {"w": 8, "t": "அறிவுடையவர்களே!"}, {"w": 9, "t": "(of) understanding"}, {"w": 10, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 11, "t": "have believed"}, {"w": 12, "t": "திட்டமாக"}, {"w": 13, "t": "இறக்கினான்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "உங்களுக்கு"}, {"w": 16, "t": "நல்லுபதேசத்தை"}, {"w": 17, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஒரு தூதரை"}, {"w": 2, "t": "ஓதிக் காண்பிக்கிறார்"}, {"w": 3, "t": "உங்களுக்கு"}, {"w": 4, "t": "வசனங்களை"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "தெளிவான(வை)"}, {"w": 7, "t": "வெளியேற்றுவதற்காக"}, {"w": 8, "t": "எவர்கள்"}, {"w": 9, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 10, "t": "இன்னும் செய்தார்கள்"}, {"w": 11, "t": "நன்மைகளை"}, {"w": 12, "t": "இருள்களிலிருந்து"}, {"w": 13, "t": "the darkness[es]"}, {"w": 14, "t": "ஒளியின் பக்கம்"}, {"w": 15, "t": "the light"}, {"w": 16, "t": "எவர்(கள்)/நம்பிக்கை கொண்டார்(கள்)"}, {"w": 17, "t": "believes"}, {"w": 18, "t": "அல்லாஹ்வை"}, {"w": 19, "t": "இன்னும் செய்வார்(கள்)"}, {"w": 20, "t": "நன்மையை"}, {"w": 21, "t": "அவர்களை பிரவேசிக்கவைப்பான்"}, {"w": 22, "t": "சொர்க்கங்களில்"}, {"w": 23, "t": "ஓடும்"}, {"w": 24, "t": "அவற்றின் கீழ்"}, {"w": 25, "t": "underneath it"}, {"w": 26, "t": "நதிகள்"}, {"w": 27, "t": "நிரந்தரமாகத் தங்குவார்கள்"}, {"w": 28, "t": "அவற்றில்/எப்போதும்"}, {"w": 29, "t": "forever"}, {"w": 30, "t": "திட்டமாக"}, {"w": 31, "t": "அழகாக வைத்திருக்கின்றான்"}, {"w": 32, "t": "அல்லாஹ்"}, {"w": 33, "t": "அவர்களுக்கு"}, {"w": 34, "t": "வாழ்வாதாரத்தை"}, {"w": 35, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "(is) He Who"}, {"w": 3, "t": "படைத்தான்"}, {"w": 4, "t": "ஏழு வானங்களையும்"}, {"w": 5, "t": "heavens"}, {"w": 6, "t": "இன்னும் பூமியில்"}, {"w": 7, "t": "the earth"}, {"w": 8, "t": "அவைப் போன்றதையும்"}, {"w": 9, "t": "இறங்குகின்றன"}, {"w": 10, "t": "கட்டளைகள்"}, {"w": 11, "t": "அவற்றுக்கு மத்தியில்"}, {"w": 12, "t": "நீங்கள் அறிவதற்காக"}, {"w": 13, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 14, "t": "Allah"}, {"w": 15, "t": "எல்லாப் பொருள்கள் மீதும்"}, {"w": 16, "t": "every"}, {"w": 17, "t": "thing"}, {"w": 18, "t": "பேராற்றலுடையவன்"}, {"w": 19, "t": "இன்னும் நிச்சயமாக அல்லாஹ்"}, {"w": 20, "t": "Allah"}, {"w": 21, "t": "திட்டமாக"}, {"w": 22, "t": "சூழ்ந்துள்ளான்"}, {"w": 23, "t": "எல்லாப் பொருள்களையும்"}, {"w": 24, "t": "things"}, {"w": 25, "t": "அறிவால்"}, {"w": 26, "t": "(12)"}]}]}