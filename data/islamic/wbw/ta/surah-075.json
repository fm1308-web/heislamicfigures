{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "சத்தியம் செய்கிறேன்!"}, {"w": 2, "t": "I swear"}, {"w": 3, "t": "நாளின் மீது"}, {"w": 4, "t": "மறுமை"}, {"w": 5, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இன்னும் சத்தியம் செய்கிறேன் !"}, {"w": 2, "t": "I swear"}, {"w": 3, "t": "ஆன்மாவின் மீது"}, {"w": 4, "t": "பழிக்கின்ற"}, {"w": 5, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "எண்ணுகின்றானா"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "அறவே ஒன்று சேர்க்க மாட்டோம் என்று"}, {"w": 4, "t": "We will assemble"}, {"w": 5, "t": "அவனுடைய எலும்புகளை"}, {"w": 6, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "ஏன் முடியாது!"}, {"w": 2, "t": "ஆற்றலுடையவர்கள்"}, {"w": 3, "t": "நாம் சரியாக அமைப்பதற்கு"}, {"w": 4, "t": "that"}, {"w": 5, "t": "We can restore"}, {"w": 6, "t": "அவனுடைய விரல் நுனிகளை"}, {"w": 7, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "நாடுகின்றான்"}, {"w": 3, "t": "மனிதன்"}, {"w": 4, "t": "பாவம் செய்வதற்கே"}, {"w": 5, "t": "தனது வருங்காலத்திலும்"}, {"w": 6, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கேட்கிறான்"}, {"w": 2, "t": "எப்போது வரும்"}, {"w": 3, "t": "மறுமை நாள்"}, {"w": 4, "t": "(of) the Resurrection"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "திகைத்துவிட்டால்"}, {"w": 2, "t": "is dazzled"}, {"w": 3, "t": "பார்வை"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் ஒளி இழந்து விட்டால்"}, {"w": 2, "t": "சந்திரன்"}, {"w": 3, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் ஒன்று சேர்க்கப்பட்டால்"}, {"w": 2, "t": "சூரியனும்"}, {"w": 3, "t": "சந்திரனும்"}, {"w": 4, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "கூறுவான்"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "அந்நாளில்"}, {"w": 4, "t": "எங்கே?"}, {"w": 5, "t": "தப்பிக்குமிடம்"}, {"w": 6, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "தப்பித்து ஓட அறவே முடியாது"}, {"w": 3, "t": "refuge"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "உமது இறைவன் பக்கம்தான்"}, {"w": 2, "t": "your Lord"}, {"w": 3, "t": "அந்நாளில்"}, {"w": 4, "t": "இறுதியாக நிலையான தங்குமிடம்"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அறிவிக்கப்படுவான்"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "அந்நாளில்"}, {"w": 4, "t": "தான் முந்தி செய்ததையும்"}, {"w": 5, "t": "he sent forth"}, {"w": 6, "t": "பிந்தி செய்ததையும்"}, {"w": 7, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "அவனுக்கே"}, {"w": 4, "t": "himself"}, {"w": 5, "t": "சாட்சியாக இருப்பான்"}, {"w": 6, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவன் கூறினாலும்"}, {"w": 2, "t": "he presents"}, {"w": 3, "t": "தனது காரணங்களை"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அசைக்காதீர்/இதற்கு"}, {"w": 2, "t": "move"}, {"w": 3, "t": "with it"}, {"w": 4, "t": "உமது நாவை"}, {"w": 5, "t": "நீர் அவசரமாக செய்வதற்காக"}, {"w": 6, "t": "இதை"}, {"w": 7, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம்மீது கடமையாகும்"}, {"w": 3, "t": "அதை ஒன்று சேர்ப்பதும்"}, {"w": 4, "t": "அதை ஓதவைப்பதும்"}, {"w": 5, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இதை நாம் ஓதினால்"}, {"w": 2, "t": "We have recited it"}, {"w": 3, "t": "நீர் பின்தொடர்வீராக!"}, {"w": 4, "t": "அது ஓதப்படுவதை"}, {"w": 5, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "நம்மீது கடமையாகும்"}, {"w": 4, "t": "அதை விவரிப்பது"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "மாறாக"}, {"w": 3, "t": "நீங்கள் நேசிக்கிறீர்கள்"}, {"w": 4, "t": "உலக வாழ்க்கையை"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "விட்டு விடுகிறீர்கள்"}, {"w": 2, "t": "மறுமையை"}, {"w": 3, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "சில முகங்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "செழிப்பாக இருக்கும்"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "தமது இறைவனை"}, {"w": 2, "t": "their Lord"}, {"w": 3, "t": "பார்த்துக் கொண்டிருக்கும்"}, {"w": 4, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "இன்னும் சில முகங்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "கருத்து காய்ந்துபோய் இருக்கும்"}, {"w": 4, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அறிந்துகொள்ளும்"}, {"w": 2, "t": "நிகழப்போகிறதுஎன்று"}, {"w": 3, "t": "will be done"}, {"w": 4, "t": "அதற்கு"}, {"w": 5, "t": "கடுமையான ஒரு பிரச்சனை"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அவ்வாறல்ல!"}, {"w": 2, "t": "உயிர் அடைந்தால்"}, {"w": 3, "t": "it reaches"}, {"w": 4, "t": "தொண்டைக் குழியை"}, {"w": 5, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "கேட்கப்பட்டால்"}, {"w": 2, "t": "யாரும்/ஒதிப்பார்ப்பவர்"}, {"w": 3, "t": "(will) cure"}, {"w": 4, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "இன்னும் அறிந்து கொண்டால்"}, {"w": 2, "t": "நிச்சயமாக இது"}, {"w": 3, "t": "பிரிவுதான்"}, {"w": 4, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "பின்னிக்கொண்டால்"}, {"w": 2, "t": "கெண்டைக் கால்"}, {"w": 3, "t": "கெண்டைக் காலுடன்"}, {"w": 4, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "உமது இறைவனிடமே"}, {"w": 2, "t": "your Lord"}, {"w": 3, "t": "அந்நாளில்"}, {"w": 4, "t": "ஓட்டிக்கொண்டு வரப்படுகின்ற இடம்"}, {"w": 5, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "உண்மைப்படுத்தவில்லை"}, {"w": 2, "t": "he accepted (the) truth"}, {"w": 3, "t": "தொழவும் இல்லை"}, {"w": 4, "t": "he prayed"}, {"w": 5, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "எனினும்"}, {"w": 2, "t": "பொய்ப்பித்தான்"}, {"w": 3, "t": "இன்னும் விலகிச் சென்றான்"}, {"w": 4, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "சென்றான்"}, {"w": 3, "t": "தனது குடும்பத்தாரிடம்"}, {"w": 4, "t": "his family"}, {"w": 5, "t": "கர்வம் கொண்டவனாக"}, {"w": 6, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "கேடுதான்"}, {"w": 2, "t": "உனக்கு"}, {"w": 3, "t": "இன்னும் கேடுதான்"}, {"w": 4, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "பிறகு(ம்)"}, {"w": 2, "t": "கேடுதான்"}, {"w": 3, "t": "உனக்கு"}, {"w": 4, "t": "இன்னும் கேடுதான்"}, {"w": 5, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "எண்ணுகின்றானா"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "விட்டு விடப்படுவான் என்று"}, {"w": 4, "t": "he will be left"}, {"w": 5, "t": "சும்மா"}, {"w": 6, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "அவன் இருக்கவில்லையா?"}, {"w": 2, "t": "he"}, {"w": 3, "t": "ஒரு துளி விந்தாக"}, {"w": 4, "t": "இந்திரியத்தின்"}, {"w": 5, "t": "semen"}, {"w": 6, "t": "இந்திரியம் செலுத்தப்படுகின்றது"}, {"w": 7, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "இருந்தான்"}, {"w": 3, "t": "கருவாக"}, {"w": 4, "t": "ஆக, அவன் படைத்தான்"}, {"w": 5, "t": "இன்னும் செம்மையாக ஆக்கினான்"}, {"w": 6, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "இன்னும் ஆக்கினான்"}, {"w": 2, "t": "அதிலிருந்து"}, {"w": 3, "t": "ஜோடிகளை"}, {"w": 4, "t": "ஆண்"}, {"w": 5, "t": "இன்னும் பெண்"}, {"w": 6, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "இல்லையா?"}, {"w": 2, "t": "இவன்"}, {"w": 3, "t": "ஆற்றல் உள்ளவனாக"}, {"w": 4, "t": "உயிர்ப்பிப்பதற்கு"}, {"w": 5, "t": "to"}, {"w": 6, "t": "give life"}, {"w": 7, "t": "இறந்தவர்களை"}, {"w": 8, "t": "(40)"}]}]}