{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "தா, சீன்."}, {"w": 2, "t": "இவை"}, {"w": 3, "t": "வசனங்கள்"}, {"w": 4, "t": "இந்த குர்ஆனுடைய"}, {"w": 5, "t": "இன்னும் வேதத்தின்"}, {"w": 6, "t": "தெளிவான"}, {"w": 7, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நேர்வழியாகவும்"}, {"w": 2, "t": "நற்செய்தியாகவும்"}, {"w": 3, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நிலை நிறுத்துவார்கள்"}, {"w": 3, "t": "தொழுகையை"}, {"w": 4, "t": "இன்னும் தருவார்கள்"}, {"w": 5, "t": "ஸகாத்தை"}, {"w": 6, "t": "இன்னும் அவர்கள்"}, {"w": 7, "t": "மறுமையை/அவர்கள்"}, {"w": 8, "t": "[they]"}, {"w": 9, "t": "நம்பிக்கை கொள்வார்கள்"}, {"w": 10, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம்பிக்கை கொள்ளாதவர்கள்"}, {"w": 3, "t": "(do) not"}, {"w": 4, "t": "believe"}, {"w": 5, "t": "மறுமையை"}, {"w": 6, "t": "நாம் அலங்கரித்து விட்டோம்"}, {"w": 7, "t": "அவர்களுக்கு"}, {"w": 8, "t": "அவர்களுடைய செயல்களை"}, {"w": 9, "t": "ஆகவே, அவர்கள்"}, {"w": 10, "t": "தறிகெட்டு அலைகிறார்கள்"}, {"w": 11, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவர்கள்தான்"}, {"w": 2, "t": "அவர்களுக்கு உண்டு"}, {"w": 3, "t": "கெட்ட"}, {"w": 4, "t": "தண்டனை"}, {"w": 5, "t": "அவர்கள்"}, {"w": 6, "t": "மறுமையில்"}, {"w": 7, "t": "in"}, {"w": 8, "t": "அவர்கள்தான்"}, {"w": 9, "t": "நஷ்டவாளிகள்"}, {"w": 10, "t": "(will be) the greatest losers"}, {"w": 11, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிச்சயமாக நீர்"}, {"w": 2, "t": "மனனம் செய்விக்கப்படுகிறீர்"}, {"w": 3, "t": "இந்த குர்ஆனை"}, {"w": 4, "t": "மகா ஞானவானிடமிருந்து"}, {"w": 5, "t": "from [near]"}, {"w": 6, "t": "the All-Wise"}, {"w": 7, "t": "நன்கறிந்தவன்"}, {"w": 8, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அந்த சமயத்தை நினைவு கூறினார்"}, {"w": 2, "t": "said"}, {"w": 3, "t": "மூசா"}, {"w": 4, "t": "தன்குடும்பத்தினருக்கு"}, {"w": 5, "t": "நிச்சயமாக நான்"}, {"w": 6, "t": "நான் பார்த்தேன்"}, {"w": 7, "t": "நெருப்பை"}, {"w": 8, "t": "உங்களுக்கு கொண்டு வருகிறேன்"}, {"w": 9, "t": "அதிலிருந்து"}, {"w": 10, "t": "ஒரு செய்தியை"}, {"w": 11, "t": "அல்லது"}, {"w": 12, "t": "உங்களுக்கு கொண்டு வருகிறேன்"}, {"w": 13, "t": "நெருப்பை"}, {"w": 14, "t": "எடுக்கப்பட்ட"}, {"w": 15, "t": "நீங்கள் குளிர் காய்வதற்காக"}, {"w": 16, "t": "warm yourselves"}, {"w": 17, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவர் அதனிடம் வந்த போது"}, {"w": 2, "t": "he came to it"}, {"w": 3, "t": "அழைக்கப்பட்டார்"}, {"w": 4, "t": "பரிசுத்தமானவன்"}, {"w": 5, "t": "Blessed is"}, {"w": 6, "t": "நெருப்பில் இருப்பவன்"}, {"w": 7, "t": "(is) at"}, {"w": 8, "t": "the fire"}, {"w": 9, "t": "இன்னும் அதை சுற்றி உள்ளவர்களும்"}, {"w": 10, "t": "(is) around it"}, {"w": 11, "t": "மிகப் பரிசுத்தமானவன்"}, {"w": 12, "t": "அல்லாஹ்"}, {"w": 13, "t": "இறைவன்"}, {"w": 14, "t": "அகிலங்களின்"}, {"w": 15, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "மூஸாவே!"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "நான்தான்"}, {"w": 4, "t": "அல்லாஹ்"}, {"w": 5, "t": "மிகைத்தவனான"}, {"w": 6, "t": "மகா ஞானமுடையவனான"}, {"w": 7, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "போடுவீராக!"}, {"w": 2, "t": "உமது தடியை"}, {"w": 3, "t": "அவர் அதை பார்த்த போது"}, {"w": 4, "t": "he saw it"}, {"w": 5, "t": "நெளிவதாக"}, {"w": 6, "t": "அது போன்று"}, {"w": 7, "t": "பாம்பை"}, {"w": 8, "t": "திரும்பினார்"}, {"w": 9, "t": "புறமுதுகிட்டு"}, {"w": 10, "t": "அவர் திரும்பவே இல்லை"}, {"w": 11, "t": "look back"}, {"w": 12, "t": "மூஸாவே!"}, {"w": 13, "t": "பயப்படாதீர்"}, {"w": 14, "t": "fear"}, {"w": 15, "t": "நிச்சயமாக நான்"}, {"w": 16, "t": "பயப்பட மாட்டார்கள்"}, {"w": 17, "t": "fear"}, {"w": 18, "t": "என்னிடம்"}, {"w": 19, "t": "இறைத்தூதர்கள்"}, {"w": 20, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "தவறிழைத்தவரை"}, {"w": 3, "t": "wrongs"}, {"w": 4, "t": "பிறகு"}, {"w": 5, "t": "மாற்றி செய்தார்"}, {"w": 6, "t": "அழகிய செயலை"}, {"w": 7, "t": "பின்னர்"}, {"w": 8, "t": "தீமைக்கு"}, {"w": 9, "t": "ஏனெனில், நிச்சயமாக நான்"}, {"w": 10, "t": "மகா மன்னிப்பாளன்"}, {"w": 11, "t": "பெரும் கருணையாளன்"}, {"w": 12, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நுழைப்பீராக!"}, {"w": 2, "t": "உமது கரத்தை"}, {"w": 3, "t": "உமது சட்டைப் பையில்"}, {"w": 4, "t": "your bosom"}, {"w": 5, "t": "வெளிவரும்"}, {"w": 6, "t": "வென்மையாக மின்னும்"}, {"w": 7, "t": "எவ்வித குறையுமின்றி"}, {"w": 8, "t": "without"}, {"w": 9, "t": "harm"}, {"w": 10, "t": "ஒன்பது"}, {"w": 11, "t": "nine"}, {"w": 12, "t": "அத்தாட்சிகளில்"}, {"w": 13, "t": "ஃபிர்அவ்னுக்கும்"}, {"w": 14, "t": "Firaun"}, {"w": 15, "t": "அவனதுமக்களுக்கும்"}, {"w": 16, "t": "நிச்சயமாக அவர்கள்"}, {"w": 17, "t": "இருக்கிறார்கள்"}, {"w": 18, "t": "மக்களாக"}, {"w": 19, "t": "பாவிகளான"}, {"w": 20, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "ஆக, அது அவர்களிடம் வந்தபோது"}, {"w": 2, "t": "came to them"}, {"w": 3, "t": "நம் அத்தாட்சிகள்"}, {"w": 4, "t": "பார்க்கும்படியாக"}, {"w": 5, "t": "கூறினர்"}, {"w": 6, "t": "இது"}, {"w": 7, "t": "சூனியம்"}, {"w": 8, "t": "தெளிவான"}, {"w": 9, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவர்கள் மறுத்தனர்"}, {"w": 2, "t": "அவற்றை"}, {"w": 3, "t": "அவற்றை உறுதியாக நம்பின"}, {"w": 4, "t": "அவர்களுடைய ஆன்மாக்களோ"}, {"w": 5, "t": "அநியாயமாக"}, {"w": 6, "t": "இன்னும் பெருமையாக"}, {"w": 7, "t": "ஆகவே நீர் கவனிப்பீராக"}, {"w": 8, "t": "எவ்வாறுஆகிவிட்டது"}, {"w": 9, "t": "was"}, {"w": 10, "t": "முடிவு"}, {"w": 11, "t": "விஷமிகளின்"}, {"w": 12, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் தந்தோம்"}, {"w": 3, "t": "தாவூதுக்கும்"}, {"w": 4, "t": "சுலைமானுக்கும்"}, {"w": 5, "t": "அறிவை"}, {"w": 6, "t": "அவ்விருவரும் கூறினர்"}, {"w": 7, "t": "எல்லாப் புகழும்"}, {"w": 8, "t": "அல்லாஹ்விற்கே"}, {"w": 9, "t": "எவன்"}, {"w": 10, "t": "எங்களை மேன்மைப்படுத்தினான்"}, {"w": 11, "t": "பலரைப் பார்க்கிலும்"}, {"w": 12, "t": "many"}, {"w": 13, "t": "தனது அடியார்களில்"}, {"w": 14, "t": "His servants"}, {"w": 15, "t": "நம்பிக்கையாளர்களான"}, {"w": 16, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "வாரிசாக ஆனார்"}, {"w": 2, "t": "சுலைமான்"}, {"w": 3, "t": "தாவூதுக்கு"}, {"w": 4, "t": "இன்னும் , கூறினார்"}, {"w": 5, "t": "மக்களே!"}, {"w": 6, "t": "people"}, {"w": 7, "t": "நாங்கள் கற்பிக்கப்பட்டோம்"}, {"w": 8, "t": "பேச்சை"}, {"w": 9, "t": "பறவைகளின்"}, {"w": 10, "t": "வழங்கப்பட்டோம்"}, {"w": 11, "t": "எல்லாம்"}, {"w": 12, "t": "every"}, {"w": 13, "t": "thing"}, {"w": 14, "t": "நிச்சயமாக"}, {"w": 15, "t": "இதுதான்"}, {"w": 16, "t": "surely, it"}, {"w": 17, "t": "மேன்மையாகும்"}, {"w": 18, "t": "தெளிவான"}, {"w": 19, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "ஒன்று திரட்டப்பட்டன"}, {"w": 2, "t": "சுலைமானுக்கு"}, {"w": 3, "t": "அவருடைய ராணுவங்கள்"}, {"w": 4, "t": "ஜின்களிலிருந்து"}, {"w": 5, "t": "jinn"}, {"w": 6, "t": "இன்னும் மனிதர்கள்"}, {"w": 7, "t": "இன்னும் பறவைகளில்"}, {"w": 8, "t": "ஆகவே, அவர்கள்"}, {"w": 9, "t": "நிறுத்தப்படுவார்கள்"}, {"w": 10, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இறுதியாக"}, {"w": 2, "t": "அவர்கள் வந்த போது"}, {"w": 3, "t": "they came"}, {"w": 4, "t": "ஒரு பள்ளத்தாக்கில்"}, {"w": 5, "t": "(the) valley"}, {"w": 6, "t": "எறும்புகளின்"}, {"w": 7, "t": "கூறியது"}, {"w": 8, "t": "ஓர் எறும்பு"}, {"w": 9, "t": "எறும்புகளே!"}, {"w": 10, "t": "ants"}, {"w": 11, "t": "நுழைந்து விடுங்கள்!"}, {"w": 12, "t": "உங்கள் பொந்துகளுக்குள்"}, {"w": 13, "t": "உங்களை மிதித்து அழித்து விடவேண்டாம்"}, {"w": 14, "t": "lest not crush you"}, {"w": 15, "t": "சுலைமானும்"}, {"w": 16, "t": "அவருடைய ராணுவங்களும்"}, {"w": 17, "t": "அவர்களோ"}, {"w": 18, "t": "உணர மாட்டார்கள்"}, {"w": 19, "t": "(do) not perceive"}, {"w": 20, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "ஆக, புன்முறுவல் பூத்தார்"}, {"w": 2, "t": "அவர் சிரித்தவராக"}, {"w": 3, "t": "அதன் பேச்சினால்"}, {"w": 4, "t": "her speech"}, {"w": 5, "t": "இன்னும் கூறினார்"}, {"w": 6, "t": "என் இறைவா!"}, {"w": 7, "t": "எனக்கு நீ அகத்தூண்டுதலை ஏற்படுத்து!"}, {"w": 8, "t": "நான் நன்றி செலுத்துவதற்கு"}, {"w": 9, "t": "I may thank You"}, {"w": 10, "t": "உன் அருளுக்கு"}, {"w": 11, "t": "எது/நீ அருள்புரிந்தாய்"}, {"w": 12, "t": "You have bestowed"}, {"w": 13, "t": "என் மீதும்"}, {"w": 14, "t": "என் பெற்றோர் மீதும்"}, {"w": 15, "t": "my parents"}, {"w": 16, "t": "நான் செய்வதற்கும்"}, {"w": 17, "t": "I may do"}, {"w": 18, "t": "நல்லதை"}, {"w": 19, "t": "நீ மகிழ்ச்சியுறுகின்ற"}, {"w": 20, "t": "இன்னும் என்னைநுழைத்துவிடு"}, {"w": 21, "t": "உன் கருணையால்"}, {"w": 22, "t": "உன் அடியார்களில்"}, {"w": 23, "t": "Your slaves"}, {"w": 24, "t": "நல்லவர்கள்"}, {"w": 25, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அவர் தேடினார்"}, {"w": 2, "t": "பறவைகளில்"}, {"w": 3, "t": "கூறினார்"}, {"w": 4, "t": "எனக்கென்ன"}, {"w": 5, "t": "Why"}, {"w": 6, "t": "நான் காணமுடியவில்லை"}, {"w": 7, "t": "I see"}, {"w": 8, "t": "ஹூத்ஹூதை"}, {"w": 9, "t": "அல்லது"}, {"w": 10, "t": "அது இருக்கிறதா?"}, {"w": 11, "t": "வராதவர்களில்"}, {"w": 12, "t": "the absent"}, {"w": 13, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "நிச்சயமாக நான் அதை தண்டிப்பேன்"}, {"w": 2, "t": "(with) a punishment"}, {"w": 3, "t": "கடுமையாக"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "அதை நிச்சயமாக நான் அறுத்து விடுவேன்"}, {"w": 6, "t": "அல்லது"}, {"w": 7, "t": "அது என்னிடம் கொண்டு வரவேண்டும்"}, {"w": 8, "t": "ஆதாரத்தை"}, {"w": 9, "t": "தெளிவான"}, {"w": 10, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "அவர் தாமதித்தார்"}, {"w": 2, "t": "சிறிது நேரம்தான்"}, {"w": 3, "t": "long"}, {"w": 4, "t": "ஆக, அது கூறியது"}, {"w": 5, "t": "அறிந்துள்ளேன்"}, {"w": 6, "t": "எதை/நீ்ர் அறியவில்லை/அதை"}, {"w": 7, "t": "not"}, {"w": 8, "t": "you have encompassed"}, {"w": 9, "t": "it"}, {"w": 10, "t": "உம்மிடம் கொண்டு வந்துள்ளேன்"}, {"w": 11, "t": "‘சபா’ இனத்தாரிடமிருந்து"}, {"w": 12, "t": "Saba"}, {"w": 13, "t": "செய்தியை"}, {"w": 14, "t": "உறுதியான"}, {"w": 15, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "கண்டேன்"}, {"w": 3, "t": "ஒரு பெண்ணை"}, {"w": 4, "t": "அவர்களை ஆட்சி செய்கின்றவளாக"}, {"w": 5, "t": "அவள் வழங்கப்பட்டு இருக்கிறாள்"}, {"w": 6, "t": "எல்லாம்"}, {"w": 7, "t": "every"}, {"w": 8, "t": "thing"}, {"w": 9, "t": "அவளுக்கு சொந்தமான"}, {"w": 10, "t": "அரச கட்டிலும்"}, {"w": 11, "t": "ஒரு பெரிய"}, {"w": 12, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "அவளையும் கண்டேன்"}, {"w": 2, "t": "அவளுடைய மக்களையும்"}, {"w": 3, "t": "சிரம் பணிந்து வணங்குகின்றவர்களாக"}, {"w": 4, "t": "சூரியனுக்கு"}, {"w": 5, "t": "அல்லாஹ்வையன்றி"}, {"w": 6, "t": "instead of Allah"}, {"w": 7, "t": "instead of Allah"}, {"w": 8, "t": "இன்னும் அலங்கரித்து விட்டான்"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "ஷைத்தான்"}, {"w": 11, "t": "அவர்களின் செயல்களை"}, {"w": 12, "t": "ஆகவே, அவன் தடுத்து விட்டான் அவர்களை"}, {"w": 13, "t": "பாதையிலிருந்து"}, {"w": 14, "t": "the Way"}, {"w": 15, "t": "ஆகவே, அவர்கள்"}, {"w": 16, "t": "நேர்வழி பெறவில்லை"}, {"w": 17, "t": "guided"}, {"w": 18, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அவர்கள் சிரம் பணியாமல் இருப்பதற்கா"}, {"w": 2, "t": "they prostrate"}, {"w": 3, "t": "அல்லாஹ்விற்கு"}, {"w": 4, "t": "எவன்"}, {"w": 5, "t": "வெளிப்படுத்துகின்றான்"}, {"w": 6, "t": "மறைந்திருப்பவற்றை"}, {"w": 7, "t": "வானங்களிலும்"}, {"w": 8, "t": "the heavens"}, {"w": 9, "t": "பூமியிலும்"}, {"w": 10, "t": "இன்னும் அறிகின்றான்"}, {"w": 11, "t": "நீங்கள் மறைப்பதையும்"}, {"w": 12, "t": "you conceal"}, {"w": 13, "t": "நீங்கள் வெளிப்படுத்துவதையும்"}, {"w": 14, "t": "you declare"}, {"w": 15, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "அறவே இல்லை"}, {"w": 3, "t": "வணக்கத்திற்குரியவன்"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "அவனை"}, {"w": 6, "t": "அதிபதி"}, {"w": 7, "t": "அர்ஷுடைய"}, {"w": 8, "t": "மகத்தான"}, {"w": 9, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "ஆராய்ந்துபார்ப்போம்"}, {"w": 3, "t": "நீ உண்மை கூறினாயா?"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "ஆகிவிட்டாயா?"}, {"w": 6, "t": "பொய்யர்களில்"}, {"w": 7, "t": "the liars"}, {"w": 8, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "எடுத்துச் செல்!"}, {"w": 2, "t": "எனது இந்தக் கடிதத்தை"}, {"w": 3, "t": "இதை"}, {"w": 4, "t": "அதைப் போடு!"}, {"w": 5, "t": "அவர்கள் முன்"}, {"w": 6, "t": "பிறகு"}, {"w": 7, "t": "விலகி இரு!"}, {"w": 8, "t": "அவர்களை விட்டு"}, {"w": 9, "t": "நீ பார்!"}, {"w": 10, "t": "என்ன"}, {"w": 11, "t": "அவர்கள் பதில் தருகிறார்கள்"}, {"w": 12, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அவள் கூறினாள்"}, {"w": 2, "t": "பிரமுகர்களே!"}, {"w": 3, "t": "chiefs"}, {"w": 4, "t": "நிச்சயமாக"}, {"w": 5, "t": "அனுப்பப்பட்டுள்ளது"}, {"w": 6, "t": "என்னிடம்"}, {"w": 7, "t": "ஒரு கடிதம்"}, {"w": 8, "t": "கண்ணியமான"}, {"w": 9, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "நிச்சயமாக அது"}, {"w": 2, "t": "சுலைமானிடமிருந்து"}, {"w": 3, "t": "Sulaiman"}, {"w": 4, "t": "நிச்சயமாக செய்தியாவது"}, {"w": 5, "t": "பெயரால்"}, {"w": 6, "t": "அல்லாஹ்வின்"}, {"w": 7, "t": "பேரருளாளன்"}, {"w": 8, "t": "பேரன்பாளன்"}, {"w": 9, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "நீங்கள் பெருமை காட்டாதீர்கள்!"}, {"w": 2, "t": "exalt yourselves"}, {"w": 3, "t": "என்னிடம்"}, {"w": 4, "t": "என்னிடம் வந்து விடுங்கள்!"}, {"w": 5, "t": "பணிந்தவர்களாக"}, {"w": 6, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "அவள் கூறினாள்"}, {"w": 2, "t": "பிரமுகர்களே!"}, {"w": 3, "t": "chiefs"}, {"w": 4, "t": "நீங்கள் எனக்கு ஆலோசனை கூறுங்கள்"}, {"w": 5, "t": "எனது காரியத்தில்"}, {"w": 6, "t": "my affair"}, {"w": 7, "t": "நான் இல்லை"}, {"w": 8, "t": "I would be"}, {"w": 9, "t": "முடிவு செய்பவளாக"}, {"w": 10, "t": "ஒரு காரியத்தை"}, {"w": 11, "t": "வரை"}, {"w": 12, "t": "நீங்கள் என்னிடம் ஆஜராகின்ற"}, {"w": 13, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "நாங்கள்"}, {"w": 3, "t": "பலமுடையவர்கள்"}, {"w": 4, "t": "(of) strength"}, {"w": 5, "t": "இன்னும் வலிமை உடையவர்கள்"}, {"w": 6, "t": "(of) might"}, {"w": 7, "t": "கடும்"}, {"w": 8, "t": "இன்னும் முடிவு"}, {"w": 9, "t": "உன்னிடம்இருக்கிறது"}, {"w": 10, "t": "ஆகவே, நீ நன்கு யோசித்துக் கொள்!"}, {"w": 11, "t": "நீ உத்தரவிடுவதை"}, {"w": 12, "t": "you will command"}, {"w": 13, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "அவள் கூறினாள்"}, {"w": 2, "t": "நிச்சயமாகமன்னர்கள்"}, {"w": 3, "t": "the kings"}, {"w": 4, "t": "நுழைந்து விட்டால்"}, {"w": 5, "t": "they enter"}, {"w": 6, "t": "ஓர் ஊருக்குள்"}, {"w": 7, "t": "அதை சின்னா பின்னப்படுத்தி விடுவார்கள்"}, {"w": 8, "t": "ஆக்கிவிடுவார்கள்"}, {"w": 9, "t": "கண்ணியவான்களை"}, {"w": 10, "t": "அந்த ஊர் வாசிகளில் உள்ள/இழிவானவர்களாக"}, {"w": 11, "t": "(the) lowest"}, {"w": 12, "t": "அப்படித்தான்"}, {"w": 13, "t": "செய்வார்கள்"}, {"w": 14, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "அனுப்புகிறேன்"}, {"w": 3, "t": "அவர்களிடம்"}, {"w": 4, "t": "ஓர் அன்பளிப்பை"}, {"w": 5, "t": "பார்க்கிறேன்"}, {"w": 6, "t": "என்ன பதில்"}, {"w": 7, "t": "திரும்ப கொண்டு வருகிறார்கள்"}, {"w": 8, "t": "தூதர்கள்"}, {"w": 9, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "அவர் வந்தபோது"}, {"w": 2, "t": "came"}, {"w": 3, "t": "சுலைமானிடம்"}, {"w": 4, "t": "அவர் கூறினார்"}, {"w": 5, "t": "நீங்கள் எனக்கு தருகிறீர்களா?"}, {"w": 6, "t": "செல்வத்தை"}, {"w": 7, "t": "எனக்கு தந்திருப்பது"}, {"w": 8, "t": "Allah has given me"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "மிகச் சிறந்தது"}, {"w": 11, "t": "அவன் உங்களுக்கு தந்திருப்பதை விட"}, {"w": 12, "t": "He has given you"}, {"w": 13, "t": "மாறாக"}, {"w": 14, "t": "நீங்கள்"}, {"w": 15, "t": "உங்கள் அன்பளிப்புகளைக் கொண்டு"}, {"w": 16, "t": "பெருமிதம் அடைவீர்கள்"}, {"w": 17, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "நீ திரும்பிப் போ!"}, {"w": 2, "t": "அவர்களிடம்"}, {"w": 3, "t": "நாம் அவர்களிடம் கொண்டு வருவோம்"}, {"w": 4, "t": "இராணுவங்களை"}, {"w": 5, "t": "அறவே வலிமை இருக்காது"}, {"w": 6, "t": "(is) resistance"}, {"w": 7, "t": "அவர்களுக்கு"}, {"w": 8, "t": "அவர்களை எதிர்க்க"}, {"w": 9, "t": "நிச்சயமாக அவர்களை நாம் வெளியேற்றுவோம்"}, {"w": 10, "t": "அதிலிருந்து"}, {"w": 11, "t": "இழிவானவர்களாக"}, {"w": 12, "t": "அவர்கள்"}, {"w": 13, "t": "சிறுமைப்படுவார்கள்"}, {"w": 14, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "பிரமுகர்களே!"}, {"w": 3, "t": "chiefs"}, {"w": 4, "t": "உங்களில் யார்"}, {"w": 5, "t": "என்னிடம் கொண்டு வருவார்"}, {"w": 6, "t": "அவளுடைய அரச கட்டிலை"}, {"w": 7, "t": "முன்னர்"}, {"w": 8, "t": "அவர்கள் என்னிடம் வருவதற்கு"}, {"w": 9, "t": "they come to me"}, {"w": 10, "t": "பணிந்தவர்களாக"}, {"w": 11, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "கூறியது"}, {"w": 2, "t": "சாதுர்யமான ஒன்று"}, {"w": 3, "t": "ஜின்களில்"}, {"w": 4, "t": "the jinn"}, {"w": 5, "t": "நான்"}, {"w": 6, "t": "உம்மிடம் கொண்டு வருவேன்"}, {"w": 7, "t": "அதை"}, {"w": 8, "t": "முன்னர்"}, {"w": 9, "t": "நீர் எழுவதற்கு"}, {"w": 10, "t": "you rise"}, {"w": 11, "t": "உமது இடத்திலிருந்து"}, {"w": 12, "t": "your place"}, {"w": 13, "t": "நிச்சயமாக நான்"}, {"w": 14, "t": "அதற்கு"}, {"w": 15, "t": "ஆற்றல் உள்ளவன்"}, {"w": 16, "t": "நம்பிக்கைக்குரியவன்"}, {"w": 17, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "ஒருவர் கூறினார்"}, {"w": 2, "t": "எவர்/தன்னிடம்"}, {"w": 3, "t": "with him"}, {"w": 4, "t": "ஞானம்"}, {"w": 5, "t": "வேதத்தின்"}, {"w": 6, "t": "the Scripture"}, {"w": 7, "t": "நான்"}, {"w": 8, "t": "உம்மிடம் கொண்டு வருவேன்"}, {"w": 9, "t": "அதை"}, {"w": 10, "t": "முன்னர்"}, {"w": 11, "t": "திரும்புவதற்கு"}, {"w": 12, "t": "returns"}, {"w": 13, "t": "உன் பக்கம்"}, {"w": 14, "t": "உமது பார்வை"}, {"w": 15, "t": "அவர் பார்த்த போது"}, {"w": 16, "t": "he saw it"}, {"w": 17, "t": "நிலையாகி விட்டதாக"}, {"w": 18, "t": "தன்னிடம்"}, {"w": 19, "t": "கூறினார்"}, {"w": 20, "t": "இது/அருளாகும்"}, {"w": 21, "t": "(is) from"}, {"w": 22, "t": "(the) Favor"}, {"w": 23, "t": "என் இறைவனின்"}, {"w": 24, "t": "அவன் என்னை சோதிப்பதற்காக"}, {"w": 25, "t": "நான் நன்றி செலுத்துகிறேனா?"}, {"w": 26, "t": "அல்லது"}, {"w": 27, "t": "நன்றி கெடுகிறேனா?"}, {"w": 28, "t": "யார்"}, {"w": 29, "t": "நன்றிசெலுத்துகிறாரோ"}, {"w": 30, "t": "அவர் நன்றி செலுத்துவதெல்லாம்"}, {"w": 31, "t": "he is grateful"}, {"w": 32, "t": "அவருக்குத்தான்"}, {"w": 33, "t": "யார்"}, {"w": 34, "t": "நிராகரிப்பாரோ"}, {"w": 35, "t": "ஏனெனில்"}, {"w": 36, "t": "என் இறைவன்"}, {"w": 37, "t": "முற்றிலும் தேவை அற்றவன்"}, {"w": 38, "t": "பெரும் தயாளன்"}, {"w": 39, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "நீங்கள் மாற்றி விடுங்கள்"}, {"w": 3, "t": "அவளுக்கு"}, {"w": 4, "t": "அவளுடைய அரச கட்டிலை"}, {"w": 5, "t": "நாம் பார்ப்போம்"}, {"w": 6, "t": "அவள் அறிந்து கொள்கிறாளா?"}, {"w": 7, "t": "அல்லது"}, {"w": 8, "t": "அவள் ஆகிவிடுகிறாளா?"}, {"w": 9, "t": "அறியாதவர்களில்"}, {"w": 10, "t": "those who"}, {"w": 11, "t": "are not guided"}, {"w": 12, "t": "are not guided"}, {"w": 13, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "அவள் வந்தபோது,"}, {"w": 2, "t": "she came"}, {"w": 3, "t": "கேட்கப்பட்டது"}, {"w": 4, "t": "இது போன்றா"}, {"w": 5, "t": "உனது அரச கட்டில்"}, {"w": 6, "t": "அவள் கூறினாள்"}, {"w": 7, "t": "அதைப் போன்றுதான்"}, {"w": 8, "t": "இது"}, {"w": 9, "t": "நாம் கொடுக்கப்பட்டோம்"}, {"w": 10, "t": "அறிவு"}, {"w": 11, "t": "இவளுக்கு முன்னரே"}, {"w": 12, "t": "before her"}, {"w": 13, "t": "இன்னும் இருக்கிறோம்"}, {"w": 14, "t": "முஸ்லிம்களாக"}, {"w": 15, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "அவளைத் தடுத்து விட்டது"}, {"w": 2, "t": "எது"}, {"w": 3, "t": "இருந்தாள்"}, {"w": 4, "t": "அவள் வணங்கிக் கொண்டு"}, {"w": 5, "t": "அல்லாஹ்வையன்றி"}, {"w": 6, "t": "besides"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "நிச்சயமாக, அவள்"}, {"w": 9, "t": "இருந்தாள்"}, {"w": 10, "t": "மக்களில்"}, {"w": 11, "t": "a people"}, {"w": 12, "t": "நிராகரிக்கின்ற"}, {"w": 13, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "கூறப்பட்டது"}, {"w": 2, "t": "அவளுக்கு"}, {"w": 3, "t": "நீ நுழை!"}, {"w": 4, "t": "மாளிகையில்"}, {"w": 5, "t": "அவள் அதைப் பார்த்த போது"}, {"w": 6, "t": "she saw it"}, {"w": 7, "t": "அவள் அதை கருதினாள்"}, {"w": 8, "t": "அலை அடிக்கும் நீராக"}, {"w": 9, "t": "அகற்றினாள்"}, {"w": 10, "t": "தன் இரு கெண்டைக் கால்களை விட்டும்"}, {"w": 11, "t": "her shins"}, {"w": 12, "t": "கூறினார்"}, {"w": 13, "t": "நிச்சயமாக இது"}, {"w": 14, "t": "மாளிகை"}, {"w": 15, "t": "சமப்படுத்தப்பட்டது"}, {"w": 16, "t": "கண்ணாடிகளால்"}, {"w": 17, "t": "glass"}, {"w": 18, "t": "அவள் கூறினாள்"}, {"w": 19, "t": "என் இறைவா!"}, {"w": 20, "t": "நிச்சயமாக நான்"}, {"w": 21, "t": "அநீதி செய்து கொண்டேன்"}, {"w": 22, "t": "எனக்கே"}, {"w": 23, "t": "நானும் முஸ்லிமாகி விட்டேன்"}, {"w": 24, "t": "சுலைமானுடன்"}, {"w": 25, "t": "Sulaiman"}, {"w": 26, "t": "அல்லாஹ்விற்கு"}, {"w": 27, "t": "இறைவனான"}, {"w": 28, "t": "அகிலங்களின்"}, {"w": 29, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "ஸமூது (மக்களு)க்கு"}, {"w": 4, "t": "Thamud"}, {"w": 5, "t": "சகோதரர் அவருடைய"}, {"w": 6, "t": "ஸாலிஹை"}, {"w": 7, "t": "நீங்கள்வணங்குங்கள்"}, {"w": 8, "t": "Worship"}, {"w": 9, "t": "அல்லாஹ்வை"}, {"w": 10, "t": "ஆனால், அவர்கள் அப்போது"}, {"w": 11, "t": "They"}, {"w": 12, "t": "இரண்டு பிரிவுகளாக"}, {"w": 13, "t": "தங்களுக்குள் தர்க்கித்துக் கொள்கின்றனர்"}, {"w": 14, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "என் மக்களே!"}, {"w": 3, "t": "ஏன் அவசரப்படுகிறீர்கள்?"}, {"w": 4, "t": "(do) you seek to hasten"}, {"w": 5, "t": "தீமையை"}, {"w": 6, "t": "நன்மைக்குமுன்னதாக"}, {"w": 7, "t": "the good"}, {"w": 8, "t": "நீங்கள் பாவமன்னிப்புத் தேடமாட்டீர்களா?"}, {"w": 9, "t": "you ask forgiveness"}, {"w": 10, "t": "அல்லாஹ்விடம்"}, {"w": 11, "t": "நீங்கள் கருணை காட்டப்படுவீர்கள்"}, {"w": 12, "t": "receive mercy"}, {"w": 13, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "நாங்கள் துற்சகுணம் அடைந்தோம்"}, {"w": 3, "t": "உம்மாலும்"}, {"w": 4, "t": "இன்னும் உம்முடன் உள்ளவர்களாலும்"}, {"w": 5, "t": "with you"}, {"w": 6, "t": "அவர் கூறினார்"}, {"w": 7, "t": "மாறாக உங்கள் துன்பத்தின் காரணம்"}, {"w": 8, "t": "அல்லாஹ்விடம்தான் இருக்கிறது"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "மாறாக"}, {"w": 11, "t": "நீங்கள்"}, {"w": 12, "t": "மக்கள்"}, {"w": 13, "t": "சோதிக்கப்படுகின்ற"}, {"w": 14, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "இருந்தனர்"}, {"w": 2, "t": "அப்பட்டணத்தில்"}, {"w": 3, "t": "the city"}, {"w": 4, "t": "ஒன்பது"}, {"w": 5, "t": "பேர்"}, {"w": 6, "t": "அவர்கள் குழப்பம் செய்தனர்"}, {"w": 7, "t": "பூமியில்"}, {"w": 8, "t": "the land"}, {"w": 9, "t": "சீர்திருத்தம் செய்யவில்லை"}, {"w": 10, "t": "reforming"}, {"w": 11, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "தங்களுக்குள் சத்தியம் செய்தனர்"}, {"w": 3, "t": "அல்லாஹ்வின் மீது"}, {"w": 4, "t": "நிச்சயமாக நாங்கள் அவரை கொன்று விடுவோம்"}, {"w": 5, "t": "அவருடைய குடும்பத்தையும்"}, {"w": 6, "t": "பிறகு கூறுவோம்"}, {"w": 7, "t": "we will surely say"}, {"w": 8, "t": "அவருடைய பொறுப்பாளருக்கு"}, {"w": 9, "t": "நாம்ஆஜராகவில்லை"}, {"w": 10, "t": "we witnessed"}, {"w": 11, "t": "அவ(ரும் அவ)ரது குடும்பம் கொல்லப்பட்ட இடத்திற்கு"}, {"w": 12, "t": "(of) his family"}, {"w": 13, "t": "நாங்கள் உண்மையாளர்கள்"}, {"w": 14, "t": "(are) surely truthful"}, {"w": 15, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "அவர்கள் ஒரு சூழ்ச்சி செய்தனர்"}, {"w": 2, "t": "a plot"}, {"w": 3, "t": "நாம் ஒரு சூழ்ச்சி செய்தோம்"}, {"w": 4, "t": "a plan"}, {"w": 5, "t": "அவர்கள்"}, {"w": 6, "t": "உணர மாட்டார்கள்"}, {"w": 7, "t": "perceive"}, {"w": 8, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நீர் பார்ப்பீராக!"}, {"w": 2, "t": "எப்படி என்று"}, {"w": 3, "t": "ஆகியது"}, {"w": 4, "t": "முடிவு"}, {"w": 5, "t": "அவர்கள் சூழ்ச்சியின்"}, {"w": 6, "t": "நிச்சயமாக நாம்"}, {"w": 7, "t": "அவர்களை அழித்து விட்டோம்"}, {"w": 8, "t": "அவர்களின் மக்கள்"}, {"w": 9, "t": "அனைவரையும்"}, {"w": 10, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "இதோ"}, {"w": 2, "t": "அவர்களது வீடுகள்"}, {"w": 3, "t": "வெறுமையாக இருக்கின்றன"}, {"w": 4, "t": "அவர்கள் தீமை செய்ததால்"}, {"w": 5, "t": "they wronged"}, {"w": 6, "t": "நிச்சயமாக"}, {"w": 7, "t": "இதில் இருக்கிறது"}, {"w": 8, "t": "that"}, {"w": 9, "t": "ஓர் அத்தாட்சி"}, {"w": 10, "t": "மக்களுக்கு"}, {"w": 11, "t": "அறிகின்ற"}, {"w": 12, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "நாம் பாதுகாத்தோம்"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்களை"}, {"w": 3, "t": "believed"}, {"w": 4, "t": "அவர்கள் அஞ்சிக் கொண்டிருந்தனர்"}, {"w": 5, "t": "fear (Allah)"}, {"w": 6, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "இன்னும் லூத்தையும்"}, {"w": 2, "t": "கூறிய சமயத்தை"}, {"w": 3, "t": "நினைவு கூறுவீராக!"}, {"w": 4, "t": "அவர் தம் மக்களுக்கு"}, {"w": 5, "t": "நீங்கள் செய்கிறீர்களா?"}, {"w": 6, "t": "மகா அசிங்கமான"}, {"w": 7, "t": "நீங்கள்"}, {"w": 8, "t": "அறியத்தான் செய்கிறீர்கள்"}, {"w": 9, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "?/நீங்கள்"}, {"w": 2, "t": "தீர்க்கிறீர்கள்"}, {"w": 3, "t": "ஆண்களிடமா"}, {"w": 4, "t": "இச்சையை"}, {"w": 5, "t": "அன்றி"}, {"w": 6, "t": "instead of"}, {"w": 7, "t": "பெண்கள்"}, {"w": 8, "t": "மாறாக"}, {"w": 9, "t": "நீங்கள்"}, {"w": 10, "t": "மக்கள்"}, {"w": 11, "t": "நீங்கள் அறிய மாட்டீர்கள்"}, {"w": 12, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "இருக்கவில்லை"}, {"w": 2, "t": "was"}, {"w": 3, "t": "பதிலோ"}, {"w": 4, "t": "அவருடைய மக்களின்"}, {"w": 5, "t": "தவிர"}, {"w": 6, "t": "கூறுவதாகவே"}, {"w": 7, "t": "they said"}, {"w": 8, "t": "வெளியேற்றுங்கள்"}, {"w": 9, "t": "குடும்பத்தாரை"}, {"w": 10, "t": "லூத்துடைய"}, {"w": 11, "t": "உங்கள் ஊரிலிருந்து"}, {"w": 12, "t": "your town"}, {"w": 13, "t": "நிச்சயமாக அவர்கள்"}, {"w": 14, "t": "அந்த மக்கள்"}, {"w": 15, "t": "அசூசைப்படுகிறார்கள்"}, {"w": 16, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "எனவே, நாம் அவரை(யும்) பாதுகாத்தோம்"}, {"w": 2, "t": "அவருடைய குடும்பத்தையும்"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "அவருடைய மனைவியை"}, {"w": 5, "t": "அவளை முடிவு செய்தோம்"}, {"w": 6, "t": "மிஞ்சியவர்களில்"}, {"w": 7, "t": "those who remained behind"}, {"w": 8, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "பொழிவித்தோம்"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "மழை"}, {"w": 4, "t": "மிகக் கெட்டதாகும்"}, {"w": 5, "t": "அந்த மழை"}, {"w": 6, "t": "எச்சரிக்கப்பட்டவர்களின்"}, {"w": 7, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "கூறுவீராக"}, {"w": 2, "t": "எல்லாப் புகழும்"}, {"w": 3, "t": "அல்லாஹ்விற்கே"}, {"w": 4, "t": "இன்னும் ஸலாம்"}, {"w": 5, "t": "அவனுடைய அடியார்களுக்கு"}, {"w": 6, "t": "His slaves"}, {"w": 7, "t": "எவர்கள்/அவன் தேர்ந்தெடுத்தான்"}, {"w": 8, "t": "He has chosen"}, {"w": 9, "t": "?/அல்லாஹ்"}, {"w": 10, "t": "சிறந்தவையா"}, {"w": 11, "t": "அல்லது அவர்கள் இணைவைப்பவையா?"}, {"w": 12, "t": "they associate (with Him)"}, {"w": 13, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "?/எவன்"}, {"w": 2, "t": "படைத்தான்"}, {"w": 3, "t": "வானங்களையும்"}, {"w": 4, "t": "பூமியையும்"}, {"w": 5, "t": "இன்னும் அவன் இறக்கினான்"}, {"w": 6, "t": "உங்களுக்கு"}, {"w": 7, "t": "மேகத்திலிருந்து"}, {"w": 8, "t": "the sky"}, {"w": 9, "t": "மழையை"}, {"w": 10, "t": "நாம் முளைக்க வைத்தோம்"}, {"w": 11, "t": "அதன்மூலம்"}, {"w": 12, "t": "தோட்டங்களை"}, {"w": 13, "t": "அழகிய காட்சியுடைய"}, {"w": 14, "t": "of beauty (and delight)"}, {"w": 15, "t": "முடியாது"}, {"w": 16, "t": "it is"}, {"w": 17, "t": "உங்களால்"}, {"w": 18, "t": "நீங்கள் முளைக்க வைக்க"}, {"w": 19, "t": "you cause to grow"}, {"w": 20, "t": "அதன் மரங்களை"}, {"w": 21, "t": "(வணங்கப்படும் வேறு) ஒரு கடவுளா?!"}, {"w": 22, "t": "அல்லாஹ்வுடன்"}, {"w": 23, "t": "Allah"}, {"w": 24, "t": "மாறாக"}, {"w": 25, "t": "அவர்கள்"}, {"w": 26, "t": "மக்கள்"}, {"w": 27, "t": "இணைவைக்கின்றனர்"}, {"w": 28, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "?/எவன்"}, {"w": 2, "t": "ஆக்கினான்"}, {"w": 3, "t": "பூமியை"}, {"w": 4, "t": "நிலையானதாக"}, {"w": 5, "t": "இன்னும் ஏற்படுத்தினான்"}, {"w": 6, "t": "அதற்கிடையில்"}, {"w": 7, "t": "ஆறுகளை"}, {"w": 8, "t": "இன்னும் படைத்தான்"}, {"w": 9, "t": "அதற்காக"}, {"w": 10, "t": "பெரும் மலைகளை"}, {"w": 11, "t": "இன்னும் அமைத்தான்"}, {"w": 12, "t": "இடையில்"}, {"w": 13, "t": "இரு கடல்களுக்கு"}, {"w": 14, "t": "தடுப்பை"}, {"w": 15, "t": "(வணங்கப்படும் வேறு) ஒரு கடவுளா?!"}, {"w": 16, "t": "அல்லாஹ்வுடன்"}, {"w": 17, "t": "Allah"}, {"w": 18, "t": "மாறாக/அதிகமானவர்கள்/அவர்களில்"}, {"w": 19, "t": "most of them"}, {"w": 20, "t": "