{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "சத்தியம் செய்கிறேன்!"}, {"w": 2, "t": "I swear"}, {"w": 3, "t": "இந்த நகரத்தின் மீது"}, {"w": 4, "t": "city"}, {"w": 5, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நீர்"}, {"w": 2, "t": "அனுமதிக்கப்பட்டவர்"}, {"w": 3, "t": "இந்நகரத்தில்"}, {"w": 4, "t": "city"}, {"w": 5, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "தந்தையின் மீது சத்தியமாக"}, {"w": 2, "t": "அவர் பெற்றெடுத்ததின் மீது சத்தியமாக"}, {"w": 3, "t": "he begot"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "படைத்தோம்"}, {"w": 3, "t": "மனிதனை"}, {"w": 4, "t": "சிரமத்தில்"}, {"w": 5, "t": "hardship"}, {"w": 6, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "எண்ணுகின்றானா"}, {"w": 2, "t": "ஆற்றல் பெறவே மாட்டான்"}, {"w": 3, "t": "not"}, {"w": 4, "t": "has power"}, {"w": 5, "t": "தன்மீது/ஒருவனும்"}, {"w": 6, "t": "anyone"}, {"w": 7, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கூறுகிறான்"}, {"w": 2, "t": "நான் அழித்தேன்"}, {"w": 3, "t": "செல்வத்தை"}, {"w": 4, "t": "அதிகமான"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "எண்ணுகின்றானா"}, {"w": 2, "t": "அவனைப் பார்க்கவில்லை"}, {"w": 3, "t": "not"}, {"w": 4, "t": "sees him"}, {"w": 5, "t": "ஒருவனும்"}, {"w": 6, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நாம் ஆக்கவில்லையா?"}, {"w": 2, "t": "We made"}, {"w": 3, "t": "அவனுக்கு"}, {"w": 4, "t": "இரு கண்களை"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் ஒரு நாவை"}, {"w": 2, "t": "இன்னும் இரு உதடுகளை"}, {"w": 3, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் அவனுக்கு வழி காட்டினோம்"}, {"w": 2, "t": "இரு பாதைகளை"}, {"w": 3, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவன் கடக்கவில்லை"}, {"w": 2, "t": "he has attempted"}, {"w": 3, "t": "அகபா (மலை)"}, {"w": 4, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "எது?"}, {"w": 2, "t": "உமக்கு அறிவித்தது"}, {"w": 3, "t": "என்ன?"}, {"w": 4, "t": "அகபா"}, {"w": 5, "t": "(12)"}]}, {"aya