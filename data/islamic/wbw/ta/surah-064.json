{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "துதிக்கின்றனர்"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "வானங்களில் உள்ளவர்களும்"}, {"w": 4, "t": "(is) in"}, {"w": 5, "t": "the heavens"}, {"w": 6, "t": "பூமியில் உள்ளவர்களும்"}, {"w": 7, "t": "(is) in"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "அவனுக்கே"}, {"w": 10, "t": "ஆட்சிகள்"}, {"w": 11, "t": "இன்னும் அவனுக்கே"}, {"w": 12, "t": "புகழ் அனைத்தும்"}, {"w": 13, "t": "அவன்தான்"}, {"w": 14, "t": "எல்லாப் பொருள்கள் மீதும்"}, {"w": 15, "t": "every"}, {"w": 16, "t": "thing"}, {"w": 17, "t": "பேராற்றலுடையவன்"}, {"w": 18, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அவன்தான்/உங்களைப் படைத்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "created you"}, {"w": 4, "t": "உங்களில்"}, {"w": 5, "t": "நிராகரிப்பாளரும்"}, {"w": 6, "t": "இன்னும் உங்களில்/ நம்பிக்கையாளரும்"}, {"w": 7, "t": "(is) a believer"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "நீங்கள் செய்பவற்றை"}, {"w": 10, "t": "you do"}, {"w": 11, "t": "உற்று நோக்குபவன்"}, {"w": 12, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அவன் படைத்தான்"}, {"w": 2, "t": "வானங்களையும்"}, {"w": 3, "t": "பூமியையும்"}, {"w": 4, "t": "உண்மையான காரணத்திற்காக"}, {"w": 5, "t": "இன்னும் உங்களுக்கு உருவமைத்தான்"}, {"w": 6, "t": "அழகாக்கினான்"}, {"w": 7, "t": "உங்கள் உருவங்களை"}, {"w": 8, "t": "அவன் பக்கமே"}, {"w": 9, "t": "மீளுமிடம்"}, {"w": 10, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவன் நன்கறிவான்"}, {"w": 2, "t": "வானங்களில் உள்ளவற்றை"}, {"w": 3, "t": "(is) in"}, {"w": 4, "t": "the heavens"}, {"w": 5, "t": "இன்னும் பூமியில்"}, {"w": 6, "t": "இன்னும் நன்கறிவான்"}, {"w": 7, "t": "நீங்கள் மறைப்பதையும்"}, {"w": 8, "t": "you conceal"}, {"w": 9, "t": "நீங்கள் வெளிப்படுத்துவதையும்"}, {"w": 10, "t": "you declare"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "நன்கறிந்தவன்"}, {"w": 13, "t": "நெஞ்சங்களில் உள்ளவற்றை"}, {"w": 14, "t": "(is in) the breasts"}, {"w": 15, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "உங்களுக்கு வரவில்லையா?"}, {"w": 2, "t": "come to you"}, {"w": 3, "t": "செய்தி"}, {"w": 4, "t": "நிராகரித்தவர்களின்"}, {"w": 5, "t": "disbelieved"}, {"w": 6, "t": "இதற்கு முன்னர்"}, {"w": 7, "t": "before"}, {"w": 8, "t": "அவர்கள் சுவைத்தனர்"}, {"w": 9, "t": "தீய முடிவை"}, {"w": 10, "t": "தங்கள் காரியத்தின்"}, {"w": 11, "t": "அவர்களுக்கு"}, {"w": 12, "t": "தண்டனை"}, {"w": 13, "t": "வலி தரக்கூடிய(து)"}, {"w": 14, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "அதற்கு காரணம் நிச்சயமாக"}, {"w": 2, "t": "(is) because"}, {"w": 3, "t": "அவர்களிடம் வந்து கொண்டிருந்தனர்"}, {"w": 4, "t": "come to them"}, {"w": 5, "t": "அவர்களின் தூதர்கள்"}, {"w": 6, "t": "தெளிவான அத்தாட்சிகளுடன்"}, {"w": 7, "t": "அவர்கள் கூறினார்கள்"}, {"w": 8, "t": "மனிதர்களா?"}, {"w": 9, "t": "எங்களுக்கு நேர்வழி காட்டுவார்கள்"}, {"w": 10, "t": "ஆகவே, அவர்கள் நிராகரித்தனர்"}, {"w": 11, "t": "இன்னும் விலகினார்கள்"}, {"w": 12, "t": "அவர்களை விட்டும் தேவையற்றவனாக இருக்கின்றான்"}, {"w": 13, "t": "அல்லாஹ்வும்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "மகா செல்வந்தன்"}, {"w": 16, "t": "மகா புகழுக்குரியவன்"}, {"w": 17, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "பிதற்றுகின்றனர்"}, {"w": 2, "t": "நிராகரித்தவர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "அறவே எழுப்பப்பட மாட்டார்கள்"}, {"w": 5, "t": "never"}, {"w": 6, "t": "will they be raised"}, {"w": 7, "t": "நீர் கூறுவீராக!"}, {"w": 8, "t": "ஏன் இல்லை!"}, {"w": 9, "t": "என் இறைவன் மீது சத்தியமாக"}, {"w": 10, "t": "நிச்சயமாகஎழுப்பப்படுவீர்கள்"}, {"w": 11, "t": "பிறகு"}, {"w": 12, "t": "நிச்சயமாக உங்களுக்கு அறிவிக்கப்படும்"}, {"w": 13, "t": "நீங்கள் செய்தவற்றை"}, {"w": 14, "t": "you did"}, {"w": 15, "t": "அது"}, {"w": 16, "t": "அல்லாஹ்விற்கு"}, {"w": 17, "t": "Allah"}, {"w": 18, "t": "மிக எளிதானதே!"}, {"w": 19, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "ஆகவே நம்பிக்கை கொள்ளுங்கள்"}, {"w": 2, "t": "அல்லாஹ்வையும்"}, {"w": 3, "t": "அவனது தூதரையும்"}, {"w": 4, "t": "ஒளியையும்"}, {"w": 5, "t": "எதை/இறக்கினோம்"}, {"w": 6, "t": "We have sent down"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "நீங்கள் செய்பவற்றை"}, {"w": 9, "t": "you do"}, {"w": 10, "t": "ஆழ்ந்தறிபவன்"}, {"w": 11, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நாளை"}, {"w": 2, "t": "அவன் உங்களை ஒன்று சேர்ப்பான்"}, {"w": 3, "t": "நாளுக்காக"}, {"w": 4, "t": "ஒன்று சேர்க்கப்படும்"}, {"w": 5, "t": "அதுதான்/நாளாகும்"}, {"w": 6, "t": "(will be the) Day"}, {"w": 7, "t": "ஏமாறுகின்ற"}, {"w": 8, "t": "யார்"}, {"w": 9, "t": "நம்பிக்கை கொள்வார்(கள்)"}, {"w": 10, "t": "அல்லாஹ்வை"}, {"w": 11, "t": "இன்னும் செய்வார்(கள்)"}, {"w": 12, "t": "நன்மையை"}, {"w": 13, "t": "போக்கிவிடுவான்"}, {"w": 14, "t": "அவர்களை விட்டும்"}, {"w": 15, "t": "அவர்களின் பாவங்களை"}, {"w": 16, "t": "இன்னும் அவர்களை நுழைப்பான்"}, {"w": 17, "t": "சொர்க்கங்களில்"}, {"w": 18, "t": "ஓடும்"}, {"w": 19, "t": "அவற்றின் கீழ்"}, {"w": 20, "t": "underneath it"}, {"w": 21, "t": "நதிகள்"}, {"w": 22, "t": "நிரந்தரமாக இருப்பார்கள்"}, {"w": 23, "t": "அவற்றில்"}, {"w": 24, "t": "எப்போதும்"}, {"w": 25, "t": "இதுதான்"}, {"w": 26, "t": "வெற்றியாகும்"}, {"w": 27, "t": "மகத்தான"}, {"w": 28, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நிராகரித்தார்களோ"}, {"w": 3, "t": "இன்னும் பொய்ப்பித்தார்களோ"}, {"w": 4, "t": "நமது வசனங்களை"}, {"w": 5, "t": "அவர்கள்தான்"}, {"w": 6, "t": "நரகவாசிகள்"}, {"w": 7, "t": "(of) the Fire"}, {"w": 8, "t": "நிரந்தரமாகத் தங்கி இருப்பார்கள்"}, {"w": 9, "t": "அதில்"}, {"w": 10, "t": "அது மிகக் கெட்டதாகும்"}, {"w": 11, "t": "மீளுமிடங்களில்"}, {"w": 12, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "ஏற்படாது"}, {"w": 2, "t": "strikes"}, {"w": 3, "t": "எந்த சோதனையும்"}, {"w": 4, "t": "disaster"}, {"w": 5, "t": "அனுமதி இல்லாமல்"}, {"w": 6, "t": "by (the) permission"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "யார் நம்பிக்கை கொள்வாரோ"}, {"w": 9, "t": "believes"}, {"w": 10, "t": "அல்லாஹ்வை"}, {"w": 11, "t": "நேர்வழி காட்டுவான்"}, {"w": 12, "t": "அவரின் உள்ளத்திற்கு"}, {"w": 13, "t": "அல்லாஹ்"}, {"w": 14, "t": "எல்லாவற்றையும்"}, {"w": 15, "t": "thing"}, {"w": 16, "t": "நன்கறிந்தவன்"}, {"w": 17, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் கீழ்ப்படியுங்கள்"}, {"w": 2, "t": "அல்லாஹ்விற்கு"}, {"w": 3, "t": "இன்னும் கீழ்ப்படியுங்கள்"}, {"w": 4, "t": "தூதருக்கு"}, {"w": 5, "t": "நீங்கள் விலகினால் /நமது தூதர் மீதுள்ள கடமை எல்லாம்"}, {"w": 6, "t": "you turn away"}, {"w": 7, "t": "then only"}, {"w": 8, "t": "upon"}, {"w": 9, "t": "Our Messenger"}, {"w": 10, "t": "எடுத்துரைப்பதுதான்"}, {"w": 11, "t": "தெளிவாக"}, {"w": 12, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அல்லாஹ்"}, {"w": 2, "t": "அறவே இல்லை"}, {"w": 3, "t": "கடவுள்"}, {"w": 4, "t": "அவனைத் தவிர"}, {"w": 5, "t": "Him"}, {"w": 6, "t": "மீதே"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "நம்பிக்கை வைக்கவும்"}, {"w": 9, "t": "நம்பிக்கையாளர்கள்"}, {"w": 10, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே!"}, {"w": 2, "t": "(you) who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "நிச்சயமாக"}, {"w": 5, "t": "உங்கள் மனைவிகளிலும்"}, {"w": 6, "t": "your spouses"}, {"w": 7, "t": "உங்கள் பிள்ளைகளிலும்"}, {"w": 8, "t": "எதிரிகள்"}, {"w": 9, "t": "உங்களுக்கு"}, {"w": 10, "t": "ஆகவே அவர்களிடம் நீங்கள் கவனமாக இருங்கள்"}, {"w": 11, "t": "நீங்கள் பிழை பொறுத்தால்"}, {"w": 12, "t": "you pardon"}, {"w": 13, "t": "இன்னும் புறக்கணித்தால்"}, {"w": 14, "t": "நீங்கள் மன்னித்தால்"}, {"w": 15, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 16, "t": "Allah"}, {"w": 17, "t": "மகா மன்னிப்பாளன்"}, {"w": 18, "t": "மகா கருணையாளன்"}, {"w": 19, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "உங்கள் செல்வங்கள் எல்லாம்"}, {"w": 2, "t": "your wealth"}, {"w": 3, "t": "இன்னும் உங்கள் பிள்ளைகள்"}, {"w": 4, "t": "சோதனைதான்"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "அவனிடம்தான்"}, {"w": 7, "t": "மகத்தான கூலி"}, {"w": 8, "t": "great"}, {"w": 9, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அஞ்சுங்கள்"}, {"w": 2, "t": "அல்லாஹ்வை"}, {"w": 3, "t": "உங்களுக்கு முடிந்தளவு"}, {"w": 4, "t": "you are able"}, {"w": 5, "t": "இன்னும் செவி தாழ்த்துங்கள்"}, {"w": 6, "t": "இன்னும் கீழ்ப்படியுங்கள்"}, {"w": 7, "t": "இன்னும் தர்மம் செய்யுங்கள்"}, {"w": 8, "t": "செல்வத்தை"}, {"w": 9, "t": "உங்கள் நன்மைக்காக"}, {"w": 10, "t": "எவர்(கள்)"}, {"w": 11, "t": "பாதுகாக்கப்படுவார்(களோ)"}, {"w": 12, "t": "கஞ்சத் தனத்தில் இருந்து"}, {"w": 13, "t": "தமது மனதின்"}, {"w": 14, "t": "அவர்கள்தான்"}, {"w": 15, "t": "[they]"}, {"w": 16, "t": "வெற்றியாளர்கள்"}, {"w": 17, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நீங்கள் கடன் கொடுத்தால்"}, {"w": 2, "t": "you loan"}, {"w": 3, "t": "அல்லாஹ்விற்கு"}, {"w": 4, "t": "கடனாக"}, {"w": 5, "t": "அழகிய"}, {"w": 6, "t": "அதை பன்மடங்காகப் பெருக்குவான்"}, {"w": 7, "t": "உங்களுக்கு"}, {"w": 8, "t": "இன்னும் மன்னிப்பான்"}, {"w": 9, "t": "உங்களை"}, {"w": 10, "t": "அல்லாஹ்"}, {"w": 11, "t": "மிகவும் நன்றியுள்ளவன்"}, {"w": 12, "t": "மகா சகிப்பாளன்"}, {"w": 13, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நன்கறிந்தவன்"}, {"w": 2, "t": "மறைவானவற்றையும்"}, {"w": 3, "t": "வெளிப்படையானவற்றையும்"}, {"w": 4, "t": "மிகைத்தவன்"}, {"w": 5, "t": "மகா ஞானவான்"}, {"w": 6, "t": "(18)"}]}]}