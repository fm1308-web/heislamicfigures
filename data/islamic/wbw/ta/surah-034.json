: "we believe"}, {"w": 6, "t": "இந்த குர்ஆனை(யும்)"}, {"w": 7, "t": "Quran"}, {"w": 8, "t": "இதற்கு முன்னுள்ளதையும்"}, {"w": 9, "t": "in (that) which"}, {"w": 10, "t": "(was) before it"}, {"w": 11, "t": "(was) before it"}, {"w": 12, "t": "நீர் பார்த்தால்"}, {"w": 13, "t": "you (could) see"}, {"w": 14, "t": "சமயத்தை/அநியாயக்காரர்கள்"}, {"w": 15, "t": "the wrongdoers"}, {"w": 16, "t": "நிறுத்தி வைக்கப்பட்டவர்கள்"}, {"w": 17, "t": "தங்கள் இறைவன் முன்னால்"}, {"w": 18, "t": "their Lord"}, {"w": 19, "t": "எதிர்த்துப் பேசுவார்(கள்)"}, {"w": 20, "t": "அவர்களில் சிலர்"}, {"w": 21, "t": "சிலரிடம்"}, {"w": 22, "t": "others"}, {"w": 23, "t": "பேசுவது"}, {"w": 24, "t": "கூறுவார்கள்"}, {"w": 25, "t": "பலவீனர்கள்"}, {"w": 26, "t": "were oppressed"}, {"w": 27, "t": "பெருமை அடித்தவர்களுக்கு"}, {"w": 28, "t": "were arrogant"}, {"w": 29, "t": "நீங்கள் இல்லை என்றால்"}, {"w": 30, "t": "(for) you"}, {"w": 31, "t": "நாங்கள் ஆகியிருப்போம்"}, {"w": 32, "t": "நம்பிக்கையாளர்களாக"}, {"w": 33, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "கூறுவார்கள்"}, {"w": 2, "t": "பெருமை அடித்தவர்கள்"}, {"w": 3, "t": "were arrogant"}, {"w": 4, "t": "பலவீனர்களுக்கு"}, {"w": 5, "t": "who were oppressed"}, {"w": 6, "t": "நாங்களா?"}, {"w": 7, "t": "உங்களை தடுத்தோம்"}, {"w": 8, "t": "நேர்வழியை விட்டும்"}, {"w": 9, "t": "the guidance"}, {"w": 10, "t": "வந்த பின்னர்"}, {"w": 11, "t": "when"}, {"w": 12, "t": "உங்களிடம்"}, {"w": 13, "t": "மாறாக"}, {"w": 14, "t": "நீங்கள்தான் இருந்தீர்கள்"}, {"w": 15, "t": "குற்றவாளிகளாக"}, {"w": 16, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "கூறுவார்கள்"}, {"w": 2, "t": "பலவீனர்கள்"}, {"w": 3, "t": "were oppressed"}, {"w": 4, "t": "பெருமை அடித்தவர்களுக்கு"}, {"w": 5, "t": "were arrogant"}, {"w": 6, "t": "மாறாக"}, {"w": 7, "t": "சூழ்ச்சியாகும்"}, {"w": 8, "t": "இரவிலும்"}, {"w": 9, "t": "பகலிலும்"}, {"w": 10, "t": "நீங்கள் எங்களை ஏவிய சமயத்தை நினைவு கூருங்கள்"}, {"w": 11, "t": "you were ordering us"}, {"w": 12, "t": "நாங்கள் நிராகரிப்பதற்கு(ம்)"}, {"w": 13, "t": "we disbelieve"}, {"w": 14, "t": "அல்லாஹ்வை"}, {"w": 15, "t": "நாங்கள்ஏற்படுத்துவதற்கும்"}, {"w": 16, "t": "அவனுக்கு"}, {"w": 17, "t": "இணைகளை"}, {"w": 18, "t": "இன்னும் அவர்கள் வெளிப்படுத்துவார்கள்"}, {"w": 19, "t": "துக்கத்தை"}, {"w": 20, "t": "அவர்கள் கண்ணால் காணும்போது"}, {"w": 21, "t": "they see"}, {"w": 22, "t": "வேதனையை"}, {"w": 23, "t": "நாம் ஆக்குவோம்"}, {"w": 24, "t": "(சங்கிலி)விலங்குகளை"}, {"w": 25, "t": "கழுத்துகளில்"}, {"w": 26, "t": "(the) necks"}, {"w": 27, "t": "நிராகரித்தவர்களின்"}, {"w": 28, "t": "disbelieved"}, {"w": 29, "t": "கூலி கொடுக்கப்படுவார்களா?"}, {"w": 30, "t": "they be recompensed"}, {"w": 31, "t": "தவிர/அவர்கள் செய்துகொண்டிருந்ததற்கே"}, {"w": 32, "t": "(for) what"}, {"w": 33, "t": "they used to"}, {"w": 34, "t": "do"}, {"w": 35, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நாம் அனுப்பவில்லை"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "ஓர் ஊரில்"}, {"w": 4, "t": "a town"}, {"w": 5, "t": "எச்சரிப்பாளரை"}, {"w": 6, "t": "warner"}, {"w": 7, "t": "தவிர"}, {"w": 8, "t": "கூறியே"}, {"w": 9, "t": "அதன் சுகவாசிகள்"}, {"w": 10, "t": "நிச்சயமாக நாங்கள்"}, {"w": 11, "t": "எதைக்கொண்டு"}, {"w": 12, "t": "நீங்கள் அனுப்பப்பட்டீர்கள்/அதை"}, {"w": 13, "t": "with"}, {"w": 14, "t": "நிராகரிக்கின்றோம்"}, {"w": 15, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "நாங்கள்"}, {"w": 3, "t": "அதிகமானவர்கள்"}, {"w": 4, "t": "செல்வங்களாலும்"}, {"w": 5, "t": "பிள்ளைகளாலும்"}, {"w": 6, "t": "ஆகவே, நாங்கள் மறுமையிலும் அறவே தண்டிக்கப்பட மாட்டோம்."}, {"w": 7, "t": "we"}, {"w": 8, "t": "will be punished"}, {"w": 9, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "என் இறைவன்"}, {"w": 4, "t": "விசாலமாக தருகின்றான்"}, {"w": 5, "t": "வாழ்வாதாரத்தை"}, {"w": 6, "t": "அவன் நாடுகின்றவர்களுக்கு"}, {"w": 7, "t": "He wills"}, {"w": 8, "t": "இன்னும் சுருக்கி கொடுக்கின்றான்"}, {"w": 9, "t": "என்றாலும்"}, {"w": 10, "t": "அதிகமானவர்கள்"}, {"w": 11, "t": "மக்களில்"}, {"w": 12, "t": "அறியமாட்டார்கள்"}, {"w": 13, "t": "know"}, {"w": 14, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "உங்கள் செல்வங்கள் இல்லை"}, {"w": 2, "t": "your wealth"}, {"w": 3, "t": "இன்னும் உங்கள் பிள்ளைகள்"}, {"w": 4, "t": "your children"}, {"w": 5, "t": "உங்களை நெருக்கமாக்கி வைக்கக்கூடியதாக"}, {"w": 6, "t": "will bring you close"}, {"w": 7, "t": "எங்களிடம்"}, {"w": 8, "t": "நெருக்கமாக"}, {"w": 9, "t": "எனினும்"}, {"w": 10, "t": "எவர்கள்"}, {"w": 11, "t": "நம்பிக்கை கொண்டு"}, {"w": 12, "t": "செய்வார்களோ"}, {"w": 13, "t": "நன்மையை"}, {"w": 14, "t": "அவர்களுக்கு உண்டு"}, {"w": 15, "t": "for them"}, {"w": 16, "t": "கூலி"}, {"w": 17, "t": "இரு மடங்கு"}, {"w": 18, "t": "அவர்கள் செய்ததற்கு பகரமாக"}, {"w": 19, "t": "they did"}, {"w": 20, "t": "அவர்கள்"}, {"w": 21, "t": "அறைகளில்"}, {"w": 22, "t": "the high dwellings"}, {"w": 23, "t": "நிம்மதியாக"}, {"w": 24, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "முயல்வார்களோ"}, {"w": 3, "t": "நமது வசனங்களில்"}, {"w": 4, "t": "Our Verses"}, {"w": 5, "t": "பலவீனப்படுத்த"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "வேதனைக்கு"}, {"w": 8, "t": "the punishment"}, {"w": 9, "t": "கொண்டு வரப்படுவார்கள்"}, {"w": 10, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "என் இறைவன்"}, {"w": 4, "t": "விசாலமாக்குகின்றான்"}, {"w": 5, "t": "வாழ்வாதாரத்தை"}, {"w": 6, "t": "தான் நாடியவர்களுக்கு"}, {"w": 7, "t": "He wills"}, {"w": 8, "t": "தனது அடியார்களில்"}, {"w": 9, "t": "His slaves"}, {"w": 10, "t": "இன்னும் சுருக்கி விடுகின்றான்"}, {"w": 11, "t": "அவனுக்கு"}, {"w": 12, "t": "நீங்கள் தர்மம் செய்தாலும்"}, {"w": 13, "t": "you spend"}, {"w": 14, "t": "எதை"}, {"w": 15, "t": "anything"}, {"w": 16, "t": "அவன்"}, {"w": 17, "t": "அதற்கு பகரத்தை ஏற்படுத்துவான்"}, {"w": 18, "t": "அவன்"}, {"w": 19, "t": "மிகச் சிறந்தவன்"}, {"w": 20, "t": "உணவளிப்பவர்களில்"}, {"w": 21, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "அவன் ஒன்று திரட்டும் நாளில்"}, {"w": 2, "t": "அவன் ஒன்று திரட்டும் நாளில் அவர்கள்"}, {"w": 3, "t": "அனைவரையும்"}, {"w": 4, "t": "பிறகு"}, {"w": 5, "t": "அவன் கூறுவான்"}, {"w": 6, "t": "வானவர்களுக்கு"}, {"w": 7, "t": "?/இவர்கள்"}, {"w": 8, "t": "உங்களை"}, {"w": 9, "t": "வணங்கிக் கொண்டிருந்தார்கள்"}, {"w": 10, "t": "worshipping"}, {"w": 11, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "நீ மகா தூயவன்"}, {"w": 3, "t": "நீதான்"}, {"w": 4, "t": "எங்கள் பாதுகாவலன்"}, {"w": 5, "t": "அவர்கள் இன்றி"}, {"w": 6, "t": "not them"}, {"w": 7, "t": "மாறாக/வணங்கிக் கொண்டிருந்தனர்"}, {"w": 8, "t": "they used"}, {"w": 9, "t": "(to) worship"}, {"w": 10, "t": "ஜின்களை"}, {"w": 11, "t": "அதிகமானவர்கள் அவர்களில்"}, {"w": 12, "t": "அவர்களைத்தான்"}, {"w": 13, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 14, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "இன்றைய தினம்"}, {"w": 2, "t": "உரிமை பெறமாட்டார்"}, {"w": 3, "t": "possess power"}, {"w": 4, "t": "உங்களில் சிலர்"}, {"w": 5, "t": "சிலருக்கு"}, {"w": 6, "t": "நன்மைசெய்வதற்கோ"}, {"w": 7, "t": "தீமை செய்வதற்கோ"}, {"w": 8, "t": "to harm"}, {"w": 9, "t": "நாம் கூறுவோம்"}, {"w": 10, "t": "அநியாயக்காரர்களுக்கு"}, {"w": 11, "t": "who wronged"}, {"w": 12, "t": "நீங்கள் சுவையுங்கள்"}, {"w": 13, "t": "நரக வேதனையை"}, {"w": 14, "t": "(of) the Fire"}, {"w": 15, "t": "நீங்கள் பொய்ப்பித்துக்கொண்டிருந்த"}, {"w": 16, "t": "you used"}, {"w": 17, "t": "to [it]"}, {"w": 18, "t": "deny"}, {"w": 19, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "ஓதப்பட்டால்"}, {"w": 2, "t": "are recited"}, {"w": 3, "t": "அவர்கள் முன்"}, {"w": 4, "t": "நமது வசனங்கள்"}, {"w": 5, "t": "தெளிவான"}, {"w": 6, "t": "அவர்கள் கூறினர்"}, {"w": 7, "t": "இவர் இல்லை"}, {"w": 8, "t": "(is) this"}, {"w": 9, "t": "தவிர"}, {"w": 10, "t": "ஓர் ஆடவரே"}, {"w": 11, "t": "நாடுகின்றனர்"}, {"w": 12, "t": "இவர் உங்களைத் தடுக்க"}, {"w": 13, "t": "hinder you"}, {"w": 14, "t": "வணங்கிக்கொண்டிருந்தவற்றை விட்டும்"}, {"w": 15, "t": "used"}, {"w": 16, "t": "(to) worship"}, {"w": 17, "t": "மூதாதைகள் உங்கள்"}, {"w": 18, "t": "இன்னும் அவர்கள்கூறினர்"}, {"w": 19, "t": "இது இல்லை"}, {"w": 20, "t": "(is) this"}, {"w": 21, "t": "தவிர"}, {"w": 22, "t": "பொய்"}, {"w": 23, "t": "இட்டுக்கட்டப்பட்ட"}, {"w": 24, "t": "இன்னும் கூறினர்"}, {"w": 25, "t": "நிராகரித்தவர்கள்"}, {"w": 26, "t": "disbelieved"}, {"w": 27, "t": "சத்தியம்"}, {"w": 28, "t": "வந்த போது"}, {"w": 29, "t": "தங்களிடம்"}, {"w": 30, "t": "இது இல்லை"}, {"w": 31, "t": "(is) this"}, {"w": 32, "t": "தவிர"}, {"w": 33, "t": "சூனியமே"}, {"w": 34, "t": "தெளிவான"}, {"w": 35, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "அவர்களுக்கு நாம் கொடுத்ததில்லை"}, {"w": 2, "t": "We (had) given them"}, {"w": 3, "t": "வேதங்களை"}, {"w": 4, "t": "Scriptures"}, {"w": 5, "t": "அவர்கள் அவற்றை படிக்கின்றனர்"}, {"w": 6, "t": "நாம் அனுப்பியதில்லை"}, {"w": 7, "t": "We sent"}, {"w": 8, "t": "அவர்களிடம்"}, {"w": 9, "t": "உமக்கு முன்னர்"}, {"w": 10, "t": "எச்சரிப்பவர் எவரையும்"}, {"w": 11, "t": "warner"}, {"w": 12, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "பொய்ப்பித்தனர்"}, {"w": 2, "t": "இவர்களுக்கு முன்னுள்ளவர்களும்"}, {"w": 3, "t": "(were) before them"}, {"w": 4, "t": "(were) before them"}, {"w": 5, "t": "அடையவில்லை"}, {"w": 6, "t": "they have attained"}, {"w": 7, "t": "அவர்களுக்கு நாம் கொடுத்ததில் பத்தில் ஒன்றை(க்கூட)"}, {"w": 8, "t": "(of) what"}, {"w": 9, "t": "We (had) given them"}, {"w": 10, "t": "(இருந்தும்) அவர்கள் பொய்ப்பித்தனர்"}, {"w": 11, "t": "எனது தூதர்களை"}, {"w": 12, "t": "எப்படி"}, {"w": 13, "t": "இருந்தது"}, {"w": 14, "t": "எனது மாற்றம்"}, {"w": 15, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் உங்களுக்கு உபதேசிப்பதெல்லாம்"}, {"w": 3, "t": "I advise you"}, {"w": 4, "t": "ஒன்றே ஒன்றைத்தான்"}, {"w": 5, "t": "நீங்கள் நில்லுங்கள்"}, {"w": 6, "t": "you stand"}, {"w": 7, "t": "அல்லாஹ்விற்காக"}, {"w": 8, "t": "இருவர் இருவராக"}, {"w": 9, "t": "இன்னும் ஒருவர் ஒருவராக"}, {"w": 10, "t": "பிறகு"}, {"w": 11, "t": "சிந்தியுங்கள்"}, {"w": 12, "t": "உங்கள் இந்த தோழருக்கு அறவே இல்லை"}, {"w": 13, "t": "(is in) your companion"}, {"w": 14, "t": "பைத்தியம்"}, {"w": 15, "t": "madness"}, {"w": 16, "t": "அவர் இல்லை"}, {"w": 17, "t": "he"}, {"w": 18, "t": "தவிர"}, {"w": 19, "t": "எச்சரிப்பவரே"}, {"w": 20, "t": "உங்களுக்கு"}, {"w": 21, "t": "முன்னர்"}, {"w": 22, "t": "before"}, {"w": 23, "t": "வேதனைக்கு"}, {"w": 24, "t": "கடுமையான(து)"}, {"w": 25, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "எதை நான் உங்களிடம் கேட்டேனோ"}, {"w": 3, "t": "I ask you"}, {"w": 4, "t": "கூலியாக"}, {"w": 5, "t": "any payment"}, {"w": 6, "t": "அது உங்களுக்கே"}, {"w": 7, "t": "for you"}, {"w": 8, "t": "என் கூலி இல்லை"}, {"w": 9, "t": "(is) my payment"}, {"w": 10, "t": "தவிர"}, {"w": 11, "t": "மீதே"}, {"w": 12, "t": "அல்லாஹ்வின்"}, {"w": 13, "t": "அவன்தான்"}, {"w": 14, "t": "அனைத்தின் மீதும்"}, {"w": 15, "t": "all"}, {"w": 16, "t": "things"}, {"w": 17, "t": "சாட்சியாளன்"}, {"w": 18, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "என் இறைவன்"}, {"w": 4, "t": "செய்தியை இறக்குகின்றான்"}, {"w": 5, "t": "உண்மையான"}, {"w": 6, "t": "மிக அறிந்தவன்"}, {"w": 7, "t": "மறைவான விஷயங்கள் அனைத்தையும்"}, {"w": 8, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "வந்துவிட்டது"}, {"w": 3, "t": "உண்மை"}, {"w": 4, "t": "புதிதாக படைக்க(வும்) மாட்டான்"}, {"w": 5, "t": "(can) originate"}, {"w": 6, "t": "பொய்யன்"}, {"w": 7, "t": "மீண்டும் உயிர்ப்பிக்கவும் மாட்டான்"}, {"w": 8, "t": "repeat"}, {"w": 9, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் வழிகெட்டால்"}, {"w": 3, "t": "I err"}, {"w": 4, "t": "நான் வழிகெடுவதெல்லாம்"}, {"w": 5, "t": "I will err"}, {"w": 6, "t": "எனக்குத்தான் தீங்காக அமையும்"}, {"w": 7, "t": "myself"}, {"w": 8, "t": "நான் நேர்வழி பெற்றால்"}, {"w": 9, "t": "I am guided"}, {"w": 10, "t": "வஹீ  அறிவிக்கின்ற காரணத்தால் ஆகும்"}, {"w": 11, "t": "reveals"}, {"w": 12, "t": "எனக்கு"}, {"w": 13, "t": "என் இறைவன்"}, {"w": 14, "t": "நிச்சயமாக அவன்"}, {"w": 15, "t": "நன்கு செவியுறுபவன்"}, {"w": 16, "t": "மிக சமீபமானவன்"}, {"w": 17, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நீர் பார்த்தால்"}, {"w": 2, "t": "you (could) see"}, {"w": 3, "t": "அவர்கள் திடுக்கிடும்போது"}, {"w": 4, "t": "they will be terrified"}, {"w": 5, "t": "தப்பிக்கவே முடியாது"}, {"w": 6, "t": "escape"}, {"w": 7, "t": "அவர்கள் பிடிக்கப்படுவார்கள்"}, {"w": 8, "t": "இடத்திலிருந்து"}, {"w": 9, "t": "a place"}, {"w": 10, "t": "வெகு சமீபமான"}, {"w": 11, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "நம்பிக்கை கொண்டோம்"}, {"w": 3, "t": "அவனை"}, {"w": 4, "t": "எங்கே"}, {"w": 5, "t": "அவர்களுக்கு சாத்தியமாகும்"}, {"w": 6, "t": "அடைவது"}, {"w": 7, "t": "இடத்திலிருந்து"}, {"w": 8, "t": "a place"}, {"w": 9, "t": "தூரமான"}, {"w": 10, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "மறுத்து விட்டனர்"}, {"w": 3, "t": "இதை"}, {"w": 4, "t": "முன்னர்"}, {"w": 5, "t": "before"}, {"w": 6, "t": "அவர்கள் அதிகம் பேசுகின்றனர்"}, {"w": 7, "t": "கற்பனையாக"}, {"w": 8, "t": "இடத்திலிருந்து"}, {"w": 9, "t": "a place"}, {"w": 10, "t": "வெகு தூரமான"}, {"w": 11, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "தடுக்கப்பட்டுவிடும்"}, {"w": 2, "t": "அவர்களுக்கு இடையிலும்"}, {"w": 3, "t": "இடையிலும்"}, {"w": 4, "t": "அவர்கள் விரும்புவதற்கு"}, {"w": 5, "t": "they desire"}, {"w": 6, "t": "போன்று"}, {"w": 7, "t": "செய்யப்பட்டதை"}, {"w": 8, "t": "அவர்கள் கூட்டங்களுக்கு"}, {"w": 9, "t": "இதற்கு முன்னர்"}, {"w": 10, "t": "before"}, {"w": 11, "t": "நிச்சயமாக இவர்கள்"}, {"w": 12, "t": "இருந்தனர்"}, {"w": 13, "t": "சந்தேகத்தில்தான்"}, {"w": 14, "t": "doubt"}, {"w": 15, "t": "பெரிய"}, {"w": 16, "t": "(54)"}]}]}