you are"}, {"w": 15, "t": "நம்பிக்கையாளராக"}, {"w": 16, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவன்/எத்தகையவன்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "இறக்குகின்றான்"}, {"w": 4, "t": "தனது அடியார் மீது"}, {"w": 5, "t": "His slave"}, {"w": 6, "t": "அத்தாட்சிகளை"}, {"w": 7, "t": "தெளிவான(வை)"}, {"w": 8, "t": "உங்களை வெளியேற்றுவதற்காக"}, {"w": 9, "t": "இருள்களிலிருந்து"}, {"w": 10, "t": "the darkness[es]"}, {"w": 11, "t": "வெளிச்சத்தின் பக்கம்"}, {"w": 12, "t": "the light"}, {"w": 13, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 14, "t": "Allah"}, {"w": 15, "t": "உங்கள் மீது"}, {"w": 16, "t": "மிக இரக்கமுடையவனும்"}, {"w": 17, "t": "கருணையாளனும்"}, {"w": 18, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "உங்களுக்கு என்ன ஆனது?"}, {"w": 2, "t": "(is) for you"}, {"w": 3, "t": "நீங்கள் தர்மம் செய்யாமல் இருப்பதற்கு"}, {"w": 4, "t": "you spend"}, {"w": 5, "t": "பாதையில்"}, {"w": 6, "t": "(the) way"}, {"w": 7, "t": "அல்லாஹ்வின்"}, {"w": 8, "t": "அல்லாஹ்விற்கே"}, {"w": 9, "t": "சொத்துக்கள்"}, {"w": 10, "t": "வானங்கள்"}, {"w": 11, "t": "இன்னும் பூமியின்"}, {"w": 12, "t": "சமமாக மாட்டார்"}, {"w": 13, "t": "are equal"}, {"w": 14, "t": "உங்களில்/எவரும்"}, {"w": 15, "t": "(those) who"}, {"w": 16, "t": "தர்மம் செய்தார்"}, {"w": 17, "t": "முன்னர்"}, {"w": 18, "t": "before"}, {"w": 19, "t": "வெற்றிக்கு"}, {"w": 20, "t": "இன்னும் போர் செய்தார்"}, {"w": 21, "t": "அவர்கள்தான்"}, {"w": 22, "t": "மிக மகத்தான/பதவி"}, {"w": 23, "t": "(in) degree"}, {"w": 24, "t": "எவர்களைவிட"}, {"w": 25, "t": "those who"}, {"w": 26, "t": "தர்மம் செய்தார்கள்"}, {"w": 27, "t": "இதற்குப் பின்னர்"}, {"w": 28, "t": "afterwards"}, {"w": 29, "t": "இன்னும் போர் செய்தார்கள்"}, {"w": 30, "t": "எல்லோருக்கும்"}, {"w": 31, "t": "வாக்களித்துள்ளான்"}, {"w": 32, "t": "அல்லாஹ்"}, {"w": 33, "t": "சொர்க்கத்தை"}, {"w": 34, "t": "அல்லாஹ்"}, {"w": 35, "t": "நீங்கள் செய்வதை"}, {"w": 36, "t": "you do"}, {"w": 37, "t": "ஆழ்ந்தறிபவன்"}, {"w": 38, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "the one who"}, {"w": 3, "t": "எவர்"}, {"w": 4, "t": "கடன் கொடுக்கின்றார்"}, {"w": 5, "t": "அல்லாஹ்விற்கு"}, {"w": 6, "t": "கடனாக"}, {"w": 7, "t": "அழகிய"}, {"w": 8, "t": "அதை பன்மடங்காக்குவான்"}, {"w": 9, "t": "அவருக்கு"}, {"w": 10, "t": "இன்னும் அவருக்கு"}, {"w": 11, "t": "கூலி உண்டு"}, {"w": 12, "t": "கண்ணியமான(து)"}, {"w": 13, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நாளில்"}, {"w": 2, "t": "நீர் பார்ப்பீர்"}, {"w": 3, "t": "நம்பிக்கை கொண்ட ஆண்களை"}, {"w": 4, "t": "இன்னும் நம்பிக்கை கொண்ட பெண்களை"}, {"w": 5, "t": "செல்லும்"}, {"w": 6, "t": "அவர்களின் ஒளி"}, {"w": 7, "t": "அவர்களுக்கு முன்னர்"}, {"w": 8, "t": "before them"}, {"w": 9, "t": "இன்னும் அவர்களின் வலப்பக்கங்களில்"}, {"w": 10, "t": "உங்கள் நற்செய்தி"}, {"w": 11, "t": "இன்று"}, {"w": 12, "t": "சொர்க்கங்களாகும்"}, {"w": 13, "t": "ஓடும்"}, {"w": 14, "t": "அவற்றின் கீழ்"}, {"w": 15, "t": "underneath it"}, {"w": 16, "t": "நதிகள்"}, {"w": 17, "t": "நிரந்தரமாக இருப்பார்கள்"}, {"w": 18, "t": "அதில்"}, {"w": 19, "t": "அதுதான்"}, {"w": 20, "t": "[it] (is)"}, {"w": 21, "t": "வெற்றியாகும்"}, {"w": 22, "t": "மகத்தான"}, {"w": 23, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அந்நாளில்"}, {"w": 2, "t": "கூறுவார்கள்"}, {"w": 3, "t": "நயவஞ்சகம் உடைய ஆண்களும்"}, {"w": 4, "t": "நயவஞ்சகம் உடைய பெண்களும்"}, {"w": 5, "t": "நம்பிக்கை கொண்டவர்களுக்கு"}, {"w": 6, "t": "believed"}, {"w": 7, "t": "எங்களை எதிர்பாருங்கள்!"}, {"w": 8, "t": "நாங்கள் எடுத்துக் கொள்கிறோம்"}, {"w": 9, "t": "உங்கள்ஒளியிலிருந்து"}, {"w": 10, "t": "your light"}, {"w": 11, "t": "கூறப்படும்"}, {"w": 12, "t": "நீங்கள் திரும்பிச்செல்லுங்கள்"}, {"w": 13, "t": "உங்களுக்குப் பின்னால்"}, {"w": 14, "t": "தேடுங்கள்!"}, {"w": 15, "t": "ஒளியை"}, {"w": 16, "t": "ஆகவே அமைக்கப்படும்"}, {"w": 17, "t": "அவர்களுக்கு மத்தியில்"}, {"w": 18, "t": "ஒரு சுவர்"}, {"w": 19, "t": "அதற்கு"}, {"w": 20, "t": "ஒரு வாசல்"}, {"w": 21, "t": "அதன் உள் பக்கம்"}, {"w": 22, "t": "அதில்"}, {"w": 23, "t": "அருள்"}, {"w": 24, "t": "இன்னும் அதன் வெளிப்பக்கம்"}, {"w": 25, "t": "அதற்கு முன்னால்"}, {"w": 26, "t": "facing towards [it]"}, {"w": 27, "t": "வேதனை"}, {"w": 28, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவர்களை கூவி அழைப்பார்கள்"}, {"w": 2, "t": "நாங்கள் இருக்கவில்லையா?"}, {"w": 3, "t": "we"}, {"w": 4, "t": "உங்களுடன்"}, {"w": 5, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 6, "t": "ஏன் இல்லை"}, {"w": 7, "t": "என்றாலும் நீங்கள்"}, {"w": 8, "t": "அழித்துக் கொண்டீர்கள்"}, {"w": 9, "t": "உங்களையே"}, {"w": 10, "t": "இன்னும் தீமையை எதிர்பார்த்தீர்கள்"}, {"w": 11, "t": "இன்னும் சந்தேகித்தீர்கள்"}, {"w": 12, "t": "உங்களை மயக்கின"}, {"w": 13, "t": "பொய்யானஆசைகள்"}, {"w": 14, "t": "இறுதியாக"}, {"w": 15, "t": "வந்துவிட்டது"}, {"w": 16, "t": "கட்டளை"}, {"w": 17, "t": "அல்லாஹ்வின்"}, {"w": 18, "t": "உங்களை மயக்கிவிட்டான்"}, {"w": 19, "t": "அல்லாஹ்வை விட்டும்"}, {"w": 20, "t": "மயக்கக் கூடியவன்"}, {"w": 21, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "இன்றைய தினம்"}, {"w": 2, "t": "வாங்கப்படாது"}, {"w": 3, "t": "will be accepted"}, {"w": 4, "t": "உங்களிடமும்"}, {"w": 5, "t": "எவ்வித பரிகாரம்"}, {"w": 6, "t": "நிராகரிப்பாளர்களிடமும்"}, {"w": 7, "t": "from"}, {"w": 8, "t": "those who"}, {"w": 9, "t": "disbelieved"}, {"w": 10, "t": "உங்கள் தங்குமிடம்"}, {"w": 11, "t": "நரகம்தான்"}, {"w": 12, "t": "அதுதான்/உங்களுக்கு மிக ஏற்றமானது"}, {"w": 13, "t": "your protector"}, {"w": 14, "t": "மீளுமிடங்களில் அது மிகக் கெட்டது"}, {"w": 15, "t": "the destination"}, {"w": 16, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "நேரம் வரவில்லையா?"}, {"w": 2, "t": "come (the) time"}, {"w": 3, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 4, "t": "believed"}, {"w": 5, "t": "நடுங்குவதற்கு"}, {"w": 6, "t": "become humble"}, {"w": 7, "t": "அவர்களின் உள்ளங்கள்"}, {"w": 8, "t": "நினைவு கூர்வதாலும்"}, {"w": 9, "t": "அல்லாஹ்வை"}, {"w": 10, "t": "இன்னும் எது/இறங்கியது"}, {"w": 11, "t": "has come down"}, {"w": 12, "t": "சத்தியவேதத்தினாலும்"}, {"w": 13, "t": "the truth"}, {"w": 14, "t": "அவர்கள் ஆகிவிட வேண்டாம்"}, {"w": 15, "t": "they become"}, {"w": 16, "t": "அவர்களைப் போல்"}, {"w": 17, "t": "வேதம் கொடுக்கப் பட்டார்கள்"}, {"w": 18, "t": "the Book"}, {"w": 19, "t": "இதற்கு முன்னர்"}, {"w": 20, "t": "before"}, {"w": 21, "t": "அவர்கள் மீது நீண்டு விட்டது"}, {"w": 22, "t": "for them"}, {"w": 23, "t": "காலம்"}, {"w": 24, "t": "ஆகவே இறுகிவிட்டன"}, {"w": 25, "t": "அவர்களின் உள்ளங்கள்"}, {"w": 26, "t": "அதிகமானவர்கள்"}, {"w": 27, "t": "அவர்களில்"}, {"w": 28, "t": "பாவிகள்"}, {"w": 29, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அறிந்து கொள்ளுங்கள்"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "உயிர்ப்பிக்கின்றான்"}, {"w": 5, "t": "பூமியை"}, {"w": 6, "t": "அது இறந்த பின்னர்"}, {"w": 7, "t": "its death"}, {"w": 8, "t": "திட்டமாக/நாம் தெளிவுபடுத்துகின்றோம்"}, {"w": 9, "t": "We have made clear"}, {"w": 10, "t": "உங்களுக்கு"}, {"w": 11, "t": "வசனங்களை"}, {"w": 12, "t": "நீங்கள் சிந்தித்து புரிவதற்காக"}, {"w": 13, "t": "understand"}, {"w": 14, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "நிச்சயமாக தர்மம் செய்த ஆண்கள்"}, {"w": 2, "t": "the men who give charity"}, {"w": 3, "t": "இன்னும் தர்மம் செய்த பெண்கள்"}, {"w": 4, "t": "இன்னும் கடன் கொடுத்தவர்கள்"}, {"w": 5, "t": "அல்லாஹ்விற்கு"}, {"w": 6, "t": "அழகிய கடனாக"}, {"w": 7, "t": "goodly"}, {"w": 8, "t": "அவர்களுக்கு பன்மடங்காக்கப்படும்"}, {"w": 9, "t": "for them"}, {"w": 10, "t": "இன்னும் அவர்களுக்கு"}, {"w": 11, "t": "கூலி/கண்ணியமான(து)"}, {"w": 12, "t": "noble"}, {"w": 13, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 2, "t": "believe"}, {"w": 3, "t": "அல்லாஹ்வையும்"}, {"w": 4, "t": "இன்னும் அவனது தூதர்களையும்"}, {"w": 5, "t": "அவர்கள்தான்"}, {"w": 6, "t": "they"}, {"w": 7, "t": "மிக உண்மையானவர்கள்"}, {"w": 8, "t": "அல்லாஹ்வின் பாதையில் கொல்லப்பட்டவர்கள்"}, {"w": 9, "t": "அவர்களின் இறைவனிடம்"}, {"w": 10, "t": "their Lord"}, {"w": 11, "t": "அவர்களுக்கு"}, {"w": 12, "t": "அவர்களின் கூலியும்"}, {"w": 13, "t": "( ஒளியும்இ) அவர்களின்"}, {"w": 14, "t": "எவர்கள்"}, {"w": 15, "t": "நிராகரித்தார்கள்"}, {"w": 16, "t": "இன்னும் பொய்ப்பித்தார்கள்"}, {"w": 17, "t": "நமது வசனங்களை"}, {"w": 18, "t": "அவர்கள்தான்"}, {"w": 19, "t": "நரகவாசிகள்"}, {"w": 20, "t": "(of) the Hellfire"}, {"w": 21, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அறிந்து கொள்ளுங்கள்"}, {"w": 2, "t": "உலக வாழ்க்கை எல்லாம்"}, {"w": 3, "t": "the life"}, {"w": 4, "t": "(of) the world"}, {"w": 5, "t": "விளையாட்டு(ம்)"}, {"w": 6, "t": "வேடிக்கையும்"}, {"w": 7, "t": "அலங்காரமும்"}, {"w": 8, "t": "பெருமை அடிப்பதும்"}, {"w": 9, "t": "உங்களுக்கு மத்தியில்"}, {"w": 10, "t": "அதிகத்தின் போட்டியும்தான்"}, {"w": 11, "t": "செல்வங்களிலும்"}, {"w": 12, "t": "the wealth"}, {"w": 13, "t": "பிள்ளைகளிலும்"}, {"w": 14, "t": "போல்தான்"}, {"w": 15, "t": "ஒரு மழையை"}, {"w": 16, "t": "கவர்ந்தது"}, {"w": 17, "t": "விவசாயிகளை"}, {"w": 18, "t": "அதன் விளைச்சல்"}, {"w": 19, "t": "பிறகு"}, {"w": 20, "t": "அது காய்ந்து விடுகிறது"}, {"w": 21, "t": "அதை நீர் பார்க்கிறீர்"}, {"w": 22, "t": "மஞ்சளாக"}, {"w": 23, "t": "பிறகு"}, {"w": 24, "t": "அது ஆகிவிடுகிறது"}, {"w": 25, "t": "குப்பையாக"}, {"w": 26, "t": "மறுமையில்"}, {"w": 27, "t": "the Hereafter"}, {"w": 28, "t": "வேதனை(யும்)"}, {"w": 29, "t": "கடுமையான(து)"}, {"w": 30, "t": "மன்னிப்பும்"}, {"w": 31, "t": "அல்லாஹ்வின் புறத்தில் இருந்து"}, {"w": 32, "t": "Allah"}, {"w": 33, "t": "திருப்பொருத்தமும்"}, {"w": 34, "t": "உலக வாழ்க்கை இல்லை"}, {"w": 35, "t": "(is) the life"}, {"w": 36, "t": "(of) the world"}, {"w": 37, "t": "இன்பமே தவிர"}, {"w": 38, "t": "(the) enjoyment"}, {"w": 39, "t": "மயக்கக் கூடிய(து)"}, {"w": 40, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "முந்துங்கள்"}, {"w": 2, "t": "மன்னிப்பின் பக்கமும்"}, {"w": 3, "t": "(the) forgiveness"}, {"w": 4, "t": "உங்கள் இறைவனின்"}, {"w": 5, "t": "your Lord"}, {"w": 6, "t": "இன்னும் சொர்க்கத்தின் பக்கமும்"}, {"w": 7, "t": "அதன் அகலம்"}, {"w": 8, "t": "அகலத்தைப் போல"}, {"w": 9, "t": "வானம்"}, {"w": 10, "t": "இன்னும் பூமியின்"}, {"w": 11, "t": "அது ஏற்பாடு செய்யப்பட்டுள்ளது"}, {"w": 12, "t": "நம்பிக்கை கொண்டவர்களுக்காக"}, {"w": 13, "t": "believe"}, {"w": 14, "t": "அல்லாஹ்வையும்"}, {"w": 15, "t": "அவனது தூதரையும்"}, {"w": 16, "t": "அது"}, {"w": 17, "t": "சிறப்பாகும்"}, {"w": 18, "t": "அல்லாஹ்வின்"}, {"w": 19, "t": "அதை அவன் கொடுக்கின்றான்"}, {"w": 20, "t": "அவன் நாடுகின்றவர்களுக்கு"}, {"w": 21, "t": "He wills"}, {"w": 22, "t": "அல்லாஹ்"}, {"w": 23, "t": "சிறப்புடையவன்"}, {"w": 24, "t": "(is) the Possessor of Bounty"}, {"w": 25, "t": "மகத்தான"}, {"w": 26, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "ஏற்படுவதில்லை"}, {"w": 2, "t": "strikes"}, {"w": 3, "t": "ஒரு சோதனை"}, {"w": 4, "t": "disaster"}, {"w": 5, "t": "பூமியிலும்"}, {"w": 6, "t": "the earth"}, {"w": 7, "t": "உங்களிலும்"}, {"w": 8, "t": "in"}, {"w": 9, "t": "yourselves"}, {"w": 10, "t": "தவிர/விதியில்இருந்தே"}, {"w": 11, "t": "in"}, {"w": 12, "t": "a Register"}, {"w": 13, "t": "முன்னர்"}, {"w": 14, "t": "before"}, {"w": 15, "t": "அதை நாம் உருவாக்குவதற்கு"}, {"w": 16, "t": "We bring it into existence"}, {"w": 17, "t": "நிச்சயமாக"}, {"w": 18, "t": "இது"}, {"w": 19, "t": "அல்லாஹ்விற்கு"}, {"w": 20, "t": "Allah"}, {"w": 21, "t": "மிக எளிதானதாகும்"}, {"w": 22, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "ஏனெனில், நீங்கள் துக்கப்படாமல் இருப்பதற்காக(வும்)"}, {"w": 2, "t": "grieve"}, {"w": 3, "t": "உங்களுக்கு தவறி விட்டதற்காக"}, {"w": 4, "t": "what"}, {"w": 5, "t": "has escaped you"}, {"w": 6, "t": "நீங்கள் பெருமைப்படாமல் இருப்பதற்காகவும்"}, {"w": 7, "t": "exult"}, {"w": 8, "t": "அவன் உங்களுக்கு கொடுத்ததைக் கொண்டு/அல்லாஹ்"}, {"w": 9, "t": "He has given you"}, {"w": 10, "t": "And Allah"}, {"w": 11, "t": "நேசிக்க மாட்டான்"}, {"w": 12, "t": "love"}, {"w": 13, "t": "எல்லோரையும்"}, {"w": 14, "t": "அகம்பாவக்காரர்கள்"}, {"w": 15, "t": "பெருமையடிப்பவர்கள்"}, {"w": 16, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "கருமித்தனம் காட்டுகிறார்கள்"}, {"w": 3, "t": "இன்னும் ஏவுகிறார்கள்"}, {"w": 4, "t": "மக்களுக்கு"}, {"w": 5, "t": "கருமித்தனத்தை"}, {"w": 6, "t": "யார்"}, {"w": 7, "t": "விலகுவாரோ"}, {"w": 8, "