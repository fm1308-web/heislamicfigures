{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அணிவகுப்பவர்கள் மீது சத்தியமாக!"}, {"w": 2, "t": "அணி அணியாக"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "விரட்டுகின்றவர்கள் மீது சத்தியமாக!"}, {"w": 2, "t": "(கடுமையாக) விரட்டுதல்"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "ஓதுபவர்கள் மீது சத்தியமாக!"}, {"w": 2, "t": "வேதத்தை"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உங்கள் கடவுள்"}, {"w": 3, "t": "ஒருவன்தான்"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இறைவன்"}, {"w": 2, "t": "வானங்கள்/இன்னும் பூமி"}, {"w": 3, "t": "and the earth"}, {"w": 4, "t": "இன்னும் அவை இரண்டுக்கும் இடையில் உள்ளவற்றின்"}, {"w": 5, "t": "(is) between both of them"}, {"w": 6, "t": "இன்னும் நிர்வகிப்பவன்"}, {"w": 7, "t": "அவன் சூரியன் உதிக்கும் இடங்களையும்"}, {"w": 8, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அலங்கரித்துள்ளோம்"}, {"w": 3, "t": "வானத்தை"}, {"w": 4, "t": "சமீபமான(து)"}, {"w": 5, "t": "அலங்காரத்தால்"}, {"w": 6, "t": "நட்சத்திரங்களின்"}, {"w": 7, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "பாதுகாப்பதற்காகவும்"}, {"w": 2, "t": "எல்லா ஷைத்தான்களிடமிருந்து"}, {"w": 3, "t": "every"}, {"w": 4, "t": "devil"}, {"w": 5, "t": "அடங்காத"}, {"w": 6, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவர்களால் செவியுற முடியாது"}, {"w": 2, "t": "they may listen"}, {"w": 3, "t": "கூட்டத்தினரின் பக்கம்"}, {"w": 4, "t": "the assembly"}, {"w": 5, "t": "மிக உயர்ந்த"}, {"w": 6, "t": "இன்னும் எறியப்படுவார்கள்"}, {"w": 7, "t": "இருந்தும்"}, {"w": 8, "t": "எல்லா"}, {"w": 9, "t": "பக்கங்களில்"}, {"w": 10, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "தடுக்கப்படுவதற்காக"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "வேதனை"}, {"w": 4, "t": "நிரந்தரமான"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "எனினும்"}, {"w": 2, "t": "யார்"}, {"w": 3, "t": "திருடினான்"}, {"w": 4, "t": "திருட்டுத்தனமாக"}, {"w": 5, "t": "அவரை பின்தொடரும்"}, {"w": 6, "t": "நெருப்புக் கங்கு"}, {"w": 7, "t": "எரிக்கின்ற"}, {"w": 8, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "அவர்களிடம் விளக்கம் கேட்பீராக!"}, {"w": 2, "t": "?/அவர்கள்"}, {"w": 3, "t": "பலமிக்கவர்கள்"}, {"w": 4, "t": "படைப்பால்"}, {"w": 5, "t": "அல்லது"}, {"w": 6, "t": "எவர்கள்/படைத்தோம்"}, {"w": 7, "t": "We have created"}, {"w": 8, "t": "நிச்சயமாக நாம்"}, {"w": 9, "t": "அவர்களை படைத்தோம்"}, {"w": 10, "t": "மண்ணிலிருந்து"}, {"w": 11, "t": "a clay"}, {"w": 12, "t": "பிசுபிசுப்பான"}, {"w": 13, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "நீர் ஆச்சரியப்பட்டீர்"}, {"w": 3, "t": "அவர்கள் பரிகாசிக்கின்றனர்"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அவர்களுக்கு அறிவுரை கூறப்பட்டால்"}, {"w": 2, "t": "they are reminded"}, {"w": 3, "t": "அறிவுரை பெறமாட்டார்கள்"}, {"w": 4, "t": "they receive admonition"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அவர்கள் பார்த்தால்"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "ஓர் அத்தாட்சியை"}, {"w": 4, "t": "பரிகாசம் செய்கிறார்கள்"}, {"w": 5, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "கூறுகின்றனர்"}, {"w": 2, "t": "இது இல்லை"}, {"w": 3, "t": "(is) this"}, {"w": 4, "t": "சூனியமே தவிர"}, {"w": 5, "t": "a magic"}, {"w": 6, "t": "தெளிவான"}, {"w": 7, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "?/நாங்கள் இறந்து விட்டால்"}, {"w": 2, "t": "we are dead"}, {"w": 3, "t": "மண்ணாக(வும்) மாறிவிட்டால்"}, {"w": 4, "t": "dust"}, {"w": 5, "t": "எலும்புகளாகவும்"}, {"w": 6, "t": "?/நிச்சயமாக நாங்கள்"}, {"w": 7, "t": "எழுப்பப்படுவோம்"}, {"w": 8, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இன்னும் எங்கள் முன்னோர்களுமா?"}, {"w": 2, "t": "முந்திய"}, {"w": 3, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "ஆம்"}, {"w": 3, "t": "நீங்கள்"}, {"w": 4, "t": "மிகவும் சிறுமைப்பட்டவர்களாக"}, {"w": 5, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அதுவெல்லாம்"}, {"w": 2, "t": "it"}, {"w": 3, "t": "பலமான சப்தம்தான்"}, {"w": 4, "t": "ஒரே ஒரு"}, {"w": 5, "t": "அப்போது அவர்கள் பார்ப்பார்கள்"}, {"w": 6, "t": "They"}, {"w": 7, "t": "will see"}, {"w": 8, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "எங்கள் நாசமே!"}, {"w": 3, "t": "இதுதான்/நாள்"}, {"w": 4, "t": "(is the) Day"}, {"w": 5, "t": "கூலி கொடுக்கப்படும்"}, {"w": 6, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "இதுதான்"}, {"w": 2, "t": "நாள்"}, {"w": 3, "t": "தீர்ப்பு"}, {"w": 4, "t": "எதை/நீங்கள் இருந்தீர்கள்"}, {"w": 5, "t": "you used to"}, {"w": 6, "t": "இதை"}, {"w": 7, "t": "பொய்ப்பிப்பவர்களாக"}, {"w": 8, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "ஒன்று திரட்டுங்கள்!"}, {"w": 2, "t": "அநியாயம் செய்தவர்களை"}, {"w": 3, "t": "wronged"}, {"w": 4, "t": "அவர்களின் இனத்தவர்களையும்"}, {"w": 5, "t": "இன்னும் அவர்கள் வணங்கி வந்தவர்களையும்"}, {"w": 6, "t": "they used (to)"}, {"w": 7, "t": "worship"}, {"w": 8, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அல்லாஹ்வையன்றி"}, {"w": 2, "t": "Besides"}, {"w": 3, "t": "Allah"}, {"w": 4, "t": "வழிகாட்டுங்கள் அவர்களுக்கு"}, {"w": 5, "t": "பாதைக்கு"}, {"w": 6, "t": "(the) Path"}, {"w": 7, "t": "நரகத்தின்"}, {"w": 8, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "நிறுத்துங்கள்! அவர்களை"}, {"w": 2, "t": "நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "விசாரிக்கப்படுவார்கள்"}, {"w": 4, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "என்ன நேர்ந்தது?"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "நீங்கள் உங்களுக்குள் உதவிக்கொள்ளவில்லை"}, {"w": 4, "t": "you help one another"}, {"w": 5, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "மாறாக அவர்கள்"}, {"w": 2, "t": "they"}, {"w": 3, "t": "இன்று"}, {"w": 4, "t": "முற்றிலும் கீழ்ப்படிந்து விடுவார்கள்"}, {"w": 5, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "முன்னோக்கி(னர்)"}, {"w": 2, "t": "அவர்களில் சிலர்"}, {"w": 3, "t": "சிலரை"}, {"w": 4, "t": "others"}, {"w": 5, "t": "விசாரித்துக் கொள்வார்கள்"}, {"w": 6, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "நிச்சயமாக நீங்கள்"}, {"w": 3, "t": "இருந்தீர்கள்"}, {"w": 4, "t": "எங்களிடம் வருபவர்களாக"}, {"w": 5, "t": "நன்மையை விட்டுத் தடுக்க"}, {"w": 6, "t": "the right"}, {"w": 7, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அவர்கள் கூறுவார்கள்"}, {"w": 2, "t": "மாறாக/நீங்கள் இருக்கவில்லை"}, {"w": 3, "t": "not"}, {"w": 4, "t": "you were"}, {"w": 5, "t": "நம்பிக்கையாளர்களாக"}, {"w": 6, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "இருக்கவில்லை"}, {"w": 2, "t": "was"}, {"w": 3, "t": "எங்களுக்கு"}, {"w": 4, "t": "உங்கள் மீது"}, {"w": 5, "t": "எவ்வித அதிகாரமும்"}, {"w": 6, "t": "authority"}, {"w": 7, "t": "மாறாக நீங்கள் இருந்தீர்கள்"}, {"w": 8, "t": "you were"}, {"w": 9, "t": "மக்களாக"}, {"w": 10, "t": "எல்லை மீறுகின்ற(வர்கள்)"}, {"w": 11, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "ஆகவே, உறுதியாகிவிட்டது"}, {"w": 2, "t": "நம் மீது"}, {"w": 3, "t": "வாக்கு"}, {"w": 4, "t": "நமது இறைவனுடைய"}, {"w": 5, "t": "நிச்சயமாக நாம்"}, {"w": 6, "t": "சுவைப்பவர்கள்தான்"}, {"w": 7, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "ஆக, நாங்கள் உங்களை வழி கெடுத்தோம்"}, {"w": 2, "t": "நிச்சயமாக நாங்கள் இருந்தோம்"}, {"w": 3, "t": "were"}, {"w": 4, "t": "வழி கெட்டவர்களாகவே"}, {"w": 5, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "வேதனையில்"}, {"w": 4, "t": "the punishment"}, {"w": 5, "t": "கூட்டாகுவார்கள்"}, {"w": 6, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இப்படித்தான்"}, {"w": 3, "t": "நடந்து கொள்வோம்"}, {"w": 4, "t": "குற்றவாளிகளுடன்"}, {"w": 5, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "இருந்தனர்"}, {"w": 3, "t": "கூறப்பட்டால்"}, {"w": 4, "t": "it was said"}, {"w": 5, "t": "அவர்களுக்கு"}, {"w": 6, "t": "அறவே இல்லை"}, {"w": 7, "t": "வணக்கத்திற்குரியவன்"}, {"w": 8, "t": "அல்லாஹ்வைத் தவிர"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "பெருமை அடிப்பவர்களாக"}, {"w": 11, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "கூறுகின்றனர்"}, {"w": 2, "t": "?/நிச்சயமாக நாங்கள்"}, {"w": 3, "t": "விட்டுவிடுவோம்"}, {"w": 4, "t": "எங்கள் தெய்வங்களை"}, {"w": 5, "t": "ஒரு கவிஞருக்காக"}, {"w": 6, "t": "பைத்தியக்காரரான"}, {"w": 7, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "மாறாக அவர் சத்தியத்தைக் கொண்டு வந்தார்"}, {"w": 2, "t": "he has brought"}, {"w": 3, "t": "the truth"}, {"w": 4, "t": "இன்னும் உண்மைப்படுத்தினார்"}, {"w": 5, "t": "தூதர்களை"}, {"w": 6, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "நிச்சயமாக நீங்கள்"}, {"w": 2, "t": "சுவைப்பீர்கள்"}, {"w": 3, "t": "வேதனையை"}, {"w": 4, "t": "வலிதரும்"}, {"w": 5, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "நீங்கள் கூலி கொடுக்கப்படமாட்டீர்கள்"}, {"w": 2, "t": "you will be recompensed"}, {"w": 3, "t": "அன்றி"}, {"w": 4, "t": "நீங்கள் செய்து வந்ததற்கே"}, {"w": 5, "t": "you used to"}, {"w": 6, "t": "do"}, {"w": 7, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "அடியார்களை"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "பரிசுத்தமான"}, {"w": 5, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "அவர்களுக்கு உண்டு"}, {"w": 2, "t": "உணவு"}, {"w": 3, "t": "அறியப்பட்ட"}, {"w": 4, "t": "determined"}, {"w": 5, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "பழங்கள்"}, {"w": 2, "t": "இன்னும் அவர்கள்"}, {"w": 3, "t": "கண்ணியப்படுத்தப்படுவார்கள்"}, {"w": 4, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "சொர்க்கங்களில்"}, {"w": 2, "t": "Gardens"}, {"w": 3, "t": "இன்பமிகு"}, {"w": 4, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "கட்டில்கள் மீது"}, {"w": 2, "t": "thrones"}, {"w": 3, "t": "ஒருவரை ஒருவர் பார்த்தவர்களாக"}, {"w": 4, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "சுற்றி வரப்படும்"}, {"w": 2, "t": "அவர்களை"}, {"w": 3, "t": "மதுவினால் நிரம்பிய கிண்ணங்களுடன்"}, {"w": 4, "t": "from"}, {"w": 5, "t": "a flowing spring"}, {"w": 6, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "வெள்ளைநிற"}, {"w": 2, "t": "மிக இன்பமான"}, {"w": 3, "t": "குடிப்பவர்களுக்கு"}, {"w": 4, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "அதில் இருக்காது"}, {"w": 2, "t": "in it"}, {"w": 3, "t": "போதை(யும்)"}, {"w": 4, "t": "அவர்கள் அதனால் மயக்கமுறவுமாட்டார்கள்"}, {"w": 5, "t": "they"}, {"w": 6, "t": "from it"}, {"w": 7, "t": "will be intoxicated"}, {"w": 8, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "அவர்களிடம்"}, {"w": 2, "t": "பார்வைகளை"}, {"w": 3, "t": "தாழ்த்திய"}, {"w": 4, "t": "கண்ணழகிகள்"}, {"w": 5, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அவர்கள் போன்று இருப்பார்கள்"}, {"w": 2, "t": "முட்டையைப்போன்று"}, {"w": 3, "t": "பாதுகாக்கப்பட்ட(து)"}, {"w": 4, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "முன்னோக்குவார்(கள்)"}, {"w": 2, "t": "அவர்களில் சிலர்"}, {"w": 3, "t": "சிலரை"}, {"w": 4, "t": "others"}, {"w": 5, "t": "விசாரிப்பார்கள்"}, {"w": 6, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "கூறுவார்"}, {"w": 2, "t": "கூறக்கூடிய ஒருவர்"}, {"w": 3, "t": "அவர்களில்"}, {"w": 4, "t": "நிச்சயமாக"}, {"w": 5, "t": "இருந்தான்"}, {"w": 6, "t": "எனக்கு"}, {"w": 7, "t": "ஒரு நண்பன்"}, {"w": 8, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "கூறுவான்"}, {"w": 2, "t": "நிச்சயமாக நீ இருக்கின்றாயா"}, {"w": 3, "t": "உண்மைப்படுத்துபவர்களில்"}, {"w": 4, "t": "those who believe"}, {"w": 5, "t": "(52)"}]}, {"ayah": 53, "words": [{"w": 1, "t": "?/நாங்கள் இறந்து விட்டால்"}, {"w": 2, "t": "we have died"}, {"w": 3, "t": "இன்னும் மாறிவிட்டால்"}, {"w": 4, "t": "மண்ணாக(வும்)"}, {"w": 5, "t": "எலும்புகளாகவும்"}, {"w": 6, "t": "?/நிச்சயமாக நாம்"}, {"w": 7, "t": "கூலி கொடுக்கப்படுவோம்"}, {"w": 8, "t": "(53)"}]}, {"ayah": 54, "words": [{"w": 1, "t": "அவர் கூறுவார்"}, {"w": 2, "t": "?/நீங்கள்"}, {"w": 3, "t": "you"}, {"w": 4, "t": "எட்டிப்பார்ப்பீர்களா"}, {"w": 5, "t": "(54)"}]}, {"ayah": 55, "words": [{"w": 1, "t": "அவர்எட்டிப்பார்ப்பார்"}, {"w": 2, "t": "அவனை பார்ப்பார்"}, {"w": 3, "t": "நடுவில்"}, {"w": 4, "t": "(the) midst"}, {"w": 5, "t": "நரகத்தின்"}, {"w": 6, "t": "(55)"}]}, {"ayah": 56, "words": [{"w": 1, "t": "அவர் கூறுவார்"}, {"w": 2, "t": "அல்லாஹ்வின் மீது சத்தியமாக"}, {"w": 3, "t": "நிச்சயமாக நீ நெருக்கமாக இருந்தாய்"}, {"w": 4, "t": "you almost"}, {"w": 5, "t": "என்னை நாசமாக்குவதற்கு"}, {"w": 6, "t": "(56)"}]}, {"ayah": 57, "words": [{"w": 1, "t": "அருள் இல்லாதிருந்தால்"}, {"w": 2, "t": "(for the) Grace"}, {"w": 3, "t": "என் இறைவனின்"}, {"w": 4, "t": "நானும் ஆகி இருப்பேன்"}, {"w": 5, "t": "ஆஜர்படுத்தப்படுபவர்களில்"}, {"w": 6, "t": "those brought"}, {"w": 7, "t": "(57)"}]}, {"ayah": 58, "words": [{"w": 1, "t": "நாங்கள் இல்லைதானே?"}, {"w": 2, "t": "we"}, {"w": 3, "t": "மரணிப்பவர்களாக"}, {"w": 4, "t": "(58)"}]}, {"ayah": 59, "words": [{"w": 1, "t": "எங்கள் மரணத்தை தவிர"}, {"w": 2, "t": "our death"}, {"w": 3, "t": "முதல்"}, {"w": 4, "t": "இன்னும் நாங்கள் இல்லை"}, {"w": 5, "t": "we"}, {"w": 6, "t": "வேதனை செய்யப்படுபவர்களாக"}, {"w": 7, "t": "(59)"}]}, {"ayah": 60, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இதுதான்"}, {"w": 3, "t": "surely"}, {"w": 4, "t": "வெற்றியாகும்"}, {"w": 5, "t": "மகத்தான"}, {"w": 6, "t": "(60)"}]}, {"ayah": 61, "words": [{"w": 1, "t": "போன்றதற்காக"}, {"w": 2, "t": "இது"}, {"w": 3, "t": "அமல் செய்யட்டும்."}, {"w": 4, "t": "அமல்செய்பவர்கள்"}, {"w": 5, "t": "(61)"}]}, {"ayah": 62, "words": [{"w": 1, "t": "அது மிகச் சிறந்ததா"}, {"w": 2, "t": "better"}, {"w": 3, "t": "விருந்தோம்பலால்"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "மரமா"}, {"w": 6, "t": "ஸக்கூம்"}, {"w": 7, "t": "(62)"}]}, {"ayah": 63, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "அதை ஆக்கினோம்"}, {"w": 3, "t": "ஒரு சோதனையாக"}, {"w": 4, "t": "இணைவைப்ப வர்களுக்கு"}, {"w": 5, "t": "(63)"}]}, {"ayah": 64, "words": [{"w": 1, "t": "நிச்சயமாக அது"}, {"w": 2, "t": "ஒரு மரமாகும்"}, {"w": 3, "t": "முளைக்கின்ற(து)"}, {"w": 4, "t": "நரகத்தின் அடியில்"}, {"w": 5, "t": "(the) bottom"}, {"w": 6, "t": "(of) the Hellfire"}, {"w": 7, "t": "(64)"}]}, {"ayah": 65, "words": [{"w": 1, "t": "அதன் கனிகள்"}, {"w": 2, "t": "போல் இருக்கும்"}, {"w": 3, "t": "தலைகளை"}, {"w": 4, "t": "ஷைத்தான்களின்"}, {"w": 5, "t": "(65)"}]}, {"ayah": 66, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "சாப்பிடுவார்கள்"}, {"w": 3, "t": "அதிலிருந்து"}, {"w": 4, "t": "இன்னும் நிரப்புவார்கள்"}, {"w": 5, "t": "அதிலிருந்து"}, {"w": 6, "t": "வயிறுகளை"}, {"w": 7, "t": "(66)"}]}, {"ayah": 67, "words": [{"w": 1, "t": "பின்னர்"}, {"w": 2, "t": "நிச்சயமாக"}, {"w": 3, "t": "அவர்களுக்கு"}, {"w": 4, "t": "அதற்கு மேல்"}, {"w": 5, "t": "கலக்கப்படும்"}, {"w": 6, "t": "கொதி நீரில் இருந்து"}, {"w": 7, "t": "boiling water"}, {"w": 8, "t": "(67)"}]}, {"ayah": 68, "words": [{"w": 1, "t": "பிறகு நிச்சயமாக"}, {"w": 2, "t": "indeed"}, {"w": 3, "t": "அவர்களின் மீளுமிடம்"}, {"w": 4, "t": "நரக நெருப்பின் பக்கம்தான்"}, {"w": 5, "t": "the Hellfire"}, {"w": 6, "t": "(68)"}]}, {"ayah": 69, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "பெற்றார்கள்"}, {"w": 3, "t": "தங்கள் மூதாதைகளை"}, {"w": 4, "t": "வழிகெட்டவர்களாக"}, {"w": 5, "t": "(69)"}]}, {"ayah": 70, "words": [{"w": 1, "t": "இவர்கள்"}, {"w": 2, "t": "அவர்களின் அடிச்சுவடுகளில்"}, {"w": 3, "t": "their footsteps"}, {"w": 4, "t": "விரைகின்றார்கள்"}, {"w": 5, "t": "(70)"}]}, {"ayah": 71, "words": [{"w": 1, "t": "திட்டமாகவழி கெட்டுள்ளனர்"}, {"w": 2, "t": "went astray"}, {"w": 3, "t": "இவர்களுக்கு முன்னர்"}, {"w": 4, "t": "அதிகமானவர்கள்"}, {"w": 5, "t": "முன்னோரில்"}, {"w": 6, "t": "(71)"}]}, {"ayah": 72, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நாம் அனுப்பினோம்"}, {"w": 3, "t": "அவர்களில்"}, {"w": 4, "t": "அச்சமூட்டி எச்சரிப்பவர்களை"}, {"w": 5, "t": "(72)"}]}, {"ayah": 73, "words": [{"w": 1, "t": "ஆகவே நீர் பார்ப்பீராக!"}, {"w": 2, "t": "எப்படி இருந்தது"}, {"w": 3, "t": "was"}, {"w": 4, "t": "முடிவு"}, {"w": 5, "t": "எச்சரிக்கப்பட்டவர்களின்"}, {"w": 6, "t": "(73)"}]}, {"ayah": 74, "words": [{"w": 1, "t": "எனினும்"}, {"w": 2, "t": "அடியார்கள்"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "பரிசுத்தமான(வர்கள்)"}, {"w": 5, "t": "(74)"}]}, {"ayah": 75, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "நம்மை அழைத்தார்"}, {"w": 3, "t": "நூஹ்"}, {"w": 4, "t": "நாம் மிகச் சிறந்தவர்கள்"}, {"w": 5, "t": "பதில் தருபவர்களில்"}, {"w": 6, "t": "(75)"}]}, {"ayah": 76, "words": [{"w": 1, "t": "அவரை(யும்) பாதுகாத்தோம்"}, {"w": 2, "t": "அவரது குடும்பத்தாரையும்"}, {"w": 3, "t": "துக்கத்தில் இருந்து"}, {"w": 4, "t": "the distress"}, {"w": 5, "t": "மிகப் பெரிய"}, {"w": 6, "t": "(76)"}]}, {"ayah": 77, "words": [{"w": 1, "t": "நாம் ஆக்கினோம்"}, {"w": 2, "t": "அவரது சந்ததிகளைத்தான்"}, {"w": 3, "t": "[they]"}, {"w": 4, "t": "மீதமானவர்களாக"}, {"w": 5, "t": "(77)"}]}, {"ayah": 78, "words": [{"w": 1, "t": "நற்பெயரை நாம் ஏற்படுத்தினோம்"}, {"w": 2, "t": "அவரைப் பற்றி"}, {"w": 3, "t": "பின் வருபவர்களில்"}, {"w": 4, "t": "the later generations"}, {"w": 5, "t": "(78)"}]}, {"ayah": 79, "words": [{"w": 1, "t": "பாதுகாப்பு உண்டாகட்டும்"}, {"w": 2, "t": "நூஹூக்கு"}, {"w": 3, "t": "Nuh"}, {"w": 4, "t": "உலகத்தார்களில்"}, {"w": 5, "t": "the worlds"}, {"w": 6, "t": "(79)"}]}, {"ayah": 80, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இவ்வாறுதான்"}, {"w": 3, "t": "கூலி கொடுப்போம்"}, {"w": 4, "t": "நல்லவர்களுக்கு"}, {"w": 5, "t": "(80)"}]}, {"ayah": 81, "words": [{"w": 1, "t": "நிச்சயமாக அவர்"}, {"w": 2, "t": "நமது அடியார்களில்"}, {"w": 3, "t": "Our slaves"}, {"w": 4, "t": "நம்பிக்கையாளர்களான"}, {"w": 5, "t": "(81)"}]}, {"ayah": 82, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம் மூழ்கடித்தோம்"}, {"w": 3, "t": "மற்றவர்களை"}, {"w": 4, "t": "(82)"}]}, {"ayah": 83, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "அவரது கொள்கையை சேர்ந்தவர்களில்"}, {"w": 3, "t": "his kind"}, {"w": 4, "t": "இப்ராஹீம்"}, {"w": 5, "t": "(83)"}]}, {"ayah": 84, "words": [{"w": 1, "t": "அவர் வந்த சமயத்தை நினைவு கூர்வீராக!"}, {"w": 2, "t": "he came"}, {"w": 3, "t": "தனது இறைவனிடம்"}, {"w": 4, "t": "உள்ளத்துடன்"}, {"w": 5, "t": "ஈடேற்றம் பெற்ற"}, {"w": 6, "t": "(84)"}]}, {"ayah": 85, "words": [{"w": 1, "t": "அவர் கூறிய சமயத்தை நினைவு கூர்வீராக!"}, {"w": 2, "t": "he said"}, {"w": 3, "t": "தனது தந்தைக்கு(ம்)"}, {"w": 4, "t": "தனது மக்களுக்கும்"}, {"w": 5, "t": "எதை"}, {"w": 6, "t": "நீங்கள் வணங்குகிறீர்கள்"}, {"w": 7, "t": "(85)"}]}, {"ayah": 86, "words": [{"w": 1, "t": "பல பொய்யான தெய்வங்களையா"}, {"w": 2, "t": "அல்லாஹ்வை அன்றி"}, {"w": 3, "t": "other than"}, {"w": 4, "t": "நீங்கள் நாடுகிறீர்கள்"}, {"w": 5, "t": "(that) you desire"}, {"w": 6, "t": "(86)"}]}, {"ayah": 87, "words": [{"w": 1, "t": "உங்கள் எண்ணம் என்ன?"}, {"w": 2, "t": "(do) you think"}, {"w": 3, "t": "இறைவனைப் பற்றி"}, {"w": 4, "t": "அகிலங்களின்"}, {"w": 5, "t": "(87)"}]}, {"ayah": 88, "words": [{"w": 1, "t": "அவர் பார்த்தார்"}, {"w": 2, "t": "ஒரு பார்வை"}, {"w": 3, "t": "நட்சத்திரங்களின் பக்கம்"}, {"w": 4, "t": "the stars"}, {"w": 5, "t": "(88)"}]}, {"ayah": 89, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "ஒரு நோயாளி"}, {"w": 4, "t": "(89)"}]}, {"ayah": 90, "words": [{"w": 1, "t": "ஆகவே, அவர்கள் விலகிச் சென்றனர்"}, {"w": 2, "t": "அவரை விட்டு"}, {"w": 3, "t": "முகம் திருப்பியவர்களாக"}, {"w": 4, "t": "(90)"}]}, {"ayah": 91, "words": [{"w": 1, "t": "ஆக, அவர் விரைந்தார்"}, {"w": 2, "t": "அவர்களின் தெய்வங்கள் பக்கம்"}, {"w": 3, "t": "their gods"}, {"w": 4, "t": "கூறினார்"}, {"w": 5, "t": "நீங்கள் சாப்பிட மாட்டீர்களா?"}, {"w": 6, "t": "you eat"}, {"w": 7, "t": "(91)"}]}, {"ayah": 92, "words": [{"w": 1, "t": "உங்களுக்கு என்ன ஏற்பட்டது?"}, {"w": 2, "t": "for you"}, {"w": 3, "t": "நீங்கள் ஏன் பேசுவதில்லை"}, {"w": 4, "t": "you speak"}, {"w": 5, "t": "(92)"}]}, {"ayah": 93, "words": [{"w": 1, "t": "பாய்ந்தார்"}, {"w": 2, "t": "அவற்றின் மீது"}, {"w": 3, "t": "அடிப்பதற்காக"}, {"w": 4, "t": "வலக்கரத்தால்"}, {"w": 5, "t": "(93)"}]}, {"ayah": 94, "words": [{"w": 1, "t": "அவர்கள் வந்தனர்"}, {"w": 2, "t": "அவரை நோக்கி"}, {"w": 3, "t": "விரைந்தவர்களாக"}, {"w": 4, "t": "(94)"}]}, {"ayah": 95, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "நீங்கள் வணங்குகிறீர்களா"}, {"w": 3, "t": "நீங்கள் செதுக்குகின்றவற்றை"}, {"w": 4, "t": "you carve"}, {"w": 5, "t": "(95)"}]}, {"ayah": 96, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "உங்களை(யும்) படைத்தான்"}, {"w": 3, "t": "நீங்கள் செய்வதையும்"}, {"w": 4, "t": "you make"}, {"w": 5, "t": "(96)"}]}, {"ayah": 97, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "கட்டுங்கள்"}, {"w": 3, "t": "அவருக்கு"}, {"w": 4, "t": "ஒரு கட்டிடத்தை"}, {"w": 5, "t": "அவரை எறிந்து விடுங்கள்"}, {"w": 6, "t": "அந்த நெருப்பில்"}, {"w": 7, "t": "the blazing Fire"}, {"w": 8, "t": "(97)"}]}, {"ayah": 98, "words": [{"w": 1, "t": "அவர்கள் நாடினர்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "ஒரு சூழ்ச்சியை"}, {"w": 4, "t": "நாம் அவர்களை(த்தான்) ஆக்கினோம்"}, {"w": 5, "t": "மிகத் தாழ்ந்தவர்களாக"}, {"w": 6, "t": "(98)"}]}, {"ayah": 99, "words": [{"w": 1, "t": "அவர் கூறினார்"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "செல்கிறேன்"}, {"w": 4, "t": "என் இறைவனின் பக்கம்"}, {"w": 5, "t": "my Lord"}, {"w": 6, "t": "அவன் எனக்கு நேர்வழி காட்டுவான்"}, {"w": 7, "t": "(99)"}]}, {"ayah": 100, "words": [{"w": 1, "t": "என் இறைவா"}, {"w": 2, "t": "எனக்கு தா!"}, {"w": 3, "t": "me"}, {"w": 4, "t": "நல்லவர்களில் (ஒருவராக இருக்கும் ஒரு குழந்தையை)"}, {"w": 5, "t": "the righteous"}, {"w": 6, "t": "(100)"}]}, {"ayah": 101, "words": [{"w": 1, "t": "ஆகவே, அவருக்கு நற்செய்தி கூறினோம்"}, {"w": 2, "t": "ஒரு குழந்தையைக்கொண்டு"}, {"w": 3, "t": "மிக சகிப்பாளரான"}, {"w": 4, "t": "(101)"}]}, {"ayah": 102, "words": [{"w": 1, "t": "பருவத்தை அடைந்தபோது"}, {"w": 2, "t": "he reached"}, {"w": 3, "t": "அவருடன்"}, {"w": 4, "t": "உழைக்கின்ற"}, {"w": 5, "t": "அவர் கூறினார்"}, {"w": 6, "t": "என் மகனே!"}, {"w": 7, "t": "நிச்சயமாக நான்"}, {"w": 8, "t": "பார்க்கிறேன்"}, {"w": 9, "t": "கனவில்"}, {"w": 10, "t": "the dream"}, {"w": 11, "t": "நிச்சயமாக நான்"}, {"w": 12, "t": "உன்னை பலியிடுவதாக"}, {"w": 13, "t": "ஆகவே, நீ யோசி"}, {"w": 14, "t": "என்ன"}, {"w": 15, "t": "நீ கருதுகிறாய்"}, {"w": 16, "t": "அவர் கூறினார்"}, {"w": 17, "t": "என் தந்தையே!"}, {"w": 18, "t": "நீர் செய்வீராக!"}, {"w": 19, "t": "உமக்கு ஏவப்படுவதை"}, {"w": 20, "t": "you are commanded"}, {"w": 21, "t": "என்னை நீர் காண்பீர்"}, {"w": 22, "t": "நாடினால்"}, {"w": 23, "t": "Allah wills"}, {"w": 24, "t": "அல்லாஹ்"}, {"w": 25, "t": "பொறுமையாளர்களில் (ஒருவராக)"}, {"w": 26, "t": "the patient ones"}, {"w": 27, "t": "(102)"}]}, {"ayah": 103, "words": [{"w": 1, "t": "அப்போது அவர்கள் இருவரும் முற்றிலும் பணிந்தனர்"}, {"w": 2, "t": "both of them had submitted"}, {"w": 3, "t": "அவர் அவரை கீழே சாய்த்தார்"}, {"w": 4, "t": "கன்னத்தின் மீது"}, {"w": 5, "t": "(103)"}]}, {"ayah": 104, "words": [{"w": 1, "t": "நாம் அவரை அழைத்தோம்"}, {"w": 2, "t": "இப்ராஹீமே! என்று"}, {"w": 3, "t": "O Ibrahim"}, {"w": 4, "t": "(104)"}]}, {"ayah": 105, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "உண்மைப்படுத்தினீர்"}, {"w": 3, "t": "கனவை"}, {"w": 4, "t": "நிச்சயமாக நாம்"}, {"w": 5, "t": "இவ்வாறுதான்"}, {"w": 6, "t": "கூலி கொடுப்போம்"}, {"w": 7, "t": "நல்லவர்களுக்கு"}, {"w": 8, "t": "(105)"}]}, {"ayah": 106, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "இதுதான்"}, {"w": 3, "t": "(was) surely [it]"}, {"w": 4, "t": "சோதனையாகும்"}, {"w": 5, "t": "தெளிவான"}, {"w": 6, "t": "(106)"}]}, {"ayah": 107, "words": [{"w": 1, "t": "அவரை விடுதலை செய்தோம்"}, {"w": 2, "t": "ஒரு பலிப் பிராணியைக்கொண்டு"}, {"w": 3, "t": "மகத்தான"}, {"w": 4, "t": "(107)"}]}, {"ayah": 108, "words": [{"w": 1, "t": "அவரைப் பற்றி அழகிய பெயரை ஏற்படுத்தினோம்"}, {"w": 2, "t": "for him"}, {"w": 3, "t": "பின்னோரில்"}, {"w": 4, "t": "the later generations"}, {"w": 5, "t": "(108)"}]}, {"ayah": 109, "words": [{"w": 1, "t": "ஈடேற்றம் உண்டாகட்டும்"}, {"w": 2, "t": "இப்றாஹீமுக்கு"}, {"w": 3, "t": "Ibrahim"}, {"w": 4, "t": "(109)"}]}, {"ayah": 110, "words": [{"w": 1, "t": "இப்படித்தான்"}, {"w": 2, "t": "நாம் கூலி கொடுப்போம்"}, {"w": 3, "t": "நல்லவர்களுக்கு"}, {"w": 4, "t": "(110)"}]}, {"ayah": 111, "words": [{"w": 1, "t": "நிச்சயமாக அவர்"}, {"w": 2, "t": "நமது அடியார்களில்"}, {"w": 3, "t": "Our slaves"}, {"w": 4, "t": "நம்பிக்கையாளர்களான"}, {"w": 5, "t": "(111)"}]}, {"ayah": 112, "words": [{"w": 1, "t": "நாம் அவருக்கு நற்செய்தி கூறினோம்"}, {"w": 2, "t": "இஸ்ஹாக்கைக் கொண்டு"}, {"w": 3, "t": "நபி(யாகவும்)"}, {"w": 4, "t": "நல்லவர்களில் (ஒருவராகவும்)"}, {"w": 5, "t": "the righteous"}, {"w": 6, "t": "(112)"}]}, {"ayah": 113, "words": [{"w": 1, "t": "அருள் வளம் புரிந்தோம்/அவருக்கு(ம்)"}, {"w": 2, "t": "him"}, {"w": 3, "t": "இஸ்ஹாக்கிற்கும்"}, {"w": 4, "t": "Isaac"}, {"w": 5, "t": "அவ்விருவரின் சந்ததியில்"}, {"w": 6, "t": "their offspring"}, {"w": 7, "t": "நல்லவரும்"}, {"w": 8, "t": "தீங்கிழைத்தவரும்"}, {"w": 9, "t": "தனக்கு"}, {"w": 10, "t": "தெளிவாக"}, {"w": 11, "t": "(113)"}]}, {"ayah": 114, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அருள்புரிந்தோம்"}, {"w": 3, "t": "மூஸாவிற்கு(ம்)"}, {"w": 4, "t": "Musa"}, {"w": 5, "t": "ஹாரூனுக்கு"}, {"w": 6, "t": "(114)"}]}, {"ayah": 115, "words": [{"w": 1, "t": "அவ்விருவரையு(ம்) பாதுகாத்தோம்"}, {"w": 2, "t": "அவ்விருவரின் மக்களையும்"}, {"w": 3, "t": "துக்கத்தில் இருந்து"}, {"w": 4, "t": "the distress"}, {"w": 5, "t": "பெரிய"}, {"w": 6, "t": "(115)"}]}, {"ayah": 116, "words": [{"w": 1, "t": "அவர்களுக்கு உதவினோம்"}, {"w": 2, "t": "ஆகவே, ஆனார்கள்"}, {"w": 3, "t": "அவர்கள்தான்"}, {"w": 4, "t": "வெற்றியாளர்களாக"}, {"w": 5, "t": "(116)"}]}, {"ayah": 117, "words": [{"w": 1, "t": "அவ்விருவருக்கும் கொடுத்தோம்"}, {"w": 2, "t": "வேதத்தை"}, {"w": 3, "t": "தெளிவான"}, {"w": 4, "t": "(117)"}]}, {"ayah": 118, "words": [{"w": 1, "t": "அவ்விருவரையும் நேர்வழி நடத்தினோம்"}, {"w": 2, "t": "பாதையில்"}, {"w": 3, "t": "நேரான"}, {"w": 4, "t": "(118)"}]}, {"ayah": 119, "words": [{"w": 1, "t": "நற்பெயரை ஏற்படுத்தினோம்"}, {"w": 2, "t": "அவ்விருவருக்கும்"}, {"w": 3, "t": "பின்னோரில்"}, {"w": 4, "t": "the later generations"}, {"w": 5, "t": "(119)"}]}, {"ayah": 120, "words": [{"w": 1, "t": "ஈடேற்றம் உண்டாகட்டும்"}, {"w": 2, "t": "மூஸாவிற்கும்"}, {"w": 3, "t": "Musa"}, {"w": 4, "t": "ஹாரூனுக்கும்"}, {"w": 5, "t": "(120)"}]}, {"ayah": 121, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இவ்வாறுதான்"}, {"w": 3, "t": "கூலி கொடுப்போம்"}, {"w": 4, "t": "நல்லவர்களுக்கு"}, {"w": 5, "t": "(121)"}]}, {"ayah": 122, "words": [{"w": 1, "t": "நிச்சயமாக அவ்விருவரும்"}, {"w": 2, "t": "நமது அடியார்களில் உள்ளவர்கள்"}, {"w": 3, "t": "Our slaves"}, {"w": 4, "t": "நம்பிக்கையாளர்களான"}, {"w": 5, "t": "(122)"}]}, {"ayah": 123, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக"}, {"w": 2, "t": "இல்யாஸ்"}, {"w": 3, "t": "தூதர்களில் உள்ளவர்தான்"}, {"w": 4, "t": "the Messengers"}, {"w": 5, "t": "(123)"}]}, {"ayah": 124, "words": [{"w": 1, "t": "அவர் கூறிய சமயத்தை"}, {"w": 2, "t": "he said"}, {"w": 3, "t": "தனது மக்களுக்கு"}, {"w": 4, "t": "நீங்கள் அஞ்சிக் கொள்ள மாட்டீர்களா?"}, {"w": 5, "t": "you fear"}, {"w": 6, "t": "(124)"}]}, {"ayah": 125, "words": [{"w": 1, "t": "நீங்கள் வணங்குகிறீர்களா?"}, {"w": 2, "t": "பஃலை"}, {"w": 3, "t": "விட்டுவிடுகிறீர்களா?"}, {"w": 4, "t": "மிக அழகியவனை"}, {"w": 5, "t": "படைப்பாளர்களில்"}, {"w": 6, "t": "(125)"}]}, {"ayah": 126, "words": [{"w": 1, "t": "அல்லாஹ்வை"}, {"w": 2, "t": "உங்கள் இறைவனான"}, {"w": 3, "t": "இன்னும் இறைவனுமான"}, {"w": 4, "t": "உங்கள் மூதாதைகளின்"}, {"w": 5, "t": "முன்னோர்களான"}, {"w": 6, "t": "(126)"}]}, {"ayah": 127, "words": [{"w": 1, "t": "அவரை பொய்ப்பித்தனர்"}, {"w": 2, "t": "ஆகவே நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "ஆஜர்படுத்தப்படுவார்கள்"}, {"w": 4, "t": "(127)"}]}, {"ayah": 128, "words": [{"w": 1, "t": "எனினும்"}, {"w": 2, "t": "அல்லாஹ்வின் அடியார்கள்"}, {"w": 3, "t": "(of) Allah"}, {"w": 4, "t": "பரிசுத்தமான"}, {"w": 5, "t": "(128)"}]}, {"ayah": 129, "words": [{"w": 1, "t": "நற்பெயரை ஏற்படுத்தினோம்"}, {"w": 2, "t": "அவருக்கு"}, {"w": 3, "t": "பின்னோரில்"}, {"w": 4, "t": "the later generations"}, {"w": 5, "t": "(129)"}]}, {"ayah": 130, "words": [{"w": 1, "t": "ஈடேற்றம் உண்டாகட்டும்"}, {"w": 2, "t": "இல்யாசுக்கு"}, {"w": 3, "t": "Elijah"}, {"w": 4, "t": "(130)"}]}, {"ayah": 131, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "இப்படித்தான்"}, {"w": 3, "t": "கூலி கொடுப்போம்"}, {"w": 4, "t": "நல்லவர்களுக்கு"}, {"w": 5, "t": "(131)"}]}, {"ayah": 132, "words": [{"w": 1, "t": "நிச்சயமாக அவர்"}, {"w": 2, "t": "நமது அடியார்களில்"}, {"w": 3, "t": "Our slaves"}, {"w": 4, "t": "நம்பிக்கையாளர்களான"}, {"w": 5, "t": "(132)"}]}, {"ayah": 133, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "லூத்"}, {"w": 3, "t": "தூதர்களில்"}, {"w": 4, "t": "the Messengers"}, {"w": 5, "t": "(133)"}]}, {"ayah": 134, "words": [{"w": 1, "t": "நாம் அவரை(யும்) பாதுகாத்த சமயத்தை நினைவு கூர்வீராக!"}, {"w": 2, "t": "We saved him"}, {"w": 3, "t": "அவரது குடும்பத்தாரையும்"}, {"w": 4, "t": "அனைவரையும்"}, {"w": 5, "t": "(134)"}]}, {"ayah": 135, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "ஒரு மூதாட்டியை"}, {"w": 3, "t": "தங்கி விடுபவர்களில் (தங்கிவிடுகின்ற)"}, {"w": 4, "t": "those who remained behind"}, {"w": 5, "t": "(135)"}]}, {"ayah": 136, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம் அழித்தோம்"}, {"w": 3, "t": "மற்றவர்களை"}, {"w": 4, "t": "(136)"}]}, {"ayah": 137, "words": [{"w": 1, "t": "நிச்சயமாக நீங்கள்"}, {"w": 2, "t": "கடந்து செல்கிறீர்கள்"}, {"w": 3, "t": "அவர்களை"}, {"w": 4, "t": "காலையிலும்"}, {"w": 5, "t": "(137)"}]}, {"ayah": 138, "words": [{"w": 1, "t": "இரவிலும்"}, {"w": 2, "t": "நீங்கள் சிந்தித்து புரிய மாட்டீர்களா?"}, {"w": 3, "t": "you use reason"}, {"w": 4, "t": "(138)"}]}, {"ayah": 139, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "யூனுஸ்"}, {"w": 3, "t": "தூதர்களில் உள்ளவர்தான்"}, {"w": 4, "t": "the Messengers"}, {"w": 5, "t": "(139)"}]}, {"ayah": 140, "words": [{"w": 1, "t": "அவர் ஓடிய சமயத்தை நினைவு கூர்வீராக"}, {"w": 2, "t": "he ran away"}, {"w": 3, "t": "கப்பலை நோக்கி"}, {"w": 4, "t": "the ship"}, {"w": 5, "t": "நிரம்பிய(து)"}, {"w": 6, "t": "(140)"}]}, {"ayah": 141, "words": [{"w": 1, "t": "குலுக்கிப் போட்டார்"}, {"w": 2, "t": "ஆகிவிட்டார்"}, {"w": 3, "t": "குலுக்கலில் பெயர்வந்தவர்களில்"}, {"w": 4, "t": "the losers"}, {"w": 5, "t": "(141)"}]}, {"ayah": 142, "words": [{"w": 1, "t": "அவரை விழுங்கியது"}, {"w": 2, "t": "திமிங்கிலம்"}, {"w": 3, "t": "அவர்"}, {"w": 4, "t": "பழிப்புக்குரியவர்"}, {"w": 5, "t": "(142)"}]}, {"ayah": 143, "words": [{"w": 1, "t": "நிச்சயமாக அவர் இருந்திருக்கவில்லை என்றால்"}, {"w": 2, "t": "that he"}, {"w": 3, "t": "was"}, {"w": 4, "t": "துதிப்பவர்களில்"}, {"w": 5, "t": "those who glorify"}, {"w": 6, "t": "(143)"}]}, {"ayah": 144, "words": [{"w": 1, "t": "தங்கி இருந்திருப்பார்"}, {"w": 2, "t": "அதனுடைய வயிற்றில்"}, {"w": 3, "t": "its belly"}, {"w": 4, "t": "நாள் வரை"}, {"w": 5, "t": "the Day"}, {"w": 6, "t": "எழுப்பப்படுகின்ற"}, {"w": 7, "t": "(144)"}]}, {"ayah": 145, "words": [{"w": 1, "t": "அவரை எறிந்தோம்"}, {"w": 2, "t": "பெருவெளியில்"}, {"w": 3, "t": "அவர்/நோயுற்றவராக இருந்தார்"}, {"w": 4, "t": "(was) ill"}, {"w": 5, "t": "(145)"}]}, {"ayah": 146, "words": [{"w": 1, "t": "முளைக்க வைத்தோம்"}, {"w": 2, "t": "அவருக்கு அருகில்"}, {"w": 3, "t": "ஒரு செடியை"}, {"w": 4, "t": "சுரைக்காய்"}, {"w": 5, "t": "gourd"}, {"w": 6, "t": "(146)"}]}, {"ayah": 147, "words": [{"w": 1, "t": "அவரைஅனுப்பினோம்"}, {"w": 2, "t": "ஒரு இலட்சம்"}, {"w": 3, "t": "a hundred"}, {"w": 4, "t": "thousand"}, {"w": 5, "t": "அல்லது"}, {"w": 6, "t": "அதிகமானவர்களுக்கு"}, {"w": 7, "t": "(147)"}]}, {"ayah": 148, "words": [{"w": 1, "t": "நம்பிக்கைகொண்டனர்"}, {"w": 2, "t": "ஆகவே, நாம் அவர்களுக்கு சுகமளித்தோம்"}, {"w": 3, "t": "ஒரு காலம் வரை"}, {"w": 4, "t": "a while"}, {"w": 5, "t": "(148)"}]}, {"ayah": 149, "words": [{"w": 1, "t": "ஆகவே, அவர்களிடம் கேட்பீராக!"}, {"w": 2, "t": "உமது இறைவனுக்கு"}, {"w": 3, "t": "பெண் பிள்ளைகளும்"}, {"w": 4, "t": "அவர்களுக்கு"}, {"w": 5, "t": "ஆண் பிள்ளைகளுமா"}, {"w": 6, "t": "(149)"}]}, {"ayah": 150, "words": [{"w": 1, "t": "?"}, {"w": 2, "t": "நாம் படைத்தோம்"}, {"w": 3, "t": "வானவர்களை"}, {"w": 4, "t": "பெண்களாகவா"}, {"w": 5, "t": "அவர்கள்"}, {"w": 6, "t": "பார்த்துக்கொண்டு இருந்தார்களா?"}, {"w": 7, "t": "(150)"}]}, {"ayah": 151, "words": [{"w": 1, "t": "அறிந்துகொள்ளுங்கள்!"}, {"w": 2, "t": "நிச்சயமாக அவர்கள்"}, {"w": 3, "t": "தங்களது பெரும் பொய்யில்"}, {"w": 4, "t": "their falsehood"}, {"w": 5, "t": "அவர்கள் கூறுகின்றனர்"}, {"w": 6, "t": "(151)"}]}, {"ayah": 152, "words": [{"w": 1, "t": "அல்லாஹ் குழந்தை பெற்றெடுத்தான்"}, {"w": 2, "t": "Allah has begotten"}, {"w": 3, "t": "நிச்சயமாக அவர்கள்"}, {"w": 4, "t": "பொய்யர்கள்"}, {"w": 5, "t": "(152)"}]}, {"ayah": 153, "words": [{"w": 1, "t": "அவன் தேர்தெடுத்துக் கொண்டானா?"}, {"w": 2, "t": "பெண் பிள்ளைகளை"}, {"w": 3, "t": "ஆண் பிள்ளைகளை விட"}, {"w": 4, "t": "sons"}, {"w": 5, "t": "(153)"}]}, {"ayah": 154, "words": [{"w": 1, "t": "உங்களுக்கு என்ன?"}, {"w": 2, "t": "What is with you"}, {"w": 3, "t": "எப்படி"}, {"w": 4, "t": "தீர்ப்பளிக்கிறீர்கள்"}, {"w": 5, "t": "(154)"}]}, {"ayah": 155, "words": [{"w": 1, "t": "நீங்கள் நல்லுபதேசம் பெறமாட்டீர்களா?"}, {"w": 2, "t": "you pay heed"}, {"w": 3, "t": "(155)"}]}, {"ayah": 156, "words": [{"w": 1, "t": "உங்களிடம் ஏதும் இருக்கிறதா?"}, {"w": 2, "t": "(is) for you"}, {"w": 3, "t": "ஆதாரம்"}, {"w": 4, "t": "தெளிவான"}, {"w": 5, "t": "(156)"}]}, {"ayah": 157, "words": [{"w": 1, "t": "உங்கள் வேதத்தை கொண்டு வாருங்கள்"}, {"w": 2, "t": "your book"}, {"w": 3, "t": "நீங்கள் இருந்தால்"}, {"w": 4, "t": "you are"}, {"w": 5, "t": "உண்மையாளர்களாக"}, {"w": 6, "t": "(157)"}]}, {"ayah": 158, "words": [{"w": 1, "t": "அவர்கள் ஏற்படுத்தினர்"}, {"w": 2, "t": "அவனுக்கு இடையில்"}, {"w": 3, "t": "இன்னும் இடையில்"}, {"w": 4, "t": "ஜின்களுக்கு"}, {"w": 5, "t": "ஓர் உறவை"}, {"w": 6, "t": "திட்டவட்டமாக"}, {"w": 7, "t": "அறிந்து கொண்டனர்"}, {"w": 8, "t": "ஜின்கள்"}, {"w": 9, "t": "நிச்சயமாக தாங்கள்"}, {"w": 10, "t": "ஆஜர்படுத்தப்படுவோம்"}, {"w": 11, "t": "(158)"}]}, {"ayah": 159, "words": [{"w": 1, "t": "மிகப் பரிசுத்தமானவன்"}, {"w": 2, "t": "அல்லாஹ்"}, {"w": 3, "t": "அவர்கள் வர்ணிப்பதை விட்டும்"}, {"w": 4, "t": "they attribute"}, {"w": 5, "t": "(159)"}]}, {"ayah": 160, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "அடியார்களை"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "பரிசுத்தமான"}, {"w": 5, "t": "(160)"}]}, {"ayah": 161, "words": [{"w": 1, "t": "நிச்சயமாக நீங்களும்"}, {"w": 2, "t": "நீங்கள் வணங்குகின்றவையும்"}, {"w": 3, "t": "you worship"}, {"w": 4, "t": "(161)"}]}, {"ayah": 162, "words": [{"w": 1, "t": "நீங்கள் இல்லை"}, {"w": 2, "t": "you"}, {"w": 3, "t": "அதன் மூலம்"}, {"w": 4, "t": "வழி கெடுப்பவர்களாக"}, {"w": 5, "t": "(162)"}]}, {"ayah": 163, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "எரிந்து பொசுங்குகின்றவரை"}, {"w": 3, "t": "he"}, {"w": 4, "t": "(is) to burn"}, {"w": 5, "t": "நரகத்தில்"}, {"w": 6, "t": "(163)"}]}, {"ayah": 164, "words": [{"w": 1, "t": "எங்களில் (யாரும்) இல்லை"}, {"w": 2, "t": "among us"}, {"w": 3, "t": "அவருக்கு இருந்தே தவிர"}, {"w": 4, "t": "for him"}, {"w": 5, "t": "தகுதி"}, {"w": 6, "t": "ஒரு குறிப்பிட்ட(து)"}, {"w": 7, "t": "(164)"}]}, {"ayah": 165, "words": [{"w": 1, "t": "நிச்சயமாக நாங்கள்தான்"}, {"w": 2, "t": "surely, [we]"}, {"w": 3, "t": "அணிவகுப்பவர்கள்"}, {"w": 4, "t": "(165)"}]}, {"ayah": 166, "words": [{"w": 1, "t": "நிச்சயமாக நாங்கள்தான்"}, {"w": 2, "t": "surely, [we]"}, {"w": 3, "t": "துதித்து தொழுபவர்கள்"}, {"w": 4, "t": "(166)"}]}, {"ayah": 167, "words": [{"w": 1, "t": "நிச்சயமாக இருந்தனர்"}, {"w": 2, "t": "they used to"}, {"w": 3, "t": "கூறுகின்றவர்களாக"}, {"w": 4, "t": "(167)"}]}, {"ayah": 168, "words": [{"w": 1, "t": "நிச்சயமாக எங்களிடம் இருந்திருந்தால்"}, {"w": 2, "t": "that"}, {"w": 3, "t": "we had"}, {"w": 4, "t": "வேதம்"}, {"w": 5, "t": "முன்னோரிடம்இருந்த"}, {"w": 6, "t": "the former (people)"}, {"w": 7, "t": "(168)"}]}, {"ayah": 169, "words": [{"w": 1, "t": "நாங்கள் ஆகியிருப்போம்"}, {"w": 2, "t": "அடியார்களாக"}, {"w": 3, "t": "அல்லாஹ்வின்"}, {"w": 4, "t": "பரிசுத்தமான"}, {"w": 5, "t": "(169)"}]}, {"ayah": 170, "words": [{"w": 1, "t": "அதை அவர்கள் நிராகரித்து விட்டனர்"}, {"w": 2, "t": "in it"}, {"w": 3, "t": "அவர்கள் விரைவில் அறிந்து கொள்வார்கள்"}, {"w": 4, "t": "they will know"}, {"w": 5, "t": "(170)"}]}, {"ayah": 171, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "முந்தி விட்டது/நமது வாக்கு"}, {"w": 3, "t": "Our Word"}, {"w": 4, "t": "நமதுஅடியார்களுக்கு"}, {"w": 5, "t": "தூதர்களான"}, {"w": 6, "t": "(171)"}]}, {"ayah": 172, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்தான்"}, {"w": 2, "t": "surely they"}, {"w": 3, "t": "உதவப்படுவார்கள்"}, {"w": 4, "t": "(172)"}]}, {"ayah": 173, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நமது இராணுவம்தான்"}, {"w": 3, "t": "அவர்கள்தான்"}, {"w": 4, "t": "வெற்றி பெறுபவர்கள்"}, {"w": 5, "t": "(173)"}]}, {"ayah": 174, "words": [{"w": 1, "t": "ஆகவே, விலகி இருப்பீராக!"}, {"w": 2, "t": "அவர்களை விட்டு"}, {"w": 3, "t": "சிறிது காலம் வரை"}, {"w": 4, "t": "a time"}, {"w": 5, "t": "(174)"}]}, {"ayah": 175, "words": [{"w": 1, "t": "(நீரும்) பார்ப்பீராக! அவர்களை"}, {"w": 2, "t": "விரைவில் பார்ப்பார்கள்"}, {"w": 3, "t": "they will see"}, {"w": 4, "t": "(175)"}]}, {"ayah": 176, "words": [{"w": 1, "t": "?/நமது வேதனையை"}, {"w": 2, "t": "அவசரமாக வேண்டுகின்றனர்"}, {"w": 3, "t": "(176)"}]}, {"ayah": 177, "words": [{"w": 1, "t": "அது இறங்கிவிட்டால்"}, {"w": 2, "t": "it descends"}, {"w": 3, "t": "அவர்களின் முற்றத்தில்"}, {"w": 4, "t": "மிக கெட்டதாக இருக்கும்"}, {"w": 5, "t": "காலை"}, {"w": 6, "t": "எச்சரிக்கப்பட்டவர்களின்"}, {"w": 7, "t": "(177)"}]}, {"ayah": 178, "words": [{"w": 1, "t": "அவர்களை விட்டு விலகி இருப்பீராக!"}, {"w": 2, "t": "from them"}, {"w": 3, "t": "சிறிது காலம் வரை"}, {"w": 4, "t": "a time"}, {"w": 5, "t": "(178)"}]}, {"ayah": 179, "words": [{"w": 1, "t": "(நீரும்) அவர்களைப் பார்ப்பீராக!"}, {"w": 2, "t": "(விரைவில்) பார்ப்பார்கள்"}, {"w": 3, "t": "they will see"}, {"w": 4, "t": "(179)"}]}, {"ayah": 180, "words": [{"w": 1, "t": "மிகப் பரிசுத்தமானவன்"}, {"w": 2, "t": "உமது இறைவன்"}, {"w": 3, "t": "அதிபதியான"}, {"w": 4, "t": "கண்ணியத்தின்"}, {"w": 5, "t": "அவர்கள் வர்ணிப்பதை விட்டும்"}, {"w": 6, "t": "they attribute"}, {"w": 7, "t": "(180)"}]}, {"ayah": 181, "words": [{"w": 1, "t": "ஈடேற்றம் உண்டாகுக!"}, {"w": 2, "t": "இறைத் தூதர்களுக்கு"}, {"w": 3, "t": "the Messengers"}, {"w": 4, "t": "(181)"}]}, {"ayah": 182, "words": [{"w": 1, "t": "புகழும் உண்டாகுக!"}, {"w": 2, "t": "அல்லாஹ்விற்கு"}, {"w": 3, "t": "அதிபதியான"}, {"w": 4, "t": "அகிலங்களின்"}, {"w": 5, "t": "(182)"}]}]}