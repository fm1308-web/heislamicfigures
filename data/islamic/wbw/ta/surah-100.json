{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அதிவேகமாக ஓடும் குதிரைகள் மீது சத்தியமாக"}, {"w": 2, "t": "மூச்சிரைக்க"}, {"w": 3, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இன்னும் (தீ) மூட்டுகின்ற குதிரைகள்"}, {"w": 2, "t": "தீப்பொறிகளை"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் பாய்கின்ற குதிரைகள்"}, {"w": 2, "t": "அதிகாலையில்"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் கிளப்பின"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "புழுதியை"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இன்னும் நடுவில் நுழைந்தன"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "கூட்டத்திற்கு"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "தன் இறைவனுக்கு"}, {"w": 4, "t": "நன்றி கெட்டவன்"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக அவன்"}, {"w": 2, "t": "அதற்கு"}, {"w": 3, "t": "that"}, {"w": 4, "t": "சாட்சி"}, {"w": 5, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக அவன்"}, {"w": 2, "t": "நேசிப்பதில்"}, {"w": 3, "t": "செல்வத்தை"}, {"w": 4, "t": "உறுதியாக  கடினமானவன்"}, {"w": 5, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவன் அறியவேண்டாமா?"}, {"w": 2, "t": "he know"}, {"w": 3, "t": "எழுப்பப்படும்போது"}, {"w": 4, "t": "will be scattered"}, {"w": 5, "t": "புதை குழிகளில் உள்ளவர்கள்"}, {"w": 6, "t": "(is) in"}, {"w": 7, "t": "the graves"}, {"w": 8, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் பிரித்தறியப்படும்"}, {"w": 2, "t": "நெஞ்சங்களில் உள்ளவை"}, {"w": 3, "t": "(is) in"}, {"w": 4, "t": "the breasts"}, {"w": 5, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "அவர்களுடைய இறைவன்"}, {"w": 3, "t": "அவர்களை"}, {"w": 4, "t": "அந்நாளில்"}, {"w": 5, "t": "ஆழ்ந்தறிபவன்"}, {"w": 6, "t": "(11)"}]}]}