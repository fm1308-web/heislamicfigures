{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அலிஃப், லாம், மீம்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இறக்கப்பட்ட"}, {"w": 2, "t": "வேதமாகும்"}, {"w": 3, "t": "அறவே சந்தேகம் இல்லை"}, {"w": 4, "t": "doubt"}, {"w": 5, "t": "இதில்"}, {"w": 6, "t": "இறைவனிடமிருந்து"}, {"w": 7, "t": "(the) Lord"}, {"w": 8, "t": "அகிலங்களின்"}, {"w": 9, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அல்லது கூறுகிறார்களா?"}, {"w": 2, "t": "(do) they say"}, {"w": 3, "t": "இதை அவர் இட்டுக் கட்டினார் என்று"}, {"w": 4, "t": "மாறாக"}, {"w": 5, "t": "இதுதான்"}, {"w": 6, "t": "உண்மையா(ன வேதமா)கும்"}, {"w": 7, "t": "உமது இறைவனிடமிருந்து"}, {"w": 8, "t": "your Lord"}, {"w": 9, "t": "நீர் எச்சரிப்பதற்காக"}, {"w": 10, "t": "ஒரு சமுதாயத்தை"}, {"w": 11, "t": "அவர்களிடம் வராத"}, {"w": 12, "t": "has come to them"}, {"w": 13, "t": "எச்சரிப்பவர் எவரும்"}, {"w": 14, "t": "warner"}, {"w": 15, "t": "இதற்கு முன்னர்"}, {"w": 16, "t": "before you"}, {"w": 17, "t": "அவர்கள் நேர்வழி பெறுவதற்காக"}, {"w": 18, "t": "be guided"}, {"w": 19, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "படைத்தான்"}, {"w": 4, "t": "வானங்களையும்"}, {"w": 5, "t": "பூமியையும்"}, {"w": 6, "t": "அவ்விரண்டுக்கும் இடையில் உள்ளவற்றையும்"}, {"w": 7, "t": "(is) between them"}, {"w": 8, "t": "ஆறு நாட்களில்"}, {"w": 9, "t": "six"}, {"w": 10, "t": "periods"}, {"w": 11, "t": "பிறகு"}, {"w": 12, "t": "உயர்ந்தான்"}, {"w": 13, "t": "அர்ஷின் மீது"}, {"w": 14, "t": "the Throne"}, {"w": 15, "t": "உங்களுக்கு இல்லை"}, {"w": 16, "t": "for you"}, {"w": 17, "t": "அவனையன்றி"}, {"w": 18, "t": "besides Him"}, {"w": 19, "t": "பொருப்பாளரோ"}, {"w": 20, "t": "protector"}, {"w": 21, "t": "பரிந்துறையாளரோ"}, {"w": 22, "t": "any intercessor"}, {"w": 23, "t": "நீங்கள் நல்லுணர்வு பெறமாட்டீர்களா ?"}, {"w": 24, "t": "you take heed"}, {"w": 25, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவன் திட்டமிட்டு நிர்வகிக்கின்றான்"}, {"w": 2, "t": "காரியத்தை"}, {"w": 3, "t": 