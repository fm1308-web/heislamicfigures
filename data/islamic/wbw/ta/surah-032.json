"}, {"w": 14, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "?/இருக்கின்றவர்"}, {"w": 2, "t": "is"}, {"w": 3, "t": "நம்பிக்கையாளராக"}, {"w": 4, "t": "இருக்கின்றவரைப் போன்று"}, {"w": 5, "t": "is"}, {"w": 6, "t": "பாவியாக"}, {"w": 7, "t": "அவர்கள் சமமாக மாட்டார்கள்"}, {"w": 8, "t": "they are equal"}, {"w": 9, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "ஆக,"}, {"w": 2, "t": "எவர்கள்/நம்பிக்கை கொண்டார்கள்"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நன்மைகளை"}, {"w": 6, "t": "அவர்களுக்கு"}, {"w": 7, "t": "சொர்க்கங்கள்"}, {"w": 8, "t": "தங்குமிடம்"}, {"w": 9, "t": "விருந்தோம்பலாக"}, {"w": 10, "t": "அவர்கள் செய்து கொண்டிருந்தவற்றுக்கு"}, {"w": 11, "t": "they used (to)"}, {"w": 12, "t": "do"}, {"w": 13, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "பாவம் செய்தவர்கள்"}, {"w": 3, "t": "are defiantly disobedient"}, {"w": 4, "t": "அவர்களின் தங்குமிடம்"}, {"w": 5, "t": "நரகமாகும்"}, {"w": 6, "t": "அவர்கள் நாடும்போதெல்லாம்"}, {"w": 7, "t": "they wish"}, {"w": 8, "t": "அவர்கள் வெளியேறுவதற்கு"}, {"w": 9, "t": "come out"}, {"w": 10, "t": "அதிலிருந்து"}, {"w": 11, "t": "அவர்கள் திரும்பக் கொண்டுவரப்படுவார்கள்"}, {"w": 12, "t": "அதில்"}, {"w": 13, "t": "இன்னும் சொல்லப்படும்"}, {"w": 14, "t": "அவர்களுக்கு"}, {"w": 15, "t": "சுவையுங்கள்"}, {"w": 16, "t": "வேதனையை"}, {"w": 17, "t": "நரக"}, {"w": 18, "t": "நீங்கள் பொய்ப்பித்துக் கொண்டிருந்த"}, {"w": 19, "t": "you used (to)"}, {"w": 20, "t": "[in it]"}, {"w": 21, "t": "deny"}, {"w": 22, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அவர்களுக்கு நிச்சயமாக நாம் சுவைக்க வைப்போம்."}, {"w": 2, "t": "வேதனையை"}, {"w": 3, "t": "the punishment"}, {"w": 4, "t": "சிறிய"}, {"w": 5, "t": "வேதனைக்கு முன்னர்"}, {"w": 6, "t": "the punishment"}, {"w": 7, "t": "மிகப் பெரிய"}, {"w": 8, "t": "அவர்கள் திரும்புவதற்காக"}, {"w": 9, "t": "return"}, {"w": 10, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "யார்?"}, {"w": 2, "t": "பெரியஅநியாயக்காரன்"}, {"w": 3, "t": "ஒருவ