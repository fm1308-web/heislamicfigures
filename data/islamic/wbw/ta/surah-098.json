{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "இருக்கவில்லை"}, {"w": 2, "t": "were"}, {"w": 3, "t": "நிராகரிப்பாளர்கள்"}, {"w": 4, "t": "disbelieved"}, {"w": 5, "t": "வேதக்காரர்களாகிய"}, {"w": 6, "t": "(the) People"}, {"w": 7, "t": "of the Book"}, {"w": 8, "t": "இன்னும் இணைவைப்போர்"}, {"w": 9, "t": "விலகியவர்களாக"}, {"w": 10, "t": "வரை"}, {"w": 11, "t": "தங்களிடம் வருகின்ற"}, {"w": 12, "t": "தெளிவான அத்தாட்சி"}, {"w": 13, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "தூதர்"}, {"w": 2, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 3, "t": "Allah"}, {"w": 4, "t": "ஓதுகின்றார்"}, {"w": 5, "t": "ஏடுகளை"}, {"w": 6, "t": "பரிசுத்தமான"}, {"w": 7, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "அவற்றில்"}, {"w": 2, "t": "சட்டங்கள்"}, {"w": 3, "t": "நேரான"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "பிரியவில்லை"}, {"w": 2, "t": "became divided"}, {"w": 3, "t": "கொடுக்கப்பட்டவர்கள்"}, {"w": 4, "t": "were given"}, {"w": 5, "t": "வேதம்"}, {"w": 6, "t": "தவிர"}, {"w": 7, "t": "பின்னர்"}, {"w": 8, "t": "after"}, {"w": 9, "t": "தங்களிடம் வந்தது"}, {"w": 10, "t": "came (to) them"}, {"w": 11, "t": "தெளிவான சான்று"}, {"w": 12, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அவர்கள் ஏவப்படவில்லை"}, {"w": 2, "t": "they were commanded"}, {"w": 3, "t": "தவிர/வணங்குவதற்கு"}, {"w": 4, "t": "to worship"}, {"w": 5, "t": "அல்லாஹ்வை"}, {"w": 6, "t": "தூய்மைப்படுத்தியவர்களாக"}, {"w": 7, "t": "அவனுக்கு"}, {"w": 8, "t": "வழிபாட்டை"}, {"w": 9, "t": "இணைவைப்பை விட்டு விலகியவர்களாக"}, {"w": 10, "t": "இன்னும் அவர்கள் நிலைநிறுத்துவது"}, {"w": 11, "t": "தொழுகையை"}, {"w": 12, "t": "இன்னும் அவர்கள் கொடுப்பது"}, {"w": 13, "t": "ஸகாத்தை"}, {"w": 14, "t": "இன்னும் இதுதான்"}, {"w": 15, "t": "மார்க்கம்"}, {"w": 16, "t": "நேரான"}, {"w": 17, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நிராகரிப்பாளர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "வேதக்காரர்களாகிய"}, {"w": 5, "t": "(the) People"}, {"w": 6, "t": "(of) the Book"}, {"w": 7, "t": "இன்னும் இணைவைப்போர்"}, {"w": 8, "t": "நெருப்பில்"}, {"w": 9, "t": "(the) Fire"}, {"w": 10, "t": "நரகம்"}, {"w": 11, "t": "நிரந்தரமானவர்களாக"}, {"w": 12, "t": "அதில்"}, {"w": 13, "t": "இவர்கள்தான்"}, {"w": 14, "t": "they"}, {"w": 15, "t": "மகா தீயோர்"}, {"w": 16, "t": "படைப்புகளில்"}, {"w": 17, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நம்பிக்கை கொண்டவர்கள்"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நற்செயல்களை"}, {"w": 6, "t": "அவர்கள்தான்"}, {"w": 7, "t": "they"}, {"w": 8, "t": "மிகச் சிறந்தோர்"}, {"w": 9, "t": "படைப்புகளில்"}, {"w": 10, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவர்களுடைய கூலி"}, {"w": 2, "t": "அவர்களின் இறைவனிடம்"}, {"w": 3, "t": "their Lord "}, {"w": 4, "t": "சொர்க்கங்கள்"}, {"w": 5, "t": "அத்ன்"}, {"w": 6, "t": "ஓடுகின்றன"}, {"w": 7, "t": "அவற்றின் கீழே"}, {"w": 8, "t": "underneath them"}, {"w": 9, "t": "நதிகள்"}, {"w": 10, "t": "நிரந்தரமானவர்களாக"}, {"w": 11, "t": "அவற்றில்"}, {"w": 12, "t": "எப்போதும்"}, {"w": 13, "t": "திருப்தி அடைவான்"}, {"w": 14, "t": "அல்லாஹ்"}, {"w": 15, "t": "அவர்களைப் பற்றி"}, {"w": 16, "t": "இன்னும் அவர்கள் திருப்தி அடைவார்கள்"}, {"w": 17, "t": "அவனைப் பற்றி"}, {"w": 18, "t": "இது"}, {"w": 19, "t": "பயந்தவருக்கு"}, {"w": 20, "t": "feared"}, {"w": 21, "t": "தன் இறைவனை"}, {"w": 22, "t": "(8)"}]}]}