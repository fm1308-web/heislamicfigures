{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "உம்மிடம் கேட்கிறார்கள்"}, {"w": 2, "t": "அன்ஃபால் பற்றி"}, {"w": 3, "t": "the spoils of war"}, {"w": 4, "t": "கூறுவீராக"}, {"w": 5, "t": "(போரில் கிடைத்த) வெற்றிப் பொருள்கள்"}, {"w": 6, "t": "அல்லாஹ்வுக்கு"}, {"w": 7, "t": "இன்னும் தூதருக்கு"}, {"w": 8, "t": "ஆகவே, அஞ்சுங்கள்"}, {"w": 9, "t": "அல்லாஹ்வை"}, {"w": 10, "t": "இன்னும் சீர்திருத்தம் செய்யுங்கள்"}, {"w": 11, "t": "உங்களுக்கு மத்தியில்"}, {"w": 12, "t": "(which is) between you"}, {"w": 13, "t": "இன்னும் கீழ்ப்படியுங்கள்"}, {"w": 14, "t": "அல்லாஹ்வுக்கு"}, {"w": 15, "t": "இன்னும் அவனுடைய தூதருக்கு"}, {"w": 16, "t": "நீங்கள் இருந்தால்/நம்பிக்கையாளர்களாக"}, {"w": 17, "t": "you are"}, {"w": 18, "t": "believers"}, {"w": 19, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நம்பிக்கையாளர்கள் எல்லாம்"}, {"w": 2, "t": "the believers"}, {"w": 3, "t": "எவர்கள்"}, {"w": 4, "t": "நினைவுகூரப்பட்டால்"}, {"w": 5, "t": "is mentioned"}, {"w": 6, "t": "அல்லாஹ்வை"}, {"w": 7, "t": "நடுங்கும்"}, {"w": 8, "t": "உள்ளங்கள்/அவர்களுடைய"}, {"w": 9, "t": "இன்னும் ஓதப்பட்டால்"}, {"w": 10, "t": "are recited"}, {"w": 11, "t": "அவர்கள் முன்"}, {"w": 12, "t": "வசனங்கள்/அவனுடைய"}, {"w": 13, "t": "அவை அதிகப்படுத்தும்/அவர்களுக்கு"}, {"w": 14, "t": "இறை நம்பிக்கையை"}, {"w": 15, "t": "இன்னும் தங்கள் இறைவன் மீதே"}, {"w": 16, "t": "their Lord"}, {"w": 17, "t": "நம்பிக்கை வைப்பார்கள்"}, {"w": 18, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நிலைநிறுத்துவார்கள்"}, {"w": 3, "t": "தொழுகையை"}, {"w": 4, "t": "இன்னும் எதிலிருந்து"}, {"w": 5, "t": "கொடுத்தோம்/அவர்களுக்கு"}, {"w": 6, "t": "தர்மம் புரிவார்கள்"}, {"w": 7, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவர்கள்தான்"}, {"w": 2, "t": "நம்பிக்கையாளர்கள்"}, {"w": 3, "t": "உண்மையில்"}, {"w": 4, "t": "அவர்களுக்கு"}, {"w": 5, "t": "பல பதவிகள்"}, {"w": 6, "t": "அவர்களின் இறைவனிடம்"}, {"w": 7, "t": "with"}, {"w": 8, "t": "இன்னும் மன்னிப்பு"}, {"w": 9, "t": "இன்னும் உணவு"}, {"w": 10, "t": "கண்ணியமானது"}, {"w": 11, "t": "noble"}, {"w": 12, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "போன்றே"}, {"w": 2, "t": "வெளியேற்றினான்/உம்மை"}, {"w": 3, "t": "உம் இறைவன்"}, {"w": 4, "t": "இருந்து"}, {"w": 5, "t": "உம் இல்லம்"}, {"w": 6, "t": "சத்தியத்தைக் கொண்டு"}, {"w": 7, "t": "நிச்சயமாக"}, {"w": 8, "t": "ஒரு பிரிவினர்"}, {"w": 9, "t": "நம்பிக்கையாளர்களில்"}, {"w": 10, "t": "the believers"}, {"w": 11, "t": "வெறுப்பவர்களே"}, {"w": 12, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "தர்க்கிக்கின்றனர்/உம்முடன்"}, {"w": 2, "t": "உண்மையில்"}, {"w": 3, "t": "the truth"}, {"w": 4, "t": "பின்னர் தெளிவானது"}, {"w": 5, "t": "was made clear"}, {"w": 6, "t": "போன்று"}, {"w": 7, "t": "ஓட்டிச் செல்லப்படுகிறார்கள்"}, {"w": 8, "t": "பக்கம்"}, {"w": 9, "t": "மரணம்"}, {"w": 10, "t": "அவர்கள் இருக்க"}, {"w": 11, "t": "பார்ப்பவர்களாக"}, {"w": 12, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "சமயம்"}, {"w": 2, "t": "வாக்களித்தான்/உங்களுக்கு"}, {"w": 3, "t": "அல்லாஹ்/ஒன்றை"}, {"w": 4, "t": "one"}, {"w": 5, "t": "இரு கூட்டங்களில்"}, {"w": 6, "t": "நிச்சயம் அது"}, {"w": 7, "t": "உங்களுக்கு"}, {"w": 8, "t": "விரும்பினீர்கள்"}, {"w": 9, "t": "நிச்சயமாக"}, {"w": 10, "t": "அல்லாதது"}, {"w": 11, "t": "உடையது"}, {"w": 12, "t": "ஆயுதம் (பலம்)"}, {"w": 13, "t": "ஆகவேண்டும்"}, {"w": 14, "t": "உங்களுக்கு"}, {"w": 15, "t": "இன்னும் நாடுகிறான்"}, {"w": 16, "t": "அல்லாஹ்"}, {"w": 17, "t": "உண்மைப்படுத்த"}, {"w": 18, "t": "justify"}, {"w": 19, "t": "உண்மையை"}, {"w": 20, "t": "தன் வாக்குகளைக் கொண்டு"}, {"w": 21, "t": "இன்னும் துண்டித்துவிட"}, {"w": 22, "t": "வேரை"}, {"w": 23, "t": "நிராகரிப்பவர்கள்"}, {"w": 24, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "அவன் உண்மைப்படுத்த"}, {"w": 2, "t": "உண்மையை"}, {"w": 3, "t": "இன்னும் அழித்துவிட, பெய்ப்பித்து விட"}, {"w": 4, "t": "பொய்யை"}, {"w": 5, "t": "வெறுத்தாலும்"}, {"w": 6, "t": "disliked (it)"}, {"w": 7, "t": "பாவிகள், குற்றவாளிகள்"}, {"w": 8, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "சமயம்/நீங்கள் பாதுகாப்புத் தேடுகிறீர்கள்"}, {"w": 2, "t": "you were seeking help"}, {"w": 3, "t": "உங்கள் இறைவனிடம்"}, {"w": 4, "t": "பதிலளித்தான்"}, {"w": 5, "t": "உங்களுக்கு"}, {"w": 6, "t": "நிச்சயமாக நான்"}, {"w": 7, "t": "உதவுவேன் உங்களுக்கு"}, {"w": 8, "t": "ஆயிரத்தைக்கொண்டு"}, {"w": 9, "t": "வானவர்களில்"}, {"w": 10, "t": "the Angels"}, {"w": 11, "t": "தொடர்ந்து வரக்கூடியவர்கள்"}, {"w": 12, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "ஆக்கவில்லை/அதை"}, {"w": 2, "t": "(it was) made"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "ஒரு நற்செய்தியாக"}, {"w": 6, "t": "இன்னும் நிம்மதி பெறுவதற்காக"}, {"w": 7, "t": "அதன் மூலம்"}, {"w": 8, "t": "உங்கள் உள்ளங்கள்"}, {"w": 9, "t": "இல்லை/உதவி"}, {"w": 10, "t": "[the] victory"}, {"w": 11, "t": "தவிர"}, {"w": 12, "t": "இருந்தே"}, {"w": 13, "t": "அல்லாஹ்விடம்"}, {"w": 14, "t": "Allah"}, {"w": 15, "t": "நிச்சயமாக"}, {"w": 16, "t": "அல்லாஹ்"}, {"w": 17, "t": "மிகைத்தவன்"}, {"w": 18, "t": "ஞானவான்"}, {"w": 19, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "சமயம்"}, {"w": 2, "t": "சூழவைக்கிறான்/உங்கள் மீது"}, {"w": 3, "t": "சிறு தூக்கத்தை"}, {"w": 4, "t": "அச்சமற்றிருப்பதற்காக"}, {"w": 5, "t": "தன் புறத்திலிருந்து"}, {"w": 6, "t": "இன்னும் இறக்குகிறான்"}, {"w": 7, "t": "உங்கள் மீது"}, {"w": 8, "t": "இருந்து/வானம்,மேகம்"}, {"w": 9, "t": "the sky"}, {"w": 10, "t": "நீரை, மழையை"}, {"w": 11, "t": "அவன் சுத்தப்படுத்துவற்காக உங்களை"}, {"w": 12, "t": "அதன் மூலம்"}, {"w": 13, "t": "இன்னும் அவன் போக்குவதற்காக"}, {"w": 14, "t": "உங்களை விட்டு"}, {"w": 15, "t": "அசுத்தத்தை"}, {"w": 16, "t": "ஷைத்தானுடைய"}, {"w": 17, "t": "இன்னும் அவன் பலப்படுத்துவதற்காக"}, {"w": 18, "t": "உங்கள் உள்ளங்களை"}, {"w": 19, "t": "your hearts"}, {"w": 20, "t": "இன்னும் அவன் உறுதிபடுத்துவதற்காக"}, {"w": 21, "t": "அதன் மூலம்"}, {"w": 22, "t": "பாதங்களை"}, {"w": 23, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "சமயம்/வஹீ  அறிவிக்கிறான்"}, {"w": 2, "t": "inspired"}, {"w": 3, "t": "உம் இறைவன்"}, {"w": 4, "t": "வானவர்களுக்கு"}, {"w": 5, "t": "the Angels"}, {"w": 6, "t": "நிச்சயமாக நான்"}, {"w": 7, "t": "உங்களுடன்"}, {"w": 8, "t": "ஆகவே உறுதிப்படுத்துங்கள்"}, {"w": 9, "t": "எவர்கள்"}, {"w": 10, "t": "நம்பிக்கை கொண்டார்கள்"}, {"w": 11, "t": "போடுவேன்"}, {"w": 12, "t": "உள்ளங்களில்"}, {"w": 13, "t": "(the) hearts"}, {"w": 14, "t": "எவர்கள்"}, {"w": 15, "t": "நிராகரித்தனர்"}, {"w": 16, "t": "திகிலை"}, {"w": 17, "t": "ஆகவே நீங்கள் வெட்டுங்கள்"}, {"w": 18, "t": "மேல்/கழுத்துகள்"}, {"w": 19, "t": "the necks"}, {"w": 20, "t": "இன்னும் வெட்டுங்கள்"}, {"w": 21, "t": "அவர்களின்"}, {"w": 22, "t": "எல்லா கணுக்களை"}, {"w": 23, "t": "fingertip[s]"}, {"w": 24, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அதற்கு காரணம் நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "(is) because they"}, {"w": 3, "t": "பிளவுபட்டனர், முரண்பட்டனர்"}, {"w": 4, "t": "அல்லாஹ்விற்கு"}, {"w": 5, "t": "இன்னும் அவனுடைய தூதருக்கு"}, {"w": 6, "t": "எவர்"}, {"w": 7, "t": "பிளவுபடுகிறார்"}, {"w": 8, "t": "அல்லாஹ்விற்கு"}, {"w": 9, "t": "இன்னும் அவனுடைய தூதருக்கு"}, {"w": 10, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 11, "t": "Allah"}, {"w": 12, "t": "கடுமையானவன்"}, {"w": 13, "t": "தண்டிப்பதில்"}, {"w": 14, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "அது"}, {"w": 2, "t": "அதை சுவையுங்கள்"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "நிராகரிப்பவர்களுக்கு"}, {"w": 5, "t": "வேதனை"}, {"w": 6, "t": "நரகம்"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "நீங்கள் சந்தித்தால்"}, {"w": 5, "t": "you meet"}, {"w": 6, "t": "எவர்கள்"}, {"w": 7, "t": "நிராகரித்தனர்"}, {"w": 8, "t": "பெரும் படையாக"}, {"w": 9, "t": "திருப்பாதீர்கள்"}, {"w": 10, "t": "திருப்பாதீர்கள் அவர்களுக்கு"}, {"w": 11, "t": "பின்புறங்களை"}, {"w": 12, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "எவர்"}, {"w": 2, "t": "திருப்புவார்/அவர்களுக்கு"}, {"w": 3, "t": "அந்நாளில்"}, {"w": 4, "t": "தன் பின் புறத்தை"}, {"w": 5, "t": "அல்லாமல்"}, {"w": 6, "t": "ஒதுங்கக்கூடியவராக"}, {"w": 7, "t": "சண்டையிடுவதற்கு"}, {"w": 8, "t": "அல்லது"}, {"w": 9, "