{"w": 19, "t": "அது அதிகமாக இருந்தாலும்"}, {"w": 20, "t": "(they are) numerous"}, {"w": 21, "t": "இன்னும் நிச்சயமாக"}, {"w": 22, "t": "அல்லாஹ்"}, {"w": 23, "t": "உடன்"}, {"w": 24, "t": "நம்பிக்கையாளர்கள்"}, {"w": 25, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "கீழ்ப்படியுங்கள்"}, {"w": 5, "t": "அல்லாஹ்விற்கு"}, {"w": 6, "t": "இன்னும் அவனுடைய தூதருக்கு"}, {"w": 7, "t": "விலகாதீர்கள்"}, {"w": 8, "t": "turn away"}, {"w": 9, "t": "அவரை விட்டு"}, {"w": 10, "t": "நீங்கள் இருக்க"}, {"w": 11, "t": "செவிமடுப்பவர்களாக"}, {"w": 12, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "ஆகிவிடாதீர்கள்"}, {"w": 2, "t": "be"}, {"w": 3, "t": "எவர்களைப் போல்"}, {"w": 4, "t": "கூறினர்"}, {"w": 5, "t": "செவியுற்றோம்"}, {"w": 6, "t": "அவர்கள் இருக்க"}, {"w": 7, "t": "செவியேற்காதவர்களாக"}, {"w": 8, "t": "hear"}, {"w": 9, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "மிகக் கொடூரமானவர்(கள்)"}, {"w": 3, "t": "ஊர்வனவற்றில்"}, {"w": 4, "t": "அல்லாஹ்விடம்"}, {"w": 5, "t": "Allah"}, {"w": 6, "t": "செவிடர்கள்"}, {"w": 7, "t": "ஊமைகளான"}, {"w": 8, "t": "எவர்கள்/சிந்தித்து புரியமாட்டார்கள்"}, {"w": 9, "t": "(do) not"}, {"w": 10, "t": "use (their) intellect"}, {"w": 11, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அறிந்திருந்தால்"}, {"w": 2, "t": "(had) known"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "அவர்களிடம்"}, {"w": 5, "t": "ஒரு நன்மையை"}, {"w": 6, "t": "செவியுறச் செய்திருப்பான்/அவர்களை"}, {"w": 7, "t": "அவன் அவர்களை செவியுறச் செய்தாலும்"}, {"w": 8, "t": "He had made them hear"}, {"w": 9, "t": "விலகி இருப்பார்கள்"}, {"w": 10, "t": "அவர்கள் இருக்க"}, {"w": 11, "t": "புறக்கணிப்பவர்களாக"}, {"w": 12, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "பதிலளியுங்கள்"}, {"w": 5, "t": "அல்லாஹ்வுக்கு"}, {"w": 6, "t": "இன்னும் தூதருக்கு"}, {"w": 7, "t": "அழைத்தால்"}, {"w": 8, "t": "உங்களை/எதற்கு"}, {"w": 9, "t": "to what"}, {"w": 10, "t": "வாழவைக்கும்/உங்களை"}, {"w": 11, "t": "அறிந்து கொள்ளுங்கள்"}, {"w": 12, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 13, "t": "Allah"}, {"w": 14, "t": "தடையாகிறான்"}, {"w": 15, "t": "நடுவில்"}, {"w": 16, "t": "மனிதனுக்கு"}, {"w": 17, "t": "இன்னும் அவனுடைய உள்ளத்திற்கு"}, {"w": 18, "t": "இன்னும் நிச்சயமாக நீங்கள்"}, {"w": 19, "t": "அவனிடமே"}, {"w": 20, "t": "ஒன்று திரட்டப்படுவீர்கள்"}, {"w": 21, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "அஞ்சுங்கள்"}, {"w": 2, "t": "ஒரு வேதனையை"}, {"w": 3, "t": "அடையாது"}, {"w": 4, "t": "which will afflict"}, {"w": 5, "t": "அநியாயக்காரர்களை"}, {"w": 6, "t": "do wrong"}, {"w": 7, "t": "உங்களில்"}, {"w": 8, "t": "மட்டுமே"}, {"w": 9, "t": "அறிந்து கொள்ளுங்கள்"}, {"w": 10, "t": "நிச்சயமாக"}, {"w": 11, "t": "அல்லாஹ்"}, {"w": 12, "t": "கடுமையானவன்"}, {"w": 13, "t": "தண்டிப்பதில்"}, {"w": 14, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "நினைவு கூருங்கள்"}, {"w": 2, "t": "(இருந்த) சமயத்தை"}, {"w": 3, "t": "நீங்கள்"}, {"w": 4, "t": "குறைவானவர்களாக"}, {"w": 5, "t": "பலவீனர்களாக"}, {"w": 6, "t": "பூமியில்"}, {"w": 7, "t": "the earth"}, {"w": 8, "t": "பயந்தவர்களாக"}, {"w": 9, "t": "தாக்கிவிடுவதை/உங்களை"}, {"w": 10, "t": "might do away with you"}, {"w": 11, "t": "மக்கள்"}, {"w": 12, "t": "அவன் இடமளித்தான்/உங்களுக்கு"}, {"w": 13, "t": "பலப்படுத்தினான்/உங்களை"}, {"w": 14, "t": "தன் உதவியைக் கொண்டு"}, {"w": 15, "t": "உணவளித்தான்/உங்களுக்கு"}, {"w": 16, "t": "நல்ல உணவுகளில்"}, {"w": 17, "t": "the good things"}, {"w": 18, "t": "நீங்கள் நன்றி செலுத்துவதற்காக"}, {"w": 19, "t": "(be) thankful"}, {"w": 20, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "மோசம்செய்யாதீர்கள்"}, {"w": 5, "t": "betray"}, {"w": 6, "t": "அல்லாஹ்வுக்கு"}, {"w": 7, "t": "இன்னும் தூதருக்கு"}, {"w": 8, "t": "இன்னும் மோசம் செய்யாதீர்கள்"}, {"w": 9, "t": "அமானிதங்களுக்கு/உங்கள்"}, {"w": 10, "t": "நீங்கள் இருக்க"}, {"w": 11, "t": "அறிந்தவர்களாக"}, {"w": 12, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "அறிந்து கொள்ளுங்கள்"}, {"w": 2, "t": "எல்லாம்"}, {"w": 3, "t": "செல்வங்கள்/உங்கள்"}, {"w": 4, "t": "இன்னும் சந்ததிகள்/உங்கள்"}, {"w": 5, "t": "ஒரு சோதனை"}, {"w": 6, "t": "நிச்சயமாக"}, {"w": 7, "t": "அல்லாஹ்"}, {"w": 8, "t": "அவனிடம்தான்"}, {"w": 9, "t": "கூலி"}, {"w": 10, "t": "மகத்தானது"}, {"w": 11, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "நம்பிக்கையாளர்களே"}, {"w": 2, "t": "who"}, {"w": 3, "t": "believe"}, {"w": 4, "t": "அஞ்சினால்"}, {"w": 5, "t": "you fear"}, {"w": 6, "t": "அல்லாஹ்வை"}, {"w": 7, "t": "ஏற்படுத்துவான்"}, {"w": 8, "t": "உங்களுக்கு"}, {"w": 9, "t": "ஒரு வித்தியாசத்தை"}, {"w": 10, "t": "இன்னும் அகற்றி விடுவான்"}, {"w": 11, "t": "உங்களை விட்டு"}, {"w": 12, "t": "உங்கள் பாவங்களை"}, {"w": 13, "t": "இன்னும் மன்னிப்பான்"}, {"w": 14, "t": "உங்களை"}, {"w": 15, "t": "அல்லாஹ்"}, {"w": 16, "t": "அருளுடையவன்"}, {"w": 17, "t": "(of) Bounty"}, {"w": 18, "t": "மகத்தானது"}, {"w": 19, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "சமயம்"}, {"w": 2, "t": "சூழ்ச்சி செய்வார்(கள்)"}, {"w": 3, "t": "உமக்கு"}, {"w": 4, "t": "எவர்கள்"}, {"w": 5, "t": "நிராகரித்தனர்"}, {"w": 6, "t": "அவர்கள் சிறைப்படுத்த/உம்மை"}, {"w": 7, "t": "அல்லது"}, {"w": 8, "t": "உம்மை அவர்கள் கொல்ல"}, {"w": 9, "t": "அல்லது"}, {"w": 10, "t": "அவர்கள் வெளியேற்ற/உம்மை"}, {"w": 11, "t": "இன்னும் சூழ்ச்சி செய்கின்றனர்"}, {"w": 12, "t": "இன்னும் சூழ்ச்சி செய்கிறான்"}, {"w": 13, "t": "அல்லாஹ்/அல்லாஹ்"}, {"w": 14, "t": "And Allah"}, {"w": 15, "t": "மிகச் சிறந்தவன்"}, {"w": 16, "t": "சூழ்ச்சி செய்பவர்களில்"}, {"w": 17, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "ஓதப்பட்டால்"}, {"w": 2, "t": "are recited"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "நம் வசனங்கள்"}, {"w": 5, "t": "கூறுகின்றனர்"}, {"w": 6, "t": "செவியேற்று விட்டோம்"}, {"w": 7, "t": "we have heard"}, {"w": 8, "t": "நாம் நாடியிருந்தால்"}, {"w": 9, "t": "we wish"}, {"w": 10, "t": "கூறியிருப்போம்"}, {"w": 11, "t": "இது போன்று"}, {"w": 12, "t": "this"}, {"w": 13, "t": "இவை இல்லை/தவிர"}, {"w": 14, "t": "is this"}, {"w": 15, "t": "but"}, {"w": 16, "t": "கட்டுக் கதைகளே"}, {"w": 17, "t": "முன்னோரின்"}, {"w": 18, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "சமயம்"}, {"w": 2, "t": "கூறினர்"}, {"w": 3, "t": "அல்லாஹ்வே"}, {"w": 4, "t": "இருக்குமேயானால்"}, {"w": 5, "t": "was"}, {"w": 6, "t": "இதுதான்"}, {"w": 7, "t": "[it]"}, {"w": 8, "t": "உண்மையாக"}, {"w": 9, "t": "உன்னிடமிருந்து"}, {"w": 10, "t": "from You"}, {"w": 11, "t": "பொழி"}, {"w": 12, "t": "எங்கள் மீது"}, {"w": 13, "t": "கல்லை"}, {"w": 14, "t": "வானத்திலிருந்து"}, {"w": 15, "t": "the sky"}, {"w": 16, "t": "அல்லது"}, {"w": 17, "t": "எங்களிடம் வா"}, {"w": 18, "t": "வேதனையைக் கொண்டு"}, {"w": 19, "t": "துன்புறுத்தும்"}, {"w": 20, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "is"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "அவர்களை வேதனை செய்பவனாக"}, {"w": 5, "t": "நீர் இருக்க"}, {"w": 6, "t": "அவர்களுடன்"}, {"w": 7, "t": "இல்லை"}, {"w": 8, "t": "is"}, {"w": 9, "t": "அல்லாஹ்"}, {"w": 10, "t": "வேதனை செய்பவனாக/அவர்களை"}, {"w": 11, "t": "அவர்கள் இருக்க"}, {"w": 12, "t": "மன்னிப்புத் தேடுபவர்களாக"}, {"w": 13, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "என்ன?"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "(அவன்) வேதனை செய்யாமலிருக்க/அவர்களை"}, {"w": 4, "t": "(should) punish them"}, {"w": 5, "t": "அல்லாஹ்"}, {"w": 6, "t": "அவர்களோ"}, {"w": 7, "t": "தடுக்கின்றனர்"}, {"w": 8, "t": "மஸ்ஜிதை விட்டு"}, {"w": 9, "t": "Al-Masjid"}, {"w": 10, "t": "புனிதமானது"}, {"w": 11, "t": "அவர்கள் இல்லை"}, {"w": 12, "t": "they are"}, {"w": 13, "t": "அதன் பொறுப்பாளர்களாக"}, {"w": 14, "t": "இல்லை/அதன் பொறுப்பாளர்கள்"}, {"w": 15, "t": "its guardians"}, {"w": 16, "t": "தவிர/இறை அச்சமுள்ளவர்கள்"}, {"w": 17, "t": "the ones who fear Allah"}, {"w": 18, "t": "எனினும் நிச்சயமாக"}, {"w": 19, "t": "அதிகமானோர் அவர்களில்"}, {"w": 20, "t": "அறியமாட்டார்கள்"}, {"w": 21, "t": "know"}, {"w": 22, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "