{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "போது"}, {"w": 2, "t": "வானம்"}, {"w": 3, "t": "பிளந்துவிடும்"}, {"w": 4, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "நட்சத்திரங்கள்"}, {"w": 3, "t": "விழுந்து சிதறும்"}, {"w": 4, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "கடல்கள்"}, {"w": 3, "t": "பிளக்கப்பட்டு"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் போது"}, {"w": 2, "t": "சமாதிகள்"}, {"w": 3, "t": "புரட்டப்படும்"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "அறியும்"}, {"w": 2, "t": "ஓர் ஆன்மா"}, {"w": 3, "t": "எதை/முற்படுத்தியது"}, {"w": 4, "t": "it has sent forth"}, {"w": 5, "t": "இன்னும் பிற்படுத்தியது"}, {"w": 6, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "மனிதனே!"}, {"w": 2, "t": "man"}, {"w": 3, "t": "எது?"}, {"w": 4, "t": "உன்னை ஏமாற்றியது"}, {"w": 5, "t": "உன் இறைவனைப் பற்றி"}, {"w": 6, "t": "கண்ணியவான்"}, {"w": 7, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "எப்படிப்பட்டவன்"}, {"w": 2, "t": "உன்னைப் படைத்தான்"}, {"w": 3, "t": "இன்னும் உன்னை சீர்செய்தான்"}, {"w": 4, "t": "இன்னும் உன்னைத் திருப்பினான்"}, {"w": 5, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "எந்த உருவத்தில்"}, {"w": 2, "t": "whatever"}, {"w": 3, "t": "form"}, {"w": 4, "t": "what"}, {"w": 5, "t": "நாடினானோ"}, {"w": 6, "t": "உன்னைப் பொறுத்தினான்"}, {"w": 7, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "மாறாக"}, {"w": 3, "t": "பொய்ப்பிக்கிறீர்கள்"}, {"w": 4, "t": "கூலி கொடுக்கப்படுவதை"}, {"w": 5, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக உங்கள் மீது"}, {"w": 2, "t": "over you"}, {"w": 3, "t": "காவலர்கள்"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "கண்ணியமானவர்கள்"}, {"w": 2, "t": "எழுத்தாளர்கள்"}, {"w": 3, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவர்கள் அறிகிறார்கள்"}, {"w": 2, "t": "நீங்கள் செய்வதை"}, {"w": 3, "t": "you do"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "நல்லோர்"}, {"w": 3, "t": "நயீம் என்ற சொர்க்கத்தில்தான்"}, {"w": 4, "t": "bliss"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக"}, {"w": 2, "t": "தீயோர்"}, {"w": 3, "t": "ஜஹீம் என்ற நரகத்தில்தான்"}, {"w": 4, "t": "Hellfire"}, {"w": 5, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அதில் எரிவார்கள்"}, {"w": 2, "t": "நாளில்"}, {"w": 3, "t": "கூலி"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இன்னும் இல்லை"}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "அதிலிருந்து"}, {"w": 4, "t": "மறைபவர்களாக"}, {"w": 5, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இன்னும் எது"}, {"w": 2, "t": "உமக்கு அறிவித்தது"}, {"w": 3, "t": "என்ன(வென்று)"}, {"w": 4, "t": "கூலி நாள்"}, {"w": 5, "t": "(of) the Judgment"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "பிறகு/எது?"}, {"w": 2, "t": "what"}, {"w": 3, "t": "உமக்கு அறிவித்தது"}, {"w": 4, "t": "என்ன(வென்று)"}, {"w": 5, "t": "கூலி நாள்"}, {"w": 6, "t": "(of) the Judgment"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நாள்"}, {"w": 2, "t": "உரிமை பெறாது"}, {"w": 3, "t": "will have power"}, {"w": 4, "t": "ஓர் ஆன்மா"}, {"w": 5, "t": "ஓர் ஆத்மாவிற்கு"}, {"w": 6, "t": "எதையும்"}, {"w": 7, "t": "இன்னும் அதிகாரம்"}, {"w": 8, "t": "அந்நாளில்"}, {"w": 9, "t": "அல்லாஹ்விற்கே"}, {"w": 10, "t": "(19)"}]}]}