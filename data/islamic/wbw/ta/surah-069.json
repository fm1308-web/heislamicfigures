{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "உண்மையான நிகழ்வு!"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "உண்மையான நிகழ்வு என்றால் என்ன?"}, {"w": 2, "t": "(is) the Inevitable Reality"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "உமக்கு எது அறிவித்தது!?"}, {"w": 2, "t": "will make you know"}, {"w": 3, "t": "உண்மையான நிகழ்வு என்றால் என்ன?"}, {"w": 4, "t": "(is) the Inevitable Reality"}, {"w": 5, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "பொய்ப்பித்தனர்"}, {"w": 2, "t": "ஸமூது மக்களும்"}, {"w": 3, "t": "ஆது மக்களும்"}, {"w": 4, "t": "தட்டக்கூடிய மறுமை நாளை"}, {"w": 5, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "ஆக, ஸமூது மக்கள்"}, {"w": 2, "t": "Thamud"}, {"w": 3, "t": "அழிக்கப்பட்டனர்"}, {"w": 4, "t": "எல்லை மீறிய சப்தத்தைக் கொண்டு"}, {"w": 5, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "ஆக,"}, {"w": 2, "t": "ஆது மக்கள்"}, {"w": 3, "t": "அழிக்கப்பட்டார்கள்"}, {"w": 4, "t": "ஒரு காற்றைக் கொண்டு"}, {"w": 5, "t": "கடுமையான குளிருடன் வீசக்கூடிய"}, {"w": 6, "t": "அதி வேகமான"}, {"w": 7, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "அவன் அதை கட்டுப்படுத்தி வைத்திருந்தான்"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "ஏழு இரவுகளும்"}, {"w": 4, "t": "nights"}, {"w": 5, "t": "எட்டு பகல்களும்"}, {"w": 6, "t": "days"}, {"w": 7, "t": "தொடர்ச்சியாக"}, {"w": 8, "t": "பார்ப்பீர்"}, {"w": 9, "t": "மக்களை"}, {"w": 10, "t": "அதில்"}, {"w": 11, "t": "செத்து மடிந்தவர்களாக"}, {"w": 12, "t": "போல்/அவர்களோ"}, {"w": 13, "t": "அடிப்பகுதிகளை"}, {"w": 14, "t": "பேரீட்ச மரத்தின்"}, {"w": 15, "t": "அழிந்துபோன"}, {"w": 16, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நீர் பார்க்கிறீரா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "அவர்களில்"}, {"w": 4, "t": "உயிரோடு மீதம் இருப்பவர் யாரையும்"}, {"w": 5, "t": "remains"}, {"w": 6, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "செய்தனர்"}, {"w": 2, "t": "ஃபிர்அவ்னும்"}, {"w": 3, "t": "அவனுக்கு முன்னுள்ளவர்களும்"}, {"w": 4, "t": "before him"}, {"w": 5, "t": "தலைக்கீழாக புரட்டப்பட்ட ஊரார்களும்"}, {"w": 6, "t": "தீய செயல்களை"}, {"w": 7, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "அவர்கள் மாறுசெய்தனர்"}, {"w": 2, "t": "தூதருக்கு"}, {"w": 3, "t": "தங்கள் இறைவனின்"}, {"w": 4, "t": "ஆகவே, அவன் அவர்களைப் பிடித்தான்"}, {"w": 5, "t": "பிடியால்"}, {"w": 6, "t": "கடுமையான"}, {"w": 7, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "மிக அதிகமாகிய போது"}, {"w": 3, "t": "தண்ணீர்"}, {"w": 4, "t": "the water"}, {"w": 5, "t": "உங்களை ஏற்றினோம்"}, {"w": 6, "t": "கப்பலில்"}, {"w": 7, "t": "the sailing (ship)"}, {"w": 8, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அதை ஆக்குவதற்காகவும்"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "ஓர் உபதேசமாக"}, {"w": 4, "t": "அவற்றை கவனித்து புரிந்து கொள்வதற்காகவும்"}, {"w": 5, "t": "செவிகள்"}, {"w": 6, "t": "கவனித்து செவியுறுகின்ற"}, {"w": 7, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "ஊதப்பட்டால்"}, {"w": 2, "t": "is blown"}, {"w": 3, "t": "சூரில்"}, {"w": 4, "t": "the trumpet "}, {"w": 5, "t": "ஊதுதல்"}, {"w": 6, "t": "ஒரு முறை"}, {"w": 7, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "சுமக்கப்பட்டு"}, {"w": 2, "t": "பூமி(யும்)"}, {"w": 3, "t": "மலைகளும்"}, {"w": 4, "t": "இரண்டும் அடித்து நொறுக்கப்பட்டால்"}, {"w": 5, "t": "அடியாக"}, {"w": 6, "t": "ஒரே"}, {"w": 7, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அந்நாளில்தான்"}, {"w": 2, "t": "நிகழும்"}, {"w": 3, "t": "நிகழக்கூடிய நாள்"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "இன்னும் பிளந்து விடும்"}, {"w": 2, "t": "வானம்"}, {"w": 3, "t": "அது"}, {"w": 4, "t": "அந்நாளில்"}, {"w": 5, "t": "பலவீனப்பட்டு விடும்"}, {"w": 6, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "வானவர்கள்/அதன் ஓரங்களில் இருப்பார்கள்"}, {"w": 2, "t": "(will be) on"}, {"w": 3, "t": "its edges"}, {"w": 4, "t": "சுமப்பார்(கள்)"}, {"w": 5, "t": "அர்ஷை"}, {"w": 6, "t": "உமது இறைவனின்"}, {"w": 7, "t": "தங்களுக்கு மேல்"}, {"w": 8, "t": "அந்நாளில்"}, {"w": 9, "t": "எட்டு வானவர்கள்"}, {"w": 10, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அந்நாளில்"}, {"w": 2, "t": "நீங்கள் சமர்ப்பிக்கப்படுவீர்கள்"}, {"w": 3, "t": "மறைந்துவிடாது"}, {"w": 4, "t": "will be hidden"}, {"w": 5, "t": "உங்களிடமிருந்து"}, {"w": 6, "t": "மறையக்கூடியது எதுவும்"}, {"w": 7, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "ஆகவே, யார்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "கொடுக்கப்பட்டாரோ"}, {"w": 4, "t": "தனது செயலேடு"}, {"w": 5, "t": "தனது வலது கரத்தில்"}, {"w": 6, "t": "அவர் கூறுவார்"}, {"w": 7, "t": "வாருங்கள்!"}, {"w": 8, "t": "படியுங்கள்!"}, {"w": 9, "t": "எனது செயலேட்டை"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "நம்பினேன்"}, {"w": 3, "t": "நிச்சயமாக நான்"}, {"w": 4, "t": "சந்திப்பேன்"}, {"w": 5, "t": "எனது விசாரணையை"}, {"w": 6, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "ஆகவே, அவர்"}, {"w": 2, "t": "வாழ்க்கையில்"}, {"w": 3, "t": "a life"}, {"w": 4, "t": "மகிழ்ச்சியான"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "சொர்க்கத்தில்"}, {"w": 2, "t": "a Garden"}, {"w": 3, "t": "உயர்ந்த"}, {"w": 4, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "அதன் கனிகள்"}, {"w": 2, "t": "மிக சமீபமாக"}, {"w": 3, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "உண்ணுங்கள்"}, {"w": 2, "t": "இன்னும் பருகுங்கள்"}, {"w": 3, "t": "இன்பமாக"}, {"w": 4, "t": "நீங்கள் முற்படுத்தியவற்றின் காரணமாக"}, {"w": 5, "t": "you sent before you"}, {"w": 6, "t": "கடந்த காலங்களில்"}, {"w": 7, "t": "the days"}, {"w": 8, "t": "past"}, {"w": 9, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "ஆக, யார்"}, {"w": 2, "t": "(him) who"}, {"w": 3, "t": "கொடுக்கப்பட்டாரோ"}, {"w": 4, "t": "தனது செயலேடு"}, {"w": 5, "t": "தனது இடது கையில்"}, {"w": 6, "t": "கூறுவார்"}, {"w": 7, "t": "எனக்கு கொடுக்கப்பட்டிருக்கக் கூடாதே!"}, {"w": 8, "t": "not"}, {"w": 9, "t": "I had been given"}, {"w": 10, "t": "எனது செயலேடு"}, {"w": 11, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "நான் அறியமாட்டேன்"}, {"w": 2, "t": "I had known"}, {"w": 3, "t": "எனது விசாரணை என்னவாகும்"}, {"w": 4, "t": "(is) my account"}, {"w": 5, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "அதுவே, இருந்திருக்க வேண்டுமே!"}, {"w": 2, "t": "had been"}, {"w": 3, "t": "முடிக்கக்கூடியதாக"}, {"w": 4, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "பலனளிக்கவில்லை"}, {"w": 2, "t": "has availed"}, {"w": 3, "t": "எனக்கு"}, {"w": 4, "t": "எனது செல்வம்"}, {"w": 5, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அழித்துவிட்டது"}, {"w": 2, "t": "என்னை விட்டு"}, {"w": 3, "t": "எனது ஆட்சி அதிகாரம்"}, {"w": 4, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "அவனைப் பிடியுங்கள்!"}, {"w": 2, "t": "அவனை விலங்கிடுங்கள்!"}, {"w": 3, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "பிறகு/நரகத்தில்"}, {"w": 2, "t": "(into) the Hellfire"}, {"w": 3, "t": "அவனை எரித்து பொசுக்குங்கள்!"}, {"w": 4, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "ஒரு சங்கிலியில்"}, {"w": 3, "t": "a chain"}, {"w": 4, "t": "அதன் முழம்"}, {"w": 5, "t": "எழுபது முழம்"}, {"w": 6, "t": "cubits"}, {"w": 7, "t": "அவனைபுகுத்துங்கள்!"}, {"w": 8, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "நிச்சயமாக அவன்"}, {"w": 2, "t": "இருந்தான்"}, {"w": 3, "t": "நம்பிக்கை கொள்ளாதவனாக"}, {"w": 4, "t": "believing"}, {"w": 5, "t": "அல்லாஹ்வை"}, {"w": 6, "t": "மகத்தான"}, {"w": 7, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இன்னும் தூண்டாத வனாக இருந்தான்"}, {"w": 2, "t": "feel the urge"}, {"w": 3, "t": "உணவிற்கு"}, {"w": 4, "t": "(the) feeding"}, {"w": 5, "t": "ஏழைகளின்"}, {"w": 6, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "ஆகவே இருக்க மாட்டார்"}, {"w": 2, "t": "அவனுக்கு"}, {"w": 3, "t": "இன்று"}, {"w": 4, "t": "இங்கு"}, {"w": 5, "t": "நெருக்கமான நண்பர்"}, {"w": 6, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "இன்னும் உணவும் இருக்காது"}, {"w": 2, "t": "any food"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "சீழ் சலங்களைத்"}, {"w": 5, "t": "(the) discharge of wounds"}, {"w": 6, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "அதை சாப்பிட மாட்டார்(கள்)"}, {"w": 2, "t": "will eat it"}, {"w": 3, "t": "பாவிகளை தவிர"}, {"w": 4, "t": "the sinners"}, {"w": 5, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "சத்தியம் செய்கிறேன்!"}, {"w": 2, "t": "I swear"}, {"w": 3, "t": "நீங்கள் பார்க்கின்றவற்றின் மீதும்"}, {"w": 4, "t": "you see"}, {"w": 5, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "நீங்கள் பார்க்காதவற்றின் மீதும்"}, {"w": 2, "t": "not"}, {"w": 3, "t": "you see"}, {"w": 4, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "நிச்சயமாக இது"}, {"w": 2, "t": "வேத வாக்காகும்"}, {"w": 3, "t": "தூதருடைய"}, {"w": 4, "t": "கண்ணியமான"}, {"w": 5, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "இது வாக்கல்ல"}, {"w": 2, "t": "it"}, {"w": 3, "t": "(is the) word"}, {"w": 4, "t": "கவிஞரின்"}, {"w": 5, "t": "மிகக் குறைவாகவே"}, {"w": 6, "t": "நம்பிக்கை கொள்கிறீர்கள்"}, {"w": 7, "t": "you believe"}, {"w": 8, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "இன்னும் இது வாக்குமல்ல"}, {"w": 2, "t": "(it is the) word"}, {"w": 3, "t": "ஜோசியக்காரனின்"}, {"w": 4, "t": "மிகக் குறைவாகவே"}, {"w": 5, "t": "நீங்கள் நல்லுபதேசம் பெறுகிறீர்கள்"}, {"w": 6, "t": "you take heed"}, {"w": 7, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "இறக்கப்பட்ட வேதம்"}, {"w": 2, "t": "இறைவனிடமிருந்து"}, {"w": 3, "t": "(the) Lord"}, {"w": 4, "t": "அகிலங்களின்"}, {"w": 5, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "அவர் இட்டுக்கட்டி பேசினால்/நம்மீது"}, {"w": 2, "t": "he (had) fabricated"}, {"w": 3, "t": "against Us"}, {"w": 4, "t": "சில பேச்சுகளை"}, {"w": 5, "t": "sayings"}, {"w": 6, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நாம் பிடித்திருப்போம்"}, {"w": 2, "t": "அவரை"}, {"w": 3, "t": "பலமாக"}, {"w": 4, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "பிறகு"}, {"w": 2, "t": "நாம் வெட்டி இருப்போம்"}, {"w": 3, "t": "அவரின்"}, {"w": 4, "t": "நாடி நரம்பை"}, {"w": 5, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "இல்லை"}, {"w": 2, "t": "உங்களில் இருந்து"}, {"w": 3, "t": "எவரும்"}, {"w": 4, "t": "one"}, {"w": 5, "t": "அவரை விட்டும்"}, {"w": 6, "t": "தடுப்பவர்கள்"}, {"w": 7, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "நிச்சயமாக இது"}, {"w": 2, "t": "ஓர் அறிவுரையாகும்"}, {"w": 3, "t": "இறையச்சமுள்ளவர்களுக்கு"}, {"w": 4, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "நாம் நன்கறிவோம்"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "உங்களில்"}, {"w": 5, "t": "பொய்ப்பிப்பவர்கள்"}, {"w": 6, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "நிச்சயமாக இது"}, {"w": 2, "t": "துக்கமானதுதான்"}, {"w": 3, "t": "நிராகரிப்பாளர்களுக்கு"}, {"w": 4, "t": "the disbelievers"}, {"w": 5, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "நிச்சயமாக இது"}, {"w": 2, "t": "உண்மையாகும்"}, {"w": 3, "t": "மிக உறுதியான"}, {"w": 4, "t": "(51)"}]}, {"ayah": 52, "words": [{"w": 1, "t": "ஆகவே, துதிப்பீராக!"}, {"w": 2, "t": "பெயரை"}, {"w": 3, "t": "உமது இறைவனின்"}, {"w": 4, "t": "மகத்தான"}, {"w": 5, "t": "(52)"}]}]}