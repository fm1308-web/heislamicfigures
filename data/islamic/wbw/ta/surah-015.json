{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "அலிஃப்; லாம்; றா"}, {"w": 2, "t": "இவை"}, {"w": 3, "t": "வசனங்கள்"}, {"w": 4, "t": "வேதங்களின்"}, {"w": 5, "t": "இன்னும் குர்ஆனின்"}, {"w": 6, "t": "தெளிவான(து)"}, {"w": 7, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "பெரிதும் விரும்புவார்(கள்)"}, {"w": 2, "t": "will wish"}, {"w": 3, "t": "எவர்கள்"}, {"w": 4, "t": "நிராகரித்தனர்"}, {"w": 5, "t": "தாங்கள் இருந்திருக்க வேண்டுமே!"}, {"w": 6, "t": "they had been"}, {"w": 7, "t": "முஸ்லிம்களாக"}, {"w": 8, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "விடுவீராக/அவர்களை"}, {"w": 2, "t": "அவர்கள் புசிக்கட்டும்"}, {"w": 3, "t": "இன்னும் அவர்கள் சுகம் அனுபவிக்கட்டும்"}, {"w": 4, "t": "இன்னும் மறக்கடிக்கட்டும்/அவர்களை"}, {"w": 5, "t": "ஆசை"}, {"w": 6, "t": "(பின்னர்) அறிவார்கள்"}, {"w": 7, "t": "they will come to know"}, {"w": 8, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "நாம் அழிக்கவில்லை"}, {"w": 2, "t": "We destroyed"}, {"w": 3, "t": "எவ்வூரையும்"}, {"w": 4, "t": "town"}, {"w": 5, "t": "தவிர/அதற்கு"}, {"w": 6, "t": "(there was) for it"}, {"w": 7, "t": "தவணை/குறிப்பிட்ட"}, {"w": 8, "t": "known"}, {"w": 9, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "முந்த மாட்டா(ர்க)ள்"}, {"w": 2, "t": "(can) advance"}, {"w": 3, "t": "எந்த சமுதாயமும்"}, {"w": 4, "t": "nation"}, {"w": 5, "t": "தங்கள் தவணையை"}, {"w": 6, "t": "இன்னும் பிந்தமாட்டார்கள்"}, {"w": 7, "t": "(can) delay it"}, {"w": 8, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "கூறுகின்றனர்"}, {"w": 2, "t": "ஓ!"}, {"w": 3, "t": "எவர்"}, {"w": 4, "t": "இறக்கப்பட்டது"}, {"w": 5, "t": "அவர்மீது"}, {"w": 6, "t": "அறிவுரை"}, {"w": 7, "t": "நிச்சயமாக நீர்"}, {"w": 8, "t": "பைத்தியக்காரர்தான்"}, {"w": 9, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நீர்வரலாமே/நம்மிடம்"}, {"w": 2, "t": "not"}, {"w": 3, "t": "you bring to us"}, {"w": 4, "t": "வானவர்களைக் கொண்டு"}, {"w": 5, "t": "நீர் இருந்தால்"}, {"w": 6, "t": "you are"}, {"w": 7, "t": "உண்மையாளர்களில்"}, {"w": 8, "t": "the truthful"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இறக்கமாட்டோம்"}, {"w": 2, "t": "We send down"}, {"w": 3, "t": "வானவர்களை"}, {"w": 4, "t": "தவிர/சத்தியத்தைக் கொண்டே"}, {"w": 5, "t": "with the truth"}, {"w": 6, "t": "இருக்கமாட்டார்கள்"}, {"w": 7, "t": "they would be"}, {"w": 8, "t": "அப்போது"}, {"w": 9, "t": "அவகாசமளிக்கப்படுபவர்களாக"}, {"w": 10, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நிச்சயமாக நாம்தான்"}, {"w": 2, "t": "We"}, {"w": 3, "t": "இறக்கினோம்"}, {"w": 4, "t": "அறிவுரையை"}, {"w": 5, "t": "இன்னும் நிச்சயமாக நாம்"}, {"w": 6, "t": "அதை"}, {"w": 7, "t": "பாதுகாப்பவர்கள்"}, {"w": 8, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "திட்டமாக அனுப்பினோம்"}, {"w": 2, "t": "We (had) sent"}, {"w": 3, "t": "உமக்கு முன்னர்"}, {"w": 4, "t": "before you"}, {"w": 5, "t": "பிரிவுகளில்"}, {"w": 6, "t": "the sects"}, {"w": 7, "t": "முன்னோர்களின்"}, {"w": 8, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "வருவதில்லை/அவர்களிடம்"}, {"w": 2, "t": "came to them"}, {"w": 3, "t": "எந்த ஒரு தூதரும்"}, {"w": 4, "t": "Messenger"}, {"w": 5, "t": "தவிர"}, {"w": 6, "t": "இருந்தனர்"}, {"w": 7, "t": "அவரை"}, {"w": 8, "t": "பரிகசிப்பார்கள்"}, {"w": 9, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "அவ்வாறே"}, {"w": 2, "t": "புகுத்துகிறோம்/அதை"}, {"w": 3, "t": "உள்ளங்களில்"}, {"w": 4, "t": "(the) hearts"}, {"w": 5, "t": "குற்றவாளிகள்"}, {"w": 6, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "அவர்கள் நம்பிக்கை கொள்ள மாட்டார்கள்"}, {"w": 2, "t": "they believe"}, {"w": 3, "t": "இவரை"}, {"w": 4, "t": "சென்றுவிட்டது"}, {"w": 5, "t": "have passed"}, {"w": 6, "t": "வழிமுறை"}, {"w": 7, "t": "முன்னோரின்"}, {"w": 8, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நாம் திறந்தால்"}, {"w": 2, "t": "We opened"}, {"w": 3, "t": "அவர்கள் மீது"}, {"w": 4, "t": "ஒரு வாசலை"}, {"w": 5, "t": "இருந்து"}, {"w": 6, "t": "வானம்"}, {"w": 7, "t": "பகலில் அவர்கள் ஆகினர்"}, {"w": 8, "t": "அதில்"}, {"w": 9, "t": "ஏறுபவர்களாக"}, {"w": 10, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "நிச்சயம் அவர்கள் கூறுவர்"}, {"w": 2, "t": "மயக்கப்பட்டு விட்டன"}, {"w": 3, "t": "have been dazzled"}, {"w": 4, "t": "எங்கள் கண்கள்"}, {"w": 5, "t": "இல்லை/நாங்கள்"}, {"w": 6, "t": "we"}, {"w": 7, "t": "மக்கள்"}, {"w": 8, "t": "சூனியம் செய்யப்பட்டவர்கள்"}, {"w": 9, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அமைத்தோம்"}, {"w": 3, "t": "வானத்தில்/பெரிய நட்சத்திரங்களை"}, {"w": 4, "t": "the heavens"}, {"w": 5, "t": "constellations"}, {"w": 6, "t": "இன்னும் அலங்காரமாக்கினோம்/அவற்றை"}, {"w": 7, "t": "பார்ப்பவர்களுக்கு"}, {"w": 8, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "இன்னும் பாதுகாத்தோம்/அதை"}, {"w": 2, "t": "எல்லாம்/விட்டு"}, {"w": 3, "t": "every"}, {"w": 4, "t": "ஷைத்தான்"}, {"w": 5, "t": "விரட்டப்பட்டவன்"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "எனினும்"}, {"w": 2, "t": "எவன்"}, {"w": 3, "t": "ஒட்டுக் கேட்பான்"}, {"w": 4, "t": "the hearing"}, {"w": 5, "t": "பின்தொடர்ந்தது/அவனை"}, {"w": 6, "t": "ஓர் எரி நட்சத்திரம்"}, {"w": 7, "t": "தெளிவானது"}, {"w": 8, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் பூமி"}, {"w": 2, "t": "விரித்தோம்/அதை"}, {"w": 3, "t": "இன்னும் நிறுவினோம்"}, {"w": 4, "t": "அதில்"}, {"w": 5, "t": "அசையாத மலைகளை"}, {"w": 6, "t": "இன்னும் முளைக்க வைத்தோம்"}, {"w": 7, "t": "அதில்"}, {"w": 8, "t": "எல்லாவற்றையும்"}, {"w": 9, "t": "every"}, {"w": 10, "t": "thing"}, {"w": 11, "t": "நிறுக்கப்படும்"}, {"w": 12, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "அமைத்தோம்"}, {"w": 2, "t": "உங்களுக்கு"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "வாழ்வாதாரங்களை"}, {"w": 5, "t": "இன்னும் எவர்"}, {"w": 6, "t": "நீங்கள் இல்லை"}, {"w": 7, "t": "அவருக்கு"}, {"w": 8, "t": "உணவளிப்பவர்களாக"}, {"w": 9, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "எப்பொருளும்/இல்லை"}, {"w": 2, "t": "(is) any"}, {"w": 3, "t": "thing"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "நம்மிடம்"}, {"w": 6, "t": "பொக்கிஷங்கள்/அதன்"}, {"w": 7, "t": "இன்னும் இறக்க மாட்டோம்/அதை"}, {"w": 8, "t": "We send it down"}, {"w": 9, "t": "தவிர/ஓர் அளவில்"}, {"w": 10, "t": "in a measure"}, {"w": 11, "t": "குறிப்பிடப்பட்ட"}, {"w": 12, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "இன்னும் அனுப்புகிறோம்"}, {"w": 2, "t": "காற்றுகளை"}, {"w": 3, "t": "கருக்கொள்ள வைக்கக் கூடியதாக"}, {"w": 4, "t": "இறக்குகிறோம்"}, {"w": 5, "t": "மேகத்திலிருந்து"}, {"w": 6, "t": "the sky"}, {"w": 7, "t": "மழை நீரை"}, {"w": 8, "t": "புகட்டுகிறோம்/உங்களுக்கு/அதை"}, {"w": 9, "t": "இல்லை/நீங்கள்"}, {"w": 10, "t": "you"}, {"w": 11, "t": "அதை"}, {"w": 12, "t": "சேகரிப்பவர்களாக"}, {"w": 13, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நிச்சயமாக நாம்தான்"}, {"w": 2, "t": "surely [We]"}, {"w": 3, "t": "உயிர் கொடுக்கிறோம்"}, {"w": 4, "t": "இன்னும் மரணிக்க வைக்கிறோம்"}, {"w": 5, "t": "நாம்"}, {"w": 6, "t": "அனந்தரக்காரர்கள்"}, {"w": 7, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "அறிந்தோம்"}, {"w": 3, "t": "முன் சென்றவர்களை"}, {"w": 4, "t": "உங்களில்"}, {"w": 5, "t": "திட்டவட்டமாக"}, {"w": 6, "t": "அறிந்தோம்"}, {"w": 7, "t": "பின் வருபவர்களை"}, {"w": 8, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உம் இறைவன்தான்"}, {"w": 3, "t": "He"}, {"w": 4, "t": "ஒன்று திரட்டுவான் இவர்களை"}, {"w": 5, "t": "நிச்சயமாக அவன்"}, {"w": 6, "t": "மகா ஞானவான்"}, {"w": 7, "t": "நன்கறிந்தவன்"}, {"w": 8, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "திட்டவட்டமாக"}, {"w": 2, "t": "படைத்தோம்"}, {"w": 3, "t": "மனிதனை"}, {"w": 4, "t": "இருந்து"}, {"w": 5, "t": "‘கன் கன்’ என்று சப்தம் வரக்கூடியது"}, {"w": 6, "t": "இருந்து/களிமண்"}, {"w": 7, "t": "black mud"}, {"w": 8, "t": "பிசுபிசுப்பானது"}, {"w": 9, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "ஜின்னை"}, {"w": 2, "t": "படைத்தோம்/அதை"}, {"w": 3, "t": "முன்பே"}, {"w": 4, "t": "before"}, {"w": 5, "t": "இருந்து"}, {"w": 6, "t": "நெருப்பு"}, {"w": 7, "t": "கொடிய உஷ்ணமுள்ளது"}, {"w": 8, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "கூறிய சமயத்தை"}, {"w": 2, "t": "your Lord said"}, {"w": 3, "t": "உம் இறைவன்"}, {"w": 4, "t": "வானவர்களுக்கு"}, {"w": 5, "t": "நிச்சயமாக நான்"}, {"w": 6, "t": "படைக்கப்போகிறேன்"}, {"w": 7, "t": "ஒரு மனிதனை"}, {"w": 8, "t": "‘கன் கன்’ என்று சப்தம் வரக்கூடியது"}, {"w": 9, "t": "clay"}, {"w": 10, "t": "இருந்து"}, {"w": 11, "t": "களிமண்"}, {"w": 12, "t": "பிசுபிசுப்பானது"}, {"w": 13, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "நான் செம்மை செய்துவிட்டால்/அவரை"}, {"w": 2, "t": "I have fashioned him"}, {"w": 3, "t": "இன்னும் ஊதினேன்"}, {"w": 4, "t": "அவரில்"}, {"w": 5, "t": "என் உயிரிலிருந்து"}, {"w": 6, "t": "My spirit"}, {"w": 7, "t": "விழுங்கள்"}, {"w": 8, "t": "அவருக்கு முன்"}, {"w": 9, "t": "சிரம்பணிந்தவர்களாக"}, {"w": 10, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "சிரம் பணிந்தார்(கள்)"}, {"w": 2, "t": "வானவர்கள்"}, {"w": 3, "t": "அவர்கள் எல்லோரும்"}, {"w": 4, "t": "அனைவரும்"}, {"w": 5, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "இப்லீஸைத் தவிர"}, {"w": 2, "t": "Iblis"}, {"w": 3, "t": "மறுத்து விட்டான்"}, {"w": 4, "t": "ஆகுவதற்கு/உடன்"}, {"w": 5, "t": "be"}, {"w": 6, "t": "with"}, {"w": 7, "t": "சிரம் பணிந்தவர்கள்"}, {"w": 8, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "இப்லீஸே!"}, {"w": 3, "t": "உனக்கென்ன நேர்ந்தது?"}, {"w": 4, "t": "(is) for you"}, {"w": 5, "t": "நீ ஆகாதிருக்க"}, {"w": 6, "t": "you are"}, {"w": 7, "t": "உடன்"}, {"w": 8, "t": "சிரம் பணிந்தவர்கள்"}, {"w": 9, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "நான் இல்லை"}, {"w": 3, "t": "I am not"}, {"w": 4, "t": "சிரம் பணிபவனாக"}, {"w": 5, "t": "ஒரு மனிதனுக்கு"}, {"w": 6, "t": "படைத்தாய்/அவனை"}, {"w": 7, "t": "இருந்து"}, {"w": 8, "t": "‘கன் கன்’ என்று சப்தம் வரக்கூடியது"}, {"w": 9, "t": "இருந்து"}, {"w": 10, "t": "களிமண்"}, {"w": 11, "t": "பிசுபிசுப்பானது"}, {"w": 12, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "கூறினான்/வெளியேறு"}, {"w": 2, "t": "Then get out"}, {"w": 3, "t": "இதிலிருந்து"}, {"w": 4, "t": "நிச்சயமாக நீ"}, {"w": 5, "t": "விரட்டப்பட்டவன்"}, {"w": 6, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக"}, {"w": 2, "t": "உம்மீது"}, {"w": 3, "t": "சாபம்"}, {"w": 4, "t": "கூலி நாள் வரை"}, {"w": 5, "t": "(the) Day"}, {"w": 6, "t": "(of) [the] Judgment"}, {"w": 7, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "என் இறைவா"}, {"w": 3, "t": "அவகாசமளி எனக்கு"}, {"w": 4, "t": "வரை"}, {"w": 5, "t": "நாள்"}, {"w": 6, "t": "எழுப்பப்படுவார்கள்"}, {"w": 7, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "நிச்சயமாக நீ"}, {"w": 3, "t": "அவகாசமளிக்கப்பட்டவர்களில்"}, {"w": 4, "t": "the ones given respite"}, {"w": 5, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "வரை"}, {"w": 2, "t": "நாள்"}, {"w": 3, "t": "நேரத்தின்"}, {"w": 4, "t": "குறிப்பிடப்பட்டது"}, {"w": 5, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "என் இறைவா"}, {"w": 3, "t": "நீ வழி கெடுத்ததன் காரணமாக/என்னை"}, {"w": 4, "t": "You misled me"}, {"w": 5, "t": "நிச்சயமாக அலங்கரிப்பேன்"}, {"w": 6, "t": "அவர்களுக்கு"}, {"w": 7, "t": "பூமியில்"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "இன்னும் நிச்சயமாக வழிகெடுப்பேன்/அவர்களை"}, {"w": 10, "t": "அனைவரையும்"}, {"w": 11, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "உன் அடியார்களை"}, {"w": 3, "t": "அவர்களில்"}, {"w": 4, "t": "பரிசுத்தமானவர்கள்"}, {"w": 5, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "கூறினான்"}, {"w": 2, "t": "இது/வழி"}, {"w": 3, "t": "(is) the way"}, {"w": 4, "t": "என் பக்கம்"}, {"w": 5, "t": "நேரானது"}, {"w": 6, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "என் அடியார்கள்"}, {"w": 3, "t": "இல்லை/உனக்கு"}, {"w": 4, "t": "you have"}, {"w": 5, "t": "அவர்கள் மீது"}, {"w": 6, "t": "அதிகாரம்"}, {"w": 7, "t": "தவிர/எவர்(கள்)"}, {"w": 8, "t": "those who"}, {"w": 9, "t": "பின்பற்றுகின்றார்(கள்)/ உன்னை"}, {"w": 10, "t": "வழிகெட்டவர்கள்"}, {"w": 11, "t": "the ones who go astray"}, {"w": 12, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "நிச்சயமாக/நரகம்"}, {"w": 2, "t": "Hell"}, {"w": 3, "t": "வாக்களிக்கப்பட்ட இடம்/அவர்கள்"}, {"w": 4, "t": "அனைவரின்"}, {"w": 5, "t": "(43)"}]}, {"ayah": 44, "words": [{"w": 1, "t": "அதற்கு"}, {"w": 2, "t": "ஏழு"}, {"w": 3, "t": "வாசல்கள்"}, {"w": 4, "t": "ஒவ்வொரு"}, {"w": 5, "t": "வாசலுக்கும்"}, {"w": 6, "t": "அவர்களில்"}, {"w": 7, "t": "ஒரு பிரிவினர்"}, {"w": 8, "t": "பிரிக்கப்பட்ட"}, {"w": 9, "t": "(44)"}]}, {"ayah": 45, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "அஞ்சியவா்கள்"}, {"w": 3, "t": "சொர்க்கங்களில்"}, {"w": 4, "t": "Gardens"}, {"w": 5, "t": "இன்னும் நீரருவிகளில்"}, {"w": 6, "t": "(45)"}]}, {"ayah": 46, "words": [{"w": 1, "t": "நுழையுங்கள் அதில்"}, {"w": 2, "t": "ஸலாம் உடன்"}, {"w": 3, "t": "அச்சமற்றவர்களாக"}, {"w": 4, "t": "(46)"}]}, {"ayah": 47, "words": [{"w": 1, "t": "நீக்கிவிடுவோம்"}, {"w": 2, "t": "எதை/நெஞ்சங்களில்/அவர்களுடைய"}, {"w": 3, "t": "(is) in"}, {"w": 4, "t": "their breasts"}, {"w": 5, "t": "குரோதத்தை"}, {"w": 6, "t": "rancor"}, {"w": 7, "t": "சகோதரர்களாக"}, {"w": 8, "t": "கட்டில்கள் மீது"}, {"w": 9, "t": "thrones"}, {"w": 10, "t": "ஒருவர் ஒருவரை முகம் நோக்கியவர்களாக"}, {"w": 11, "t": "(47)"}]}, {"ayah": 48, "words": [{"w": 1, "t": "ஏற்படாது/அவர்களுக்கு"}, {"w": 2, "t": "will touch them"}, {"w": 3, "t": "அதில்"}, {"w": 4, "t": "சிரமம்"}, {"w": 5, "t": "இன்னும் இல்லை"}, {"w": 6, "t": "அவர்கள்"}, {"w": 7, "t": "அதிலிருந்து"}, {"w": 8, "t": "வெளியேற்றப்படுபவர்களாக"}, {"w": 9, "t": "(48)"}]}, {"ayah": 49, "words": [{"w": 1, "t": "அறிவிப்பீராக"}, {"w": 2, "t": "என் அடியார்களுக்கு"}, {"w": 3, "t": "நிச்சயமாக நான்தான்"}, {"w": 4, "t": "I am"}, {"w": 5, "t": "மகா மன்னிப்பாளன்"}, {"w": 6, "t": "மகா கருணையாளன்"}, {"w": 7, "t": "(49)"}]}, {"ayah": 50, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக"}, {"w": 2, "t": "என் வேதனைதான்"}, {"w": 3, "t": "it"}, {"w": 4, "t": "வேதனை"}, {"w": 5, "t": "துன்புறுத்தக்கூடியது"}, {"w": 6, "t": "(50)"}]}, {"ayah": 51, "words": [{"w": 1, "t": "அறிவிப்பீராக/அவர்களுக்கு"