{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "விடியற்காலையின் மீது சத்தியமாக"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நாள்களின் மீது சத்தியமாக"}, {"w": 2, "t": "பத்து"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இரட்டையின் மீது சத்தியமாக"}, {"w": 2, "t": "ஒற்றையின் மீது சத்தியமாக"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இரவின் மீது சத்தியமாக"}, {"w": 2, "t": "அது செல்லும்போது"}, {"w": 3, "t": "it passes"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இதில் இருக்கிறதா?"}, {"w": 2, "t": "in"}, {"w": 3, "t": "that"}, {"w": 4, "t": "சத்தியம்"}, {"w": 5, "t": "அறிவுடையவருக்கு"}, {"w": 6, "t": "who understand"}, {"w": 7, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நீர் கவனிக்கவில்லையா?"}, {"w": 2, "t": "you see"}, {"w": 3, "t": "எவ்வாறு"}, {"w": 4, "t": "(வேதனை)செய்தான்"}, {"w": 5, "t": "உம் இறைவன்"}, {"w": 6, "t": "ஆது சமுதாயத்தை"}, {"w": 7, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இரம்"}, {"w": 2, "t": "தூண்களுடைய"}, {"w": 3, "t": "lofty pillars"}, {"w": 4, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "எது"}, {"w": 2, "t": "படைக்கவில்லை"}, {"w": 3, "t": "had been created"}, {"w": 4, "t": "அதுபோன்று"}, {"w": 5, "t": "நகரங்களில்"}, {"w": 6, "t": "the cities"}, {"w": 7, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் ஸமூது சமுதாயத்தை"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "குடைந்தனர்"}, {"w": 4, "t": "பாறையை"}, {"w": 5, "t": "பள்ளத்தாக்கில்"}, {"w": 6, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் ஃபிர்அவ்ன்"}, {"w": 2, "t": "ஆணிகளுடைய"}, {"w": 3, "t": "stakes"}, {"w": 4, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "வரம்பு மீறினார்கள்"}, {"w": 3, "t": "நகரங்களில்"}, {"w": 4, "t": "the lands"}, {"w": 5, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் அதிகப்படுத்தினர்"}, {"w": 2, "t": "அவற்றில்"}, {"w": 3, "t": "விஷமத்தை"}, {"w": 4, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "எனவே சுழற்றினான்"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "உம் இறைவன்"}, {"w": 4, "t": "சாட்டையை"}, {"w": 5, "t": "வேதனையின்"}, {"w": 6, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "உம் இறைவன்"}, {"w": 3, "t": "எதிர்பார்க்குமிடத்தில்"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "மனிதன்"}, {"w": 3, "t": "அவனைச் சோதித்த போது"}, {"w": 4, "t": "does"}, {"w": 5, "t": "try him"}, {"w": 6, "t": "அவனுடைய இறைவன்"}, {"w": 7, "t": "இன்னும் அவனைக் கண்ணியப்படுத்தினான்"}, {"w": 8, "t": "இன்னும் அவனுக்கு அருட்கொடை புரிந்தான்"}, {"w": 9, "t": "கூறுகிறான்"}, {"w": 10, "t": "என் இறைவன்"}, {"w": 11, "t": "என்னைக் கண்ணியப்படுத்தினான்"}, {"w": 12, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "ஆக"}, {"w": 2, "t": "அவனைச் சோதித்த போது"}, {"w": 3, "t": "does"}, {"w": 4, "t": "He try him"}, {"w": 5, "t": "இன்னும் சுருக்கினான்"}, {"w": 6, "t": "அவன் மீது"}, {"w": 7, "t": "அவனுடைய வாழ்வாதாரத்தை"}, {"w": 8, "t": "கூறுகிறான்"}, {"w": 9, "t": "என் இறைவன்"}, {"w": 10, "t": "என்னை இழிவுபடுத்திவிட்டான்"}, {"w": 11, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "அவ்வாறல்ல/மாறாக"}, {"w": 2, "t": "But"}, {"w": 3, "t": "நீங்கள் கண்ணியப்படுத்துவதில்லை"}, {"w": 4, "t": "you honor"}, {"w": 5, "t": "அநாதையை"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இன்னும் தூண்டுவதில்லை"}, {"w": 2, "t": "you feel the urge"}, {"w": 3, "t": "உணவிற்கு"}, {"w": 4, "t": "feed"}, {"w": 5, "t": "ஏழையின்"}, {"w": 6, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "இன்னும் புசிக்கிறீர்கள்"}, {"w": 2, "t": "பிறருடைய சொத்தை"}, {"w": 3, "t": "புசித்தல்/சேர்த்து"}, {"w": 4, "t": "altogether"}, {"w": 5, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இன்னும் நேசிக்கிறீர்கள்"}, {"w": 2, "t": "செல்வத்தை"}, {"w": 3, "t": "நேசித்தல்"}, {"w": 4, "t": "கடுமையாக"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "அவ்வாறல்ல"}, {"w": 2, "t": "தூள் தூளாகத் தகர்க்கப்படும் போது"}, {"w": 3, "t": "is leveled"}, {"w": 4, "t": "பூமி"}, {"w": 5, "t": "தூள் தூளாகத் தகர்க்கப்படுதல்"}, {"w": 6, "t": "(and) crushed"}, {"w": 7, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "இன்னும் வருவான்"}, {"w": 2, "t": "உம் இறைவன்"}, {"w": 3, "t": "இன்னும் மலக்கு"}, {"w": 4, "t": "அணி அணியாக"}, {"w": 5, "t": "(upon) rank"}, {"w": 6, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "இன்னும் வரப்படும்"}, {"w": 2, "t": "அந்நாளில்"}, {"w": 3, "t": "நரகத்தைக்கொண்டு"}, {"w": 4, "t": "அந்நாளில்"}, {"w": 5, "t": "நல்லறிவு பெறுவான்"}, {"w": 6, "t": "மனிதன்/இன்னும் எப்படி"}, {"w": 7, "t": "but how"}, {"w": 8, "t": "அவனுக்கு"}, {"w": 9, "t": "நல்லறிவு"}, {"w": 10, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "கூறுவான்"}, {"w": 2, "t": "நான் முற்படுத்தி இருக்க வேண்டுமே"}, {"w": 3, "t": "I had sent forth"}, {"w": 4, "t": "என் வாழ்வுக்காக"}, {"w": 5, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "ஆகவே அந்நாளில்"}, {"w": 2, "t": "வேதனை செய்ய மாட்டான்"}, {"w": 3, "t": "will punish"}, {"w": 4, "t": "அவனுடைய வேதனையை"}, {"w": 5, "t": "ஒருவனும்"}, {"w": 6, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "இன்னும் கட்டமாட்டான்"}, {"w": 2, "t": "will bind"}, {"w": 3, "t": "அவனுடைய கட்டுதலை"}, {"w": 4, "t": "ஒருவனும்"}, {"w": 5, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "ஆன்மாவே!"}, {"w": 2, "t": "soul"}, {"w": 3, "t": "நிம்மதியடைந்த"}, {"w": 4, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "திரும்பு"}, {"w": 2, "t": "பக்கம்"}, {"w": 3, "t": "உன் இறைவன்"}, {"w": 4, "t": "திருப்தி பெற்றதாக"}, {"w": 5, "t": "திருப்தி கொள்ளப்பட்டதாக"}, {"w": 6, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "இன்னும் சேர்ந்து விடு"}, {"w": 2, "t": "என் அடியார்களில்"}, {"w": 3, "t": "My slaves"}, {"w": 4, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "இன்னும் நுழைந்து விடு"}, {"w": 2, "t": "என் சொர்க்கத்தில்"}, {"w": 3, "t": "(30)"}]}]}