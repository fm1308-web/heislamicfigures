{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "யா சீன்"}, {"w": 2, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "குர்ஆன் மீது சத்தியமாக!"}, {"w": 2, "t": "ஞானமிகுந்த(து)"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "நிச்சயமாக நீர்"}, {"w": 2, "t": "இறைத்தூதர்களில் ஒருவர் ஆவீர்"}, {"w": 3, "t": "the Messengers"}, {"w": 4, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "பாதையில்"}, {"w": 2, "t": "a Path"}, {"w": 3, "t": "நேரான(து)"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இறக்கிய வேதமாகும்"}, {"w": 2, "t": "மிகைத்தவன்"}, {"w": 3, "t": "மகா கருணையாளன்"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நீர் எச்சரிப்பதற்காக"}, {"w": 2, "t": "ஒரு சமுதாயத்தை"}, {"w": 3, "t": "எச்சரிக்கப்படவில்லை"}, {"w": 4, "t": "were warned"}, {"w": 5, "t": "மூதாதைகள் அவர்களின்"}, {"w": 6, "t": "ஆகவே, அவர்கள்"}, {"w": 7, "t": "அலட்சியக்காரர்களாக இருக்கின்றனர்"}, {"w": 8, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "திட்டமாக"}, {"w": 2, "t": "உறுதியாகிவிட்டது"}, {"w": 3, "t": "வாக்கு"}, {"w": 4, "t": "அதிகமானவர்கள் மீது"}, {"w": 5, "t": "அதிகமானவர்கள் மீது அவர்களில்"}, {"w": 6, "t": "ஆகவே, அவர்கள்"}, {"w": 7, "t": "நம்பிக்கை கொள்ள மாட்டார்கள்"}, {"w": 8, "t": "believe"}, {"w": 9, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "நிச்சயமாக நாம்"}, {"w": 2, "t": "ஏற்படுத்தி விட்டோம்"}, {"w": 3, "t": "அவர்களின் கழுத்துகள் மீது"}, {"w": 4, "t": "their necks"}, {"w": 5, "t": "அரிகண்டங்களை"}, {"w": 6, "t": "அவை"}, {"w": 7, "t": "தாடைகள் வரை"}, {"w": 8, "t": "the chins"}, {"w": 9, "t": "ஆகவே, அவர்கள்"}, {"w": 10, "t": "உயர்த்தியவர்களாக"}, {"w": 11, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "நாம் ஆக்கினோம்"}, {"w": 2, "t": "அவர்களுக்கு முன்னும்"}, {"w": 3, "t": "before/between"}, {"w": 4, "t": "their hands/their front"}, {"w": 5, "t": "ஒரு தடுப்பை"}, {"w": 6, "t": "அவர்களுக்கு பின்னும்"}, {"w": 7, "t": "behind them"}, {"w": 8, "t": "ஒரு தடுப்பை"}, {"w": 9, "t": "ஆகவே நாம் அவர்களை குருடாக்கிவிட்டோம்"}, {"w": 10, "t": "ஆகவே, அவர்கள்"}, {"w": 11, "t": "பார்க்கமாட்டார்கள்"}, {"w": 12, "t": "see"}, {"w": 13, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "சமம் தான்"}, {"w": 2, "t": "அவர்கள் மீது"}, {"w": 3, "t": "நீர் அவர்களை எச்சரித்தாலும்"}, {"w": 4, "t": "அல்லது"}, {"w": 5, "t": "அவர்களை நீர் எச்சரிக்கவில்லை என்றாலும்"}, {"w": 6, "t": "warn them"}, {"w": 7, "t": "அவர்கள் நம்பிக்கை கொள்ள மாட்டார்கள்"}, {"w": 8, "t": "they will believe"}, {"w": 9, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நீர் எச்சரிப்பதெல்லாம்"}, {"w": 2, "t": "you (can) warn"}, {"w": 3, "t": "எவர்/பின்பற்றினார்"}, {"w": 4, "t": "follows"}, {"w": 5, "t": "இந்த வேதத்தை"}, {"w": 6, "t": "இன்னும் பயந்தார்"}, {"w": 7, "t": "பேரருளாளனை"}, {"w": 8, "t": "மறைவில்"}, {"w": 9, "t": "ஆகவே அவருக்கு நற்செய்தி கூறுவீராக!"}, {"w": 10, "t": "மன்னிப்பைக் கொண்டும்"}, {"w": 11, "t": "கூலியைக் கொண்டும்"}, {"w": 12, "t": "கண்ணியமான"}, {"w": 13, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நிச்சயமாக நாம்தான்"}, {"w": 2, "t": "[We]"}, {"w": 3, "t": "உயிர்ப்பிக்கின்றோம்"}, {"w": 4, "t": "இறந்தவர்களை"}, {"w": 5, "t": "இன்னும் பதிவு செய்வோம்"}, {"w": 6, "t": "அவர்கள் முன்னர் செய்தவற்றையும்"}, {"w": 7, "t": "they have sent before"}, {"w": 8, "t": "காலடிச் சுவடுகளை அவர்களின்"}, {"w": 9, "t": "எல்லாவற்றையும்"}, {"w": 10, "t": "thing"}, {"w": 11, "t": "அதைப் பதிவு செய்துள்ளோம்"}, {"w": 12, "t": "பதிவேட்டில்"}, {"w": 13, "t": "a Register"}, {"w": 14, "t": "தெளிவான"}, {"w": 15, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "எடுத்துச் சொல்வீராக!"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "உதாரணமாக"}, {"w": 4, "t": "அந்த ஊர் வாசிகளை"}, {"w": 5, "t": "(of) the city"}, {"w": 6, "t": "அவர்களிடம் வந்த சமயத்தை நினைவு கூர்வீராக!"}, {"w": 7, "t": "came to it"}, {"w": 8, "t": "தூதர்கள்"}, {"w": 9, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "நாம் அனுப்பியபோது"}, {"w": 2, "t": "We sent"}, {"w": 3, "t": "அவர்களிடம்"}, {"w": 4, "t": "இருவரை"}, {"w": 5, "t": "அவர்கள் பொய்ப்பித்தனர் அவ்விருவரையும்"}, {"w": 6, "t": "பலப்படுத்தினோம்"}, {"w": 7, "t": "மூன்றாவது ஒருவரைக்கொண்டு"}, {"w": 8, "t": "அவர்கள் கூறினர்"}, {"w": 9, "t": "நிச்சயமாக நாங்கள்"}, {"w": 10, "t": "உங்கள் பக்கம்"}, {"w": 11, "t": "அனுப்பப்பட்ட தூதர்கள்"}, {"w": 12, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "நீங்கள் இல்லை"}, {"w": 3, "t": "you"}, {"w": 4, "t": "அன்றி"}, {"w": 5, "t": "மனிதர்கள்"}, {"w": 6, "t": "எங்களைப் போன்ற"}, {"w": 7, "t": "இறக்கவில்லை"}, {"w": 8, "t": "has revealed"}, {"w": 9, "t": "பேரருளாளன்"}, {"w": 10, "t": "எதையும்"}, {"w": 11, "t": "thing"}, {"w": 12, "t": "நீங்கள் இல்லை"}, {"w": 13, "t": "you"}, {"w": 14, "t": "தவிர"}, {"w": 15, "t": "பொய் சொல்கின்றவர்களாகவே"}, {"w": 16, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "எங்கள் இறைவன்"}, {"w": 3, "t": "நன்கறிவான்"}, {"w": 4, "t": "நிச்சயமாக நாங்கள்"}, {"w": 5, "t": "உங்கள் பக்கம்"}, {"w": 6, "t": "அனுப்பப்பட்ட தூதர்கள்"}, {"w": 7, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "எங்கள் மீது இல்லை"}, {"w": 2, "t": "(is) on us"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "எடுத்துரைப்பதை"}, {"w": 5, "t": "தெளிவாக"}, {"w": 6, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "நிச்சயமாக நாங்கள்"}, {"w": 3, "t": "துர்ச்குனமாக கருதுகின்றோம்"}, {"w": 4, "t": "உங்களை"}, {"w": 5, "t": "நீங்கள் விலகவில்லை என்றால்"}, {"w": 6, "t": "not"}, {"w": 7, "t": "you desist"}, {"w": 8, "t": "நிச்சயமாக நாங்கள் உங்களை கல்லால் எறிவோம்"}, {"w": 9, "t": "இன்னும் நிச்சயமாக உங்களை வந்தடையும்"}, {"w": 10, "t": "எங்களிடமிருந்து"}, {"w": 11, "t": "வேதனை/வலிமிகுந்த"}, {"w": 12, "t": "painful"}, {"w": 13, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "அவர்கள் கூறினர்"}, {"w": 2, "t": "துர்ச்சகுனம் உங்கள்"}, {"w": 3, "t": "உங்களுடன்தான்"}, {"w": 4, "t": "நீங்கள் அறிவுறுத்தப்பட்டாலுமா"}, {"w": 5, "t": "you are admonished"}, {"w": 6, "t": "மாறாக"}, {"w": 7, "t": "நீங்கள்"}, {"w": 8, "t": "மக்கள்"}, {"w": 9, "t": "வரம்பு மீறுகின்ற"}, {"w": 10, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "வந்தார்"}, {"w": 2, "t": "கடைக்கோடியில் இருந்து"}, {"w": 3, "t": "(the) farthest end"}, {"w": 4, "t": "பட்டணத்தின்"}, {"w": 5, "t": "ஓர் ஆடவர்"}, {"w": 6, "t": "விரைந்தவராக"}, {"w": 7, "t": "அவர் கூறினார்"}, {"w": 8, "t": "என் மக்களே!"}, {"w": 9, "t": "நீங்கள் பின்பற்றுங்கள்"}, {"w": 10, "t": "தூதர்களை"}, {"w": 11, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "பின்பற்றுங்கள்"}, {"w": 2, "t": "எவர்"}, {"w": 3, "t": "உங்களிடம் கேட்க மாட்டார்"}, {"w": 4, "t": "ask (of) you"}, {"w": 5, "t": "கூலியை"}, {"w": 6, "t": "அவர்கள்தான்"}, {"w": 7, "t": "நேர்வழி பெற்றவர்கள்"}, {"w": 8, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "எனக்கு என்ன நேர்ந்தது?"}, {"w": 2, "t": "(is) for me"}, {"w": 3, "t": "நான் வணங்காமல் இருப்பதற்கு"}, {"w": 4, "t": "I worship"}, {"w": 5, "t": "என்னைப் படைத்தவனை"}, {"w": 6, "t": "created me"}, {"w": 7, "t": "அவன் பக்கம்தான்"}, {"w": 8, "t": "நீங்களும் திரும்பக் கொண்டு வரப்படுவீர்கள்"}, {"w": 9, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "நான் எடுத்துக் கொள்வேனா!"}, {"w": 2, "t": "அவனையன்றி"}, {"w": 3, "t": "besides Him"}, {"w": 4, "t": "(வேறு) தெய்வங்களை"}, {"w": 5, "t": "எனக்கு நாடினால்"}, {"w": 6, "t": "intends for me"}, {"w": 7, "t": "பேரருளாளன்"}, {"w": 8, "t": "ஒரு தீங்கை"}, {"w": 9, "t": "தடுக்காது"}, {"w": 10, "t": "will avail"}, {"w": 11, "t": "என்னை விட்டும்"}, {"w": 12, "t": "அவற்றின் சிபாரிசு"}, {"w": 13, "t": "எதையும்"}, {"w": 14, "t": "and not"}, {"w": 15, "t": "இன்னும் அவர்கள் என்னை காப்பாற்ற மாட்டார்கள்"}, {"w": 16, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "அப்போது"}, {"w": 3, "t": "வழிகேட்டில்தான்"}, {"w": 4, "t": "an error"}, {"w": 5, "t": "தெளிவான"}, {"w": 6, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "நிச்சயமாக நான்"}, {"w": 2, "t": "நம்பிக்கை கொண்டேன்"}, {"w": 3, "t": "உங்கள் இறைவனை"}, {"w": 4, "t": "ஆகவே எனக்கு செவிசாயுங்கள்!"}, {"w": 5, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "கூறப்பட்டது"}, {"w": 2, "t": "நீர் நுழைவீராக!"}, {"w": 3, "t": "சொர்க்கத்தில்"}, {"w": 4, "t": "அவர் கூறினார்"}, {"w": 5, "t": "என் மக்கள் (இதை) அறியவேண்டுமே!"}, {"w": 6, "t": "my people"}, {"w": 7, "t": "knew"}, {"w": 8, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "மன்னிப்பு வழங்கியதையும்"}, {"w": 2, "t": "has forgiven"}, {"w": 3, "t": "எனக்கு"}, {"w": 4, "t": "என் இறைவன்"}, {"w": 5, "t": "என்னை அவன் ஆக்கியதையும்"}, {"w": 6, "t": "கண்ணியமானவர்களில்"}, {"w": 7, "t": "the honored ones"}, {"w": 8, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "நாம் இறக்கவில்லை"}, {"w": 2, "t": "We sent down"}, {"w": 3, "t": "மீது"}, {"w": 4, "t": "அவருடைய மக்கள்"}, {"w": 5, "t": "அவருக்குப் பின்னர்"}, {"w": 6, "t": "after him"}, {"w": 7, "t": "ஒரு படையை"}, {"w": 8, "t": "host"}, {"w": 9, "t": "வானத்திலிருந்து"}, {"w": 10, "t": "the heaven"}, {"w": 11, "t": "நாம் இல்லை"}, {"w": 12, "t": "were We"}, {"w": 13, "t": "இறக்குபவர்களாகவும்"}, {"w": 14, "t": "(28)"}]}, {"ayah": 29, "words": [{"w": 1, "t": "அது இருக்கவில்லை"}, {"w": 2, "t": "it was"}, {"w": 3, "t": "தவிர"}, {"w": 4, "t": "ஒரு சப்தமாகவே"}, {"w": 5, "t": "ஒரே ஒரு"}, {"w": 6, "t": "ஆகவே, அப்போது அவர்கள்"}, {"w": 7, "t": "They"}, {"w": 8, "t": "அழிந்து விட்டார்கள்"}, {"w": 9, "t": "(29)"}]}, {"ayah": 30, "words": [{"w": 1, "t": "நிகழ்ந்த துக்கமே!"}, {"w": 2, "t": "அடியார்கள் மீது"}, {"w": 3, "t": "the servants"}, {"w": 4, "t": "அவர்களிடம் வரவில்லை"}, {"w": 5, "t": "came to them"}, {"w": 6, "t": "எந்த ஒரு தூதரும்"}, {"w": 7, "t": "Messenger"}, {"w": 8, "t": "தவிர"}, {"w": 9, "t": "அவர்கள் இருந்தே"}, {"w": 10, "t": "அவரை"}, {"w": 11, "t": "அவர்கள் பரிகாசம் செய்பவர்களாக"}, {"w": 12, "t": "(30)"}]}, {"ayah": 31, "words": [{"w": 1, "t": "அவர்கள் கவனிக்க மாட்டார்களா?"}, {"w": 2, "t": "they see"}, {"w": 3, "t": "எத்தனையோ"}, {"w": 4, "t": "நாம் அழித்திருக்கின்றோம்"}, {"w": 5, "t": "அவர்களுக்கு முன்னர்"}, {"w": 6, "t": "தலைமுறைகளை"}, {"w": 7, "t": "the generations"}, {"w": 8, "t": "நிச்சயமாக அவர்கள்"}, {"w": 9, "t": "தங்கள் பக்கம்"}, {"w": 10, "t": "திரும்பி வரமாட்டார்கள்"}, {"w": 11, "t": "will not return"}, {"w": 12, "t": "(31)"}]}, {"ayah": 32, "words": [{"w": 1, "t": "(அவர்கள்) எல்லோரும் இல்லை"}, {"w": 2, "t": "all"}, {"w": 3, "t": "தவிர/அனைவரும்"}, {"w": 4, "t": "together"}, {"w": 5, "t": "நம்மிடம்"}, {"w": 6, "t": "ஆஜர்படுத்தப்பட்டவர்களாகவே"}, {"w": 7, "t": "(32)"}]}, {"ayah": 33, "words": [{"w": 1, "t": "அத்தாட்சி"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "பூமியாகும்"}, {"w": 4, "t": "இறந்துபோன"}, {"w": 5, "t": "அதை நாம் உயிர்ப்பித்தோம்"}, {"w": 6, "t": "நாம் வெளியாக்கினோம்"}, {"w": 7, "t": "அதிலிருந்து"}, {"w": 8, "t": "வித்துக்களை"}, {"w": 9, "t": "அதில் இருந்துதான்"}, {"w": 10, "t": "அவர்கள் சாப்பிடுகின்றார்கள்"}, {"w": 11, "t": "(33)"}]}, {"ayah": 34, "words": [{"w": 1, "t": "இன்னும் ஏற்படுத்தினோம்"}, {"w": 2, "t": "அதில்"}, {"w": 3, "t": "தோட்டங்களை"}, {"w": 4, "t": "பேரித்த மரங்கள்"}, {"w": 5, "t": "date-palms"}, {"w": 6, "t": "இன்னும் திராட்சைகளின்"}, {"w": 7, "t": "உதித்தோடச்செய்தோம்"}, {"w": 8, "t": "அதில்"}, {"w": 9, "t": "ஊற்றுக் கண்களை"}, {"w": 10, "t": "the springs"}, {"w": 11, "t": "(34)"}]}, {"ayah": 35, "words": [{"w": 1, "t": "அவர்கள் புசிப்பதற்காக"}, {"w": 2, "t": "அவனுடைய கனிகளில் இருந்து"}, {"w": 3, "t": "its fruit"}, {"w": 4, "t": "இவற்றை செய்யவில்லை"}, {"w": 5, "t": "made it"}, {"w": 6, "t": "அவர்களின் கரங்கள்"}, {"w": 7, "t": "அவர்கள் நன்றி செலுத்த வேண்டாமா?"}, {"w": 8, "t": "they be grateful"}, {"w": 9, "t": "(35)"}]}, {"ayah": 36, "words": [{"w": 1, "t": "மிகப் பரிசுத்தமானவன்"}, {"w": 2, "t": "படைத்தவன்"}, {"w": 3, "t": "created"}, {"w": 4, "t": "பல வகைகளை"}, {"w": 5, "t": "எல்லாம்"}, {"w": 6, "t": "முளைக்க வைக்கக்கூடியதில்"}, {"w": 7, "t": "grows"}, {"w": 8, "t": "பூமி"}, {"w": 9, "t": "அவர்களிலும்"}, {"w": 10, "t": "themselves"}, {"w": 11, "t": "அவர்கள் அறியாதவற்றிலும்"}, {"w": 12, "t": "not"}, {"w": 13, "t": "they know"}, {"w": 14, "t": "(36)"}]}, {"ayah": 37, "words": [{"w": 1, "t": "இன்னும் அத்தாட்சி"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "இரவாகும்"}, {"w": 4, "t": "உரித்தெடுக்கின்றோம்"}, {"w": 5, "t": "அதிலிருந்து"}, {"w": 6, "t": "பகலை"}, {"w": 7, "t": "அப்போது அவர்கள்"}, {"w": 8, "t": "They"}, {"w": 9, "t": "இருளில் ஆகிவிடுகின்றனர்"}, {"w": 10, "t": "(37)"}]}, {"ayah": 38, "words": [{"w": 1, "t": "சூரியன்"}, {"w": 2, "t": "ஓடுகிறது"}, {"w": 3, "t": "இருப்பிடத்தை நோக்கி"}, {"w": 4, "t": "தனது"}, {"w": 5, "t": "அது"}, {"w": 6, "t": "ஏற்பாடாகும்"}, {"w": 7, "t": "மிகைத்தவனுடைய"}, {"w": 8, "t": "நன்கறிந்த(வன்)"}, {"w": 9, "t": "(38)"}]}, {"ayah": 39, "words": [{"w": 1, "t": "சந்திரனை"}, {"w": 2, "t": "அதை நாம் திட்டமிட்டோம்"}, {"w": 3, "t": "பல தங்குமிடங்களில்"}, {"w": 4, "t": "இறுதியாக"}, {"w": 5, "t": "திரும்பிவிடுகின்றது"}, {"w": 6, "t": "பேரிச்ச குலையின் காய்ந்த மட்டையைப் போல்"}, {"w": 7, "t": "பழைய"}, {"w": 8, "t": "(39)"}]}, {"ayah": 40, "words": [{"w": 1, "t": "சூரியன் ஆகுமாகாது"}, {"w": 2, "t": "the sun"}, {"w": 3, "t": "is permitted"}, {"w": 4, "t": "அதற்கு"}, {"w": 5, "t": "அது அடைவது"}, {"w": 6, "t": "it overtakes"}, {"w": 7, "t": "சந்திரனை"}, {"w": 8, "t": "இரவு முந்திவிடாது"}, {"w": 9, "t": "the night"}, {"w": 10, "t": "(can) outstrip"}, {"w": 11, "t": "பகலை"}, {"w": 12, "t": "ஒவ்வொன்றும்"}, {"w": 13, "t": "ஒரு கோளில்"}, {"w": 14, "t": "an orbit"}, {"w": 15, "t": "நீந்துகின்றன"}, {"w": 16, "t": "(40)"}]}, {"ayah": 41, "words": [{"w": 1, "t": "இன்னும் அத்தாட்சியாவது"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "நிச்சயமாக நாம்"}, {"w": 4, "t": "நாம் பயணிக்க வைத்தோம்"}, {"w": 5, "t": "அவர்களின் சந்ததிகளை"}, {"w": 6, "t": "கப்பலில்"}, {"w": 7, "t": "the ship"}, {"w": 8, "t": "நிரம்பிய"}, {"w": 9, "t": "(41)"}]}, {"ayah": 42, "words": [{"w": 1, "t": "நாம் படைத்தோம்"}, {"w": 2, "t": "அவர்களுக்கு"}, {"w": 3, "t": "அதைப் போன்று"}, {"w": 4, "t": "(the) likes of it"}, {"w": 5, "t": "அவர்கள் வாகணிப்பதை"}, {"w": 6, "t": "they ride"}, {"w": 7, "t": "(42)"}]}, {"ayah": 43, "words": [{"w": 1, "t": "நாம் நாடினால்"}, {"w": 2, "t": "We will"}, {"w": 3, "t": "அவர்களை மூழ்கடிப்போம்"}, {"w": 4, "t": "அவர்களுக்கு உதவ