rr"}, {"w": 11, "t": "(82)"}]}, {"ayah": 83, "words": [{"w": 1, "t": "ஆக, அவன் மகா பரிசுத்தமானவன்"}, {"w": 2, "t": "எவன்/ அவனுடைய கரத்தில்"}, {"w": 3, "t": "in Whose hand"}, {"w": 4, "t": "பேராட்சி"}, {"w": 5, "t": "எல்லாவற்றின்"}, {"w": 6, "t": "things"}, {"w": 7, "t": "அவன் பக்கம்தான்"}, {"w": 8, "t": "நீங்கள் திரும்பக் கொண்டு வரப்படுவீர்கள்"}, {"w": 9, "t": "(83)"}]}]}