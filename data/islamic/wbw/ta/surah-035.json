{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "எல்லாப் புகழும்"}, {"w": 2, "t": "அல்லாஹ்விற்கே"}, {"w": 3, "t": "படைத்தவன்"}, {"w": 4, "t": "வானங்களையும்"}, {"w": 5, "t": "பூமியையும்"}, {"w": 6, "t": "ஆக்கக்கூடியவன்"}, {"w": 7, "t": "வானவர்களை"}, {"w": 8, "t": "தூதர்களாகவும்"}, {"w": 9, "t": "இறக்கைகளை உடையவர்களாகவும்"}, {"w": 10, "t": "having wings"}, {"w": 11, "t": "இரண்டு இரண்டு"}, {"w": 12, "t": "இன்னும் மூன்று மூன்று"}, {"w": 13, "t": "இன்னும் நான்கு நான்கு"}, {"w": 14, "t": "அதிகப்படுத்துவான்"}, {"w": 15, "t": "படைப்புகளில்"}, {"w": 16, "t": "the creation"}, {"w": 17, "t": "தான் நாடுவதை"}, {"w": 18, "t": "He wills"}, {"w": 19, "t": "நிச்சயமாக"}, {"w": 20, "t": "அல்லாஹ்"}, {"w": 21, "t": "எல்லாவற்றின் மீதும்"}, {"w": 22, "t": "every"}, {"w": 23, "t": "thing"}, {"w": 24, "t": "பேராற்றலுடையவன்"}, {"w": 25, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "எதை(யும்)/திறந்தால்"}, {"w": 2, "t": "Allah grants"}, {"w": 3, "t": "அல்லாஹ்"}, {"w": 4, "t": "மக்களுக்கு"}, {"w": 5, "t": "இருந்து/அருள்(கள்)"}, {"w": 6, "t": "Mercy"}, {"w": 7, "t": "தடுப்பவர் எவரும் இல்லை/அதை"}, {"w": 8, "t": "(can) withhold"}, {"w": 9, "t": "it"}, {"w": 10, "t": "எதை/அவன் தடுத்து நிறுத்திவிட்டால்"}, {"w": 11, "t": "He withholds"}, {"w": 12, "t": "விடுபவர் எவரும் இல்லை"}, {"w": 13, "t": "(can) release"}, {"w": 14, "t": "அதை"}, {"w": 15, "t": "அவனுக்குப் பின்"}, {"w": 16, "t": "thereafter"}, {"w": 17, "t": "அவன்தான்"}, {"w": 18, "t": "மிகைத்தவன்"}, {"w": 19, "t": "மகா ஞானவான்"}, {"w": 20, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "மக்களே!"}, {"w": 2, "t": "mankind"}, {"w": 3, "t": "நினைவு கூறுங்கள்"}, {"w": 4, "t": "அருட்கொடையை"}, {"w": 5, "t": "அல்லாஹ்வுடைய"}, {"w": 6, "t": "உங்கள் மீதுள்ள"}, {"w": 7, "t": "?/படைப்பாளன் யாரும்"}, {"w": 8, "t": "(there) any"}, {"w": 9, "t": "creator"}, {"w": 10, "t": "அல்லாஹ்வை அன்றி"}, {"w": 11, "t": "other (than) Allah"}, {"w": 12, "t": "உணவளிக்கின்றான்/உங்களுக்கு"}, {"w": 13, "t": "வானங்களில்இருந்தும்"}, {"w": 14, "t": "the sky"}, {"w": 15, "t": "பூமியில் இருந்தும்"}, {"w": 16, "t": "அறவே இல்லை"}, {"w": 17, "t": "வணக்கத்திற்குரியவன்"}, {"w": 18, "t": "தவிர"}, {"w": 19, "t": "அவனை"}, {"w": 20, "t": "ஆகவே எப்படி"}, {"w": 21, "t": "திருப்பப்படுகிறீர்கள்"}, {"w": 22, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அவர்கள் உம்மை பொய்ப்பித்தால்"}, {"w": 2, "t": "they deny you"}, {"w": 3, "t": "திட்டமாக"}, {"w": 4, "t": "பொய்ப்பிக்கப் பட்டுள்ளனர்"}, {"w": 5, "t": "பல தூதர்கள்"}, {"w": 6, "t": "உமக்கு முன்னரும்"}, {"w": 7, "t": "before you"}, {"w": 8, "t": "அல்லாஹ்வின் பக்கமே"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "திருப்பப்படும்"}, {"w": 11, "t": "எல்லாக் காரியங்களும்"}, {"w": 12, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "மக்களே!"}, {"w": 2, "t": "mankind"}, {"w": 3, "t": "நிச்சயமாக"}, {"w": 4, "t": "வாக்கு"}, {"w": 5, "t": "அல்லாஹ்வின்"}, {"w": 6, "t": "உண்மையானதே!"}, {"w": 7, "t": "ஆகவே, உங்களை மயக்கிவிட வேண்டாம்"}, {"w": 8, "t": "deceive you"}, {"w": 9, "t": "உலக வாழ்க்கை"}, {"w": 10, "t": "(of) the world"}, {"w": 11, "t": "இன்னும் உங்களை மயக்கிவிட வேண்டாம்"}, {"w": 12, "t": "deceive you"}, {"w": 13, "t": "அல்லாஹ்வின் விஷயத்தில்"}, {"w": 14, "t": "ஏமாற்றக் கூடியவன்"}, {"w": 15, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "ஷைத்தான்"}, {"w": 3, "t": "உங்களுக்கு"}, {"w": 4, "t": "எதிரி"}, {"w": 5, "t": "ஆகவே, அவனை எடுத்துக்கொள்ளுங்கள்!"}, {"w": 6, "t": "எதிரியாகவே"}, {"w": 7, "t": "அவன் அழைப்பதெல்லாம்"}, {"w": 8, "t": "he invites"}, {"w": 9, "t": "தனது கூட்டத்தார்களை"}, {"w": 10, "t": "அவர்கள் ஆகுவதற்காகத்தான்"}, {"w": 11, "t": "கொழுந்துவிட்டெரியும் நரகவாசிகளாக"}, {"w": 12, "t": "(the) companions"}, {"w": 13, "t": "(of) the Blaze"}, {"w": 14, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "எவர்கள்"}, {"w": 2, "t": "நிராகரித்தார்களோ"}, {"w": 3, "t": "அவர்களுக்கு உண்டு"}, {"w": 4, "t": "தண்டனை"}, {"w": 5, "t": "கடுமையான"}, {"w": 6, "t": "எவர்கள்"}, {"w": 7, "t": "நம்பிக்கை கொண்டனர்"}, {"w": 8, "t": "இன்னும் செய்தார்களோ"}, {"w": 9, "t": "நன்மைகளை"}, {"w": 10, "t": "அவர்களுக்கு உண்டு"}, {"w": 11, "t": "மன்னிப்பும்"}, {"w": 12, "t": "பெரிய கூலியும்"}, {"w": 13, "t": "great"}, {"w": 14, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "?/எவர் ஒருவர்"}, {"w": 2, "t": "அலங்கரிக்கப்பட்டது"}, {"w": 3, "t": "அவருக்கு"}, {"w": 4, "t": "கெட்ட(து)"}, {"w": 5, "t": "தனது செயல்"}, {"w": 6, "t": "கருதினார்/அதை"}, {"w": 7, "t": "அழகாக"}, {"w": 8, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "வழிகெடுக்கின்றான்"}, {"w": 11, "t": "தான் நாடுகின்றவரை"}, {"w": 12, "t": "He wills"}, {"w": 13, "t": "இன்னும் நேர்வழிபடுத்துகின்றான்"}, {"w": 14, "t": "தான் நாடுகின்றவரை"}, {"w": 15, "t": "He wills"}, {"w": 16, "t": "ஆகவே போய்விடவேண்டாம்"}, {"w": 17, "t": "go out"}, {"w": 18, "t": "உமது உயிர்"}, {"w": 19, "t": "அவர்கள் மீது"}, {"w": 20, "t": "கவலைகளால்"}, {"w": 21, "t": "நிச்சயமாக அல்லாஹ்"}, {"w": 22, "t": "Allah"}, {"w": 23, "t": "நன்கறிந்தவன்"}, {"w": 24, "t": "அவர்கள் செய்வதை"}, {"w": 25, "t": "they do"}, {"w": 26, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "அல்லாஹ்தான்"}, {"w": 2, "t": "(is) the One Who"}, {"w": 3, "t": "அனுப்புகின்றான்"}, {"w": 4, "t": "காற்றுகளை"}, {"w": 5, "t": "அவை கிளப்புகின்றன"}, {"w": 6, "t": "மேகத்தை"}, {"w": 7, "t": "அதை ஓட்டி வருகிறோம்"}, {"w": 8, "t": "ஊருக்கு"}, {"w": 9, "t": "a land"}, {"w": 10, "t": "வறண்டுபோன"}, {"w": 11, "t": "நாம் உயிர்ப்பிக்கின்றோம்"}, {"w": 12, "t": "அதன்மூலம்"}, {"w": 13, "t": "அந்த பூமியை"}, {"w": 14, "t": "பின்னர்"}, {"w": 15, "t": "அது வறண்டதற்கு"}, {"w": 16, "t": "இப்படித்தான்"}, {"w": 17, "t": "எழுப்பப்படுவது(ம்)"}, {"w": 18, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "யார்"}, {"w": 2, "t": "இருப்பாரோ"}, {"w": 3, "t": "நாடுகின்றவராக"}, {"w": 4, "t": "கண்ணியத்தை"}, {"w": 5, "t": "அல்லாஹ்விற்குத்தான்"}, {"w": 6, "t": "கண்ணியம்"}, {"w": 7, "t": "அனைத்தும்"}, {"w": 8, "t": "அவன் பக்கம் தான்"}, {"w": 9, "t": "உயர்கின்றன"}, {"w": 10, "t": "சொற்கள்"}, {"w": 11, "t": "நல்ல"}, {"w": 12, "t": "இன்னும் செயல்"}, {"w": 13, "t": "நல்ல(து)"}, {"w": 14, "t": "அதை 