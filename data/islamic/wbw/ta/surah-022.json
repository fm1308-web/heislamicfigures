}, {"w": 62, "t": "மழைநீரை"}, {"w": 63, "t": "அது அசைகிறது"}, {"w": 64, "t": "இன்னும் அதிகப்படுத்துகிறது"}, {"w": 65, "t": "இன்னும் முளைக்க வைக்கிறது"}, {"w": 66, "t": "எல்லா விதமான"}, {"w": 67, "t": "every"}, {"w": 68, "t": "அழகிய தாவரங்களை"}, {"w": 69, "t": "beautiful"}, {"w": 70, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இது"}, {"w": 2, "t": "ஏனெனில் நிச்சயமாக"}, {"w": 3, "t": "அல்லாஹ்தான்"}, {"w": 4, "t": "He"}, {"w": 5, "t": "உண்மையானவன்"}, {"w": 6, "t": "இன்னும் நிச்சயமாக அவன்தான்"}, {"w": 7, "t": "உயிர்ப்பிக்கிறான்"}, {"w": 8, "t": "இறந்தவர்களை"}, {"w": 9, "t": "இன்னும் நிச்சயமாக அவன்தான்"}, {"w": 10, "t": "எல்லாப் பொருள்கள் மீதும்"}, {"w": 11, "t": "every"}, {"w": 12, "t": "thing"}, {"w": 13, "t": "பேராற்றலுடையவன்"}, {"w": 14, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "மேலும் நிச்சயமாக"}, {"w": 2, "t": "மறுமை"}, {"w": 3, "t": "வரக்கூடியதுதான்"}, {"w": 4, "t": "அறவே சந்தேகம் இல்லை"}, {"w": 5, "t": "doubt"}, {"w": 6, "t": "அதில்"}, {"w": 7, "t": "மேலும் நிச்சயமாக அல்லாஹ்"}, {"w": 8, "t": "Allah"}, {"w": 9, "t": "எழுப்புவான்"}, {"w": 10, "t": "புதைக்குழிகளில் உள்ளவர்களை"}, {"w": 11, "t": "(are) in"}, {"w": 12, "t": "the graves"}, {"w": 13, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "மனிதர்களில்"}, {"w": 2, "t": "mankind"}, {"w": 3, "t": "எவர்/தர்க்கிப்பார்"}, {"w": 4, "t": "disputes"}, {"w": 5, "t": "அல்லாஹ்வின் விஷயத்தில்"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "எவ்வித அறிவுமில்லாமலும்"}, {"w": 8, "t": "any knowledge"}, {"w": 9, "t": "நேர்வழி இல்லாமலும்"}, {"w": 10, "t": "any guidance"}, {"w": 11, "t": "வேதமும் இல்லாமலும்"}, {"w": 12, "t": "a Book"}, {"w": 13, "t": "வெளிப்படுத்தக்கூடிய"}, {"w": 14, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "தனது கழுத்தைத் திருப்பியவனாக"}, {"w": 2, "t": "his neck"}, {"w": 3, "t": "தடுப்பதற்காக"}, {"w": 4, "t": "மார்க்கத்திலிருந்து"}, {"w": 5, "t": "(the) way"}, {"w": 6, "t": "அல்லாஹ்வின்"}, {"w": 7, "t": "அவனுக்கு"}, {"w": 8, "t": "இவ்வுலகத்தில்"}, {"w": 9, "t": "the world"}, {"w": 10, "t": 