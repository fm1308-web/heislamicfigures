{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "வானத்தின் மீது சத்தியமாக!"}, {"w": 2, "t": "கோள்களுடைய"}, {"w": 3, "t": "the constellations"}, {"w": 4, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "நாள் மீது சத்தியமாக"}, {"w": 2, "t": "வாக்களிக்கப்பட்ட"}, {"w": 3, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "சாட்சியாளர் மீது சத்தியமாக"}, {"w": 2, "t": "சாட்சியாக்கப்பட்டதின் மீது சத்தியமாக"}, {"w": 3, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "அழிக்கப்பட்டார்கள்"}, {"w": 2, "t": "அகழ்காரர்கள்"}, {"w": 3, "t": "(of) the pit"}, {"w": 4, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "நெருப்புடையவர்கள்"}, {"w": 2, "t": "விறகுகளுடைய"}, {"w": 3, "t": "(of) the fuel"}, {"w": 4, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "போது"}, {"w": 2, "t": "அவர்கள்"}, {"w": 3, "t": "அதனருகில்"}, {"w": 4, "t": "உட்கார்ந்திருந்தனர்"}, {"w": 5, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "இன்னும் அவர்கள்"}, {"w": 2, "t": "எதை"}, {"w": 3, "t": "what"}, {"w": 4, "t": "செய்வார்கள்"}, {"w": 5, "t": "நம்பிக்கையாளர்களுக்கு"}, {"w": 6, "t": "ஆஜராகி இருந்தார்கள்"}, {"w": 7, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் தண்டிக்கவில்லை"}, {"w": 2, "t": "they resented"}, {"w": 3, "t": "அவர்களை"}, {"w": 4, "t": "தவிர"}, {"w": 5, "t": "அவர்கள் நம்பிக்கை கொண்டதற்காகவே"}, {"w": 6, "t": "they believed"}, {"w": 7, "t": "அல்லாஹ்வை"}, {"w": 8, "t": "மிகைத்தவன்"}, {"w": 9, "t": "புகழாளன்"}, {"w": 10, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "எப்படிப்பட்டவன்"}, {"w": 2, "t": "அவனுக்குரியதே"}, {"w": 3, "t": "ஆட்சி/வானங்கள்"}, {"w": 4, "t": "(of) the heavens"}, {"w": 5, "t": "இன்னும் பூமி"}, {"w": 6, "t": "இன்னும் அல்லாஹ்"}, {"w": 7, "t": "எல்லாப் பொருள்கள் மீதும்"}, {"w": 8, "t": "every"}, {"w": 9, "t": "thing"}, {"w": 10, "t": "சாட்சியாளன்"}, {"w": 11, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "நிச்சயமாக எவர்கள்"}, {"w": 2, "t": "those who"}, {"w": 3, "t": "துன்புறுத்தினார்கள்"}, {"w": 4, "t": "நம்பிக்கை கொண்ட ஆண்களை"}, {"w": 5, "t": "இன்னும் நம்பிக்கை கொண்ட பெண்களை"}, {"w": 6, "t": "பிறகு"}, {"w": 7, "t": "அவர்கள் திருந்தவில்லை"}, {"w": 8, "t": "they repented"}, {"w": 9, "t": "அவர்களுக்கு"}, {"w": 10, "t": "வேதனை"}, {"w": 11, "t": "ஜஹன்னம் என்ற நரகத்தின்"}, {"w": 12, "t": "இன்னும் அவர்களுக்கு"}, {"w": 13, "t": "வேதனை"}, {"w": 14, "t": "சுட்டெரிக்கக்கூடிய"}, {"w": 15, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "எவர்கள்"}, {"w": 3, "t": "நம்பிக்கை கொண்டார்கள்"}, {"w": 4, "t": "இன்னும் செய்தார்கள்"}, {"w": 5, "t": "நற்செயல்களை"}, {"w": 6, "t": "அவர்களுக்கு"}, {"w": 7, "t": "சொர்க்கங்கள்"}, {"w": 8, "t": "ஓடும்"}, {"w": 9, "t": "அவற்றின் கீழிருந்து"}, {"w": 10, "t": "underneath it"}, {"w": 11, "t": "நதிகள்"}, {"w": 12, "t": "அதுதான்"}, {"w": 13, "t": "வெற்றி"}, {"w": 14, "t": "பெரும்"}, {"w": 15, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "நிச்சயமாக"}, {"w": 2, "t": "பிடி"}, {"w": 3, "t": "உம் இறைவனின்"}, {"w": 4, "t": "கடுமையானதுதான்"}, {"w": 5, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "நிச்சயமாக அவன்தான்"}, {"w": 2, "t": "He"}, {"w": 3, "t": "உற்பத்திசெய்கிறான்"}, {"w": 4, "t": "இன்னும் மீட்கிறான்"}, {"w": 5, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் அவன்தான்"}, {"w": 2, "t": "மகா மன்னிப்பாளன்"}, {"w": 3, "t": "மகா நேசன்"}, {"w": 4, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "அர்ஷுடையவன்"}, {"w": 2, "t": "the Throne"}, {"w": 3, "t": "பெரும் மதிப்பிற்குரியவன்"}, {"w": 4, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "செய்து முடிப்பவன்"}, {"w": 2, "t": "தான் நாடுவதை"}, {"w": 3, "t": "He intends"}, {"w": 4, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "உமக்கு வந்ததா?"}, {"w": 2, "t": "come to you"}, {"w": 3, "t": "செய்தி/ராணுவங் களின்"}, {"w": 4, "t": "(of) the hosts"}, {"w": 5, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "ஃபிர்அவ்ன்"}, {"w": 2, "t": "இன்னும் ஸமூது"}, {"w": 3, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "நிராகரிப்பாளர்கள்"}, {"w": 3, "t": "disbelieve"}, {"w": 4, "t": "பொய்ப்பிப்பதில்தான்"}, {"w": 5, "t": "denial"}, {"w": 6, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "இன்னும் அல்லாஹ்"}, {"w": 2, "t": "அவர்களுக்குப் பின்னாலிருந்து"}, {"w": 3, "t": "behind them"}, {"w": 4, "t": "சூழ்ந்திருக்கின்றான்"}, {"w": 5, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "மாறாக"}, {"w": 2, "t": "இது"}, {"w": 3, "t": "குர்ஆன்"}, {"w": 4, "t": "பெரும்மதிப்பிற்குரிய"}, {"w": 5, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "பலகையில்"}, {"w": 2, "t": "a Tablet"}, {"w": 3, "t": "பாதுகாக்கப்பட்டது"}, {"w": 4, "t": "(22)"}]}]}