{"ayahs": [{"ayah": 1, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "வஹீ  அறிவிக்கப்பட்டது"}, {"w": 3, "t": "எனக்கு"}, {"w": 4, "t": "நிச்சயமாக செய்தியாவது"}, {"w": 5, "t": "செவியுற்றனர்"}, {"w": 6, "t": "சில நபர்கள்"}, {"w": 7, "t": "ஜின்களில்"}, {"w": 8, "t": "the jinn"}, {"w": 9, "t": "மேலும் அவர்கள் கூறினார்கள்"}, {"w": 10, "t": "நிச்சயமாக நாங்கள்"}, {"w": 11, "t": "செவியுற்றோம்"}, {"w": 12, "t": "குர்ஆனை"}, {"w": 13, "t": "அதிசயமான"}, {"w": 14, "t": "(1)"}]}, {"ayah": 2, "words": [{"w": 1, "t": "அது வழிகாட்டுகிறது"}, {"w": 2, "t": "நேர்வழிக்கு"}, {"w": 3, "t": "the right way"}, {"w": 4, "t": "ஆகவே, நாங்கள் நம்பிக்கை கொண்டோம்/அதை"}, {"w": 5, "t": "in it"}, {"w": 6, "t": "இன்னும் நாங்கள் இணையாக்க மாட்டோம்"}, {"w": 7, "t": "we will associate"}, {"w": 8, "t": "எங்கள் இறைவனுக்கு"}, {"w": 9, "t": "ஒருவரையும்"}, {"w": 10, "t": "(2)"}]}, {"ayah": 3, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக செய்தியாவது"}, {"w": 2, "t": "மிக உயர்ந்தது"}, {"w": 3, "t": "மதிப்பு"}, {"w": 4, "t": "எங்கள் இறைவனின்"}, {"w": 5, "t": "அவன் எடுத்துக் கொள்ளவில்லை"}, {"w": 6, "t": "He has taken"}, {"w": 7, "t": "மனைவியை(யும்)"}, {"w": 8, "t": "பிள்ளைகளையும்"}, {"w": 9, "t": "a son"}, {"w": 10, "t": "(3)"}]}, {"ayah": 4, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக செய்தியாவது"}, {"w": 2, "t": "இருந்தான்"}, {"w": 3, "t": "கூறுபவனாக"}, {"w": 4, "t": "எங்களில் உள்ள மூடன்"}, {"w": 5, "t": "அல்லாஹ்வின் மீது"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "அநியாயமான விஷயத்தை"}, {"w": 8, "t": "(4)"}]}, {"ayah": 5, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "நம்பினோம்"}, {"w": 3, "t": "சொல்ல மாட்டார்கள்"}, {"w": 4, "t": "never"}, {"w": 5, "t": "will say"}, {"w": 6, "t": "மனிதர்களும்"}, {"w": 7, "t": "ஜின்களும்"}, {"w": 8, "t": "அல்லாஹ்வின் மீது"}, {"w": 9, "t": "Allah"}, {"w": 10, "t": "பொய்"}, {"w": 11, "t": "(5)"}]}, {"ayah": 6, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக செய்தியாவது"}, {"w": 2, "t": "இருந்தார்(கள்)"}, {"w": 3, "t": "ஆண்கள் சிலர்"}, {"w": 4, "t": "மனிதர்களில் உள்ள"}, {"w": 5, "t": "mankind"}, {"w": 6, "t": "பாதுகாவல் தேடுபவர்களாக"}, {"w": 7, "t": "ஆண்கள் சிலரிடம்"}, {"w": 8, "t": "ஜின்களில் உள்ள"}, {"w": 9, "t": "the jinn"}, {"w": 10, "t": "எனவே அவர்கள் அவர்களுக்கு அதிகப்படுத்தினர்"}, {"w": 11, "t": "பயத்தை"}, {"w": 12, "t": "(6)"}]}, {"ayah": 7, "words": [{"w": 1, "t": "நிச்சயமாக அவர்கள்"}, {"w": 2, "t": "எண்ணினர்"}, {"w": 3, "t": "நீங்கள் எண்ணுவது போன்றுதான்"}, {"w": 4, "t": "you thought"}, {"w": 5, "t": "அறவே எழுப்ப மாட்டான்"}, {"w": 6, "t": "never"}, {"w": 7, "t": "will raise"}, {"w": 8, "t": "அல்லாஹ்"}, {"w": 9, "t": "ஒருவரையும்"}, {"w": 10, "t": "(7)"}]}, {"ayah": 8, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "தேடினோம்"}, {"w": 3, "t": "வானத்தை"}, {"w": 4, "t": "அதை நாங்கள் கண்டோம்"}, {"w": 5, "t": "நிரப்பப்பட்டிருப்பதாக"}, {"w": 6, "t": "காவல்களாலும்"}, {"w": 7, "t": "கடுமையான"}, {"w": 8, "t": "இன்னும் எரி நட்சத்திரங்களாலும்"}, {"w": 9, "t": "(8)"}]}, {"ayah": 9, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "இருந்தோம்"}, {"w": 3, "t": "உட்காருபவர்களாக"}, {"w": 4, "t": "அதில்"}, {"w": 5, "t": "பல இடங்களில்"}, {"w": 6, "t": "ஒட்டுக்கேட்க"}, {"w": 7, "t": "யார்"}, {"w": 8, "t": "ஒட்டுக் கேட்பாரோ"}, {"w": 9, "t": "இப்போது"}, {"w": 10, "t": "தனக்கு காண்பார்"}, {"w": 11, "t": "for him"}, {"w": 12, "t": "எரி நட்சத்திரத்தை"}, {"w": 13, "t": "எதிர்பார்த்திருக்கின்ற"}, {"w": 14, "t": "(9)"}]}, {"ayah": 10, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "அறியமாட்டோம்"}, {"w": 3, "t": "we know"}, {"w": 4, "t": "தீமை ஏதும் நாடப்பட்டதா?"}, {"w": 5, "t": "is intended"}, {"w": 6, "t": "பூமியில் உள்ளவர்களுக்கு"}, {"w": 7, "t": "(are) in"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "அல்லது நாடினானா?"}, {"w": 10, "t": "intends"}, {"w": 11, "t": "அவர்களுக்கு"}, {"w": 12, "t": "அவர்களின் இறைவன்"}, {"w": 13, "t": "நேர்வழியை"}, {"w": 14, "t": "(10)"}]}, {"ayah": 11, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "எங்களில்"}, {"w": 3, "t": "நல்லவர்களும்"}, {"w": 4, "t": "இன்னும் எங்களில்"}, {"w": 5, "t": "மற்றவர்களும்"}, {"w": 6, "t": "that"}, {"w": 7, "t": "நாங்கள் இருந்தோம்"}, {"w": 8, "t": "பிரிவுகளாக"}, {"w": 9, "t": "பலதரப்பட்ட"}, {"w": 10, "t": "(11)"}]}, {"ayah": 12, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "அறிந்தோம்"}, {"w": 3, "t": "நாங்கள் அறவே இயலாமல் ஆக்கிவிட முடியாது"}, {"w": 4, "t": "never"}, {"w": 5, "t": "we will cause failure"}, {"w": 6, "t": "அல்லாஹ்வை"}, {"w": 7, "t": "பூமியில்"}, {"w": 8, "t": "the earth"}, {"w": 9, "t": "இன்னும் அவனை இயலாமல் ஆக்கிவிட முடியாது/ஓடி"}, {"w": 10, "t": "we can escape Him"}, {"w": 11, "t": "(by) flight"}, {"w": 12, "t": "(12)"}]}, {"ayah": 13, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "நாங்கள் செவியுற்ற போது"}, {"w": 3, "t": "we heard"}, {"w": 4, "t": "நேர்வழியை"}, {"w": 5, "t": "நாங்கள் நம்பிக்கை கொண்டோம்"}, {"w": 6, "t": "அதை"}, {"w": 7, "t": "எவர்/நம்பிக்கை கொள்வாரோ"}, {"w": 8, "t": "believes"}, {"w": 9, "t": "தன் இறைவனை"}, {"w": 10, "t": "பயப்படமாட்டார்"}, {"w": 11, "t": "he will fear"}, {"w": 12, "t": "குறைவதையும்"}, {"w": 13, "t": "அநியாயத்தையும்"}, {"w": 14, "t": "any burden"}, {"w": 15, "t": "(13)"}]}, {"ayah": 14, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக நாங்கள்"}, {"w": 2, "t": "எங்களில்"}, {"w": 3, "t": "முஸ்லிம்களும்"}, {"w": 4, "t": "இன்னும் எங்களில்"}, {"w": 5, "t": "அநியாயக்காரர்களும்"}, {"w": 6, "t": "யார்"}, {"w": 7, "t": "இஸ்லாமை ஏற்றாரோ"}, {"w": 8, "t": "அவர்கள்தான்"}, {"w": 9, "t": "நன்கு தேடினார்கள்"}, {"w": 10, "t": "நேர்வழியை"}, {"w": 11, "t": "(14)"}]}, {"ayah": 15, "words": [{"w": 1, "t": "ஆக, அநியாயக்காரர்கள்"}, {"w": 2, "t": "the unjust"}, {"w": 3, "t": "இருக்கின்றனர்"}, {"w": 4, "t": "நரகத்தின்"}, {"w": 5, "t": "எரி கொல்லிகளாக"}, {"w": 6, "t": "(15)"}]}, {"ayah": 16, "words": [{"w": 1, "t": "அவர்கள் நிலையாக இருந்திருந்தால்"}, {"w": 2, "t": "நேரான மார்க்கத்தில்"}, {"w": 3, "t": "on"}, {"w": 4, "t": "நாம் அவர்களுக்கு புகட்டி இருப்போம்"}, {"w": 5, "t": "நீரை"}, {"w": 6, "t": "பலன்தரக்கூடிய அதிகமான"}, {"w": 7, "t": "(in) abundance"}, {"w": 8, "t": "(16)"}]}, {"ayah": 17, "words": [{"w": 1, "t": "நாம் சோதிப்பதற்காக/அவர்களை"}, {"w": 2, "t": "அதன்மூலம்/எவர்"}, {"w": 3, "t": "And whoever"}, {"w": 4, "t": "புறக்கணிப்பாரோ"}, {"w": 5, "t": "அறிவுரையை"}, {"w": 6, "t": "the Remembrance"}, {"w": 7, "t": "தன் இறைவனின்"}, {"w": 8, "t": "புகுத்துவான்/அவரை"}, {"w": 9, "t": "தண்டனையில்/ கடினமான"}, {"w": 10, "t": "severe"}, {"w": 11, "t": "(17)"}]}, {"ayah": 18, "words": [{"w": 1, "t": "இன்னும் நிச்சயமாக"}, {"w": 2, "t": "மஸ்ஜிதுகள்"}, {"w": 3, "t": "அல்லாஹ்விற்கு"}, {"w": 4, "t": "ஆகவேஅழைக்காதீர்கள்"}, {"w": 5, "t": "call"}, {"w": 6, "t": "அல்லாஹ்வுடன்"}, {"w": 7, "t": "Allah"}, {"w": 8, "t": "வேறு ஒருவரை"}, {"w": 9, "t": "(18)"}]}, {"ayah": 19, "words": [{"w": 1, "t": "நிச்சயமாக செய்தி"}, {"w": 2, "t": "நின்ற போது"}, {"w": 3, "t": "stood up"}, {"w": 4, "t": "அல்லாஹ்வின் அடியார்"}, {"w": 5, "t": "(of) Allah"}, {"w": 6, "t": "அவனை அழைப்பதற்காக"}, {"w": 7, "t": "முயற்சித்தனர்"}, {"w": 8, "t": "ஆகிவிட"}, {"w": 9, "t": "அவருக்கு எதிராக"}, {"w": 10, "t": "எல்லோரும் சேர்ந்து"}, {"w": 11, "t": "(19)"}]}, {"ayah": 20, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நான் அழைப்பதெல்லாம்"}, {"w": 3, "t": "I call upon"}, {"w": 4, "t": "என் இறைவனை"}, {"w": 5, "t": "இன்னும் இணையாக்க மாட்டேன்"}, {"w": 6, "t": "I associate"}, {"w": 7, "t": "அவனுக்கு"}, {"w": 8, "t": "ஒருவரையும்"}, {"w": 9, "t": "(20)"}]}, {"ayah": 21, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "உரிமை பெறமாட்டேன்"}, {"w": 4, "t": "possess"}, {"w": 5, "t": "உங்களின்"}, {"w": 6, "t": "கெட்டதற்கும்"}, {"w": 7, "t": "நல்லதற்கும்"}, {"w": 8, "t": "right path"}, {"w": 9, "t": "(21)"}]}, {"ayah": 22, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "நிச்சயமாக நான்"}, {"w": 3, "t": "என்னை அறவே காப்பாற்ற மாட்டார்"}, {"w": 4, "t": "can protect me"}, {"w": 5, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 6, "t": "Allah"}, {"w": 7, "t": "ஒருவரும்"}, {"w": 8, "t": "இன்னும் அறவே காணமாட்டேன்"}, {"w": 9, "t": "can I find"}, {"w": 10, "t": "அவனையன்றி"}, {"w": 11, "t": "besides Him"}, {"w": 12, "t": "ஒதுங்குமிடத்தை"}, {"w": 13, "t": "(22)"}]}, {"ayah": 23, "words": [{"w": 1, "t": "தவிர/ எடுத்துரைப்பதற்கும்"}, {"w": 2, "t": "(the) notification"}, {"w": 3, "t": "அல்லாஹ்விடமிருந்து"}, {"w": 4, "t": "Allah"}, {"w": 5, "t": "அவனுடைய தூதுத்துவ செய்திகளுக்கும்"}, {"w": 6, "t": "எவர்"}, {"w": 7, "t": "மாறு செய்வாரோ"}, {"w": 8, "t": "அல்லாஹ்விற்கு(ம்)"}, {"w": 9, "t": "அவனது தூதருக்கும்"}, {"w": 10, "t": "நிச்சயமாக"}, {"w": 11, "t": "அவருக்கு"}, {"w": 12, "t": "நெருப்புதான்"}, {"w": 13, "t": "நரக"}, {"w": 14, "t": "அவர்கள் நிரந்தரமாக தங்கி இருப்பார்கள்"}, {"w": 15, "t": "அதில்"}, {"w": 16, "t": "எப்போதும்"}, {"w": 17, "t": "(23)"}]}, {"ayah": 24, "words": [{"w": 1, "t": "இறுதியாக"}, {"w": 2, "t": "அவர்கள் பார்த்தால்"}, {"w": 3, "t": "they see"}, {"w": 4, "t": "தாங்கள் எச்சரிக்கப்பட்டதை"}, {"w": 5, "t": "they are promised"}, {"w": 6, "t": "அறி(ந்து கொள்)வார்கள்"}, {"w": 7, "t": "எவர்"}, {"w": 8, "t": "மிக பலவீனமானவர்"}, {"w": 9, "t": "உதவியாளரால்"}, {"w": 10, "t": "இன்னும் மிக குறைவானவர்"}, {"w": 11, "t": "எண்ணிக்கையால்"}, {"w": 12, "t": "(24)"}]}, {"ayah": 25, "words": [{"w": 1, "t": "கூறுவீராக!"}, {"w": 2, "t": "அறியமாட்டேன்"}, {"w": 3, "t": "I know"}, {"w": 4, "t": "சமீபமாக உள்ளதா"}, {"w": 5, "t": "நீங்கள் எச்சரிக்கப்படுவது"}, {"w": 6, "t": "you are promised"}, {"w": 7, "t": "அல்லது ஆக்கி இருக்கின்றானா?/அதற்கு"}, {"w": 8, "t": "will appoint"}, {"w": 9, "t": "for it"}, {"w": 10, "t": "என் இறைவன்"}, {"w": 11, "t": "ஒரு அவகாசத்தை"}, {"w": 12, "t": "(25)"}]}, {"ayah": 26, "words": [{"w": 1, "t": "நன்கறிந்தவன்"}, {"w": 2, "t": "மறைவான ஞானங்களை"}, {"w": 3, "t": "வெளிப்படுத்த மாட்டான்"}, {"w": 4, "t": "He reveals"}, {"w": 5, "t": "அவன் தன் மறைவான ஞானங்களை"}, {"w": 6, "t": "His unseen"}, {"w": 7, "t": "ஒருவருக்கும்"}, {"w": 8, "t": "(26)"}]}, {"ayah": 27, "words": [{"w": 1, "t": "தவிர"}, {"w": 2, "t": "எவர்(களை)"}, {"w": 3, "t": "திருப்திகொண்டானோ"}, {"w": 4, "t": "தூதர்களில்"}, {"w": 5, "t": "a Messenger"}, {"w": 6, "t": "நிச்சயமாக அவன்"}, {"w": 7, "t": "அனுப்புவான்"}, {"w": 8, "t": "அவர்களுக்கு முன்னும்"}, {"w": 9, "t": "before"}, {"w": 10, "t": "him"}, {"w": 11, "t": "அவர்களுக்குப் பின்னும்"}, {"w": 12, "t": "behind him"}, {"w": 13, "t": "பாதுகாவலர்களை"}, {"w": 14, "t": "(27)"}]}, {"ayah": 28, "words": [{"w": 1, "t": "அவர் அறிவதற்காக"}, {"w": 2, "t": "என்று/திட்டமாக"}, {"w": 3, "t": "indeed"}, {"w": 4, "t": "எடுத்துரைத்தார்கள்"}, {"w": 5, "t": "தூதுத்துவ செய்திகளை"}, {"w": 6, "t": "தங்கள் இறைவனின்"}, {"w": 7, "t": "இன்னும் சூழ்ந்து அறிவான்"}, {"w": 8, "t": "அவர்களிடம் உள்ளவற்றை"}, {"w": 9, "t": "(is) with them"}, {"w": 10, "t": "இன்னும் கணக்கிட்டுள்ளான்"}, {"w": 11, "t": "எல்லா பொருள்களையும்"}, {"w": 12, "t": "things"}, {"w": 13, "t": "எண்ணிக்கையால்"}, {"w": 14, "t": "(28)"}]}]}