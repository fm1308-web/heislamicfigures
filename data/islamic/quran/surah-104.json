{
    "surah":  104,
    "name_ar":  "سُورَةُ الهُمَزَةِ",
    "name_en":  "The Traducer",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ",
                       "english":  "Woe to every scorner and mocker"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ",
                       "english":  "Who collects wealth and [continuously] counts it."
                   },
                   {
                       "ayah":  3,
                       "arabic":  "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
                       "english":  "He thinks that his wealth will make him immortal."
                   },
                   {
                       "ayah":  4,
                       "arabic":  "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
                       "english":  "No! He will surely be thrown into the Crusher."
                   },
                   {
                       "ayah":  5,
                       "arabic":  "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
                       "english":  "And what can make you know what is the Crusher?"
                   },
                   {
                       "ayah":  6,
                       "arabic":  "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
                       "english":  "It is the fire of Allah, [eternally] fueled,"
                   },
                   {
                       "ayah":  7,
                       "arabic":  "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
                       "english":  "Which mounts directed at the hearts."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ",
                       "english":  "Indeed, Hellfire will be closed down upon them"
                   },
                   {
                       "ayah":  9,
                       "arabic":  "فِى عَمَدٍۢ مُّمَدَّدَةٍۭ",
                       "english":  "In extended columns."
                   }
               ]
}