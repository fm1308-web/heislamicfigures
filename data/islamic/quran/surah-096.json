{
    "surah":  96,
    "name_ar":  "سُورَةُ العَلَقِ",
    "name_en":  "The Clot",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
                       "english":  "Recite in the name of your Lord who created -"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ",
                       "english":  "Created man from a clinging substance."
                   },
                   {
                       "ayah":  3,
                       "arabic":  "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
                       "english":  "Recite, and your Lord is the most Generous -"
                   },
                   {
                       "ayah":  4,
                       "arabic":  "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
                       "english":  "Who taught by the pen -"
                   },
                   {
                       "ayah":  5,
                       "arabic":  "عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ",
                       "english":  "Taught man that which he knew not."
                   },
                   {
                       "ayah":  6,
                       "arabic":  "كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ",
                       "english":  "No! [But] indeed, man transgresses"
                   },
                   {
                       "ayah":  7,
                       "arabic":  "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
                       "english":  "Because he sees himself self-sufficient."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
                       "english":  "Indeed, to your Lord is the return."
                   },
                   {
                       "ayah":  9,
                       "arabic":  "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
                       "english":  "Have you seen the one who forbids"
                   },
                   {
                       "ayah":  10,
                       "arabic":  "عَبْدًا إِذَا صَلَّىٰٓ",
                       "english":  "A servant when he prays?"
                   },
                   {
                       "ayah":  11,
                       "arabic":  "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
                       "english":  "Have you seen if he is upon guidance"
                   },
                   {
                       "ayah":  12,
                       "arabic":  "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
                       "english":  "Or enjoins righteousness?"
                   },
                   {
                       "ayah":  13,
                       "arabic":  "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
                       "english":  "Have you seen if he denies and turns away -"
                   },
                   {
                       "ayah":  14,
                       "arabic":  "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
                       "english":  "Does he not know that Allah sees?"
                   },
                   {
                       "ayah":  15,
                       "arabic":  "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
                       "english":  "No! If he does not desist, We will surely drag him by the forelock -"
                   },
                   {
                       "ayah":  16,
                       "arabic":  "نَاصِيَةٍۢ كَٰذِبَةٍ خَاطِئَةٍۢ",
                       "english":  "A lying, sinning forelock."
                   },
                   {
                       "ayah":  17,
                       "arabic":  "فَلْيَدْعُ نَادِيَهُۥ",
                       "english":  "Then let him call his associates;"
                   },
                   {
                       "ayah":  18,
                       "arabic":  "سَنَدْعُ ٱلزَّبَانِيَةَ",
                       "english":  "We will call the angels of Hell."
                   },
                   {
                       "ayah":  19,
                       "arabic":  "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
                       "english":  "No! Do not obey him. But prostrate and draw near [to Allah]."
                   }
               ]
}