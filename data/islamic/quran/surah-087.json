{
    "surah":  87,
    "name_ar":  "سُورَةُ الأَعۡلَىٰ",
    "name_en":  "The Most High",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
                       "english":  "Exalt the name of your Lord, the Most High,"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
                       "english":  "Who created and proportioned"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
                       "english":  "And who destined and [then] guided"
                   },
                   {
                       "ayah":  4,
                       "arabic":  "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
                       "english":  "And who brings out the pasture"
                   },
                   {
                       "ayah":  5,
                       "arabic":  "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
                       "english":  "And [then] makes it black stubble."
                   },
                   {
                       "ayah":  6,
                       "arabic":  "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
                       "english":  "We will make you recite, [O Muhammad], and you will not forget,"
                   },
                   {
                       "ayah":  7,
                       "arabic":  "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
                       "english":  "Except what Allah should will. Indeed, He knows what is declared and what is hidden."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
                       "english":  "And We will ease you toward ease."
                   },
                   {
                       "ayah":  9,
                       "arabic":  "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
                       "english":  "So remind, if the reminder should benefit;"
                   },
                   {
                       "ayah":  10,
                       "arabic":  "سَيَذَّكَّرُ مَن يَخْشَىٰ",
                       "english":  "He who fears [Allah] will be reminded."
                   },
                   {
                       "ayah":  11,
                       "arabic":  "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
                       "english":  "But the wretched one will avoid it -"
                   },
                   {
                       "ayah":  12,
                       "arabic":  "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
                       "english":  "[He] who will [enter and] burn in the greatest Fire,"
                   },
                   {
                       "ayah":  13,
                       "arabic":  "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
                       "english":  "Neither dying therein nor living."
                   },
                   {
                       "ayah":  14,
                       "arabic":  "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
                       "english":  "He has certainly succeeded who purifies himself"
                   },
                   {
                       "ayah":  15,
                       "arabic":  "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
                       "english":  "And mentions the name of his Lord and prays."
                   },
                   {
                       "ayah":  16,
                       "arabic":  "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
                       "english":  "But you prefer the worldly life,"
                   },
                   {
                       "ayah":  17,
                       "arabic":  "وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ",
                       "english":  "While the Hereafter is better and more enduring."
                   },
                   {
                       "ayah":  18,
                       "arabic":  "إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
                       "english":  "Indeed, this is in the former scriptures,"
                   },
                   {
                       "ayah":  19,
                       "arabic":  "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
                       "english":  "The scriptures of Abraham and Moses."
                   }
               ]
}