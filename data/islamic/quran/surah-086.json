{
    "surah":  86,
    "name_ar":  "سُورَةُ الطَّارِقِ",
    "name_en":  "The Morning Star",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
                       "english":  "By the sky and the night comer -"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
                       "english":  "And what can make you know what is the night comer?"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "ٱلنَّجْمُ ٱلثَّاقِبُ",
                       "english":  "It is the piercing star -"
                   },
                   {
                       "ayah":  4,
                       "arabic":  "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
                       "english":  "There is no soul but that it has over it a protector."
                   },
                   {
                       "ayah":  5,
                       "arabic":  "فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ",
                       "english":  "So let man observe from what he was created."
                   },
                   {
                       "ayah":  6,
                       "arabic":  "خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ",
                       "english":  "He was created from a fluid, ejected,"
                   },
                   {
                       "ayah":  7,
                       "arabic":  "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
                       "english":  "Emerging from between the backbone and the ribs."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ",
                       "english":  "Indeed, Allah, to return him [to life], is Able."
                   },
                   {
                       "ayah":  9,
                       "arabic":  "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
                       "english":  "The Day when secrets will be put on trial,"
                   },
                   {
                       "ayah":  10,
                       "arabic":  "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
                       "english":  "Then man will have no power or any helper."
                   },
                   {
                       "ayah":  11,
                       "arabic":  "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
                       "english":  "By the sky which returns [rain]"
                   },
                   {
                       "ayah":  12,
                       "arabic":  "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
                       "english":  "And [by] the earth which cracks open,"
                   },
                   {
                       "ayah":  13,
                       "arabic":  "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
                       "english":  "Indeed, the Qur\u0027an is a decisive statement,"
                   },
                   {
                       "ayah":  14,
                       "arabic":  "وَمَا هُوَ بِٱلْهَزْلِ",
                       "english":  "And it is not amusement."
                   },
                   {
                       "ayah":  15,
                       "arabic":  "إِنَّهُمْ يَكِيدُونَ كَيْدًۭا",
                       "english":  "Indeed, they are planning a plan,"
                   },
                   {
                       "ayah":  16,
                       "arabic":  "وَأَكِيدُ كَيْدًۭا",
                       "english":  "But I am planning a plan."
                   },
                   {
                       "ayah":  17,
                       "arabic":  "فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
                       "english":  "So allow time for the disbelievers. Leave them awhile."
                   }
               ]
}