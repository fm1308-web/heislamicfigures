{
    "surah":  77,
    "name_ar":  "سُورَةُ المُرۡسَلَاتِ",
    "name_en":  "The Emissaries",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْمُرْسَلَٰتِ عُرْفًۭا",
                       "english":  "By those [winds] sent forth in gusts"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "فَٱلْعَٰصِفَٰتِ عَصْفًۭا",
                       "english":  "And the winds that blow violently"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "وَٱلنَّٰشِرَٰتِ نَشْرًۭا",
                       "english":  "And [by] the winds that spread [clouds]"
                   },
                   {
                       "ayah":  4,
                       "arabic":  "فَٱلْفَٰرِقَٰتِ فَرْقًۭا",
                       "english":  "And those [angels] who bring criterion"
                   },
                   {
                       "ayah":  5,
                       "arabic":  "فَٱلْمُلْقِيَٰتِ ذِكْرًا",
                       "english":  "And those [angels] who deliver a message"
                   },
                   {
                       "ayah":  6,
                       "arabic":  "عُذْرًا أَوْ نُذْرًا",
                       "english":  "As justification or warning,"
                   },
                   {
                       "ayah":  7,
                       "arabic":  "إِنَّمَا تُوعَدُونَ لَوَٰقِعٌۭ",
                       "english":  "Indeed, what you are promised is to occur."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "فَإِذَا ٱلنُّجُومُ طُمِسَتْ",
                       "english":  "So when the stars are obliterated"
                   },
                   {
                       "ayah":  9,
                       "arabic":  "وَإِذَا ٱلسَّمَآءُ فُرِجَتْ",
                       "english":  "And when the heaven is opened"
                   },
                   {
                       "ayah":  10,
                       "arabic":  "وَإِذَا ٱلْجِبَالُ نُسِفَتْ",
                       "english":  "And when the mountains are blown away"
                   },
                   {
                       "ayah":  11,
                       "arabic":  "وَإِذَا ٱلرُّسُلُ أُقِّتَتْ",
                       "english":  "And when the messengers\u0027 time has come..."
                   },
                   {
                       "ayah":  12,
                       "arabic":  "لِأَىِّ يَوْمٍ أُجِّلَتْ",
                       "english":  "For what Day was it postponed?"
                   },
                   {
                       "ayah":  13,
                       "arabic":  "لِيَوْمِ ٱلْفَصْلِ",
                       "english":  "For the Day of Judgement."
                   },
                   {
                       "ayah":  14,
                       "arabic":  "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ",
                       "english":  "And what can make you know what is the Day of Judgement?"
                   },
                   {
                       "ayah":  15,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  16,
                       "arabic":  "أَلَمْ نُهْلِكِ ٱلْأَوَّلِينَ",
                       "english":  "Did We not destroy the former peoples?"
                   },
                   {
                       "ayah":  17,
                       "arabic":  "ثُمَّ نُتْبِعُهُمُ ٱلْءَاخِرِينَ",
                       "english":  "Then We will follow them with the later ones."
                   },
                   {
                       "ayah":  18,
                       "arabic":  "كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ",
                       "english":  "Thus do We deal with the criminals."
                   },
                   {
                       "ayah":  19,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  20,
                       "arabic":  "أَلَمْ نَخْلُقكُّم مِّن مَّآءٍۢ مَّهِينٍۢ",
                       "english":  "Did We not create you from a liquid disdained?"
                   },
                   {
                       "ayah":  21,
                       "arabic":  "فَجَعَلْنَٰهُ فِى قَرَارٍۢ مَّكِينٍ",
                       "english":  "And We placed it in a firm lodging"
                   },
                   {
                       "ayah":  22,
                       "arabic":  "إِلَىٰ قَدَرٍۢ مَّعْلُومٍۢ",
                       "english":  "For a known extent."
                   },
                   {
                       "ayah":  23,
                       "arabic":  "فَقَدَرْنَا فَنِعْمَ ٱلْقَٰدِرُونَ",
                       "english":  "And We determined [it], and excellent [are We] to determine."
                   },
                   {
                       "ayah":  24,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  25,
                       "arabic":  "أَلَمْ نَجْعَلِ ٱلْأَرْضَ كِفَاتًا",
                       "english":  "Have We not made the earth a container"
                   },
                   {
                       "ayah":  26,
                       "arabic":  "أَحْيَآءًۭ وَأَمْوَٰتًۭا",
                       "english":  "Of the living and the dead?"
                   },
                   {
                       "ayah":  27,
                       "arabic":  "وَجَعَلْنَا فِيهَا رَوَٰسِىَ شَٰمِخَٰتٍۢ وَأَسْقَيْنَٰكُم مَّآءًۭ فُرَاتًۭا",
                       "english":  "And We placed therein lofty, firmly set mountains and have given you to drink sweet water."
                   },
                   {
                       "ayah":  28,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  29,
                       "arabic":  "ٱنطَلِقُوٓا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ",
                       "english":  "[They will be told], \"Proceed to that which you used to deny."
                   },
                   {
                       "ayah":  30,
                       "arabic":  "ٱنطَلِقُوٓا۟ إِلَىٰ ظِلٍّۢ ذِى ثَلَٰثِ شُعَبٍۢ",
                       "english":  "Proceed to a shadow [of smoke] having three columns"
                   },
                   {
                       "ayah":  31,
                       "arabic":  "لَّا ظَلِيلٍۢ وَلَا يُغْنِى مِنَ ٱللَّهَبِ",
                       "english":  "[But having] no cool shade and availing not against the flame.\""
                   },
                   {
                       "ayah":  32,
                       "arabic":  "إِنَّهَا تَرْمِى بِشَرَرٍۢ كَٱلْقَصْرِ",
                       "english":  "Indeed, it throws sparks [as huge] as a fortress,"
                   },
                   {
                       "ayah":  33,
                       "arabic":  "كَأَنَّهُۥ جِمَٰلَتٌۭ صُفْرٌۭ",
                       "english":  "As if they were yellowish [black] camels."
                   },
                   {
                       "ayah":  34,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  35,
                       "arabic":  "هَٰذَا يَوْمُ لَا يَنطِقُونَ",
                       "english":  "This is a Day they will not speak,"
                   },
                   {
                       "ayah":  36,
                       "arabic":  "وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ",
                       "english":  "Nor will it be permitted for them to make an excuse."
                   },
                   {
                       "ayah":  37,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  38,
                       "arabic":  "هَٰذَا يَوْمُ ٱلْفَصْلِ ۖ جَمَعْنَٰكُمْ وَٱلْأَوَّلِينَ",
                       "english":  "This is the Day of Judgement; We will have assembled you and the former peoples."
                   },
                   {
                       "ayah":  39,
                       "arabic":  "فَإِن كَانَ لَكُمْ كَيْدٌۭ فَكِيدُونِ",
                       "english":  "So if you have a plan, then plan against Me."
                   },
                   {
                       "ayah":  40,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  41,
                       "arabic":  "إِنَّ ٱلْمُتَّقِينَ فِى ظِلَٰلٍۢ وَعُيُونٍۢ",
                       "english":  "Indeed, the righteous will be among shades and springs"
                   },
                   {
                       "ayah":  42,
                       "arabic":  "وَفَوَٰكِهَ مِمَّا يَشْتَهُونَ",
                       "english":  "And fruits from whatever they desire,"
                   },
                   {
                       "ayah":  43,
                       "arabic":  "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ",
                       "english":  "[Being told], \"Eat and drink in satisfaction for what you used to do.\""
                   },
                   {
                       "ayah":  44,
                       "arabic":  "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
                       "english":  "Indeed, We thus reward the doers of good."
                   },
                   {
                       "ayah":  45,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  46,
                       "arabic":  "كُلُوا۟ وَتَمَتَّعُوا۟ قَلِيلًا إِنَّكُم مُّجْرِمُونَ",
                       "english":  "[O disbelievers], eat and enjoy yourselves a little; indeed, you are criminals."
                   },
                   {
                       "ayah":  47,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  48,
                       "arabic":  "وَإِذَا قِيلَ لَهُمُ ٱرْكَعُوا۟ لَا يَرْكَعُونَ",
                       "english":  "And when it is said to them, \"Bow [in prayer],\" they do not bow."
                   },
                   {
                       "ayah":  49,
                       "arabic":  "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
                       "english":  "Woe, that Day, to the deniers."
                   },
                   {
                       "ayah":  50,
                       "arabic":  "فَبِأَىِّ حَدِيثٍۭ بَعْدَهُۥ يُؤْمِنُونَ",
                       "english":  "Then in what statement after the Qur\u0027an will they believe?"
                   }
               ]
}