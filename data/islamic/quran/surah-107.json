{
    "surah":  107,
    "name_ar":  "سُورَةُ المَاعُونِ",
    "name_en":  "Almsgiving",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
                       "english":  "Have you seen the one who denies the Recompense?"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
                       "english":  "For that is the one who drives away the orphan"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
                       "english":  "And does not encourage the feeding of the poor."
                   },
                   {
                       "ayah":  4,
                       "arabic":  "فَوَيْلٌۭ لِّلْمُصَلِّينَ",
                       "english":  "So woe to those who pray"
                   },
                   {
                       "ayah":  5,
                       "arabic":  "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
                       "english":  "[But] who are heedless of their prayer -"
                   },
                   {
                       "ayah":  6,
                       "arabic":  "ٱلَّذِينَ هُمْ يُرَآءُونَ",
                       "english":  "Those who make show [of their deeds]"
                   },
                   {
                       "ayah":  7,
                       "arabic":  "وَيَمْنَعُونَ ٱلْمَاعُونَ",
                       "english":  "And withhold [simple] assistance."
                   }
               ]
}