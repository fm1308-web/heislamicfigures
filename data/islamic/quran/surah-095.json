{
    "surah":  95,
    "name_ar":  "سُورَةُ التِّينِ",
    "name_en":  "The Fig",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِّسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلتِّينِ وَٱلزَّيْتُونِ",
                       "english":  "By the fig and the olive"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "وَطُورِ سِينِينَ",
                       "english":  "And [by] Mount Sinai"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "وَهَٰذَا ٱلْبَلَدِ ٱلْأَمِينِ",
                       "english":  "And [by] this secure city [Makkah],"
                   },
                   {
                       "ayah":  4,
                       "arabic":  "لَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍۢ",
                       "english":  "We have certainly created man in the best of stature;"
                   },
                   {
                       "ayah":  5,
                       "arabic":  "ثُمَّ رَدَدْنَٰهُ أَسْفَلَ سَٰفِلِينَ",
                       "english":  "Then We return him to the lowest of the low,"
                   },
                   {
                       "ayah":  6,
                       "arabic":  "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۢ",
                       "english":  "Except for those who believe and do righteous deeds, for they will have a reward uninterrupted."
                   },
                   {
                       "ayah":  7,
                       "arabic":  "فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ",
                       "english":  "So what yet causes you to deny the Recompense?"
                   },
                   {
                       "ayah":  8,
                       "arabic":  "أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَٰكِمِينَ",
                       "english":  "Is not Allah the most just of judges?"
                   }
               ]
}