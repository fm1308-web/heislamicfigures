{
    "surah":  105,
    "name_ar":  "سُورَةُ الفِيلِ",
    "name_en":  "The Elephant",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَٰبِ ٱلْفِيلِ",
                       "english":  "Have you not considered, [O Muhammad], how your Lord dealt with the companions of the elephant?"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍۢ",
                       "english":  "Did He not make their plan into misguidance?"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ",
                       "english":  "And He sent against them birds in flocks,"
                   },
                   {
                       "ayah":  4,
                       "arabic":  "تَرْمِيهِم بِحِجَارَةٍۢ مِّن سِجِّيلٍۢ",
                       "english":  "Striking them with stones of hard clay,"
                   },
                   {
                       "ayah":  5,
                       "arabic":  "فَجَعَلَهُمْ كَعَصْفٍۢ مَّأْكُولٍۭ",
                       "english":  "And He made them like eaten straw."
                   }
               ]
}