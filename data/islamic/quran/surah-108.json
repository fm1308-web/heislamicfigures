{
    "surah":  108,
    "name_ar":  "سُورَةُ الكَوۡثَرِ",
    "name_en":  "Abundance",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَعْطَيْنَٰكَ ٱلْكَوْثَرَ",
                       "english":  "Indeed, We have granted you, [O Muhammad], al-Kawthar."
                   },
                   {
                       "ayah":  2,
                       "arabic":  "فَصَلِّ لِرَبِّكَ وَٱنْحَرْ",
                       "english":  "So pray to your Lord and sacrifice [to Him alone]."
                   },
                   {
                       "ayah":  3,
                       "arabic":  "إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ",
                       "english":  "Indeed, your enemy is the one cut off."
                   }
               ]
}