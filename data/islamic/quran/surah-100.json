{
    "surah":  100,
    "name_ar":  "سُورَةُ العَادِيَاتِ",
    "name_en":  "The Chargers",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَٰدِيَٰتِ ضَبْحًۭا",
                       "english":  "By the racers, panting,"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "فَٱلْمُورِيَٰتِ قَدْحًۭا",
                       "english":  "And the producers of sparks [when] striking"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "فَٱلْمُغِيرَٰتِ صُبْحًۭا",
                       "english":  "And the chargers at dawn,"
                   },
                   {
                       "ayah":  4,
                       "arabic":  "فَأَثَرْنَ بِهِۦ نَقْعًۭا",
                       "english":  "Stirring up thereby [clouds of] dust,"
                   },
                   {
                       "ayah":  5,
                       "arabic":  "فَوَسَطْنَ بِهِۦ جَمْعًا",
                       "english":  "Arriving thereby in the center collectively,"
                   },
                   {
                       "ayah":  6,
                       "arabic":  "إِنَّ ٱلْإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٌۭ",
                       "english":  "Indeed mankind, to his Lord, is ungrateful."
                   },
                   {
                       "ayah":  7,
                       "arabic":  "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌۭ",
                       "english":  "And indeed, he is to that a witness."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ",
                       "english":  "And indeed he is, in love of wealth, intense."
                   },
                   {
                       "ayah":  9,
                       "arabic":  "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ",
                       "english":  "But does he not know that when the contents of the graves are scattered"
                   },
                   {
                       "ayah":  10,
                       "arabic":  "وَحُصِّلَ مَا فِى ٱلصُّدُورِ",
                       "english":  "And that within the breasts is obtained,"
                   },
                   {
                       "ayah":  11,
                       "arabic":  "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ",
                       "english":  "Indeed, their Lord with them, that Day, is [fully] Acquainted."
                   }
               ]
}