{
    "surah":  102,
    "name_ar":  "سُورَةُ التَّكَاثُرِ",
    "name_en":  "Competition",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ",
                       "english":  "Competition in [worldly] increase diverts you"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ",
                       "english":  "Until you visit the graveyards."
                   },
                   {
                       "ayah":  3,
                       "arabic":  "كَلَّا سَوْفَ تَعْلَمُونَ",
                       "english":  "No! You are going to know."
                   },
                   {
                       "ayah":  4,
                       "arabic":  "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
                       "english":  "Then no! You are going to know."
                   },
                   {
                       "ayah":  5,
                       "arabic":  "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ",
                       "english":  "No! If you only knew with knowledge of certainty..."
                   },
                   {
                       "ayah":  6,
                       "arabic":  "لَتَرَوُنَّ ٱلْجَحِيمَ",
                       "english":  "You will surely see the Hellfire."
                   },
                   {
                       "ayah":  7,
                       "arabic":  "ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ",
                       "english":  "Then you will surely see it with the eye of certainty."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ",
                       "english":  "Then you will surely be asked that Day about pleasure."
                   }
               ]
}