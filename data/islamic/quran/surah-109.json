{
    "surah":  109,
    "name_ar":  "سُورَةُ الكَافِرُونَ",
    "name_en":  "The Disbelievers",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ يَٰٓأَيُّهَا ٱلْكَٰفِرُونَ",
                       "english":  "Say, \"O disbelievers,"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "لَآ أَعْبُدُ مَا تَعْبُدُونَ",
                       "english":  "I do not worship what you worship."
                   },
                   {
                       "ayah":  3,
                       "arabic":  "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُ",
                       "english":  "Nor are you worshippers of what I worship."
                   },
                   {
                       "ayah":  4,
                       "arabic":  "وَلَآ أَنَا۠ عَابِدٌۭ مَّا عَبَدتُّمْ",
                       "english":  "Nor will I be a worshipper of what you worship."
                   },
                   {
                       "ayah":  5,
                       "arabic":  "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُ",
                       "english":  "Nor will you be worshippers of what I worship."
                   },
                   {
                       "ayah":  6,
                       "arabic":  "لَكُمْ دِينُكُمْ وَلِىَ دِينِ",
                       "english":  "For you is your religion, and for me is my religion.\""
                   }
               ]
}