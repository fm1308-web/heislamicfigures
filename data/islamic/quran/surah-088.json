{
    "surah":  88,
    "name_ar":  "سُورَةُ الغَاشِيَةِ",
    "name_en":  "The Overwhelming",
    "revelation":  "Meccan",
    "verses":  [
                   {
                       "ayah":  1,
                       "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ",
                       "english":  "Has there reached you the report of the Overwhelming [event]?"
                   },
                   {
                       "ayah":  2,
                       "arabic":  "وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ",
                       "english":  "[Some] faces, that Day, will be humbled,"
                   },
                   {
                       "ayah":  3,
                       "arabic":  "عَامِلَةٌۭ نَّاصِبَةٌۭ",
                       "english":  "Working [hard] and exhausted."
                   },
                   {
                       "ayah":  4,
                       "arabic":  "تَصْلَىٰ نَارًا حَامِيَةًۭ",
                       "english":  "They will [enter to] burn in an intensely hot Fire."
                   },
                   {
                       "ayah":  5,
                       "arabic":  "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ",
                       "english":  "They will be given drink from a boiling spring."
                   },
                   {
                       "ayah":  6,
                       "arabic":  "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ",
                       "english":  "For them there will be no food except from a poisonous, thorny plant"
                   },
                   {
                       "ayah":  7,
                       "arabic":  "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ",
                       "english":  "Which neither nourishes nor avails against hunger."
                   },
                   {
                       "ayah":  8,
                       "arabic":  "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ",
                       "english":  "[Other] faces, that Day, will show pleasure."
                   },
                   {
                       "ayah":  9,
                       "arabic":  "لِّسَعْيِهَا رَاضِيَةٌۭ",
                       "english":  "With their effort [they are] satisfied"
                   },
                   {
                       "ayah":  10,
                       "arabic":  "فِى جَنَّةٍ عَالِيَةٍۢ",
                       "english":  "In an elevated garden,"
                   },
                   {
                       "ayah":  11,
                       "arabic":  "لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ",
                       "english":  "Wherein they will hear no unsuitable speech."
                   },
                   {
                       "ayah":  12,
                       "arabic":  "فِيهَا عَيْنٌۭ جَارِيَةٌۭ",
                       "english":  "Within it is a flowing spring."
                   },
                   {
                       "ayah":  13,
                       "arabic":  "فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ",
                       "english":  "Within it are couches raised high"
                   },
                   {
                       "ayah":  14,
                       "arabic":  "وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ",
                       "english":  "And cups put in place"
                   },
                   {
                       "ayah":  15,
                       "arabic":  "وَنَمَارِقُ مَصْفُوفَةٌۭ",
                       "english":  "And cushions lined up"
                   },
                   {
                       "ayah":  16,
                       "arabic":  "وَزَرَابِىُّ مَبْثُوثَةٌ",
                       "english":  "And carpets spread around."
                   },
                   {
                       "ayah":  17,
                       "arabic":  "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
                       "english":  "Then do they not look at the camels - how they are created?"
                   },
                   {
                       "ayah":  18,
                       "arabic":  "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
                       "english":  "And at the sky - how it is raised?"
                   },
                   {
                       "ayah":  19,
                       "arabic":  "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
                       "english":  "And at the mountains - how they are erected?"
                   },
                   {
                       "ayah":  20,
                       "arabic":  "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
                       "english":  "And at the earth - how it is spread out?"
                   },
                   {
                       "ayah":  21,
                       "arabic":  "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ",
                       "english":  "So remind, [O Muhammad]; you are only a reminder."
                   },
                   {
                       "ayah":  22,
                       "arabic":  "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
                       "english":  "You are not over them a controller."
                   },
                   {
                       "ayah":  23,
                       "arabic":  "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
                       "english":  "However, he who turns away and disbelieves -"
                   },
                   {
                       "ayah":  24,
                       "arabic":  "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
                       "english":  "Then Allah will punish him with the greatest punishment."
                   },
                   {
                       "ayah":  25,
                       "arabic":  "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
                       "english":  "Indeed, to Us is their return."
                   },
                   {
                       "ayah":  26,
                       "arabic":  "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
                       "english":  "Then indeed, upon Us is their account."
                   }
               ]
}