  "modal": {
    "modal_title": {
      "ar": "كيف يعمل هذا",
      "ur": "یہ کیسے کام کرتا ہے"
    },
    "modal_what_heading": {
      "ar": "ما تراه أمامك",
      "ur": "آپ کیا دیکھ رہے ہیں"
    },
    "modal_what_text": {
      "ar": "يعرض كل مفهوم جميع الشخصيات التاريخية التي تعاملت مع تلك الفكرة، مرتبة على خط زمني حسب فترة حياتهم. تُلوَّن الشخصيات حسب الدور الذي لعبته — سواء أسّست المفهوم أو طوّرته أو انتقدته أو أحيته أو جمعت بين عناصره أو نقلته. اختر عدة مفاهيم لرؤية الشخصيات المشتركة عبر التقاليد الفكرية.",
      "ur": "ہر تصور ان تمام تاریخی شخصیات کو دکھاتا ہے جنہوں نے اس خیال سے تعامل کیا، ان کی عمر کے مطابق ٹائم لائن پر مرتب۔ شخصیات کو ان کے کردار کے مطابق رنگ دیا گیا ہے — چاہے انہوں نے تصور کی بنیاد رکھی، اسے ترقی دی، تنقید کی، احیا کیا، تالیف کی، یا آگے منتقل کیا۔ متعدد تصورات منتخب کریں تاکہ فکری روایات میں مشترک شخصیات دیکھ سکیں۔"
    },
    "modal_roles_heading": {
      "ar": "تعريف الأدوار",
      "ur": "کرداروں کی تعریف"
    },
    "modal_role_originator": {
      "ar": "مؤسس",
      "ur": "بانی"
    },
    "modal_role_originator_desc": {
