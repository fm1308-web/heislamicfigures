    },
    "modal_role_reviver_desc": {
      "ar": "أحيا المفهوم أو جدّد الاهتمام به",
      "ur": "تصور کو زندہ کیا یا اس میں نئی دلچسپی پیدا کی"
    },
    "modal_role_synthesizer": {
      "ar": "مُوَلِّف",
      "ur": "جامع"
    },
    "modal_role_synthesizer_desc": {
      "ar": "جمع بين عناصر من تقاليد متعددة",
      "ur": "متعدد روایات کے عناصر کو یکجا کیا"
    },
    "modal_role_transmitter": {
      "ar": "ناقل",
      "ur": "ناقل"
    },
    "modal_role_transmitter_desc": {
      "ar": "نقل المفهوم عبر التعليم أو الكتابة",
      "ur": "تعلیم یا تحریر کے ذریعے تصور کو آگے منتقل کیا"
    },
    "modal_ai_heading": {
      "ar": "محتوى مُولَّد بالذكاء الاصطناعي",
      "ur": "مصنوعی ذہانت سے تیار کردہ مواد"
    },
    "modal_ai_text": {
      "ar": "تم إنشاء ربط المفاهيم بالشخصيات بواسطة الذكاء الاصطناعي استناداً إلى بيانات الكتب (العناوين، الموضوعات، المؤلف، التقليد، التواريخ). تمثّل العلامات تعاملاً فكرياً محتملاً وليس إجماعاً علمياً مُوثَّقاً. يُرجى دائماً الرجوع إلى المصادر الأولية.",
      "ur": "تصورات اور شخصیات کے درمیان ربط مصنوعی ذہانت نے کتابوں کے میٹا ڈیٹا (عنوانات، موضوعات، مصنف، روایت، تاریخیں) کی بنیاد پر تیار کیا ہے۔ یہ ٹیگ ممکنہ فکری تعامل کی نشاندہی کرتے ہیں، تصدیق شدہ علمی اتفاق رائے نہیں۔ ہمیشہ بنیادی مصادر سے تصدیق کریں۔"
    }
  }
